<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.dhyana.litestream</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/litestream</string>
        <string>replicate</string>
        <string>-config</string>
        <string>/Users/dhyana/dharma_swarm/scripts/litestream.yml</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/dhyana/.dharma/logs/litestream.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/dhyana/.dharma/logs/litestream.err</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/dhyana</string>
    </dict>
</dict>
</plist>
