buildControlPlaneSyncState({\n    isLoading: runtimeLoading,\n    isFetching: runtimeFetching,\n  });\n  const surfaces = buildControlPlaneSurfaces({\n    snapshot,\n    chatStatus,\n    currentPath: \"/dashboard\",\n  });\n  const primarySurface = surfaces.find((surface) => surface.id === \"command-post\") ?? surfaces[0] ?? null;\n  const stableSurfaces = surfaces.filter((surface) => surface.tone === \"ok\").length;\n  const blockedSurfaces = surfaces.filter((surface) => surface.tone === \"error\").length;\n\n  return (\n    <motion.div\n      variants={container}\n      initial=\"hidden\"\n      animate=\"show\"\n      className=\"space-y-6\"\n    >\n      <motion.div variants={item}>\n        <div className=\"glass-panel overflow-hidden p-6\">\n          <div className=\"flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between\">\n            <div className=\"max-w-3xl space-y-3\">\n              <div className=\"flex items-center gap-3\">\n                <div className=\"rounded-2xl border border-aozora/25 bg-aozora/10 p-3 text-aozora\">\n                  <BrainCircuit size={20} />\n                </div>\n                <div>\n                  <div className=\"font-mono text-[11px] uppercase tracking-[0.2em] text-sumi-600\">\n                    Front Door\n                  </div>\n                  <h1 className=\"glow-aozora font-heading text-3xl font-bold tracking-tight text-aozora\">\n                    Mission Control\n                  </h1>\n                </div>\n              </div>\n              <p className=\"text-sm leading-6 text-sumi-600\">\n                This is the operator-facing surface for actually running the swarm. Command Post is the live\n                coordination lane, Qwen Surgeon is the bounded intervention lane, Observatory is the fleet pulse,\n                and Runtime is the canonical shell truth.\n              </p>\n              <div className=\"flex flex-wrap gap-2\">\n                <RoutePill\n                  href=\"/dashboard/command-post\"\n                  icon={<Radio size={14} />}\n                  label=\"Open Command Post\"\n                  accent=\"aozora\"\n                />\n                <RoutePill\n                  href=\"/dashboard/qwen35\"\n                  icon={<Sparkles size={14} />}\n                  label=\"Open Qwen Surgeon\"\n                  accent=\"rokusho\"\n                />\n                <RoutePill\n                  href=\"/dashboard/observatory\"\n                  icon={<HeartPulse size={14} />}\n                  label=\"Open Observatory\"\n                  accent=\"botan\"\n                />\n                <RoutePill\n                  href=\"/dashboard/runtime\"\n                  icon={<Settings2 size={14} />}\n                  label=\"Open Runtime\"\n                  accent=\"kinpaku\"\n                />\n              </div>\n            </div>\n\n            <div className=\"grid min-w-[320px] grid-cols-2 gap-3\">\n              <MissionStat\n                label=\"Primary Route\"\n                value={primarySurface?.label ?? \"Command Post\"}\n                detail={primarySurface?.metric ?? \"Awaiting control-plane signal\"}\n              />\n              <MissionStat\n                label=\"Control Plane\"\n                value={snapshot.statusLabel}\n                detail={snapshot.detail}\n              />\n              <MissionStat\n                label=\"Stable Routes\"\n                value={String(stableSurfaces)}\n                detail={`${blockedSurfaces} blocked`}\n              />\n              <MissionStat\n                label=\"Health\"\n                value={healthStatus}\n                detail={`${health?.anomalies?.length ?? 0} anomalies`}\n              />\n            </div>\n          </div>\n        </div>\n      </motion.div>\n\n      <motion.div variants={item}>\n        <ControlPlaneStrip\n          snapshot={snapshot}\n          surfaces={surfaces}\n          syncState={syncState}\n          onRefresh={() => {\n            void refresh();\n          }}\n        />\n      </motion.div>\n\n      <motion.div variants={item}>\n        <ControlPlaneSurfaceGrid\n          surfaces={surfaces}\n          title=\"Operator Deck\"\n          detail=\"These four routes are the actual front-facing operating surface. Everything else is support, diagnostics, or deep inspection.\"\n        />\n      </motion.div>\n\n      <motion.div\n        variants={item}\n        className=\"grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4\"\n      >\n        <MetricCard\n          label=\"Agents\"\n          value={agentCount}\n          trend={agentCount > 0 ? \"up\" : null}\n          trendLabel={`${agents.filter((a) => a.status === \"busy\").length} active`}\n          accentColor={colors.aozora}\n          index={0}\n        />\n        <MetricCard\n          label=\"Tasks\"\n          value={taskCount}\n          trend={\n            overview && overview.tasks_completed > overview.tasks_failed\n              ? \"up\"\n              : overview && overview.tasks_failed > 0\n                ? \"down\"\n                : null\n          }\n          trendLabel={\n            overview\n              ? `${overview.tasks_completed} done, ${overview.tasks_failed} failed`\n              : undefined\n          }\n          accentColor={colors.botan}\n          index={1}\n        />\n        <MetricCard\n          label=\"Fitness\"\n          value={fitness.toFixed(3)}\n          trend={fitness > 0.5 ? \"up\" : fitness > 0 ? \"down\" : null}\n          trendLabel={`${overview?.evolution_entries ?? 0} entries`}\n          accentColor={colors.kinpaku}\n          index={2}\n        />\n        <MetricCard\n          label=\"Health\"\n          value={healthStatus}\n          trend={healthStatus === \"healthy\" ? \"up\" : healthStatus === \"critical\" ? \"down\" : null}\n          trendLabel={`${health?.anomalies?.length ?? 0} anomalies`}\n          accentColor={healthStatus === \"healthy\" ? colors.rokusho : healthStatus === \"critical\" ? colors.bengara : colors.kinpaku}\n          index={3}\n        />\n      </motion.div>\n\n      <motion.div\n        variants={item}\n        className=\"grid grid-cols-1 gap-4 lg:grid-cols-3\"\n      >"
