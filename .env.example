# ============================================================
# DHARMA SWARM — Environment Configuration
# Copy to .env and fill in your values.
# ============================================================

# ── Core LLM Providers (at least one required) ──────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
GROQ_API_KEY=gsk_...                  # May 403 from some networks (Bali)
OLLAMA_BASE_URL=http://localhost:11434 # Local Ollama instance

# ── Evolution & Autonomy ─────────────────────────────────────
# CRITICAL: Set these to enable real (non-shadow) evolution
DHARMA_EVOLUTION_SHADOW=0             # 0=real mutation, 1=dry-run (default: 1)
DGC_AUTONOMY_LEVEL=2                  # 0=passive, 1=suggest, 2=act (default: 1)

# ── Optional Providers ───────────────────────────────────────
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
MOONSHOT_API_KEY=...
LANGFUSE_PUBLIC_KEY=...               # Observability (optional)
LANGFUSE_SECRET_KEY=...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Guardian Crew ────────────────────────────────────────────
GUARDIAN_INTERVAL_SECONDS=14400       # 4 hours (default)

# ── Knowledge & Memory ───────────────────────────────────────
ENABLE_KNOWLEDGE_EXTRACTION=true
DHARMA_STATE_DIR=~/.dharma            # Where all state is written

# ── Ginko Trading Bridge (optional) ─────────────────────────
GINKO_WEBHOOK_URL=...
GINKO_DAILY_BUDGET=100
GINKO_WEEKLY_BUDGET=500

# ── Feature Flags ────────────────────────────────────────────
DHARMA_FAST_BOOT=false
ENABLE_EFE_ROUTING=true
ENABLE_FITNESS_ROUTING=true
