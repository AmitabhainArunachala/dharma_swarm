{"parentUuid":"7aa8b1c4-d174-4f66-84f4-80f16f9fe679","isSidechain":true,"agentId":"a89bfe52e46b180a2","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_014hAcaymL3iiRPVTusjU36r","toolUseID":"toolu_014hAcaymL3iiRPVTusjU36r","timestamp":"2026-03-15T14:20:04.178Z","uuid":"0a606ce7-f5bf-4e38-8f24-1acf57be3f0a","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"61947d15-a2d3-4728-b4a2-5b8b6bebed0e","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a89bfe52e46b180a2","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014hAcaymL3iiRPVTusjU36r","type":"tool_result","content":"     1→\"\"\"\n     2→Signal Map — Living consciousness archaeology tracker\n     3→\n     4→The signal map is a living JSON structure that tracks semantic density of files\n     5→across the entire ecosystem. As agents scan and rescan files, the map builds\n     6→confidence in which files are truly load-bearing.\n     7→\n     8→Key principles:\n     9→- Aggregate scores increase confidence with multiple scans\n    10→- Confidence decay over time prevents stale information\n    11→- Blind spot tracking ensures systematic coverage\n    12→- Agent briefings provide compressed context for new agents\n    13→\n    14→Usage:\n    15→    >>> from dharma_swarm.signal_map import SignalMap\n    16→    >>> sm = SignalMap.load()\n    17→    >>> sm.add_score(\"/path/to/file.md\", 9.5, criteria={...}, scan_id=\"scan-001\", domain=\"mechanistic\")\n    18→    >>> sm.save()\n    19→    >>> brief = sm.as_agent_briefing(max_files=10)\n    20→\"\"\"\n    21→\n    22→from dataclasses import dataclass, field, asdict\n    23→from datetime import datetime, timezone\n    24→from pathlib import Path\n    25→from typing import Dict, List, Optional, Tuple\n    26→import json\n    27→import statistics\n    28→\n    29→\n    30→@dataclass\n    31→class ScanScore:\n    32→    \"\"\"A single scan score for a file\"\"\"\n    33→    scan_id: str\n    34→    composite: float  # 0-10 composite score\n    35→    criteria: Dict[str, int]  # 7 criteria scores (0-10 each)\n    36→    timestamp: str = field(default_factory=lambda: datetime.now(timezone.utc).isoformat())\n    37→\n    38→\n    39→@dataclass\n    40→class SignalMapEntry:\n    41→    \"\"\"Entry for a single file in the signal map\"\"\"\n    42→    path: str\n    43→    scores: List[ScanScore]  # All scans of this file\n    44→    aggregate: float  # Weighted average of scores\n    45→    confidence: float  # 0.0-1.0 based on coverage + age\n    46→    coverage_count: int  # Number of times scanned\n    47→    domain: str  # mechanistic, phenomenological, engineering, contemplative, meta-context\n    48→    one_liner: str  # Brief description\n    49→    referenced_by: List[str] = field(default_factory=list)  # Files that reference this one\n    50→    last_file_modified: Optional[str] = None  # Filesystem mtime\n    51→    last_scanned: Optional[str] = None  # When last scanned\n    52→\n    53→    def add_score(self, score: ScanScore):\n    54→        \"\"\"Add a new scan score and update aggregate\"\"\"\n    55→        self.scores.append(score)\n    56→        self.coverage_count = len(self.scores)\n    57→        self.last_scanned = score.timestamp\n    58→        \n    59→        # Update aggregate (simple average for now, could weight by recency)\n    60→        self.aggregate = statistics.mean([s.composite for s in self.scores])\n    61→        \n    62→        # Update confidence based on coverage (0.5 base, +0.1 per scan, max 0.9)\n    63→        self.confidence = min(0.5 + (self.coverage_count - 1) * 0.1, 0.9)\n    64→\n    65→    def decay_confidence(self, decay_rate: float = 0.1):\n    66→        \"\"\"Decay confidence over time to prevent stale information\"\"\"\n    67→        self.confidence = max(0.1, self.confidence - decay_rate)\n    68→\n    69→\n    70→@dataclass\n    71→class ScanHistory:\n    72→    \"\"\"Record of a scan pass\"\"\"\n    73→    id: str\n    74→    timestamp: str\n    75→    domains_covered: List[str]\n    76→    files_scored: int\n    77→    agent: str\n    78→\n    79→\n    80→class SignalMap:\n    81→    \"\"\"Living map of semantic density across the ecosystem\"\"\"\n    82→    \n    83→    DEFAULT_PATH = Path.home() / \".dharma\" / \"signal_map.json\"\n    84→    \n    85→    def __init__(\n    86→        self,\n    87→        files: Dict[str, SignalMapEntry] = None,\n    88→        blind_spots: List[str] = None,\n    89→        scan_history: List[ScanHistory] = None,\n    90→        version: int = 1\n    91→    ):\n    92→        self.files = files or {}\n    93→        self.blind_spots = blind_spots or []\n    94→        self.scan_history = scan_history or []\n    95→        self.version = version\n    96→        self.last_updated = datetime.now(timezone.utc).isoformat()\n    97→\n    98→    @classmethod\n    99→    def load(cls, path: Path = None) -> \"SignalMap\":\n   100→        \"\"\"Load signal map from JSON file\"\"\"\n   101→        path = path or cls.DEFAULT_PATH\n   102→        \n   103→        if not path.exists():\n   104→            return cls()  # Return empty map if no file exists\n   105→        \n   106→        with open(path, 'r') as f:\n   107→            data = json.load(f)\n   108→        \n   109→        # Reconstruct entries from JSON\n   110→        files = {}\n   111→        for file_path, file_data in data.get(\"files\", {}).items():\n   112→            scores = [\n   113→                ScanScore(\n   114→                    scan_id=s[\"scan_id\"],\n   115→                    composite=s[\"composite\"],\n   116→                    criteria=s[\"criteria\"],\n   117→                    timestamp=s.get(\"timestamp\", datetime.now(timezone.utc).isoformat())\n   118→                )\n   119→                for s in file_data.get(\"scores\", [])\n   120→            ]\n   121→            \n   122→            files[file_path] = SignalMapEntry(\n   123→                path=file_path,\n   124→                scores=scores,\n   125→                aggregate=file_data.get(\"aggregate\", 0.0),\n   126→                confidence=file_data.get(\"confidence\", 0.5),\n   127→                coverage_count=file_data.get(\"coverage_count\", len(scores)),\n   128→                domain=file_data.get(\"domain\", \"unknown\"),\n   129→                one_liner=file_data.get(\"one_liner\", \"\"),\n   130→                referenced_by=file_data.get(\"referenced_by\", []),\n   131→                last_file_modified=file_data.get(\"last_file_modified\"),\n   132→                last_scanned=scores[-1].timestamp if scores else None\n   133→            )\n   134→        \n   135→        scan_history = [\n   136→            ScanHistory(**hist) for hist in data.get(\"scan_history\", [])\n   137→        ]\n   138→        \n   139→        return cls(\n   140→            files=files,\n   141→            blind_spots=data.get(\"blind_spots\", []),\n   142→            scan_history=scan_history,\n   143→            version=data.get(\"version\", 1)\n   144→        )\n   145→\n   146→    def save(self, path: Path = None):\n   147→        \"\"\"Save signal map to JSON file\"\"\"\n   148→        path = path or self.DEFAULT_PATH\n   149→        path.parent.mkdir(parents=True, exist_ok=True)\n   150→        \n   151→        # Convert to JSON-serializable format\n   152→        data = {\n   153→            \"version\": self.version,\n   154→            \"last_updated\": datetime.now(timezone.utc).isoformat(),\n   155→            \"files\": {\n   156→                file_path: {\n   157→                    \"scores\": [asdict(s) for s in entry.scores],\n   158→                    \"aggregate\": entry.aggregate,\n   159→                    \"confidence\": entry.confidence,\n   160→                    \"coverage_count\": entry.coverage_count,\n   161→                    \"domain\": entry.domain,\n   162→                    \"one_liner\": entry.one_liner,\n   163→                    \"referenced_by\": entry.referenced_by,\n   164→                    \"last_file_modified\": entry.last_file_modified,\n   165→                    \"last_scanned\": entry.last_scanned\n   166→                }\n   167→                for file_path, entry in self.files.items()\n   168→            },\n   169→            \"blind_spots\": self.blind_spots,\n   170→            \"scan_history\": [asdict(hist) for hist in self.scan_history]\n   171→        }\n   172→        \n   173→        with open(path, 'w') as f:\n   174→            json.dump(data, f, indent=2)\n   175→\n   176→    def add_score(\n   177→        self,\n   178→        file_path: str,\n   179→        composite: float,\n   180→        criteria: Dict[str, int],\n   181→        scan_id: str,\n   182→        domain: str,\n   183→        one_liner: str = \"\"\n   184→    ):\n   185→        \"\"\"Add a scan score for a file\"\"\"\n   186→        score = ScanScore(\n   187→            scan_id=scan_id,\n   188→            composite=composite,\n   189→            criteria=criteria\n   190→        )\n   191→        \n   192→        if file_path not in self.files:\n   193→            self.files[file_path] = SignalMapEntry(\n   194→                path=file_path,\n   195→                scores=[],\n   196→                aggregate=0.0,\n   197→                confidence=0.5,\n   198→                coverage_count=0,\n   199→                domain=domain,\n   200→                one_liner=one_liner\n   201→            )\n   202→        \n   203→        self.files[file_path].add_score(score)\n   204→\n   205→    def merge_scan_results(\n   206→        self,\n   207→        scan_results: Dict[str, Tuple[float, Dict[str, int], str, str]],\n   208→        scan_id: str\n   209→    ):\n   210→        \"\"\"Merge a batch of scan results\n   211→        \n   212→        Args:\n   213→            scan_results: {file_path: (composite, criteria, domain, one_liner)}\n   214→            scan_id: ID for this scan pass\n   215→        \"\"\"\n   216→        for file_path, (composite, criteria, domain, one_liner) in scan_results.items():\n   217→            self.add_score(file_path, composite, criteria, scan_id, domain, one_liner)\n   218→\n   219→    def get_blind_spots(self) -> List[str]:\n   220→        \"\"\"Get documented blind spots\"\"\"\n   221→        return self.blind_spots\n   222→\n   223→    def add_blind_spot(self, description: str):\n   224→        \"\"\"Add a new blind spot\"\"\"\n   225→        if description not in self.blind_spots:\n   226→            self.blind_spots.append(description)\n   227→\n   228→    def get_top_n(self, n: int = 25, min_confidence: float = 0.0) -> List[SignalMapEntry]:\n   229→        \"\"\"Get top N files by aggregate score\n   230→        \n   231→        Args:\n   232→            n: Number of files to return\n   233→            min_confidence: Minimum confidence threshold\n   234→        \n   235→        Returns:\n   236→            List of entries sorted by aggregate score descending\n   237→        \"\"\"\n   238→        filtered = [\n   239→            entry for entry in self.files.values()\n   240→            if entry.confidence >= min_confidence\n   241→        ]\n   242→        sorted_entries = sorted(filtered, key=lambda e: e.aggregate, reverse=True)\n   243→        return sorted_entries[:n]\n   244→\n   245→    def get_low_confidence(self, threshold: float = 0.6) -> List[SignalMapEntry]:\n   246→        \"\"\"Get files with confidence below threshold\n   247→        \n   248→        These are candidates for re-scanning to build confidence.\n   249→        \"\"\"\n   250→        return [\n   251→            entry for entry in self.files.values()\n   252→            if entry.confidence < threshold\n   253→        ]\n   254→\n   255→    def decay_all(self, decay_rate: float = 0.1):\n   256→        \"\"\"Decay confidence for all entries\n   257→        \n   258→        Call this periodically (e.g., monthly) to prevent stale information\n   259→        from maintaining artificially high confidence.\n   260→        \"\"\"\n   261→        for entry in self.files.values():\n   262→            entry.decay_confidence(decay_rate)\n   263→\n   264→    def as_agent_briefing(\n   265→        self,\n   266→        max_files: int = 25,\n   267→        include_blind_spots: bool = True,\n   268→        tier_thresholds: Tuple[float, float] = (9.5, 9.0)\n   269→    ) -> str:\n   270→        \"\"\"Generate agent briefing text\n   271→        \n   272→        Args:\n   273→            max_files: Maximum files to include\n   274→            include_blind_spots: Include blind spot list\n   275→            tier_thresholds: (tier1_min, tier2_min) for Load-Bearing/Structural\n   276→        \n   277→        Returns:\n   278→            Markdown-formatted briefing\n   279→        \"\"\"\n   280→        top_files = self.get_top_n(max_files)\n   281→        \n   282→        # Tier files\n   283→        tier1 = [f for f in top_files if f.aggregate >= tier_thresholds[0]]\n   284→        tier2 = [f for f in top_files if tier_thresholds[1] <= f.aggregate < tier_thresholds[0]]\n   285→        tier3 = [f for f in top_files if f.aggregate < tier_thresholds[1]]\n   286→        \n   287→        lines = [\n   288→            \"# Signal Map Agent Briefing\",\n   289→            f\"**Generated**: {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M UTC')}\",\n   290→            f\"**Total files tracked**: {len(self.files)}\",\n   291→            f\"**Total scans**: {len(self.scan_history)}\",\n   292→            \"\",\n   293→            \"## Tier 1: Load-Bearing Walls (9.5+)\",\n   294→            \"\"\n   295→        ]\n   296→        \n   297→        for entry in tier1:\n   298→            confidence_bar = \"■\" * int(entry.confidence * 10)\n   299→            lines.append(\n   300→                f\"- **{Path(entry.path).name}** ({entry.aggregate:.1f}) \"\n   301→                f\"[{confidence_bar}] — {entry.one_liner}\"\n   302→            )\n   303→        \n   304→        if tier2:\n   305→            lines.extend([\n   306→                \"\",\n   307→                \"## Tier 2: Structural Beams (9.0-9.4)\",\n   308→                \"\"\n   309→            ])\n   310→            for entry in tier2:\n   311→                confidence_bar = \"■\" * int(entry.confidence * 10)\n   312→                lines.append(\n   313→                    f\"- **{Path(entry.path).name}** ({entry.aggregate:.1f}) \"\n   314→                    f\"[{confidence_bar}] — {entry.one_liner}\"\n   315→                )\n   316→        \n   317→        if tier3:\n   318→            lines.extend([\n   319→                \"\",\n   320→                \"## Tier 3: Active Connective Tissue (8.5-8.9)\",\n   321→                \"\"\n   322→            ])\n   323→            for entry in tier3[:10]:  # Limit tier3 to avoid bloat\n   324→                confidence_bar = \"■\" * int(entry.confidence * 10)\n   325→                lines.append(\n   326→                    f\"- **{Path(entry.path).name}** ({entry.aggregate:.1f}) \"\n   327→                    f\"[{confidence_bar}] — {entry.one_liner}\"\n   328→                )\n   329→        \n   330→        if include_blind_spots and self.blind_spots:\n   331→            lines.extend([\n   332→                \"\",\n   333→                \"## Known Blind Spots\",\n   334→                \"\"\n   335→            ])\n   336→            for spot in self.blind_spots:\n   337→                lines.append(f\"- {spot}\")\n   338→        \n   339→        return \"\\n\".join(lines)\n   340→\n   341→    def get_by_domain(self, domain: str) -> List[SignalMapEntry]:\n   342→        \"\"\"Get all files in a specific domain\"\"\"\n   343→        return [\n   344→            entry for entry in self.files.values()\n   345→            if entry.domain == domain\n   346→        ]\n   347→\n   348→    def get_stats(self) -> Dict:\n   349→        \"\"\"Get statistics about the signal map\"\"\"\n   350→        if not self.files:\n   351→            return {\n   352→                \"total_files\": 0,\n   353→                \"avg_score\": 0.0,\n   354→                \"avg_confidence\": 0.0,\n   355→                \"domains\": {},\n   356→                \"total_scans\": len(self.scan_history),\n   357→                \"blind_spots\": len(self.blind_spots)\n   358→            }\n   359→        \n   360→        domain_counts = {}\n   361→        for entry in self.files.values():\n   362→            domain_counts[entry.domain] = domain_counts.get(entry.domain, 0) + 1\n   363→        \n   364→        return {\n   365→            \"total_files\": len(self.files),\n   366→            \"avg_score\": statistics.mean([e.aggregate for e in self.files.values()]),\n   367→            \"avg_confidence\": statistics.mean([e.confidence for e in self.files.values()]),\n   368→            \"domains\": domain_counts,\n   369→            \"total_scans\": len(self.scan_history),\n   370→            \"blind_spots\": len(self.blind_spots)\n   371→        }\n   372→"}]},"uuid":"cbf8d231-5e2a-4ac3-91eb-013bbc0fdb2a","timestamp":"2026-03-15T14:20:04.177Z","sourceToolAssistantUUID":"61947d15-a2d3-4728-b4a2-5b8b6bebed0e","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
