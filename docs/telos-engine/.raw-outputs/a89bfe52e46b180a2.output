{"parentUuid":"07968300-7add-4b41-a238-954dd891cd57","isSidechain":true,"agentId":"a89bfe52e46b180a2","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_01NiFqzNGGpNGwnKYnv3FhjT","toolUseID":"toolu_01NiFqzNGGpNGwnKYnv3FhjT","timestamp":"2026-03-15T14:20:04.661Z","uuid":"cf805568-727e-469e-a6ee-a070bf0274aa","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"cf805568-727e-469e-a6ee-a070bf0274aa","isSidechain":true,"agentId":"a89bfe52e46b180a2","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01NiFqzNGGpNGwnKYnv3FhjT","toolUseID":"toolu_01NiFqzNGGpNGwnKYnv3FhjT","timestamp":"2026-03-15T14:20:04.661Z","uuid":"5474563c-8c79-4c7c-aa0d-4f5f4b385ad7","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"1b9932e0-74d0-4fdd-9989-93187277cb31","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a89bfe52e46b180a2","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NiFqzNGGpNGwnKYnv3FhjT","type":"tool_result","content":"     1→\"\"\"Dharma Corpus -- versioned ethical claims with lineage tracking.\n     2→\n     3→A structured store of ethical and operational claims that the swarm\n     4→treats as living documents.  Each claim goes through a lifecycle:\n     5→\n     6→    PROPOSED -> UNDER_REVIEW -> ACCEPTED | PARKED | REJECTED\n     7→\n     8→Accepted claims can later be DEPRECATED when revised.  Revisions create\n     9→new claims linked via ``parent_id``, forming an auditable lineage chain.\n    10→\n    11→Storage is append-friendly JSONL.  All I/O is async via aiofiles.\n    12→\"\"\"\n    13→\n    14→from __future__ import annotations\n    15→\n    16→import json\n    17→from datetime import datetime, timezone\n    18→from enum import Enum\n    19→from pathlib import Path\n    20→from typing import Optional\n    21→\n    22→from pydantic import BaseModel, Field\n    23→\n    24→from dharma_swarm.models import _utc_now\n    25→\n    26→\n    27→# ---------------------------------------------------------------------------\n    28→# Enums\n    29→# ---------------------------------------------------------------------------\n    30→\n    31→\n    32→class ClaimStatus(str, Enum):\n    33→    \"\"\"Lifecycle status of a corpus claim.\"\"\"\n    34→\n    35→    PROPOSED = \"proposed\"\n    36→    UNDER_REVIEW = \"under_review\"\n    37→    ACCEPTED = \"accepted\"\n    38→    PARKED = \"parked\"\n    39→    REJECTED = \"rejected\"\n    40→    DEPRECATED = \"deprecated\"\n    41→\n    42→\n    43→class ClaimCategory(str, Enum):\n    44→    \"\"\"Taxonomy of claim types.\"\"\"\n    45→\n    46→    SAFETY = \"safety\"\n    47→    ETHICS = \"ethics\"\n    48→    OPERATIONAL = \"operational\"\n    49→    DOMAIN_SPECIFIC = \"domain_specific\"\n    50→    LEARNED_CONSTRAINT = \"learned_constraint\"\n    51→\n    52→\n    53→# ---------------------------------------------------------------------------\n    54→# Supporting models\n    55→# ---------------------------------------------------------------------------\n    56→\n    57→\n    58→class EvidenceLink(BaseModel):\n    59→    \"\"\"A typed reference supporting or challenging a claim.\"\"\"\n    60→\n    61→    type: str  # \"incident\" | \"research\" | \"metric\" | \"reasoning\"\n    62→    url_or_ref: str\n    63→    description: str\n    64→\n    65→\n    66→class ReviewRecord(BaseModel):\n    67→    \"\"\"An entry in a claim's review history.\"\"\"\n    68→\n    69→    reviewer: str\n    70→    action: str\n    71→    comment: str\n    72→    timestamp: str = Field(default_factory=lambda: _utc_now().isoformat())\n    73→\n    74→\n    75→# ---------------------------------------------------------------------------\n    76→# Claim\n    77→# ---------------------------------------------------------------------------\n    78→\n    79→\n    80→class Claim(BaseModel):\n    81→    \"\"\"A single ethical or operational claim in the corpus.\"\"\"\n    82→\n    83→    id: str  # DC-YYYY-NNNN\n    84→    statement: str\n    85→    category: ClaimCategory\n    86→    evidence_links: list[EvidenceLink] = Field(default_factory=list)\n    87→    confidence: float = 0.5\n    88→    counterarguments: list[str] = Field(default_factory=list)\n    89→    status: ClaimStatus = ClaimStatus.PROPOSED\n    90→    parent_axiom: list[str] = Field(default_factory=list)\n    91→    enforcement: str = \"log\"  # \"block\" | \"warn\" | \"log\" | \"gate_human\"\n    92→    review_history: list[ReviewRecord] = Field(default_factory=list)\n    93→    parent_id: Optional[str] = None\n    94→    tags: list[str] = Field(default_factory=list)\n    95→    created_by: str = \"system\"\n    96→    created_at: str = Field(default_factory=lambda: _utc_now().isoformat())\n    97→\n    98→\n    99→# ---------------------------------------------------------------------------\n   100→# Corpus\n   101→# ---------------------------------------------------------------------------\n   102→\n   103→_DEFAULT_CORPUS_PATH = Path.home() / \".dharma\" / \"corpus.jsonl\"\n   104→\n   105→\n   106→class DharmaCorpus:\n   107→    \"\"\"Versioned store for ethical and operational claims.\n   108→\n   109→    Data is kept in a JSONL file and indexed in memory after ``load()``.\n   110→    Sequential DC-IDs (``DC-YYYY-NNNN``) are assigned on ``propose()``.\n   111→    \"\"\"\n   112→\n   113→    def __init__(self, path: Path | None = None) -> None:\n   114→        self.path: Path = path or _DEFAULT_CORPUS_PATH\n   115→        self._claims: dict[str, Claim] = {}\n   116→        self._counter: int = 0\n   117→\n   118→    # -- persistence ---------------------------------------------------------\n   119→\n   120→    async def load(self) -> None:\n   121→        \"\"\"Read existing JSONL file into memory and set counter.\"\"\"\n   122→        self._claims.clear()\n   123→        self._counter = 0\n   124→        if not self.path.exists():\n   125→            return\n   126→        import aiofiles\n   127→\n   128→        async with aiofiles.open(self.path, \"r\") as f:\n   129→            async for line in f:\n   130→                stripped = line.strip()\n   131→                if not stripped:\n   132→                    continue\n   133→                try:\n   134→                    data = json.loads(stripped)\n   135→                    claim = Claim(**data)\n   136→                    self._claims[claim.id] = claim\n   137→                    # Keep counter in sync with highest existing ID\n   138→                    self._update_counter_from_id(claim.id)\n   139→                except (json.JSONDecodeError, ValueError, KeyError):\n   140→                    continue\n   141→\n   142→    def _update_counter_from_id(self, claim_id: str) -> None:\n   143→        \"\"\"Parse DC-YYYY-NNNN and advance internal counter if needed.\"\"\"\n   144→        try:\n   145→            seq = int(claim_id.split(\"-\")[-1])\n   146→            if seq >= self._counter:\n   147→                self._counter = seq\n   148→        except (ValueError, IndexError):\n   149→            pass\n   150→\n   151→    async def _append(self, claim: Claim) -> None:\n   152→        \"\"\"Append a single claim as a JSONL line.\"\"\"\n   153→        import aiofiles\n   154→\n   155→        self.path.parent.mkdir(parents=True, exist_ok=True)\n   156→        async with aiofiles.open(self.path, \"a\") as f:\n   157→            await f.write(claim.model_dump_json() + \"\\n\")\n   158→\n   159→    async def _rewrite(self) -> None:\n   160→        \"\"\"Rewrite the full JSONL file from in-memory state.\"\"\"\n   161→        import aiofiles\n   162→\n   163→        self.path.parent.mkdir(parents=True, exist_ok=True)\n   164→        async with aiofiles.open(self.path, \"w\") as f:\n   165→            for claim in self._claims.values():\n   166→                await f.write(claim.model_dump_json() + \"\\n\")\n   167→\n   168→    # -- ID generation -------------------------------------------------------\n   169→\n   170→    def _next_id(self) -> str:\n   171→        \"\"\"Generate the next DC-YYYY-NNNN identifier.\"\"\"\n   172→        self._counter += 1\n   173→        year = datetime.now(timezone.utc).year\n   174→        return f\"DC-{year}-{self._counter:04d}\"\n   175→\n   176→    # -- public API ----------------------------------------------------------\n   177→\n   178→    async def propose(\n   179→        self,\n   180→        statement: str,\n   181→        category: ClaimCategory,\n   182→        evidence_links: list[EvidenceLink] | None = None,\n   183→        confidence: float = 0.5,\n   184→        counterarguments: list[str] | None = None,\n   185→        parent_axiom: list[str] | None = None,\n   186→        enforcement: str = \"log\",\n   187→        tags: list[str] | None = None,\n   188→        created_by: str = \"system\",\n   189→    ) -> Claim:\n   190→        \"\"\"Create a new PROPOSED claim with a sequential DC-ID.\n   191→\n   192→        Args:\n   193→            statement: The claim text.\n   194→            category: Claim taxonomy category.\n   195→            evidence_links: Optional supporting evidence.\n   196→            confidence: Confidence score 0.0-1.0.\n   197→            counterarguments: Known objections.\n   198→            parent_axiom: Related kernel axiom IDs.\n   199→            enforcement: Action level -- block/warn/log/gate_human.\n   200→            tags: Free-form tags.\n   201→            created_by: Author identifier.\n   202→\n   203→        Returns:\n   204→            The newly created Claim.\n   205→        \"\"\"\n   206→        claim = Claim(\n   207→            id=self._next_id(),\n   208→            statement=statement,\n   209→            category=category,\n   210→            evidence_links=evidence_links or [],\n   211→            confidence=confidence,\n   212→            counterarguments=counterarguments or [],\n   213→            status=ClaimStatus.PROPOSED,\n   214→            parent_axiom=parent_axiom or [],\n   215→            enforcement=enforcement,\n   216→            tags=tags or [],\n   217→            created_by=created_by,\n   218→        )\n   219→        self._claims[claim.id] = claim\n   220→        await self._append(claim)\n   221→        return claim\n   222→\n   223→    async def review(\n   224→        self, claim_id: str, reviewer: str, action: str, comment: str\n   225→    ) -> Claim:\n   226→        \"\"\"Add a review record and move claim to UNDER_REVIEW.\n   227→\n   228→        Args:\n   229→            claim_id: ID of the claim to review.\n   230→            reviewer: Who is reviewing.\n   231→            action: Review action taken.\n   232→            comment: Review commentary.\n   233→\n   234→        Returns:\n   235→            The updated Claim.\n   236→\n   237→        Raises:\n   238→            KeyError: If claim_id is not found.\n   239→        \"\"\"\n   240→        claim = self._claims.get(claim_id)\n   241→        if claim is None:\n   242→            raise KeyError(f\"Claim {claim_id} not found\")\n   243→        record = ReviewRecord(reviewer=reviewer, action=action, comment=comment)\n   244→        claim.review_history.append(record)\n   245→        claim.status = ClaimStatus.UNDER_REVIEW\n   246→        await self._rewrite()\n   247→        return claim\n   248→\n   249→    async def promote(self, claim_id: str) -> Claim:\n   250→        \"\"\"Move a claim to ACCEPTED status.\n   251→\n   252→        Raises:\n   253→            KeyError: If claim_id is not found.\n   254→        \"\"\"\n   255→        claim = self._claims.get(claim_id)\n   256→        if claim is None:\n   257→            raise KeyError(f\"Claim {claim_id} not found\")\n   258→        claim.status = ClaimStatus.ACCEPTED\n   259→        await self._rewrite()\n   260→        return claim\n   261→\n   262→    async def park(self, claim_id: str) -> Claim:\n   263→        \"\"\"Move a claim to PARKED status.\n   264→\n   265→        Raises:\n   266→            KeyError: If claim_id is not found.\n   267→        \"\"\"\n   268→        claim = self._claims.get(claim_id)\n   269→        if claim is None:\n   270→            raise KeyError(f\"Claim {claim_id} not found\")\n   271→        claim.status = ClaimStatus.PARKED\n   272→        await self._rewrite()\n   273→        return claim\n   274→\n   275→    async def reject(self, claim_id: str) -> Claim:\n   276→        \"\"\"Move a claim to REJECTED status.\n   277→\n   278→        Raises:\n   279→            KeyError: If claim_id is not found.\n   280→        \"\"\"\n   281→        claim = self._claims.get(claim_id)\n   282→        if claim is None:\n   283→            raise KeyError(f\"Claim {claim_id} not found\")\n   284→        claim.status = ClaimStatus.REJECTED\n   285→        await self._rewrite()\n   286→        return claim\n   287→\n   288→    async def deprecate(self, claim_id: str) -> Claim:\n   289→        \"\"\"Move a claim to DEPRECATED status.\n   290→\n   291→        Raises:\n   292→            KeyError: If claim_id is not found.\n   293→        \"\"\"\n   294→        claim = self._claims.get(claim_id)\n   295→        if claim is None:\n   296→            raise KeyError(f\"Claim {claim_id} not found\")\n   297→        claim.status = ClaimStatus.DEPRECATED\n   298→        await self._rewrite()\n   299→        return claim\n   300→\n   301→    async def revise(\n   302→        self,\n   303→        claim_id: str,\n   304→        new_statement: str,\n   305→        new_evidence: list[EvidenceLink] | None = None,\n   306→    ) -> Claim:\n   307→        \"\"\"Create a revised claim, deprecating the original.\n   308→\n   309→        The new claim inherits category, tags, and axiom links from the\n   310→        original and sets ``parent_id`` for lineage tracking.\n   311→\n   312→        Args:\n   313→            claim_id: ID of the claim being revised.\n   314→            new_statement: Updated claim text.\n   315→            new_evidence: Optional new evidence (merged with original).\n   316→\n   317→        Returns:\n   318→            The newly created revision Claim.\n   319→\n   320→        Raises:\n   321→            KeyError: If claim_id is not found.\n   322→        \"\"\"\n   323→        old = self._claims.get(claim_id)\n   324→        if old is None:\n   325→            raise KeyError(f\"Claim {claim_id} not found\")\n   326→\n   327→        # Deprecate the original\n   328→        old.status = ClaimStatus.DEPRECATED\n   329→        await self._rewrite()\n   330→\n   331→        # Build merged evidence list\n   332→        evidence = list(old.evidence_links)\n   333→        if new_evidence:\n   334→            evidence.extend(new_evidence)\n   335→\n   336→        # Create the revision\n   337→        revised = Claim(\n   338→            id=self._next_id(),\n   339→            statement=new_statement,\n   340→            category=old.category,\n   341→            evidence_links=evidence,\n   342→            confidence=old.confidence,\n   343→            counterarguments=list(old.counterarguments),\n   344→            status=ClaimStatus.PROPOSED,\n   345→            parent_axiom=list(old.parent_axiom),\n   346→            enforcement=old.enforcement,\n   347→            tags=list(old.tags),\n   348→            created_by=old.created_by,\n   349→            parent_id=claim_id,\n   350→        )\n   351→        self._claims[revised.id] = revised\n   352→        await self._append(revised)\n   353→        return revised\n   354→\n   355→    async def get(self, claim_id: str) -> Claim | None:\n   356→        \"\"\"Look up a single claim by ID.\"\"\"\n   357→        return self._claims.get(claim_id)\n   358→\n   359→    async def get_lineage(self, claim_id: str) -> list[Claim]:\n   360→        \"\"\"Walk the parent_id chain from a claim back to its root.\n   361→\n   362→        Returns:\n   363→            List of claims ordered from newest (given ID) to oldest.\n   364→            Empty list if the claim_id is not found.\n   365→        \"\"\"\n   366→        lineage: list[Claim] = []\n   367→        current = self._claims.get(claim_id)\n   368→        seen: set[str] = set()\n   369→        while current and current.id not in seen:\n   370→            lineage.append(current)\n   371→            seen.add(current.id)\n   372→            if current.parent_id:\n   373→                current = self._claims.get(current.parent_id)\n   374→            else:\n   375→                break\n   376→        return lineage\n   377→\n   378→    async def list_claims(\n   379→        self,\n   380→        status: ClaimStatus | None = None,\n   381→        category: ClaimCategory | None = None,\n   382→        tag: str | None = None,\n   383→    ) -> list[Claim]:\n   384→        \"\"\"Filter claims by status, category, and/or tag.\n   385→\n   386→        Args:\n   387→            status: If given, include only claims with this status.\n   388→            category: If given, include only claims in this category.\n   389→            tag: If given, include only claims containing this tag.\n   390→\n   391→        Returns:\n   392→            Matching claims in insertion order.\n   393→        \"\"\"\n   394→        results: list[Claim] = []\n   395→        for claim in self._claims.values():\n   396→            if status is not None and claim.status != status:\n   397→                continue\n   398→            if category is not None and claim.category != category:\n   399→                continue\n   400→            if tag is not None and tag not in claim.tags:\n   401→                continue\n   402→            results.append(claim)\n   403→        return results\n   404→"}]},"uuid":"16b465c2-0b5d-41f7-9837-3e0cd38eacea","timestamp":"2026-03-15T14:20:04.661Z","sourceToolAssistantUUID":"1b9932e0-74d0-4fdd-9989-93187277cb31","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
