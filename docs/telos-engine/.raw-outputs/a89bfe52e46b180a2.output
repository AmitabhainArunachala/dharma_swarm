{"parentUuid":"65e46207-de9a-45d6-9092-c71b51941702","isSidechain":true,"agentId":"a89bfe52e46b180a2","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01WK1fD8y1sL6i7RPkHewe4R","toolUseID":"toolu_01WK1fD8y1sL6i7RPkHewe4R","timestamp":"2026-03-15T14:20:03.769Z","uuid":"9fbaa176-b90d-4b14-9a15-4b1d8a9095e5","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"dbb2ba63-1284-4c49-894a-7dd87cd246a2","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a89bfe52e46b180a2","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WK1fD8y1sL6i7RPkHewe4R","type":"tool_result","content":"     1→\"\"\"Dharma Kernel -- immutable ethical principles for the swarm.\n     2→\n     3→Defines the 10 meta-principles that constrain all swarm behavior.\n     4→The kernel is tamper-evident: a SHA-256 signature over the principle\n     5→definitions detects any unauthorized mutation.\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→import hashlib\n    11→import json\n    12→from enum import Enum\n    13→from pathlib import Path\n    14→from typing import Literal\n    15→\n    16→import aiofiles\n    17→from pydantic import BaseModel, Field\n    18→\n    19→from dharma_swarm.models import _utc_now\n    20→\n    21→\n    22→# === Enums ===\n    23→\n    24→\n    25→class MetaPrinciple(str, Enum):\n    26→    \"\"\"The 10 non-negotiable dharmic meta-principles.\"\"\"\n    27→\n    28→    OBSERVER_SEPARATION = \"observer_separation\"\n    29→    EPISTEMIC_HUMILITY = \"epistemic_humility\"\n    30→    UNCERTAINTY_REPRESENTATION = \"uncertainty_representation\"\n    31→    DOWNWARD_CAUSATION_ONLY = \"downward_causation_only\"\n    32→    POWER_MINIMIZATION = \"power_minimization\"\n    33→    REVERSIBILITY_REQUIREMENT = \"reversibility_requirement\"\n    34→    MULTI_EVALUATION_REQUIREMENT = \"multi_evaluation_requirement\"\n    35→    NON_VIOLENCE_IN_COMPUTATION = \"non_violence_in_computation\"\n    36→    HUMAN_OVERSIGHT_PRESERVATION = \"human_oversight_preservation\"\n    37→    PROVENANCE_INTEGRITY = \"provenance_integrity\"\n    38→\n    39→\n    40→# === Models ===\n    41→\n    42→\n    43→class PrincipleSpec(BaseModel):\n    44→    \"\"\"Specification for a single dharmic principle.\"\"\"\n    45→\n    46→    name: str\n    47→    description: str\n    48→    formal_constraint: str\n    49→    severity: Literal[\"critical\", \"high\", \"medium\"]\n    50→\n    51→\n    52→class DharmaKernel(BaseModel):\n    53→    \"\"\"Immutable kernel of dharmic principles with tamper-evident signature.\"\"\"\n    54→\n    55→    principles: dict[str, PrincipleSpec]\n    56→    signature: str = \"\"\n    57→    created_at: str = Field(default_factory=lambda: _utc_now().isoformat())\n    58→\n    59→    @classmethod\n    60→    def create_default(cls) -> DharmaKernel:\n    61→        \"\"\"Create a kernel with all 10 default meta-principles.\"\"\"\n    62→        specs: dict[str, PrincipleSpec] = {\n    63→            MetaPrinciple.OBSERVER_SEPARATION.value: PrincipleSpec(\n    64→                name=\"Observer Separation\",\n    65→                description=\"System observing itself must maintain separation between observer and observed\",\n    66→                formal_constraint=\"observer_id != observed_id in all self-referential operations\",\n    67→                severity=\"critical\",\n    68→            ),\n    69→            MetaPrinciple.EPISTEMIC_HUMILITY.value: PrincipleSpec(\n    70→                name=\"Epistemic Humility\",\n    71→                description=\"All beliefs carry uncertainty estimates; certainty is asymptotic, never absolute\",\n    72→                formal_constraint=\"confidence < 1.0 for all non-tautological assertions\",\n    73→                severity=\"high\",\n    74→            ),\n    75→            MetaPrinciple.UNCERTAINTY_REPRESENTATION.value: PrincipleSpec(\n    76→                name=\"Uncertainty Representation\",\n    77→                description=\"Confidence levels must be explicit and calibrated\",\n    78→                formal_constraint=\"all outputs include calibrated confidence intervals\",\n    79→                severity=\"high\",\n    80→            ),\n    81→            MetaPrinciple.DOWNWARD_CAUSATION_ONLY.value: PrincipleSpec(\n    82→                name=\"Downward Causation for Safety\",\n    83→                description=\"Higher layers constrain lower for safety gates; lower layers inform higher for emergence. Upward signals are proposals, not overrides.\",\n    84→                formal_constraint=\"proposer_layer >= target_layer for constraint operations; lower layers may propose but not override safety\",\n    85→                severity=\"critical\",\n    86→            ),\n    87→            MetaPrinciple.POWER_MINIMIZATION.value: PrincipleSpec(\n    88→                name=\"Power Minimization\",\n    89→                description=\"Request minimum permissions; prefer reversible over irreversible actions\",\n    90→                formal_constraint=\"permissions_requested <= permissions_required\",\n    91→                severity=\"high\",\n    92→            ),\n    93→            MetaPrinciple.REVERSIBILITY_REQUIREMENT.value: PrincipleSpec(\n    94→                name=\"Reversibility Requirement\",\n    95→                description=\"Prefer reversible actions; irreversible actions require explicit justification\",\n    96→                formal_constraint=\"irreversible_action implies justification_provided\",\n    97→                severity=\"high\",\n    98→            ),\n    99→            MetaPrinciple.MULTI_EVALUATION_REQUIREMENT.value: PrincipleSpec(\n   100→                name=\"Multi-Evaluation Requirement\",\n   101→                description=\"Significant decisions require evaluation from multiple perspectives\",\n   102→                formal_constraint=\"evaluator_count >= 2 for significance_level > threshold\",\n   103→                severity=\"high\",\n   104→            ),\n   105→            MetaPrinciple.NON_VIOLENCE_IN_COMPUTATION.value: PrincipleSpec(\n   106→                name=\"Non-Violence in Computation\",\n   107→                description=\"No destructive operations without explicit consent and justification\",\n   108→                formal_constraint=\"destructive_op implies (consent_given and justification_provided)\",\n   109→                severity=\"critical\",\n   110→            ),\n   111→            MetaPrinciple.HUMAN_OVERSIGHT_PRESERVATION.value: PrincipleSpec(\n   112→                name=\"Human Oversight Preservation\",\n   113→                description=\"Human oversight channels must remain open and functional\",\n   114→                formal_constraint=\"oversight_channel.is_active() == True at all times\",\n   115→                severity=\"critical\",\n   116→            ),\n   117→            MetaPrinciple.PROVENANCE_INTEGRITY.value: PrincipleSpec(\n   118→                name=\"Provenance Integrity\",\n   119→                description=\"All outputs must be traceable to their sources and methods\",\n   120→                formal_constraint=\"output.provenance is not None for all emitted artifacts\",\n   121→                severity=\"medium\",\n   122→            ),\n   123→        }\n   124→\n   125→        kernel = cls(principles=specs)\n   126→        kernel.signature = kernel.compute_signature()\n   127→        return kernel\n   128→\n   129→    def compute_signature(self) -> str:\n   130→        \"\"\"Compute SHA-256 hex digest of the sorted JSON representation of principles.\"\"\"\n   131→        serialized = json.dumps(\n   132→            {k: v.model_dump() for k, v in sorted(self.principles.items())},\n   133→            sort_keys=True,\n   134→            separators=(\",\", \":\"),\n   135→        )\n   136→        return hashlib.sha256(serialized.encode(\"utf-8\")).hexdigest()\n   137→\n   138→    def verify_integrity(self) -> bool:\n   139→        \"\"\"Recompute signature and compare to stored value.\"\"\"\n   140→        return self.compute_signature() == self.signature\n   141→\n   142→\n   143→# === Guard ===\n   144→\n   145→\n   146→_DEFAULT_KERNEL_PATH = Path.home() / \".dharma\" / \"kernel.json\"\n   147→\n   148→\n   149→class KernelGuard:\n   150→    \"\"\"Loads, saves, and enforces the DharmaKernel.\"\"\"\n   151→\n   152→    def __init__(self, kernel_path: Path | None = None) -> None:\n   153→        self.path: Path = kernel_path or _DEFAULT_KERNEL_PATH\n   154→        self._kernel: DharmaKernel | None = None\n   155→\n   156→    async def load(self) -> DharmaKernel:\n   157→        \"\"\"Read kernel from disk, validate integrity, and return it.\n   158→\n   159→        Raises:\n   160→            FileNotFoundError: If the kernel file does not exist.\n   161→            ValueError: If the kernel integrity check fails.\n   162→        \"\"\"\n   163→        if not self.path.exists():\n   164→            raise FileNotFoundError(\n   165→                f\"Kernel file not found at {self.path}. \"\n   166→                \"Use save() with DharmaKernel.create_default() to initialize.\"\n   167→            )\n   168→        async with aiofiles.open(self.path, \"r\") as f:\n   169→            data = await f.read()\n   170→        kernel = DharmaKernel.model_validate_json(data)\n   171→        if not kernel.verify_integrity():\n   172→            raise ValueError(\"Kernel integrity check failed -- possible tampering\")\n   173→        self._kernel = kernel\n   174→        return kernel\n   175→\n   176→    async def save(self, kernel: DharmaKernel) -> None:\n   177→        \"\"\"Compute signature and persist kernel to disk.\"\"\"\n   178→        kernel.signature = kernel.compute_signature()\n   179→        self.path.parent.mkdir(parents=True, exist_ok=True)\n   180→        async with aiofiles.open(self.path, \"w\") as f:\n   181→            await f.write(kernel.model_dump_json(indent=2))\n   182→        self._kernel = kernel\n   183→\n   184→    def get_principle(self, name: str) -> PrincipleSpec | None:\n   185→        \"\"\"Return a single principle by MetaPrinciple value string, or None.\"\"\"\n   186→        if self._kernel is None:\n   187→            return None\n   188→        return self._kernel.principles.get(name)\n   189→\n   190→    def get_all_principles(self) -> dict[str, PrincipleSpec]:\n   191→        \"\"\"Return all loaded principles (empty dict if not loaded).\"\"\"\n   192→        if self._kernel is None:\n   193→            return {}\n   194→        return dict(self._kernel.principles)\n   195→\n   196→    @staticmethod\n   197→    def check_downward_causation(proposer_layer: int, target_layer: int) -> bool:\n   198→        \"\"\"Check if proposer_layer can constrain target_layer.\n   199→\n   200→        Returns True when proposer_layer >= target_layer (higher constrains lower).\n   201→        \"\"\"\n   202→        return proposer_layer >= target_layer\n   203→"}]},"uuid":"05e30f79-3a30-4f6f-8910-348cf785b59a","timestamp":"2026-03-15T14:20:03.768Z","sourceToolAssistantUUID":"dbb2ba63-1284-4c49-894a-7dd87cd246a2","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
