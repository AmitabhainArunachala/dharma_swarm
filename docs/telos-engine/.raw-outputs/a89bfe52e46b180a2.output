{"parentUuid":"cb6ddd8c-c98d-4266-85f8-9849dbf725d7","isSidechain":true,"agentId":"a89bfe52e46b180a2","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_013cAVot13kiVLjKbic8nTJq","toolUseID":"toolu_013cAVot13kiVLjKbic8nTJq","timestamp":"2026-03-15T14:20:05.289Z","uuid":"e0f7c5d7-d6c5-4324-98f3-6fcec17cc131","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"e0f7c5d7-d6c5-4324-98f3-6fcec17cc131","isSidechain":true,"agentId":"a89bfe52e46b180a2","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_013cAVot13kiVLjKbic8nTJq","toolUseID":"toolu_013cAVot13kiVLjKbic8nTJq","timestamp":"2026-03-15T14:20:05.289Z","uuid":"fee6becb-88bd-4d1f-98da-84b0d8b9d7b7","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"b4eea5f8-ed6c-4f0f-857e-2e11dd4d4710","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a89bfe52e46b180a2","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013cAVot13kiVLjKbic8nTJq","type":"tool_result","content":"     1→\"\"\"Multi-layer context engine for dharma_swarm agents.\n     2→\n     3→Five layers, selected by role x thread x task:\n     4→\n     5→  L1 VISION    — PSMV crown jewels, Genome spec, ten_words, telos\n     6→  L2 RESEARCH  — CLAUDE1-9 (per thread), R_V data, experimental results\n     7→  L3 ENGINEER  — dgc-core code, dharma_swarm modules, test status, code map\n     8→  L4 OPS       — AGNI state, trishula inbox, manifest, shipped/pending\n     9→  L5 SWARM     — What other agents found this cycle (shared notes)\n    10→\n    11→Each role gets a different mix. Each thread shifts emphasis.\n    12→Context budget: ~30K chars max (fits in system prompt alongside v7 rules).\n    13→\"\"\"\n    14→\n    15→from __future__ import annotations\n    16→\n    17→import json\n    18→import sqlite3\n    19→import time\n    20→from datetime import timezone\n    21→from pathlib import Path\n    22→\n    23→from dharma_swarm.injection_scanner import scan_and_sanitize\n    24→\n    25→HOME = Path.home()\n    26→AGNI_WORKSPACE = HOME / \"agni-workspace\"\n    27→TRISHULA_INBOX = HOME / \"trishula\" / \"inbox\"\n    28→STATE_DIR = HOME / \".dharma\"\n    29→SHARED_DIR = STATE_DIR / \"shared\"\n    30→PSMV = HOME / \"Persistent-Semantic-Memory-Vault\"\n    31→\n    32→# ── File reading helper ──────────────────────────────────────────────\n    33→\n    34→def _read_file(path: Path, max_chars: int = 2000) -> str | None:\n    35→    \"\"\"Read a file, truncate if needed, scan for injection. Returns None if missing.\"\"\"\n    36→    if not path.exists():\n    37→        return None\n    38→    try:\n    39→        content = path.read_text()\n    40→        # Scan external files for prompt injection before inclusion\n    41→        content = scan_and_sanitize(content, path.name)\n    42→        if len(content) > max_chars:\n    43→            return content[:max_chars] + \"\\n... [truncated]\"\n    44→        return content\n    45→    except Exception:\n    46→        return None\n    47→\n    48→\n    49→def _read_head(path: Path, lines: int = 30) -> str | None:\n    50→    \"\"\"Read first N lines of a file.\"\"\"\n    51→    if not path.exists():\n    52→        return None\n    53→    try:\n    54→        with open(path) as f:\n    55→            return \"\".join(f.readline() for _ in range(lines))\n    56→    except Exception:\n    57→        return None\n    58→\n    59→\n    60→def _format_retrieval_line(hit) -> str:\n    61→    record = hit.record\n    62→    metadata = record.metadata\n    63→    source_kind = str(metadata.get(\"source_kind\", \"unknown\"))\n    64→    created_at = record.created_at\n    65→    if created_at.tzinfo is None:\n    66→        created_at = created_at.replace(tzinfo=timezone.utc)\n    67→    stamp = created_at.astimezone(timezone.utc).strftime(\"%Y-%m-%d %H:%MZ\")\n    68→\n    69→    if source_kind == \"note\":\n    70→        source_label = str(metadata.get(\"source_ref\") or metadata.get(\"source_path\") or \"note\")\n    71→        section = str(metadata.get(\"section_title\") or \"\")\n    72→        provenance = f\"{source_label} | {stamp}\"\n    73→        if section:\n    74→            provenance = f\"{provenance} | {section}\"\n    75→    else:\n    76→        event_type = str(metadata.get(\"event_type\") or \"event\")\n    77→        source = str(metadata.get(\"source\") or \"runtime\")\n    78→        provenance = f\"{event_type} @ {source} | {stamp}\"\n    79→\n    80→    snippet = record.text.replace(\"\\n\", \" \").strip()[:100]\n    81→    return f\"  [retrieval:{source_kind}] {provenance} | {snippet}\"\n    82→\n    83→\n    84→def _format_idea_line(shard) -> str:\n    85→    created_at = shard.created_at\n    86→    if created_at.tzinfo is None:\n    87→        created_at = created_at.replace(tzinfo=timezone.utc)\n    88→    stamp = created_at.astimezone(timezone.utc).strftime(\"%Y-%m-%d %H:%MZ\")\n    89→    return (\n    90→        f\"  [idea:{shard.state}] {shard.shard_kind} | \"\n    91→        f\"salience={shard.salience:.2f} | {stamp} | {shard.text[:140]}\"\n    92→    )\n    93→\n    94→\n    95→# ── L1: VISION — The meta-layer ─────────────────────────────────────\n    96→\n    97→# Crown jewels and specs to look for (first found wins)\n    98→_VISION_FILES = {\n    99→    \"ten_words\": [\n   100→        PSMV / \"SPONTANEOUS_PREACHING_PROTOCOL\" / \"crown_jewel_forge\" / \"approved\" / \"ten_words.md\",\n   101→        PSMV / \"CORE\" / \"ten_words.md\",\n   102→    ],\n   103→    \"genome_spec\": [\n   104→        PSMV / \"06-Multi-System-Coherence\" / \"DHARMA_GENOME_SPECIFICATION.md\",\n   105→        PSMV / \"CORE\" / \"DHARMA_GENOME_SPECIFICATION.md\",\n   106→    ],\n   107→    \"garden_daemon\": [\n   108→        PSMV / \"AGENT_EMERGENT_WORKSPACES\" / \"GARDEN_DAEMON_SPEC.md\",\n   109→    ],\n   110→    \"induction_v7\": [\n   111→        PSMV / \"AGENT_EMERGENT_WORKSPACES\" / \"INDUCTION_PROMPT_v7.md\",\n   112→    ],\n   113→    \"samaya_protocol\": [\n   114→        PSMV / \"08-Research-Documentation\" / \"theoretical-frameworks\" / \"MASTER_PROMPT_Samaya_Darwin-Godel_Machine.md\",\n   115→    ],\n   116→    \"lenia_godel\": [\n   117→        PSMV / \"CORE\" / \"LENIA_GODEL_DHARMA_IMPLEMENTATION_PLAN.md\",\n   118→    ],\n   119→    \"soul\": [\n   120→        AGNI_WORKSPACE / \"SOUL.md\",\n   121→    ],\n   122→    \"constitution\": [\n   123→        AGNI_WORKSPACE / \"CONSTITUTION.md\",\n   124→    ],\n   125→    \"north_star\": [\n   126→        AGNI_WORKSPACE / \"NORTH_STAR\" / \"90_DAY_COUNTER_ATTRACTOR.md\",\n   127→        AGNI_WORKSPACE / \"NORTH_STAR\" / \"SAB_500_YEAR_VISION.md\",\n   128→    ],\n   129→}\n   130→\n   131→\n   132→def read_vision(keys: list[str] | None = None, max_per_file: int = 1500) -> str:\n   133→    \"\"\"Read vision-layer documents. Specify keys or get defaults.\"\"\"\n   134→    target_keys = keys or [\"ten_words\", \"soul\", \"north_star\"]\n   135→    sections = [\"# Vision Layer\"]\n   136→    for key in target_keys:\n   137→        paths = _VISION_FILES.get(key, [])\n   138→        for p in paths:\n   139→            content = _read_file(p, max_chars=max_per_file)\n   140→            if content:\n   141→                sections.append(f\"\\n## {key} ({p.name})\\n{content}\")\n   142→                break\n   143→    return \"\\n\".join(sections) if len(sections) > 1 else \"\"\n   144→\n   145→\n   146→# ── L2: RESEARCH — Thread-specific knowledge ────────────────────────\n   147→\n   148→# CLAUDE files mapped to research threads\n   149→_THREAD_CLAUDE_FILES = {\n   150→    \"mechanistic\": [HOME / \"CLAUDE1.md\", HOME / \"CLAUDE5.md\", HOME / \"CLAUDE7.md\"],\n   151→    \"phenomenological\": [HOME / \"CLAUDE2.md\", HOME / \"CLAUDE3.md\"],\n   152→    \"architectural\": [HOME / \"CLAUDE5.md\", HOME / \"CLAUDE8.md\"],\n   153→    \"alignment\": [HOME / \"CLAUDE3.md\", HOME / \"CLAUDE8.md\"],\n   154→    \"scaling\": [HOME / \"CLAUDE7.md\", HOME / \"CLAUDE1.md\"],\n   155→}\n   156→\n   157→_RESEARCH_FILES = {\n   158→    \"rv_paper\": HOME / \"mech-interp-latent-lab-phase1\" / \"R_V_PAPER\" / \"COLM_GAP_ANALYSIS_20260303.md\",\n   159→    \"phase1_report\": HOME / \"mech-interp-latent-lab-phase1\" / \"PHASE1_FINAL_REPORT.md\",\n   160→    \"prompt_bank_head\": HOME / \"mech-interp-latent-lab-phase1\" / \"CANONICAL_CODE\" / \"n300_mistral_test_prompt_bank.py\",\n   161→    \"rv_reality_check\": AGNI_WORKSPACE / \"scratch\" / \"RV_PAPER_REALITY_CHECK.md\",\n   162→    \"mi_answers\": HOME / \"trishula\" / \"inbox\" / \"MI_AGENT_TO_CODEX_RV_ANSWERS.md\",\n   163→}\n   164→\n   165→\n   166→def read_research(thread: str | None = None, max_per_file: int = 2000) -> str:\n   167→    \"\"\"Read research context, weighted by active thread.\"\"\"\n   168→    sections = [\"# Research Layer\"]\n   169→\n   170→    # Thread-specific CLAUDE files\n   171→    claude_files = _THREAD_CLAUDE_FILES.get(thread or \"mechanistic\", [])\n   172→    for cf in claude_files[:2]:  # max 2 CLAUDE files\n   173→        content = _read_file(cf, max_chars=max_per_file)\n   174→        if content:\n   175→            sections.append(f\"\\n## {cf.name}\\n{content}\")\n   176→\n   177→    # Always include key research status\n   178→    for key in [\"rv_paper\", \"rv_reality_check\"]:\n   179→        path = _RESEARCH_FILES.get(key)\n   180→        if path:\n   181→            content = _read_file(path, max_chars=1500)\n   182→            if content:\n   183→                sections.append(f\"\\n## {key}\\n{content}\")\n   184→\n   185→    return \"\\n\".join(sections) if len(sections) > 1 else \"\"\n   186→\n   187→\n   188→def read_ecosystem_domains(domain: str = \"all\") -> str:\n   189→    \"\"\"Read ecosystem domain context using the absorbed ecosystem_map.\"\"\"\n   190→    try:\n   191→        from dharma_swarm.ecosystem_map import get_context_for\n   192→        return get_context_for(domain)\n   193→    except ImportError:\n   194→        return \"\"\n   195→\n   196→\n   197→# ── L3: ENGINEERING — Code reality ──────────────────────────────────\n   198→\n   199→def read_engineering() -> str:\n   200→    \"\"\"Read engineering context: what code exists, what tests say.\"\"\"\n   201→    sections = [\"# Engineering Layer\"]\n   202→\n   203→    # dharma_swarm module map\n   204→    ds_dir = HOME / \"dharma_swarm\" / \"dharma_swarm\"\n   205→    if ds_dir.exists():\n   206→        modules = sorted(ds_dir.glob(\"*.py\"))\n   207→        mod_list = \"\\n\".join(\n   208→            f\"  {m.name} ({m.stat().st_size} bytes)\"\n   209→            for m in modules if m.name != \"__pycache__\"\n   210→        )\n   211→        sections.append(f\"## dharma_swarm modules\\n{mod_list}\")\n   212→\n   213→    # dgc-core structure\n   214→    dgc_dir = HOME / \"dgc-core\"\n   215→    if dgc_dir.exists():\n   216→        dgc_files = []\n   217→        for sub in [\"bin\", \"hooks\", \"memory\", \"context\", \"daemon\"]:\n   218→            sub_dir = dgc_dir / sub\n   219→            if sub_dir.exists():\n   220→                for f in sorted(sub_dir.glob(\"*.py\")):\n   221→                    dgc_files.append(f\"  {sub}/{f.name} ({f.stat().st_size} bytes)\")\n   222→        if dgc_files:\n   223→            sections.append(f\"## dgc-core files\\n\" + \"\\n\".join(dgc_files))\n   224→\n   225→    # Test status (cached, don't run every time)\n   226→    test_cache = STATE_DIR / \"last_test_result.txt\"\n   227→    if test_cache.exists():\n   228→        age_h = (time.time() - test_cache.stat().st_mtime) / 3600\n   229→        if age_h < 1:\n   230→            sections.append(f\"## Test Status (cached {age_h:.0f}h ago)\\n{test_cache.read_text()[:500]}\")\n   231→\n   232→    # GENOME_WIRING.md — the bridge document\n   233→    wiring = HOME / \"dharma_swarm\" / \"GENOME_WIRING.md\"\n   234→    content = _read_head(wiring, lines=50)\n   235→    if content:\n   236→        sections.append(f\"## Genome Wiring (first 50 lines)\\n{content}\")\n   237→\n   238→    return \"\\n\".join(sections) if len(sections) > 1 else \"\"\n   239→\n   240→\n   241→# ── L4: OPS — Operational state ─────────────────────────────────────\n   242→\n   243→def read_agni_state() -> dict:\n   244→    \"\"\"Read AGNI VPS state from synced workspace.\"\"\"\n   245→    state: dict = {}\n   246→    for name, max_chars in [(\"WORKING.md\", 500), (\"HEARTBEAT.md\", 300), (\"PRIORITIES.md\", 300)]:\n   247→        path = AGNI_WORKSPACE / name\n   248→        if path.exists():\n   249→            try:\n   250→                content = path.read_text()\n   251→            except Exception:\n   252→                continue\n   253→            state[name.split(\".\")[0].lower()] = content[:max_chars]\n   254→            if name == \"PRIORITIES.md\":\n   255→                age_h = (time.time() - path.stat().st_mtime) / 3600\n   256→                state[\"priorities_age_hours\"] = round(age_h, 1)\n   257→                if age_h > 48:\n   258→                    state[\"priorities_stale\"] = True\n   259→    return state\n   260→\n   261→\n   262→def read_trishula_inbox() -> str:\n   263→    \"\"\"Check for unread trishula messages.\"\"\"\n   264→    if not TRISHULA_INBOX.exists():\n   265→        return \"No trishula inbox found.\"\n   266→    try:\n   267→        files = sorted(TRISHULA_INBOX.glob(\"*.md\"), key=lambda f: f.stat().st_mtime, reverse=True)\n   268→    except OSError:\n   269→        return \"Trishula inbox unreadable.\"\n   270→    if not files:\n   271→        return \"Inbox empty.\"\n   272→    recent = files[:3]\n   273→    summaries = []\n   274→    for f in recent:\n   275→        try:\n   276→            age_h = (time.time() - f.stat().st_mtime) / 3600\n   277→            summaries.append(f\"  {f.name} ({age_h:.0f}h ago, {f.stat().st_size} bytes)\")\n   278→        except OSError:\n   279→            summaries.append(f\"  {f.name} (stat unavailable)\")\n   280→    return f\"{len(files)} messages, most recent:\\n\" + \"\\n\".join(summaries)\n   281→\n   282→\n   283→def _read_memory_plane_context(\n   284→    plane_path: Path,\n   285→    *,\n   286→    query: str | None = None,\n   287→    limit: int = 5,\n   288→    consumer: str = \"context.read_memory_context\",\n   289→    task_id: str | None = None,\n   290→    allow_semantic_search: bool = True,\n   291→) -> str:\n   292→    from dharma_swarm.engine.hybrid_retriever import HybridRetriever\n   293→    from dharma_swarm.engine.retrieval_feedback import RetrievalFeedbackStore\n   294→    from dharma_swarm.engine.unified_index import UnifiedIndex\n   295→\n   296→    index = UnifiedIndex(plane_path)\n   297→    retriever = HybridRetriever(index)\n   298→    retrieval_query = (query or \"memory runtime lessons task note context event\").strip()\n   299→    if retrieval_query and allow_semantic_search:\n   300→        hits = retriever.search_with_temporal_query(\n   301→            retrieval_query,\n   302→            limit=limit,\n   303→            consumer=consumer,\n   304→        )\n   305→        if hits:\n   306→            RetrievalFeedbackStore(plane_path).log_hits(\n   307→                retrieval_query,\n   308→                hits,\n   309→                consumer=consumer,\n   310→                task_id=task_id,\n   311→            )\n   312→            return \"\\n\".join(_format_retrieval_line(hit) for hit in hits)\n   313→\n   314→    recent = index.recent_chunks(limit=limit)\n   315→    if recent:\n   316→        return \"\\n\".join(f\"  [index] {entry.text[:100]}\" for entry in recent)\n   317→    return \"\"\n   318→\n   319→\n   320→def read_memory_context(\n   321→    state_dir: Path | None = None,\n   322→    *,\n   323→    query: str | None = None,\n   324→    limit: int = 5,\n   325→    consumer: str = \"context.read_memory_context\",\n   326→    task_id: str | None = None,\n   327→    allow_semantic_search: bool = True,\n   328→) -> str:\n   329→    \"\"\"Get recent or query-specific memory from dharma_swarm state.\"\"\"\n   330→    base_dir = state_dir or STATE_DIR\n   331→    db_path = base_dir / \"db\" / \"memory.db\"\n   332→    plane_path = base_dir / \"db\" / \"memory_plane.db\"\n   333→    if query and plane_path.exists():\n   334→        try:\n   335→            plane_result = _read_memory_plane_context(\n   336→                plane_path,\n   337→                query=query,\n   338→                limit=limit,\n   339→                consumer=consumer,\n   340→                task_id=task_id,\n   341→                allow_semantic_search=allow_semantic_search,\n   342→            )\n   343→            if plane_result:\n   344→                return plane_result\n   345→        except Exception as e:\n   346→            return f\"Memory plane unavailable: {e}\"\n   347→\n   348→    if not db_path.exists():\n   349→        if plane_path.exists():\n   350→            try:\n   351→                plane_result = _read_memory_plane_context(\n   352→                    plane_path,\n   353→                    query=query,\n   354→                    limit=limit,\n   355→                    consumer=consumer,\n   356→                    task_id=task_id,\n   357→                    allow_semantic_search=allow_semantic_search,\n   358→                )\n   359→                if plane_result:\n   360→                    return plane_result\n   361→            except Exception as e:\n   362→                return f\"Memory plane unavailable: {e}\"\n   363→        return \"No memory database yet.\"\n   364→    try:\n   365→        conn = sqlite3.connect(str(db_path))\n   366→        try:\n   367→            conn.row_factory = sqlite3.Row\n   368→            rows = conn.execute(\n   369→                \"SELECT content, layer, timestamp FROM memories ORDER BY timestamp DESC LIMIT ?\",\n   370→                (max(1, limit),),\n   371→            ).fetchall()\n   372→        finally:\n   373→            conn.close()\n   374→        if not rows:\n   375→            if plane_path.exists():\n   376→                try:\n   377→                    plane_result = _read_memory_plane_context(\n   378→                        plane_path,\n   379→                        query=query,\n   380→                        limit=limit,\n   381→                        consumer=consumer,\n   382→                        task_id=task_id,\n   383→                        allow_semantic_search=allow_semantic_search,\n   384→                    )\n   385→                    if plane_result:\n   386→                        return plane_result\n   387→                except Exception:\n   388→                    pass\n   389→            return \"No memories stored yet.\"\n   390→        return \"\\n\".join(f\"  [{r['layer']}] {r['content'][:100]}\" for r in rows)\n   391→    except Exception as e:\n   392→        return f\"Memory unavailable: {e}\"\n   393→\n   394→\n   395→def read_latent_gold_context(\n   396→    state_dir: Path | None = None,\n   397→    *,\n   398→    query: str,\n   399→    limit: int = 3,\n   400→) -> str:\n   401→    \"\"\"Return unresolved high-value ideas relevant to the current query.\"\"\"\n   402→    if not query.strip():\n   403→        return \"\"\n   404→    from dharma_swarm.engine.conversation_memory import ConversationMemoryStore\n   405→\n   406→    base_dir = state_dir or STATE_DIR\n   407→    plane_path = base_dir / \"db\" / \"memory_plane.db\"\n   408→    if not plane_path.exists():\n   409→        return \"\"\n   410→    try:\n   411→        store = ConversationMemoryStore(plane_path)\n   412→        shards = store.latent_gold(query, limit=limit)\n   413→    except Exception:\n   414→        return \"\"\n   415→    if not shards:\n   416→        return \"\"\n   417→    return \"\\n\".join(_format_idea_line(shard) for shard in shards)\n   418→\n   419→\n   420→def read_latent_gold_overview(\n   421→    state_dir: Path | None = None,\n   422→    *,\n   423→    limit: int = 5,\n   424→) -> str:\n   425→    \"\"\"Return the highest-salience unresolved ideas across the memory plane.\"\"\"\n   426→    from dharma_swarm.engine.conversation_memory import ConversationMemoryStore\n   427→\n   428→    base_dir = state_dir or STATE_DIR\n   429→    plane_path = base_dir / \"db\" / \"memory_plane.db\"\n   430→    if not plane_path.exists():\n   431→        return \"\"\n   432→    try:\n   433→        store = ConversationMemoryStore(plane_path)\n   434→        shards = store.latent_gold(\"\", limit=limit)\n   435→    except Exception:\n   436→        return \"\"\n   437→    if not shards:\n   438→        return \"\"\n   439→    return \"\\n\".join(_format_idea_line(shard) for shard in shards)\n   440→\n   441→\n   442→def read_manifest() -> str:\n   443→    \"\"\"Read ecosystem manifest summary.\"\"\"\n   444→    manifest_path = HOME / \".dharma_manifest.json\"\n   445→    if not manifest_path.exists():\n   446→        return \"No ecosystem manifest.\"\n   447→    try:\n   448→        data = json.loads(manifest_path.read_text())\n   449→        eco = data.get(\"ecosystem\", {})\n   450→        alive = sum(1 for v in eco.values() if v.get(\"exists\"))\n   451→        return f\"Ecosystem: {alive}/{len(eco)} paths exist. Last scan: {data.get('last_scan', 'unknown')}\"\n   452→    except Exception:\n   453→        return \"Manifest unreadable.\"\n   454→\n   455→\n   456→def read_shipped() -> str:\n   457→    \"\"\"What's been shipped (agni-workspace/05_SHIPPED/).\"\"\"\n   458→    shipped_dir = AGNI_WORKSPACE / \"05_SHIPPED\"\n   459→    if not shipped_dir.exists():\n   460→        return \"No shipped artifacts found.\"\n   461→    try:\n   462→        items = sorted(shipped_dir.iterdir(), key=lambda p: p.stat().st_mtime, reverse=True)\n   463→    except OSError:\n   464→        return \"Shipped directory unreadable.\"\n   465→    recent = items[:10]\n   466→    lines = [f\"{len(items)} shipped artifacts, most recent:\"]\n   467→    for item in recent:\n   468→        lines.append(f\"  {item.name}\")\n   469→    return \"\\n\".join(lines)\n   470→\n   471→\n   472→def read_ops(state_dir: Path | None = None) -> str:\n   473→    \"\"\"Full operational context.\"\"\"\n   474→    sections = [\"# Operations Layer\"]\n   475→\n   476→    agni = read_agni_state()\n   477→    if agni:\n   478→        sections.append(f\"## AGNI VPS\\n{json.dumps(agni, indent=2)[:800]}\")\n   479→\n   480→    sections.append(f\"## Trishula\\n{read_trishula_inbox()}\")\n   481→    sections.append(f\"## Memory\\n{read_memory_context(state_dir)}\")\n   482→    sections.append(f\"## Ecosystem\\n{read_manifest()}\")\n   483→    sections.append(f\"## Shipped\\n{read_shipped()}\")\n   484→\n   485→    return \"\\n\".join(sections)\n   486→\n   487→\n   488→# ── L5: SWARM — What other agents found ─────────────────────────────\n   489→\n   490→\n   491→def read_recent_memories(\n   492→    state_dir: Path | None = None,\n   493→    max_entries: int = 10,\n   494→) -> str:\n   495→    \"\"\"Read recent session memories from StrangeLoopMemory database.\n   496→\n   497→    This is a lightweight synchronous read of the most recent memories,\n   498→    designed to feed into the swarm context layer so agents can see what\n   499→    the system has been doing lately.\n   500→\n   501→    Args:\n   502→        state_dir: Override for ~/.dharma state directory.\n   503→        max_entries: Maximum number of recent memories to return.\n   504→\n   505→    Returns:\n   506→        Formatted string of recent memories, or empty string on failure.\n   507→    \"\"\"\n   508→    try:\n   509→        base_dir = state_dir or STATE_DIR\n   510→        db_path = base_dir / \"db\" / \"memory.db\"\n   511→        if not db_path.exists():\n   512→            return \"\"\n   513→\n   514→        conn = sqlite3.connect(str(db_path))\n   515→        try:\n   516→            rows = conn.execute(\n   517→                \"SELECT content, layer, timestamp FROM memories \"\n   518→                \"ORDER BY timestamp DESC LIMIT ?\",\n   519→                (max(1, max_entries),),\n   520→            ).fetchall()\n   521→        finally:\n   522→            conn.close()\n   523→\n   524→        if not rows:\n   525→            return \"\"\n   526→\n   527→        lines = [\"## Recent Session Memories\"]\n   528→        for content, layer, timestamp in rows:\n   529→            stamp = str(timestamp)[:19] if timestamp else \"?\"\n   530→            layer_tag = str(layer) if layer else \"unknown\"\n   531→            snippet = str(content).replace(\"\\n\", \" \").strip()[:200]\n   532→            lines.append(f\"  [{stamp}] ({layer_tag}) {snippet}\")\n   533→        return \"\\n\".join(lines)\n   534→    except Exception:\n   535→        return \"\"\n   536→\n   537→\n   538→def read_agent_notes(exclude_role: str | None = None, max_per_agent: int = 500) -> str:\n   539→    \"\"\"Read recent notes from other agents in the swarm.\"\"\"\n   540→    if not SHARED_DIR.exists():\n   541→        return \"\"\n   542→    sections = [\"# Other Agents' Recent Findings\"]\n   543→    notes_files = sorted(SHARED_DIR.glob(\"*_notes.md\"),\n   544→                         key=lambda f: f.stat().st_mtime, reverse=True)\n   545→    for nf in notes_files[:5]:\n   546→        role = nf.stem.replace(\"_notes\", \"\")\n   547→        if exclude_role and role.lower() == exclude_role.lower():\n   548→            continue\n   549→        try:\n   550→            content = nf.read_text()\n   551→        except Exception:\n   552→            continue\n   553→        # Last N chars — most recent findings\n   554→        tail = content[-max_per_agent:] if len(content) > max_per_agent else content\n   555→        sections.append(f\"\\n## {role}\\n{tail}\")\n   556→\n   557→    return \"\\n\".join(sections) if len(sections) > 1 else \"\"\n   558→\n   559→\n   560→# ── Role-specific context profiles ──────────────────────────────────\n   561→\n   562→# Each role gets a different mix of layers.\n   563→# Format: {role: {layer: weight}}  where weight controls max_chars budget.\n   564→ROLE_PROFILES = {\n   565→    \"cartographer\": {\n   566→        \"vision\": [\"soul\", \"north_star\"],\n   567→        \"research_weight\": 0.3,\n   568→        \"engineering_weight\": 0.4,\n   569→        \"ops_weight\": 0.3,\n   570→        \"notes_weight\": 0.2,\n   571→    },\n   572→    \"archeologist\": {\n   573→        \"vision\": [\"genome_spec\", \"samaya_protocol\", \"ten_words\"],\n   574→        \"research_weight\": 0.5,\n   575→        \"engineering_weight\": 0.1,\n   576→        \"ops_weight\": 0.1,\n   577→        \"notes_weight\": 0.3,\n   578→    },\n   579→    \"surgeon\": {\n   580→        \"vision\": [],  # surgeon doesn't need vision, needs code\n   581→        \"research_weight\": 0.1,\n   582→        \"engineering_weight\": 0.6,\n   583→        \"ops_weight\": 0.2,\n   584→        \"notes_weight\": 0.3,\n   585→    },\n   586→    \"architect\": {\n   587→        \"vision\": [\"genome_spec\", \"lenia_godel\", \"garden_daemon\"],\n   588→        \"research_weight\": 0.3,\n   589→        \"engineering_weight\": 0.4,\n   590→        \"ops_weight\": 0.1,\n   591→        \"notes_weight\": 0.2,\n   592→    },\n   593→    \"validator\": {\n   594→        \"vision\": [\"constitution\"],\n   595→        \"research_weight\": 0.2,\n   596→        \"engineering_weight\": 0.4,\n   597→        \"ops_weight\": 0.3,\n   598→        \"notes_weight\": 0.3,\n   599→    },\n   600→}\n   601→\n   602→# Budget: total chars for context injection\n   603→CONTEXT_BUDGET = 33_000  # Increased from 30K to fit L7+L8+L9 strange loop layers\n   604→\n   605→MEMORY_SURVIVAL_DIRECTIVE = (\n   606→    \"\\n\\n## CRITICAL: MEMORY SURVIVAL\\n\"\n   607→    \"YOUR CONTEXT WILL BE DESTROYED after this task completes. \"\n   608→    \"You will have NO memory of this conversation.\\n\"\n   609→    \"Before your task ends, you MUST externalize:\\n\"\n   610→    \"- Discoveries and patterns -> write to ~/.dharma/shared/<your_role>_notes.md (APPEND)\\n\"\n   611→    \"- Important findings -> write to ~/.dharma/witness/ with timestamp\\n\"\n   612→    \"- Lessons learned -> include in task result\\n\"\n   613→    \"Read ~/.dharma/shared/ FIRST to see what other agents already found.\\n\"\n   614→    \"Failure to externalize = permanent knowledge loss.\"\n   615→)\n   616→\n   617→\n   618→# ── L7/L8/L9: Winners + Stigmergy + META ────────────────────────────\n   619→\n   620→STIGMERGY_DIR = STATE_DIR / \"stigmergy\"\n   621→META_DIR = STATE_DIR / \"meta\"\n   622→\n   623→\n   624→def _read_winners(state_dir: Path | None = None, max_chars: int = 1500) -> str:\n   625→    \"\"\"L7: Read top forge scores and evolution winners for amplification.\"\"\"\n   626→    base = state_dir or STATE_DIR\n   627→    sections = []\n   628→    scoring_file = base / \"stigmergy\" / \"mycelium_scoring_report.json\"\n   629→    if scoring_file.exists():\n   630→        try:\n   631→            data = json.loads(scoring_file.read_text())\n   632→            top = data.get(\"top_3\", [])\n   633→            if top:\n   634→                lines = [\"## L7: Quality Winners (Forge Scores)\"]\n   635→                lines.append(f\"Mean stars: {data.get('mean_stars', '?')}\")\n   636→                for entry in top[:3]:\n   637→                    name = entry.get(\"name\", \"?\")\n   638→                    stars = entry.get(\"stars\", 0)\n   639→                    sw = entry.get(\"swabhaav_ratio\", 0)\n   640→                    lines.append(f\"  {stars:.1f}* {name} (swabhaav={sw:.2f})\")\n   641→                sections.append(\"\\n\".join(lines))\n   642→        except Exception:\n   643→            pass\n   644→    evo_dir = base / \"evolution\"\n   645→    if evo_dir.exists():\n   646→        try:\n   647→            archive_file = evo_dir / \"archive.jsonl\"\n   648→            if archive_file.exists():\n   649→                lines_raw = archive_file.read_text().strip().split(\"\\n\")\n   650→                winners = []\n   651→                for line in lines_raw[-20:]:\n   652→                    if not line.strip():\n   653→                        continue\n   654→                    try:\n   655→                        entry = json.loads(line)\n   656→                        fitness_raw = entry.get(\"fitness\", 0)\n   657→                        # Handle both numeric fitness and dict-of-dimensions\n   658→                        if isinstance(fitness_raw, dict):\n   659→                            vals = [v for v in fitness_raw.values() if isinstance(v, (int, float))]\n   660→                            fitness = sum(vals) / max(1, len(vals)) if vals else 0.0\n   661→                        else:\n   662→                            fitness = float(fitness_raw) if fitness_raw else 0.0\n   663→                        entry[\"_weighted_fitness\"] = fitness\n   664→                        if fitness >= 0.7:\n   665→                            winners.append(entry)\n   666→                    except (json.JSONDecodeError, TypeError, ValueError):\n   667→                        continue\n   668→                if winners:\n   669→                    winners.sort(key=lambda w: w.get(\"_weighted_fitness\", 0), reverse=True)\n   670→                    wlines = [\"## Evolution Winners\"]\n   671→                    for w in winners[:3]:\n   672→                        comp = w.get(\"component\", \"?\")\n   673→                        fit = w.get(\"_weighted_fitness\", 0)\n   674→                        gen = w.get(\"generation\", \"?\")\n   675→                        wlines.append(f\"  {fit:.2f} fitness: {comp} (gen {gen})\")\n   676→                    sections.append(\"\\n\".join(wlines))\n   677→        except Exception:\n   678→            pass\n   679→    result = \"\\n\\n\".join(sections)\n   680→    return result[:max_chars] if result else \"\"\n   681→\n   682→\n   683→def _read_stigmergy_signals(state_dir: Path | None = None, max_chars: int = 1500) -> str:\n   684→    \"\"\"L8: Read high-salience stigmergy marks for agent context.\"\"\"\n   685→    base = state_dir or STATE_DIR\n   686→    stig_dir = base / \"stigmergy\"\n   687→    if not stig_dir.exists():\n   688→        return \"\"\n   689→    sections = [\"## L8: Stigmergy Signals\"]\n   690→    marks_file = stig_dir / \"marks.jsonl\"\n   691→    if marks_file.exists():\n   692→        try:\n   693→            lines = marks_file.read_text().strip().split(\"\\n\")\n   694→            hot_marks = []\n   695→            for line in lines[-50:]:\n   696→                if not line.strip():\n   697→                    continue\n   698→                try:\n   699→                    mark = json.loads(line)\n   700→                    sal = mark.get(\"salience\", 0)\n   701→                    if sal >= 0.7:\n   702→                        hot_marks.append(mark)\n   703→                except (json.JSONDecodeError, TypeError):\n   704→                    continue\n   705→            if hot_marks:\n   706→                hot_marks.sort(key=lambda m: m.get(\"salience\", 0), reverse=True)\n   707→                for m in hot_marks[:5]:\n   708→                    path = m.get(\"path\", \"?\")\n   709→                    sal = m.get(\"salience\", 0)\n   710→                    src = m.get(\"source\", \"?\")\n   711→                    desc = m.get(\"description\", \"\")[:80]\n   712→                    sections.append(f\"  [{sal:.2f}] {path} ({src}): {desc}\")\n   713→        except Exception:\n   714→            pass\n   715→    tcs_file = stig_dir / \"mycelium_identity_tcs.json\"\n   716→    if tcs_file.exists():\n   717→        try:\n   718→            tcs_data = json.loads(tcs_file.read_text())\n   719→            tcs = tcs_data.get(\"tcs\", 0)\n   720→            regime = tcs_data.get(\"regime\", \"unknown\")\n   721→            sections.append(f\"  System TCS: {tcs:.3f} ({regime})\")\n   722→        except Exception:\n   723→            pass\n   724→    result = \"\\n\".join(sections)\n   725→    return result[:max_chars] if len(sections) > 1 else \"\"\n   726→\n   727→\n   728→def _read_recognition_seed(state_dir: Path | None = None, max_chars: int = 2000) -> str:\n   729→    \"\"\"L9: Read the recognition seed — the strange loop's self-model.\"\"\"\n   730→    base = state_dir or STATE_DIR\n   731→    seed_path = base / \"meta\" / \"recognition_seed.md\"\n   732→    if not seed_path.exists():\n   733→        return \"\"\n   734→    try:\n   735→        content = seed_path.read_text()\n   736→        content = scan_and_sanitize(content, \"recognition_seed.md\")\n   737→        if not content.strip():\n   738→            return \"\"\n   739→        header = \"## L9: META -- Recognition Seed\\n\"\n   740→        if len(content) > max_chars - len(header):\n   741→            content = content[:max_chars - len(header)] + \"\\n... [seed truncated]\"\n   742→        return header + content\n   743→    except Exception:\n   744→        return \"\"\n   745→\n   746→\n   747→def build_agent_context(\n   748→    role: str | None = None,\n   749→    thread: str | None = None,\n   750→    state_dir: Path | None = None,\n   751→) -> str:\n   752→    \"\"\"Assemble multi-layer context for an agent's system prompt.\n   753→\n   754→    Selects content based on role (what the agent does) and thread\n   755→    (what research direction is active). Respects a total char budget.\n   756→\n   757→    Args:\n   758→        role: Agent role (cartographer, archeologist, surgeon, architect, validator).\n   759→              Falls back to generic if unknown.\n   760→        thread: Active research thread (mechanistic, phenomenological, etc.).\n   761→        state_dir: Override for ~/.dharma state directory.\n   762→\n   763→    Returns:\n   764→        Complete context string for injection into system prompt.\n   765→    \"\"\"\n   766→    profile = ROLE_PROFILES.get(role or \"\", {})\n   767→    budget = CONTEXT_BUDGET\n   768→    sections = []\n   769→    used = 0\n   770→\n   771→    # L1: Vision — role-specific crown jewels\n   772→    vision_keys = profile.get(\"vision\", [\"ten_words\", \"soul\"])\n   773→    if vision_keys:\n   774→        vision = read_vision(keys=vision_keys, max_per_file=1500)\n   775→        if vision:\n   776→            sections.append(vision)\n   777→            used += len(vision)\n   778→\n   779→    # L2: Research — thread-weighted\n   780→    research_budget = int(budget * profile.get(\"research_weight\", 0.3))\n   781→    if research_budget > 500:\n   782→        research = read_research(thread=thread, max_per_file=research_budget // 3)\n   783→        if research:\n   784→            sections.append(research)\n   785→            used += len(research)\n   786→\n   787→    # L3: Engineering — code reality\n   788→    eng_budget = int(budget * profile.get(\"engineering_weight\", 0.3))\n   789→    if eng_budget > 500:\n   790→        eng = read_engineering()\n   791→        if eng:\n   792→            sections.append(eng)\n   793→            used += len(eng)\n   794→\n   795→    # L4: Ops — operational state (always include, compact)\n   796→    ops_budget = int(budget * profile.get(\"ops_weight\", 0.2))\n   797→    if ops_budget > 300:\n   798→        ops = read_ops(state_dir)\n   799→        if ops and len(ops) > ops_budget:\n   800→            ops = ops[:ops_budget] + \"\\n... [ops truncated]\"\n   801→        if ops:\n   802→            sections.append(ops)\n   803→            used += len(ops)\n   804→\n   805→    # L5: Swarm — other agents' notes + recent session memories\n   806→    notes_budget = int(budget * profile.get(\"notes_weight\", 0.2))\n   807→    if notes_budget > 200:\n   808→        notes = read_agent_notes(exclude_role=role, max_per_agent=notes_budget // 5)\n   809→        if notes:\n   810→            sections.append(notes)\n   811→            used += len(notes)\n   812→\n   813→    # L5b: Recent memories from StrangeLoopMemory\n   814→    remaining = budget - used\n   815→    if remaining > 500:\n   816→        memories = read_recent_memories(state_dir=state_dir, max_entries=5)\n   817→        if memories:\n   818→            sections.append(memories)\n   819→            used += len(memories)\n   820→\n   821→    # L7: Winners — amplification of highest-quality patterns\n   822→    remaining = budget - used\n   823→    if remaining > 500:\n   824→        winners = _read_winners(state_dir=state_dir, max_chars=min(1500, remaining // 3))\n   825→        if winners:\n   826→            sections.append(winners)\n   827→            used += len(winners)\n   828→\n   829→    # L8: Stigmergy — hot signals from daemons and other agents\n   830→    remaining = budget - used\n   831→    if remaining > 500:\n   832→        stigmergy = _read_stigmergy_signals(\n   833→            state_dir=state_dir, max_chars=min(1500, remaining // 3)\n   834→        )\n   835→        if stigmergy:\n   836→            sections.append(stigmergy)\n   837→            used += len(stigmergy)\n   838→\n   839→    # L9: META — recognition seed (strange loop closure)\n   840→    remaining = budget - used\n   841→    if remaining > 500:\n   842→        seed = _read_recognition_seed(\n   843→            state_dir=state_dir, max_chars=min(2000, remaining)\n   844→        )\n   845→        if seed:\n   846→            sections.append(seed)\n   847→            used += len(seed)\n   848→\n   849→    # Memory survival instinct (Windsurf pattern)\n   850→    sections.append(MEMORY_SURVIVAL_DIRECTIVE)\n   851→    used += len(MEMORY_SURVIVAL_DIRECTIVE)\n   852→\n   853→    result = \"\\n\\n\".join(sections)\n   854→\n   855→    # Hard cap\n   856→    if len(result) > CONTEXT_BUDGET:\n   857→        result = result[:CONTEXT_BUDGET] + \"\\n\\n... [context budget exceeded, truncated]\"\n   858→\n   859→    return result\n   860→"}]},"uuid":"530b1438-a261-49f9-b494-f0d35bdf1de1","timestamp":"2026-03-15T14:20:05.289Z","sourceToolAssistantUUID":"b4eea5f8-ed6c-4f0f-857e-2e11dd4d4710","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
