{"parentUuid":"7e5a7a80-72ed-4140-af49-6235cdd2e2fb","isSidechain":true,"agentId":"a89bfe52e46b180a2","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_01FBCRw4f18Hd9UhWoKPjaPt","toolUseID":"toolu_01FBCRw4f18Hd9UhWoKPjaPt","timestamp":"2026-03-15T14:19:56.229Z","uuid":"a957b426-8531-4e34-85f6-40a31a88ca42","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
