a/Downloads/DHARMA_GPU_RV_Strategic_Synthesis.md\n-rw-r--r--@ 1 dhyana  staff    21K Mar  4 21:29 /Users/dhyana/Downloads/DHARMA_SWARM_MEGA_PROMPT.md\n-rw-r--r--@ 1 dhyana  staff   154K Mar  9 20:50 /Users/dhyana/Downloads/dharma_swarm_memory_palace_research.pdf\n-rw-r--r--@ 1 dhyana  staff    51K Mar  4 21:29 /Users/dhyana/Downloads/DHARMA_SWARM_PLAN.md\n-rw-r--r--@ 1 dhyana  staff    36K Mar 10 21:29 /Users/dhyana/Downloads/dharmic_singularity_engine_mega_prompt.md\n-rw-r--r--@ 1 dhyana  staff    47K Mar  5 17:27 /Users/dhyana/Downloads/GODEL_CLAW_V1_REPORT.md\n-rw-r--r--@ 1 dhyana  staff    26K Mar  4 23:22 /Users/dhyana/Downloads/MEGA_BUILD_PROMPT_2026-03-04.md\n-rw-r--r--@ 1 dhyana  staff    71K Mar  9 20:50 /Users/dhyana/Downloads/pkm_research_domains_1_3.md\n-rw-r--r--@ 1 dhyana  staff    61K Mar  9 20:50 /Users/dhyana/Downloads/pkm_research_domains_4_6.md\n-rw-r--r--@ 1 dhyana  staff   476K Feb  3 18:18 /Users/dhyana/Downloads/proton-recovery-kit-2.pdf\n-rw-r--r--@ 1 dhyana  staff   476K Feb  2 19:34 /Users/dhyana/Downloads/proton-recovery-kit.pdf\n-rw-r--r--@ 1 dhyana  staff    70K Mar  4 10:03 /Users/dhyana/Downloads/research_memory_context.md\n-rw-r--r--@ 1 dhyana  staff    50K Mar 10 09:24 /Users/dhyana/Downloads/research_router_evolution_loops.md\n-rw-r--r--@ 1 dhyana  staff    48K Mar 10 09:24 /Users/dhyana/Downloads/research_router_learning_swarm.md\n-rw-r--r--@ 1 dhyana  staff    63K Mar  4 09:25 /Users/dhyana/Downloads/research_self_evolving.md\n-rw-r--r--@ 1 dhyana  staff    62K Mar  5 18:18 /Users/dhyana/Downloads/research_shakti_creative_autonomy.md\n-rw-r--r--@ 1 dhyana  staff    74K Mar  5 18:18 /Users/dhyana/Downloads/research_stigmergy_agents.md\n-rw-r--r--@ 1 dhyana  staff    65K Mar  5 18:18 /Users/dhyana/Downloads/research_subconscious_ai.md\n-rw-r--r--@ 1 dhyana  staff    73K Mar  4 09:31 /Users/dhyana/Downloads/research_swarm_frameworks.md\n-rw-r--r--@ 1 dhyana  staff    89K Mar  4 10:07 /Users/dhyana/Downloads/research_tools_sandboxes.m