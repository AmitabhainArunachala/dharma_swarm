{"parentUuid":"d7474799-7b7f-482d-bda8-cb1ebcf8e32b","isSidechain":true,"agentId":"a8eae6b52af6c3ba8","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_016dWJaBNKwnyfSap1RBZbFY","toolUseID":"toolu_016dWJaBNKwnyfSap1RBZbFY","timestamp":"2026-03-15T13:46:40.124Z","uuid":"285c69aa-9af9-4838-b573-cc589a793c20","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"ac25cd67-31ab-4ef0-b8ec-02a6a29ee8fc","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"a8eae6b52af6c3ba8","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016dWJaBNKwnyfSap1RBZbFY","type":"tool_result","content":"     1→\"\"\"\n     2→Geometric metrics for transformer representations.\n     3→\n     4→Core metrics:\n     5→- Participation Ratio (PR): effective dimensionality of V-projection column space\n     6→- R_V: PR_late / PR_early — geometric contraction ratio\n     7→- Spectral Stats: top-1 ratio, spectral gap, effective rank, condition number\n     8→- Cosine Similarity: directional alignment between early/late representations\n     9→- Attention Entropy: focus/diffuseness of attention patterns\n    10→\n    11→All metrics operate on raw tensors and are model-agnostic.\n    12→The GeometricProbe class (in probe.py) handles model interaction.\n    13→\"\"\"\n    14→\n    15→from __future__ import annotations\n    16→\n    17→import logging\n    18→from dataclasses import dataclass\n    19→from typing import Dict, Optional, Tuple\n    20→\n    21→import numpy as np\n    22→import torch\n    23→\n    24→logger = logging.getLogger(__name__)\n    25→\n    26→\n    27→@dataclass\n    28→class SpectralStats:\n    29→    \"\"\"Spectral shape statistics from SVD singular values.\"\"\"\n    30→\n    31→    top1_ratio: float        # σ₁ / Σσᵢ — dominance of first component\n    32→    spectral_gap: float      # σ₁ - σ₂ — separation of top direction\n    33→    effective_rank: float    # exp(entropy of normalized σ²)\n    34→    condition_number: float  # σ_max / σ_min\n    35→\n    36→    def to_dict(self) -> Dict[str, float]:\n    37→        return {\n    38→            \"top1_ratio\": self.top1_ratio,\n    39→            \"spectral_gap\": self.spectral_gap,\n    40→            \"effective_rank\": self.effective_rank,\n    41→            \"condition_number\": self.condition_number,\n    42→        }\n    43→\n    44→\n    45→# ── Core: Participation Ratio ────────────────────────────────────────────────\n    46→\n    47→def participation_ratio(\n    48→    tensor: Optional[torch.Tensor],\n    49→    window_size: int = 16,\n    50→) -> float:\n    51→    \"\"\"\n    52→    Compute Participation Ratio (PR) — effective dimensionality.\n    53→\n    54→    PR = (Σλᵢ²)² / Σ(λᵢ²)²\n    55→\n    56→    where λᵢ are singular values from SVD of the last W tokens.\n    57→\n    58→    Args:\n    59→        tensor: Shape (batch, seq, dim) or (seq, dim).\n    60→        window_size: Number of tokens from end. Default: 16.\n    61→\n    62→    Returns:\n    63→        PR value (float). NaN if computation fails.\n    64→\n    65→    Measurement contract:\n    66→        - SVD in float64 for numerical stability\n    67→        - Returns NaN (not 0) for degenerate inputs\n    68→        - Requires T >= window_size (no silent truncation)\n    69→    \"\"\"\n    70→    if tensor is None:\n    71→        return float(\"nan\")\n    72→\n    73→    if tensor.dim() == 3:\n    74→        tensor = tensor[0]\n    75→\n    76→    T, D = tensor.shape\n    77→    if T < window_size:\n    78→        return float(\"nan\")\n    79→\n    80→    # Always compute SVD on CPU to avoid cusolver convergence failures\n    81→    # that trigger CUDA device-side asserts and corrupt the CUDA context\n    82→    W = min(window_size, T)\n    83→    v_cpu = tensor[-W:, :].cpu().double()\n    84→\n    85→    # Guard against NaN/Inf in activations (e.g. fp16 overflow at deep layers)\n    86→    if torch.isnan(v_cpu).any() or torch.isinf(v_cpu).any():\n    87→        return float(\"nan\")\n    88→\n    89→    try:\n    90→        U, S, Vt = torch.linalg.svd(v_cpu.T, full_matrices=False)\n    91→        S_np = S.numpy()\n    92→    except Exception:\n    93→        return float(\"nan\")\n    94→\n    95→    S_sq = S_np ** 2\n    96→    total_variance = S_sq.sum()\n    97→    if total_variance < 1e-10:\n    98→        return float(\"nan\")\n    99→\n   100→    pr = (S_sq.sum() ** 2) / (S_sq ** 2).sum()\n   101→    return float(pr)\n   102→\n   103→\n   104→# ── R_V Metric ───────────────────────────────────────────────────────────────\n   105→\n   106→def compute_rv(\n   107→    v_early: Optional[torch.Tensor],\n   108→    v_late: Optional[torch.Tensor],\n   109→    window: int = 16,\n   110→) -> float:\n   111→    \"\"\"\n   112→    Compute R_V = PR_late / PR_early from pre-captured tensors.\n   113→\n   114→    Args:\n   115→        v_early: V-projection at early layer.\n   116→        v_late: V-projection at late layer.\n   117→        window: Window size for PR.\n   118→\n   119→    Returns:\n   120→        R_V value. R_V < 1 = contraction, R_V > 1 = expansion.\n   121→    \"\"\"\n   122→    pr_early = participation_ratio(v_early, window)\n   123→    pr_late = participation_ratio(v_late, window)\n   124→\n   125→    if pr_early == 0 or np.isnan(pr_early) or np.isnan(pr_late):\n   126→        return float(\"nan\")\n   127→\n   128→    return float(pr_late / pr_early)\n   129→\n   130→\n   131→def compute_rv_with_components(\n   132→    v_early: Optional[torch.Tensor],\n   133→    v_late: Optional[torch.Tensor],\n   134→    window: int = 16,\n   135→) -> Tuple[float, float, float]:\n   136→    \"\"\"\n   137→    Compute R_V with separate PR components.\n   138→\n   139→    Returns:\n   140→        (rv, pr_early, pr_late)\n   141→    \"\"\"\n   142→    pr_early = participation_ratio(v_early, window)\n   143→    pr_late = participation_ratio(v_late, window)\n   144→\n   145→    if pr_early == 0 or np.isnan(pr_early) or np.isnan(pr_late):\n   146→        return (float(\"nan\"), float(\"nan\"), float(\"nan\"))\n   147→\n   148→    rv = float(pr_late / pr_early)\n   149→    return (rv, float(pr_early), float(pr_late))\n   150→\n   151→\n   152→# ── Spectral Stats ───────────────────────────────────────────────────────────\n   153→\n   154→def compute_spectral_stats(\n   155→    tensor: Optional[torch.Tensor],\n   156→    window_size: int = 16,\n   157→) -> SpectralStats:\n   158→    \"\"\"\n   159→    Compute spectral shape statistics from V-projection (or any tensor).\n   160→\n   161→    Beyond PR (single number), reveals the shape of the spectrum:\n   162→    - top1_ratio: variance dominance of first direction\n   163→    - spectral_gap: separation between top two directions\n   164→    - effective_rank: exp(entropy of normalized σ²)\n   165→    - condition_number: numerical stability indicator\n   166→\n   167→    Args:\n   168→        tensor: Shape (batch, seq, dim) or (seq, dim).\n   169→        window_size: Tokens from end.\n   170→\n   171→    Returns:\n   172→        SpectralStats dataclass. NaN-filled on failure.\n   173→    \"\"\"\n   174→    nan_result = SpectralStats(\n   175→        top1_ratio=float(\"nan\"), spectral_gap=float(\"nan\"),\n   176→        effective_rank=float(\"nan\"), condition_number=float(\"nan\"),\n   177→    )\n   178→\n   179→    if tensor is None:\n   180→        return nan_result\n   181→\n   182→    if tensor.dim() == 3:\n   183→        tensor = tensor[0]\n   184→\n   185→    T, D = tensor.shape\n   186→    W = min(window_size, T)\n   187→    if W == 0:\n   188→        return nan_result\n   189→\n   190→    v_cpu = tensor[-W:, :].cpu().float()\n   191→\n   192→    try:\n   193→        U, S, Vt = torch.linalg.svd(v_cpu.T, full_matrices=False)\n   194→        S_np = S.numpy()\n   195→\n   196→        if len(S_np) == 0 or S_np.sum() < 1e-10:\n   197→            return nan_result\n   198→\n   199→        top1_ratio = float(S_np[0] / S_np.sum())\n   200→        spectral_gap = float(S_np[0] - S_np[1]) if len(S_np) >= 2 else float(S_np[0])"}]},"uuid":"7d472189-cf41-4343-b0ff-f7e83b36e23b","timestamp":"2026-03-15T13:46:40.124Z","sourceToolAssistantUUID":"ac25cd67-31ab-4ef0-b8ec-02a6a29ee8fc","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
