{"parentUuid":"c31238c5-17be-4710-9499-7584021143d7","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"a8eae6b52af6c3ba8","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KY3XyzUDge9nAZ9atePWVo","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→P0 Canonical Pipeline — R_V Paper (COLM 2026)\n     4→==============================================\n     5→\n     6→Single canonical script that runs ONE model through the standardised\n     7→R_V measurement pipeline.  Resolves the sign-reversal problem observed\n     8→between earlier pipelines by enforcing:\n     9→\n    10→  - bfloat16 precision (MANDATORY — float16 causes NaN in deep OPT/GPT-2 layers)\n    11→  - Architecture-specific L_early / L_late via the canonical ModelSpec registry\n    12→  - Frozen prompt subset resolved from prompts/bank.json\n    13→  - Fixed token window W=16\n    14→  - Hedges' g effect size with bootstrap CI (not raw Cohen's d)\n    15→  - Mann-Whitney U as non-parametric companion test\n    16→\n    17→Run one model at a time; submit all five in parallel on RunPod.\n    18→\n    19→Usage\n    20→-----\n    21→    python p0_canonical_pipeline.py --model mistralai/Mistral-7B-v0.1\n    22→    python p0_canonical_pipeline.py --model facebook/opt-6.7b --n 50\n    23→    python p0_canonical_pipeline.py --model openai-community/gpt2-xl\n    24→    python p0_canonical_pipeline.py --model Qwen/Qwen2.5-7B-Instruct\n    25→    python p0_canonical_pipeline.py --model EleutherAI/pythia-1.4b\n    26→\n    27→Output\n    28→------\n    29→    ~/mech-interp-latent-lab-phase1/results/p0_canonical/{model_safe_name}_p0_result.json\n    30→\n    31→Sign convention\n    32→---------------\n    33→    Hedges' g = (mean_selfref - mean_baseline) / pooled_SD\n    34→    g < 0  →  self-referential prompts produce LOWER R_V  (CONTRACTION — expected)\n    35→    g > 0  →  self-referential prompts produce HIGHER R_V  (EXPANSION — sign reversal)\n    36→\"\"\"\n    37→\n    38→from __future__ import annotations\n    39→\n    40→import argparse\n    41→import csv\n    42→import json\n    43→import logging\n    44→import os\n    45→import sys\n    46→import time\n    47→import warnings\n    48→from pathlib import Path\n    49→from typing import Any, Dict, List, Optional, Tuple\n    50→\n    51→import numpy as np\n    52→import torch\n    53→\n    54→# ---------------------------------------------------------------------------\n    55→# Logging\n    56→# ---------------------------------------------------------------------------\n    57→logging.basicConfig(\n    58→    level=logging.INFO,\n    59→    format=\"%(asctime)s  %(levelname)-8s  %(message)s\",\n    60→    datefmt=\"%H:%M:%S\",\n    61→)\n    62→log = logging.getLogger(\"p0\")\n    63→\n    64→# ---------------------------------------------------------------------------\n    65→# Repository paths\n    66→# ---------------------------------------------------------------------------\n    67→REPO_ROOT = Path(__file__).resolve().parent.parent  # mech-interp-latent-lab-phase1/\n    68→PROMPT_BANK_PATH = REPO_ROOT / \"prompts\" / \"bank.json\"\n    69→PROMPT_SUBSET_PATH = REPO_ROOT / \"prompts\" / \"subsets\" / \"mistral_hardening_v1.json\"\n    70→RESULTS_DIR = REPO_ROOT / \"results\" / \"p0_canonical\"\n    71→\n    72→# Add repo root to sys.path so geometric_lens is importable without install\n    73→if str(REPO_ROOT) not in sys.path:\n    74→    sys.path.insert(0, str(REPO_ROOT))\n    75→\n    76→from prompts.loader import PromptLoader\n    77→from prompts.subsets import FrozenPromptSubset\n    78→from src.utils.canonical_registry import CANONICAL_REGISTRY_PATH, get_canonical_model_spec\n    79→from src.utils.run_metadata import get_git_commit, get_hardware_info\n    80→\n    81→# Models where bfloat16 is supported natively on the target GPU family.\n    82→# GPT-2-XL was originally a float32 model; bfloat16 cast is safe on A100/H100\n    83→# but may silently degrade on older (V100) hardware.  We enforce it regardless\n    84→# because float16 causes NaN at deep layers — see MI_AGENT_TO_CODEX_RV_ANSWERS §1.\n    85→BFLOAT16_REQUIRED = True\n    86→\n    87→\n    88→def select_prompts(\n    89→    subset: FrozenPromptSubset,\n    90→    n: int,\n    91→) -> Tuple[List[Tuple[str, str]], List[Tuple[str, str]]]:\n    92→    \"\"\"\n    93→    Draw up to n prompts from the frozen core measurement tier.\n    94→\n    95→    Self-referential prompts are identified by pillar == \"dose_response\".\n    96→    Baseline prompts are identified by pillar == \"baselines\".\n    97→\n    98→    Sampling is deterministic (sorted key order) so results are reproducible\n    99→    without a fixed random seed.\n   100→\n   101→    Args:\n   102→        subset: Frozen prompt subset resolved against prompts/bank.json.\n   103→        n: Maximum prompts per condition.\n   104→\n   105→    Returns:\n   106→        (selfref_items, baseline_items) where each item is (prompt_id, text).\n   107→    \"\"\"\n   108→    selfref_items: List[Tuple[str, str]] = []\n   109→    baseline_items: List[Tuple[str, str]] = []\n   110→\n   111→    for prompt_id, entry in subset.get_records_for_tier(\"core_measurement\"):\n   112→        pillar = entry.get(\"pillar\", \"\")\n   113→        text = entry.get(\"text\", \"\")\n   114→        if not text:\n   115→            continue\n   116→        if pillar == \"dose_response\":\n   117→            selfref_items.append((prompt_id, text))\n   118→        elif pillar == \"baselines\":\n   119→            baseline_items.append((prompt_id, text))\n   120→\n   121→    # Cap at n each\n   122→    selfref_items = selfref_items[:n]\n   123→    baseline_items = baseline_items[:n]\n   124→\n   125→    log.info(\n   126→        \"Prompt selection from frozen subset: %d self-ref, %d baseline\",\n   127→        len(selfref_items),\n   128→        len(baseline_items),\n   129→    )\n   130→    return selfref_items, baseline_items\n   131→\n   132→\n   133→# ---------------------------------------------------------------------------\n   134→# Robust Hedges' g  (copied verbatim from MI_AGENT_TO_CODEX_RV_ANSWERS §6)\n   135→# ---------------------------------------------------------------------------\n   136→\n   137→def robust_effect_size(\n   138→    x: np.ndarray,\n   139→    y: np.ndarray,\n   140→    variance_floor: float = 0.01,\n   141→    clamp: float = 10.0,\n   142→    n_bootstrap: int = 5000,\n   143→    rng_seed: int = 42,\n   144→) -> dict:\n   145→    \"\"\"\n   146→    Compute Hedges' g with variance floor and bootstrap CI.\n   147→\n   148→    Sign convention: g = (mean_x - mean_y) / pooled_SD\n   149→    Caller passes (selfref_rv, baseline_rv), so g < 0 means contraction.\n   150→\n   151→    Args:\n   152→        x: Self-referential R_V values.\n   153→        y: Baseline R_V values.\n   154→        variance_floor: Prevents d -> inf when one group has near-zero variance.\n   155→        clamp: |g| values beyond this are flagged and clamped.\n   156→        n_bootstrap: Number of bootstrap resamples for 95% CI.\n   157→        rng_seed: Seed for reproducibility.\n   158→\n   159→    Returns:\n   160→        dict matching the production schema from MI_AGENT answers §6.\n   161→    \"\"\"\n   162→    from scipy import stats\n   163→\n   164→    rng = np.random.default_rng(rng_seed)\n   165→\n   166→    x = np.array(x, dtype=float)\n   167→    y = np.array(y, dtype=float)\n   168→    x = x[~np.isnan(x)]\n   169→    y = y[~np.isnan(y)]\n   170→\n   171→    warn_list: List[str] = []\n   172→    nx, ny = len(x), len(y)\n   173→\n   174→    if nx < 3 or ny < 3:\n   175→        return {\n   176→            \"effect_size\": None,\n   177→            \"method\": \"insufficient_n\",\n   178→            \"warnings\": [f\"n_x={nx}, n_y={ny}, need >=3 each\"],\n   179→            \"raw_means\": [\n   180→                float(np.mean(x)) if nx > 0 else None,\n   181→                float(np.mean(y)) if ny > 0 else None,\n   182→            ],\n   183→        }\n   184→\n   185→    mx, my = float(np.mean(x)), float(np.mean(y))\n   186→    sx, sy = float(np.std(x, ddof=1)), float(np.std(y, ddof=1))\n   187→\n   188→    sp = float(\n   189→        np.sqrt(((nx - 1) * sx ** 2 + (ny - 1) * sy ** 2) / (nx + ny - 2))\n   190→    )\n   191→    if sp < variance_floor:\n   192→        warn_list.append(\"variance_floor_applied\")\n   193→        sp = variance_floor\n   194→\n   195→    d = (mx - my) / sp\n   196→    # Hedges' g small-sample correction\n   197→    correction = 1.0 - 3.0 / (4.0 * (nx + ny) - 9.0)\n   198→    g = d * correction\n   199→\n   200→    # Bootstrap 95% CI\n   201→    boot_gs: List[float] = []\n   202→    for _ in range(n_bootstrap):\n   203→        bx = rng.choice(x, size=nx, replace=True)\n   204→        by = rng.choice(y, size=ny, replace=True)\n   205→        bsp = float(\n   206→            np.sqrt(\n   207→                ((nx - 1) * np.std(bx, ddof=1) ** 2 + (ny - 1) * np.std(by, ddof=1) ** 2)\n   208→                / (nx + ny - 2)\n   209→            )\n   210→        )\n   211→        bsp = max(bsp, variance_floor)\n   212→        bd = (float(np.mean(bx)) - float(np.mean(by))) / bsp\n   213→        boot_gs.append(bd * correction)\n   214→\n   215→    ci_lower, ci_upper = float(np.percentile(boot_gs, 2.5)), float(np.percentile(boot_gs, 97.5))\n   216→\n   217→    if abs(g) > clamp:\n   218→        warn_list.append(f\"clamped_from_{g:.4f}\")\n   219→        g = float(np.sign(g) * clamp)\n   220→\n   221→    # Welch's t-test (parametric companion)\n   222→    t_stat, p_welch = stats.ttest_ind(x, y, equal_var=False)\n   223→\n   224→    # Mann-Whitney U (non-parametric; primary test for this script)\n   225→    u_stat, p_mwu = stats.mannwhitneyu(x, y, alternative=\"two-sided\")\n   226→\n   227→    return {\n   228→        \"effect_size\": round(float(g), 6),\n   229→        \"ci_lower\": round(ci_lower, 6),\n   230→        \"ci_upper\": round(ci_upper, 6),\n   231→        \"p_value_welch\": round(float(p_welch), 8),\n   232→        \"p_value_mwu\": round(float(p_mwu), 8),\n   233→        \"u_stat\": round(float(u_stat), 4),\n   234→        \"method\": \"hedges_g_bootstrap\",\n   235→        \"n\": [nx, ny],\n   236→        \"raw_means\": [round(mx, 6), round(my, 6)],\n   237→        \"raw_sds\": [round(sx, 6), round(sy, 6)],\n   238→        \"variance_floor\": variance_floor,\n   239→        \"warnings\": warn_list,\n   240→    }\n   241→\n   242→\n   243→# ---------------------------------------------------------------------------\n   244→# Core measurement loop\n   245→# ---------------------------------------------------------------------------\n   246→\n   247→def measure_prompts(\n   248→    probe,  # GeometricProbe instance\n   249→    prompt_items: List[Tuple[str, str]],\n   250→    condition_label: str,\n   251→) -> Tuple[List[Optional[float]], List[Dict[str, Any]]]:\n   252→    \"\"\"\n   253→    Run each text through the probe and return a list of R_V values.\n   254→\n   255→    OOM errors are caught per-prompt: that prompt is logged and skipped\n   256→    (returns None in its slot).  This prevents a single bad prompt from\n   257→    aborting the entire run.\n   258→\n   259→    Args:\n   260→        probe: Initialised GeometricProbe.\n   261→        prompt_items: Sequence of (prompt_id, prompt_text) tuples.\n   262→        condition_label: \"selfref\" or \"baseline\" (for logging only).\n   263→\n   264→    Returns:\n   265→        Tuple of:\n   266→        - List of R_V floats (or None on OOM/error).\n   267→        - Per-sample records for CSV export.\n   268→    \"\"\"\n   269→    try:\n   270→        from tqdm import tqdm\n   271→        iterator = tqdm(prompt_items, desc=condition_label, unit=\"prompt\", ncols=90)\n   272→    except ImportError:\n   273→        log.warning(\"tqdm not installed — progress will not display per-prompt.\")\n   274→        iterator = prompt_items  # type: ignore[assignment]\n   275→\n   276→    rv_values: List[Optional[float]] = []\n   277→    per_sample_rows: List[Dict[str, Any]] = []\n   278→    oom_count = 0\n   279→    nan_count = 0\n   280→\n   281→    for i, (prompt_id, text) in enumerate(iterator):\n   282→        try:\n   283→            result = probe.measure(text, metrics=[\"rv\"])\n   284→            rv = result.rv\n   285→            if rv is not None and not (isinstance(rv, float) and np.isnan(rv)):\n   286→                rv_values.append(float(rv))\n   287→                per_sample_rows.append(\n   288→                    {\n   289→                        \"condition\": condition_label,\n   290→                        \"prompt_id\": prompt_id,\n   291→                        \"rv\": round(float(rv), 6),\n   292→                        \"status\": \"ok\",\n   293→                    }\n   294→                )\n   295→            else:\n   296→                nan_count += 1\n   297→                rv_values.append(None)\n   298→                per_sample_rows.append(\n   299→                    {\n   300→                        \"condition\": condition_label,\n   301→                        \"prompt_id\": prompt_id,\n   302→                        \"rv\": \"\",\n   303→                        \"status\": \"nan\",\n   304→                    }\n   305→                )\n   306→                log.debug(\"[%s] prompt %d returned NaN R_V\", condition_label, i)\n   307→        except RuntimeError as exc:\n   308→            if \"out of memory\" in str(exc).lower() or \"CUDA out of memory\" in str(exc):\n   309→                oom_count += 1\n   310→                rv_values.append(None)\n   311→                per_sample_rows.append(\n   312→                    {\n   313→                        \"condition\": condition_label,\n   314→                        \"prompt_id\": prompt_id,\n   315→                        \"rv\": \"\",\n   316→                        \"status\": \"oom\",\n   317→                    }\n   318→                )\n   319→                log.warning(\"[%s] OOM on prompt %d — skipping\", condition_label, i)\n   320→                # Free cache and continue; do NOT re-raise\n   321→                if torch.cuda.is_available():\n   322→                    torch.cuda.empty_cache()\n   323→            else:\n   324→                # Non-OOM RuntimeError: log and skip\n   325→                rv_values.append(None)\n   326→                per_sample_rows.append(\n   327→                    {\n   328→                        \"condition\": condition_label,\n   329→                        \"prompt_id\": prompt_id,\n   330→                        \"rv\": \"\",\n   331→                        \"status\": f\"runtime_error:{type(exc).__name__}\",\n   332→                    }\n   333→                )\n   334→                log.warning(\"[%s] RuntimeError on prompt %d: %s\", condition_label, i, exc)\n   335→        except Exception as exc:\n   336→            rv_values.append(None)\n   337→            per_sample_rows.append(\n   338→                {\n   339→                    \"condition\": condition_label,\n   340→                    \"prompt_id\": prompt_id,\n   341→                    \"rv\": \"\",\n   342→                    \"status\": f\"error:{type(exc).__name__}\",\n   343→                }\n   344→            )\n   345→            log.warning(\"[%s] Unexpected error on prompt %d: %s\", condition_label, i, exc)\n   346→\n   347→    valid_count = sum(1 for v in rv_values if v is not None)\n   348→    log.info(\n   349→        \"[%s] Done: %d/%d valid, %d NaN, %d OOM\",\n   350→        condition_label, valid_count, len(prompt_items), nan_count, oom_count,\n   351→    )\n   352→    return rv_values, per_sample_rows\n   353→\n   354→\n   355→# ---------------------------------------------------------------------------\n   356→# Model loader\n   357→# ---------------------------------------------------------------------------\n   358→\n   359→def load_model_and_probe(model_name: str, device: str, arch_cfg: dict):\n   360→    \"\"\"\n   361→    Load model + tokenizer and return an initialised GeometricProbe.\n   362→\n   363→    Enforces bfloat16.  Uses attn_implementation=\"eager\" so that attention\n   364→    pattern hooks work (flash-attention bypasses the hook registration points).\n   365→\n   366→    Args:\n   367→        model_name: HuggingFace model identifier.\n   368→        device: \"cuda\" or \"cpu\".\n   369→        arch_cfg: Dict with early_layer, late_layer from ARCH_LAYER_MAP.\n   370→\n   371→    Returns:\n   372→        GeometricProbe instance ready for .measure() calls.\n   373→    \"\"\"\n   374→    from geometric_lens.probe import GeometricProbe\n   375→\n   376→    log.info(\"Loading model: %s\", model_name)\n   377→    log.info(\"  device=%s  dtype=bfloat16  early=%d  late=%d\",\n   378→             device, arch_cfg[\"early_layer\"], arch_cfg[\"late_layer\"])\n   379→    log.info(\"  attn_implementation=eager (required for hook registration)\")\n   380→\n   381→    # OPT models in some HF versions emit a spurious UserWarning about\n   382→    # positional embeddings being too long; suppress it.\n   383→    with warnings.catch_warnings():\n   384→        warnings.filterwarnings(\"ignore\", category=UserWarning)\n   385→        probe = GeometricProbe(\n   386→            model_name=model_name,\n   387→            device=device,\n   388→            dtype=torch.bfloat16,\n   389→            attn_implementation=\"eager\",\n   390→            window=16,\n   391→            max_length=512,\n   392→            early_layer=arch_cfg[\"early_layer\"],\n   393→            late_layer=arch_cfg[\"late_layer\"],\n   394→        )\n   395→\n   396→    log.info(\"Model loaded. Spec: %s\", probe.spec)\n   397→    return probe\n   398→\n   399→\n   400→# ---------------------------------------------------------------------------\n   401→# Result serialisation\n   402→# ---------------------------------------------------------------------------\n   403→\n   404→def build_result_payload(\n   405→    model_name: str,\n   406→    arch_cfg: dict,\n   407→    selfref_rv: List[Optional[float]],\n   408→    baseline_rv: List[Optional[float]],\n   409→    selfref_prompt_ids: List[str],\n   410→    baseline_prompt_ids: List[str],\n   411→    n_requested: int,\n   412→    elapsed_seconds: float,\n   413→    device: str,\n   414→    prompt_contract: Dict[str, Any],\n   415→) -> dict:\n   416→    \"\"\"\n   417→    Assemble the final JSON payload from raw R_V lists and effect-size stats.\n   418→\n   419→    Args:\n   420→        model_name: Model identifier string.\n   421→        arch_cfg: Architecture config dict.\n   422→        selfref_rv: Raw R_V values (with Nones) for self-referential condition.\n   423→        baseline_rv: Raw R_V values (with Nones) for baseline condition.\n   424→        n_requested: Prompts requested per condition.\n   425→        elapsed_seconds: Wall time for the full run.\n   426→        device: \"cuda\" or \"cpu\".\n   427→\n   428→    Returns:\n   429→        Flat dict ready for json.dumps.\n   430→    \"\"\"\n   431→    # Filter to valid (non-None, non-NaN) floats\n   432→    sr_valid = [v for v in selfref_rv if v is not None and not np.isnan(v)]\n   433→    bl_valid = [v for v in baseline_rv if v is not None and not np.isnan(v)]\n   434→\n   435→    sr_arr = np.array(sr_valid, dtype=float)\n   436→    bl_arr = np.array(bl_valid, dtype=float)\n   437→\n   438→    stats = robust_effect_size(sr_arr, bl_arr)\n   439→\n   440→    # Determine direction label\n   441→    g = stats.get(\"effect_size\")\n   442→    if g is None:\n   443→        direction = \"undetermined\"\n   444→        sign_label = \"undetermined\"\n   445→    elif g < -0.2:\n   446→        direction = \"contraction\"\n   447→        sign_label = \"EXPECTED (g < 0 = self-ref has lower R_V)\"\n   448→    elif g > 0.2:\n   449→        direction = \"expansion\"\n   450→        sign_label = \"SIGN REVERSAL (g > 0 = self-ref has higher R_V)\"\n   451→    else:\n   452→        direction = \"null\"\n   453→        sign_label = \"NULL (|g| < 0.2)\"\n   454→\n   455→    return {\n   456→        # Identity\n   457→        \"schema_version\": \"p0-canonical-v1.0\",\n   458→        \"model_name\": model_name,\n   459→        \"measurement_version\": \"rv-1.0.0-bfloat16-w16\",\n   460→        \"run_timestamp\": time.strftime(\"%Y-%m-%dT%H:%M:%SZ\", time.gmtime()),\n   461→        \"device\": device,\n   462→        \"dtype\": \"bfloat16\",\n   463→\n   464→        # Architecture\n   465→        \"num_layers\": arch_cfg[\"num_layers\"],\n   466→        \"early_layer\": arch_cfg[\"early_layer\"],\n   467→        \"late_layer\": arch_cfg[\"late_layer\"],\n   468→        \"depth_fraction_early\": round(arch_cfg[\"early_layer\"] / arch_cfg[\"num_layers\"], 4),\n   469→        \"depth_fraction_late\": round(arch_cfg[\"late_layer\"] / arch_cfg[\"num_layers\"], 4),\n   470→        \"window_size\": 16,\n   471→\n   472→        # Sample sizes\n   473→        \"n_requested_per_condition\": n_requested,\n   474→        \"n_selfref_attempted\": len(selfref_rv),\n   475→        \"n_selfref_valid\": len(sr_valid),\n   476→        \"n_baseline_attempted\": len(baseline_rv),\n   477→        \"n_baseline_valid\": len(bl_valid),\n   478→\n   479→        # Condition summaries\n   480→        \"selfref_rv_mean\": round(float(np.mean(sr_arr)), 6) if len(sr_arr) > 0 else None,\n   481→        \"selfref_rv_std\": round(float(np.std(sr_arr, ddof=1)), 6) if len(sr_arr) > 1 else None,\n   482→        \"selfref_rv_median\": round(float(np.median(sr_arr)), 6) if len(sr_arr) > 0 else None,\n   483→        \"baseline_rv_mean\": round(float(np.mean(bl_arr)), 6) if len(bl_arr) > 0 else None,\n   484→        \"baseline_rv_std\": round(float(np.std(bl_arr, ddof=1)), 6) if len(bl_arr) > 1 else None,\n   485→        \"baseline_rv_median\": round(float(np.median(bl_arr)), 6) if len(bl_arr) > 0 else None,\n   486→\n   487→        # Effect size (primary)\n   488→        \"hedges_g\": stats.get(\"effect_size\"),\n   489→        \"hedges_g_ci_lower\": stats.get(\"ci_lower\"),\n   490→        \"hedges_g_ci_upper\": stats.get(\"ci_upper\"),\n   491→        \"p_value_mwu\": stats.get(\"p_value_mwu\"),\n   492→        \"p_value_welch\": stats.get(\"p_value_welch\"),\n   493→        \"u_stat\": stats.get(\"u_stat\"),\n   494→        \"effect_size_method\": stats.get(\"method\"),\n   495→        \"effect_size_n\": stats.get(\"n\"),\n   496→        \"effect_size_warnings\": stats.get(\"warnings\", []),\n   497→\n   498→        # Interpretation\n   499→        \"direction\": direction,\n   500→        \"sign_label\": sign_label,\n   501→        \"significant_p05_mwu\": (\n   502→            bool(stats.get(\"p_value_mwu\", 1.0) < 0.05)\n   503→            if stats.get(\"p_value_mwu\") is not None\n   504→            else None\n   505→        ),\n   506→\n   507→        # Raw data (for downstream aggregation)\n   508→        \"selfref_rv_values\": [round(v, 6) for v in sr_valid],\n   509→        \"baseline_rv_values\": [round(v, 6) for v in bl_valid],\n   510→        \"selfref_prompt_ids\": selfref_prompt_ids,\n   511→        \"baseline_prompt_ids\": baseline_prompt_ids,\n   512→\n   513→        # Provenance\n   514→        \"prompt_bank\": prompt_contract[\"prompt_bank_path\"],\n   515→        \"prompt_bank_version\": prompt_contract[\"prompt_bank_version\"],\n   516→        \"prompt_subset_path\": prompt_contract[\"prompt_subset_path\"],\n   517→        \"prompt_subset_name\": prompt_contract[\"prompt_subset_name\"],\n   518→        \"prompt_subset_schema_version\": prompt_contract[\"prompt_subset_schema_version\"],\n   519→        \"prompt_subset_tier\": prompt_contract[\"prompt_subset_tier\"],\n   520→        \"canonical_registry_path\": prompt_contract[\"canonical_registry_path\"],\n   521→        \"canonical_registry_schema_version\": prompt_contract[\"canonical_registry_schema_version\"],\n   522→        \"elapsed_seconds\": round(elapsed_seconds, 1),\n   523→    }\n   524→\n   525→\n   526→def build_config_payload(\n   527→    args: argparse.Namespace,\n   528→    arch_cfg: Dict[str, Any],\n   529→    device: str,\n   530→    prompt_contract: Dict[str, Any],\n   531→) -> Dict[str, Any]:\n   532→    return {\n   533→        \"schema_version\": \"p0-canonical-config-v1\",\n   534→        \"model_name\": args.model,\n   535→        \"device\": device,\n   536→        \"dtype\": \"bfloat16\",\n   537→        \"window_size\": 16,\n   538→        \"n_requested_per_condition\": args.n,\n   539→        \"prompt_bank_path\": prompt_contract[\"prompt_bank_path\"],\n   540→        \"prompt_bank_version\": prompt_contract[\"prompt_bank_version\"],\n   541→        \"prompt_subset_path\": prompt_contract[\"prompt_subset_path\"],\n   542→        \"prompt_subset_name\": prompt_contract[\"prompt_subset_name\"],\n   543→        \"prompt_subset_schema_version\": prompt_contract[\"prompt_subset_schema_version\"],\n   544→        \"prompt_subset_tier\": prompt_contract[\"prompt_subset_tier\"],\n   545→        \"canonical_registry_path\": prompt_contract[\"canonical_registry_path\"],\n   546→        \"canonical_registry_schema_version\": prompt_contract[\"canonical_registry_schema_version\"],\n   547→        \"num_layers\": arch_cfg[\"num_layers\"],\n   548→        \"early_layer\": arch_cfg[\"early_layer\"],\n   549→        \"late_layer\": arch_cfg[\"late_layer\"],\n   550→    }\n   551→\n   552→\n   553→def build_provenance_payload(\n   554→    prompt_contract: Dict[str, Any],\n   555→    metric_path: str,\n   556→) -> Dict[str, Any]:\n   557→    return {\n   558→        \"schema_version\": \"p0-canonical-provenance-v1\",\n   559→        \"git_commit\": get_git_commit(),\n   560→        \"hardware\": get_hardware_info(),\n   561→        \"metric_path\": metric_path,\n   562→        \"prompt_bank_path\": prompt_contract[\"prompt_bank_path\"],\n   563→        \"prompt_bank_version\": prompt_contract[\"prompt_bank_version\"],\n   564→        \"prompt_subset_path\": prompt_contract[\"prompt_subset_path\"],\n   565→        \"prompt_subset_name\": prompt_contract[\"prompt_subset_name\"],\n   566→        \"prompt_subset_tier\": prompt_contract[\"prompt_subset_tier\"],\n   567→        \"canonical_registry_path\": prompt_contract[\"canonical_registry_path\"],\n   568→        \"canonical_registry_schema_version\": prompt_contract[\"canonical_registry_schema_version\"],\n   569→        \"cwd\": os.getcwd(),\n   570→    }\n   571→\n   572→\n   573→# ---------------------------------------------------------------------------\n   574→# Main\n   575→# ---------------------------------------------------------------------------\n   576→\n   577→def parse_args() -> argparse.Namespace:\n   578→    parser = argparse.ArgumentParser(\n   579→        description=\"P0 canonical R_V pipeline (COLM 2026)\",\n   580→        formatter_class=argparse.RawDescriptionHelpFormatter,\n   581→        epilog=__doc__,\n   582→    )\n   583→    parser.add_argument(\n   584→        \"--model\",\n   585→        type=str,\n   586→        required=True,\n   587→        help=\"HuggingFace model name (e.g. mistralai/Mistral-7B-v0.1)\",\n   588→    )\n   589→    parser.add_argument(\n   590→        \"--n\",\n   591→        type=int,\n   592→        default=100,\n   593→        help=\"Max prompts per condition (default: 100).  Use --n 20 for a quick smoke test.\",\n   594→    )\n   595→    parser.add_argument(\n   596→        \"--device\",\n   597→        type=str,\n   598→        default=None,\n   599→        help=\"Compute device: 'cuda' or 'cpu'.  Auto-detected if omitted.\",\n   600→    )\n   601→    parser.add_argument(\n   602→        \"--output-dir\",\n   603→        type=Path,\n   604→        default=RESULTS_DIR,\n   605→        help=f\"Output directory (default: {RESULTS_DIR})\",\n   606→    )\n   607→    parser.add_argument(\n   608→        \"--prompt-subset\",\n   609→        type=Path,\n   610→        default=PROMPT_SUBSET_PATH,\n   611→        help=f\"Frozen prompt subset manifest (default: {PROMPT_SUBSET_PATH})\",\n   612→    )\n   613→    parser.add_argument(\n   614→        \"--dry-run\",\n   615→        action=\"store_true\",\n   616→        help=\"Load prompts and model spec, then exit without running inference.\",\n   617→    )\n   618→    return parser.parse_args()\n   619→\n   620→\n   621→def model_to_safe_name(model_name: str) -> str:\n   622→    \"\"\"Convert 'org/model-name' to a filesystem-safe slug.\"\"\"\n   623→    return model_name.replace(\"/\", \"__\").replace(\".\", \"-\")\n   624→\n   625→\n   626→def display_value(value: Optional[float]) -> float:\n   627→    \"\"\"Preserve legitimate 0.0 values in logs; only substitute NaN for None.\"\"\"\n   628→    return float(\"nan\") if value is None else float(value)\n   629→\n   630→\n   631→def main() -> None:\n   632→    args = parse_args()\n   633→\n   634→    # ── Device ──────────────────────────────────────────────────────────────\n   635→    if args.device:\n   636→        device = args.device\n   637→    else:\n   638→        device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n   639→        log.info(\"Auto-detected device: %s\", device)\n   640→\n   641→    if device == \"cpu\":\n   642→        log.warning(\n   643→            \"Running on CPU.  Expect very slow inference (~120-300s/prompt for 7B models). \"\n   644→            \"This is fine for Pythia-1.4B smoke tests but impractical for 7B models.\"\n   645→        )\n   646→\n   647→    # ── Architecture config ──────────────────────────────────────────────────\n   648→    try:\n   649→        arch_cfg = get_canonical_model_spec(args.model)\n   650→        log.info(\"Architecture config from canonical registry: %s\", arch_cfg)\n   651→    except KeyError:\n   652→        log.warning(\n   653→            \"Model '%s' not in canonical registry %s. Will fall back to GeometricProbe \"\n   654→            \"auto-detection. Verify early/late layers before using results for paper claims.\",\n   655→            args.model,\n   656→            CANONICAL_REGISTRY_PATH,\n   657→        )\n   658→        arch_cfg = {\n   659→            \"num_layers\": -1,\n   660→            \"early_layer\": -1,\n   661→            \"late_layer\": -1,\n   662→            \"name\": args.model,\n   663→            \"registry_path\": str(CANONICAL_REGISTRY_PATH),\n   664→            \"registry_schema_version\": \"unknown\",\n   665→            \"note\": \"auto-detected\",\n   666→        }\n   667→\n   668→    # ── Load frozen prompt subset ────────────────────────────────────────────\n   669→    log.info(\"Loading prompt bank from %s\", PROMPT_BANK_PATH)\n   670→    loader = PromptLoader(PROMPT_BANK_PATH)\n   671→    log.info(\"Prompt bank loaded: %d entries (version=%s)\", len(loader.prompts), loader.version)\n   672→    log.info(\"Loading frozen prompt subset from %s\", args.prompt_subset)\n   673→    subset = FrozenPromptSubset.load(args.prompt_subset, loader=loader)\n   674→\n   675→    selfref_items, baseline_items = select_prompts(subset, n=args.n)\n   676→\n   677→    if len(selfref_items) == 0 or len(baseline_items) == 0:\n   678→        log.error(\n   679→            \"Prompt selection returned 0 texts in one or more conditions.  \"\n   680→            \"Check the frozen subset manifest and prompts/bank.json.\"\n   681→        )\n   682→        sys.exit(1)\n   683→\n   684→    selfref_prompt_ids = [prompt_id for prompt_id, _ in selfref_items]\n   685→    baseline_prompt_ids = [prompt_id for prompt_id, _ in baseline_items]\n   686→    prompt_contract = {\n   687→        \"prompt_bank_path\": str(loader.bank_path),\n   688→        \"prompt_bank_version\": loader.version,\n   689→        \"prompt_subset_path\": str(subset.manifest_path),\n   690→        \"prompt_subset_name\": subset.name,\n   691→        \"prompt_subset_schema_version\": subset.schema_version,\n   692→        \"prompt_subset_tier\": \"core_measurement\",\n   693→        \"canonical_registry_path\": str(CANONICAL_REGISTRY_PATH),\n   694→        \"canonical_registry_schema_version\": arch_cfg.get(\"registry_schema_version\", \"unknown\"),\n   695→    }\n   696→\n   697→    if args.dry_run:\n   698→        log.info(\n   699→            \"DRY RUN: would measure %d self-ref + %d baseline prompts with %s\",\n   700→            len(selfref_items), len(baseline_items), args.model,\n   701→        )\n   702→        log.info(\"  prompt_bank_version=%s\", prompt_contract[\"prompt_bank_version\"])\n   703→        log.info(\"  prompt_subset=%s\", prompt_contract[\"prompt_subset_name\"])\n   704→        log.info(\"Exiting without inference (--dry-run).\")\n   705→        return\n   706→\n   707→    # ── Load model ────────────────────────────────────────────────────────────\n   708→    t0 = time.monotonic()\n   709→\n   710→    # When arch_cfg has -1 sentinels, GeometricProbe uses its own auto-detection.\n   711→    if arch_cfg[\"early_layer\"] != -1:\n   712→        probe = load_model_and_probe(args.model, device, arch_cfg)\n   713→    else:\n   714→        from geometric_lens.probe import GeometricProbe\n   715→        probe = GeometricProbe(\n   716→            model_name=args.model,\n   717→            device=device,\n   718→            dtype=torch.bfloat16,\n   719→            attn_implementation=\"eager\",\n   720→            window=16,\n   721→            max_length=512,\n   722→        )\n   723→        # Update arch_cfg with auto-detected values for the output payload\n   724→        arch_cfg = {\n   725→            \"num_layers\": probe.spec.num_layers,\n   726→            \"early_layer\": probe.early_layer,\n   727→            \"late_layer\": probe.late_layer,\n   728→            \"note\": \"auto-detected\",\n   729→        }\n   730→        log.info(\"Auto-detected layers: early=%d  late=%d\", probe.early_layer, probe.late_layer)\n   731→\n   732→    # ── Measure ───────────────────────────────────────────────────────────────\n   733→    log.info(\"=== SELF-REFERENTIAL CONDITION (core_measurement, n=%d) ===\", len(selfref_items))\n   734→    selfref_rv, selfref_rows = measure_prompts(probe, selfref_items, condition_label=\"selfref\")\n   735→\n   736→    log.info(\"=== BASELINE CONDITION (core_measurement, n=%d) ===\", len(baseline_items))\n   737→    baseline_rv, baseline_rows = measure_prompts(probe, baseline_items, condition_label=\"baseline\")\n   738→\n   739→    elapsed = time.monotonic() - t0\n   740→\n   741→    # ── Build and save result ─────────────────────────────────────────────────\n   742→    payload = build_result_payload(\n   743→        model_name=args.model,\n   744→        arch_cfg=arch_cfg,\n   745→        selfref_rv=selfref_rv,\n   746→        baseline_rv=baseline_rv,\n   747→        selfref_prompt_ids=selfref_prompt_ids,\n   748→        baseline_prompt_ids=baseline_prompt_ids,\n   749→        n_requested=args.n,\n   750→        elapsed_seconds=elapsed,\n   751→        device=device,\n   752→        prompt_contract=prompt_contract,\n   753→    )\n   754→\n   755→    out_dir = args.output_dir\n   756→    out_dir.mkdir(parents=True, exist_ok=True)\n   757→    safe_name = model_to_safe_name(args.model)\n   758→    out_path = out_dir / f\"{safe_name}_p0_result.json\"\n   759→    csv_path = out_dir / f\"{safe_name}_per_sample.csv\"\n   760→    config_path = out_dir / f\"{safe_name}_config.json\"\n   761→    provenance_path = out_dir / f\"{safe_name}_provenance.json\"\n   762→    run_id = time.strftime(\"%Y%m%d_%H%M%S\", time.gmtime())\n   763→    run_dir = out_dir / \"runs\" / f\"{run_id}_{safe_name}\"\n   764→    run_dir.mkdir(parents=True, exist_ok=True)\n   765→\n   766→    with out_path.open(\"w\") as fh:\n   767→        json.dump(payload, fh, indent=2)\n   768→\n   769→    with csv_path.open(\"w\", newline=\"\") as fh:\n   770→        writer = csv.DictWriter(fh, fieldnames=[\"condition\", \"prompt_id\", \"rv\", \"status\"])\n   771→        writer.writeheader()\n   772→        writer.writerows(selfref_rows + baseline_rows)\n   773→\n   774→    config_payload = build_config_payload(args, arch_cfg, device, prompt_contract)\n   775→    provenance_payload = build_provenance_payload(\n   776→        prompt_contract=prompt_contract,\n   777→        metric_path=\"geometric_lens.metrics.participation_ratio\",\n   778→    )\n   779→\n   780→    for path, data in (\n   781→        (config_path, config_payload),\n   782→        (provenance_path, provenance_payload),\n   783→        (run_dir / \"config.json\", config_payload),\n   784→        (run_dir / \"summary.json\", payload),\n   785→        (run_dir / \"provenance.json\", provenance_payload),\n   786→    ):\n   787→        with path.open(\"w\") as fh:\n   788→            json.dump(data, fh, indent=2)\n   789→\n   790→    with (run_dir / \"per_sample.csv\").open(\"w\", newline=\"\") as fh:\n   791→        writer = csv.DictWriter(fh, fieldnames=[\"condition\", \"prompt_id\", \"rv\", \"status\"])\n   792→        writer.writeheader()\n   793→        writer.writerows(selfref_rows + baseline_rows)\n   794→\n   795→    # ── Console summary ───────────────────────────────────────────────────────\n   796→    log.info(\"=\" * 60)\n   797→    log.info(\"P0 RESULT SUMMARY: %s\", args.model)\n   798→    log.info(\"  early_layer=%d  late_layer=%d  window=16  dtype=bfloat16\",\n   799→             payload[\"early_layer\"], payload[\"late_layer\"])\n   800→    log.info(\"  n_selfref_valid=%d  n_baseline_valid=%d\",\n   801→             payload[\"n_selfref_valid\"], payload[\"n_baseline_valid\"])\n   802→    log.info(\"  selfref  R_V = %.4f ± %.4f\",\n   803→             display_value(payload[\"selfref_rv_mean\"]),\n   804→             display_value(payload[\"selfref_rv_std\"]))\n   805→    log.info(\"  baseline R_V = %.4f ± %.4f\",\n   806→             display_value(payload[\"baseline_rv_mean\"]),\n   807→             display_value(payload[\"baseline_rv_std\"]))\n   808→    log.info(\"  Hedges' g = %.4f  [95%% CI %.4f, %.4f]\",\n   809→             display_value(payload[\"hedges_g\"]),\n   810→             display_value(payload[\"hedges_g_ci_lower\"]),\n   811→             display_value(payload[\"hedges_g_ci_upper\"]))\n   812→    log.info(\"  p (MWU)   = %.4g\", display_value(payload[\"p_value_mwu\"]))\n   813→    log.info(\"  direction = %s\", payload[\"direction\"].upper())\n   814→    log.info(\"  sign      = %s\", payload[\"sign_label\"])\n   815→    log.info(\"  prompt subset = %s\", payload[\"prompt_subset_name\"])\n   816→    log.info(\"  prompt bank   = %s\", payload[\"prompt_bank_version\"])\n   817→    log.info(\"  elapsed   = %.0f s\", elapsed)\n   818→    log.info(\"  saved to  = %s\", out_path)\n   819→    log.info(\"  per-sample= %s\", csv_path)\n   820→    log.info(\"  config    = %s\", config_path)\n   821→    log.info(\"  provenance= %s\", provenance_path)\n   822→    log.info(\"  run dir   = %s\", run_dir)\n   823→    log.info(\"=\" * 60)\n   824→\n   825→\n   826→if __name__ == \"__main__\":\n   827→    main()\n   828→"}]},"uuid":"dc56988e-9f40-4c37-b0cd-33b8bcb612d9","timestamp":"2026-03-15T13:46:29.544Z","sourceToolAssistantUUID":"c31238c5-17be-4710-9499-7584021143d7","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
