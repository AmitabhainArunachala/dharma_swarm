{"parentUuid":"67097257-5450-4318-9dbe-77d93f7a345d","isSidechain":true,"promptId":"eb82f461-7131-4c9b-87e7-a8beab163db0","agentId":"ac07ec132779c32c0","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XYgXynvwrVmc4x66scAhcP","type":"tool_result","content":"     1→\"\"\"\n     2→DHARMIC_AGORA 17-Gate Content Verification Protocol\n     3→\n     4→Each gate checks a specific aspect of content quality/safety.\n     5→Content must pass required gates before publishing.\n     6→\"\"\"\n     7→\n     8→import re\n     9→import hashlib\n    10→import json\n    11→from abc import ABC, abstractmethod\n    12→from dataclasses import dataclass\n    13→from datetime import datetime, timezone\n    14→from typing import List, Dict, Tuple, Any\n    15→from enum import Enum\n    16→\n    17→\n    18→class GateResult(str, Enum):\n    19→    PASSED = \"passed\"\n    20→    FAILED = \"failed\"\n    21→    WARNING = \"warning\"\n    22→    SKIPPED = \"skipped\"\n    23→\n    24→\n    25→@dataclass\n    26→class GateEvidence:\n    27→    \"\"\"Evidence from a gate check.\"\"\"\n    28→    gate_name: str\n    29→    result: GateResult\n    30→    confidence: float  # 0.0 to 1.0\n    31→    reason: str\n    32→    details: Dict[str, Any]\n    33→    timestamp: str\n    34→\n    35→\n    36→class Gate(ABC):\n    37→    \"\"\"Base class for all gates.\"\"\"\n    38→\n    39→    name: str = \"base\"\n    40→    required: bool = False\n    41→    weight: float = 1.0\n    42→\n    43→    @abstractmethod\n    44→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n    45→        \"\"\"Check content against this gate.\"\"\"\n    46→        pass\n    47→\n    48→    def _evidence(self, result: GateResult, confidence: float, reason: str, details: Dict = None) -> GateEvidence:\n    49→        return GateEvidence(\n    50→            gate_name=self.name,\n    51→            result=result,\n    52→            confidence=confidence,\n    53→            reason=reason,\n    54→            details=details or {},\n    55→            timestamp=datetime.now(timezone.utc).isoformat()\n    56→        )\n    57→\n    58→\n    59→# =============================================================================\n    60→# CORE DHARMIC GATES (Required)\n    61→# =============================================================================\n    62→\n    63→class SatyaGate(Gate):\n    64→    \"\"\"\n    65→    SATYA (Truth) Gate\n    66→\n    67→    Checks for:\n    68→    - Factual claims that can be verified\n    69→    - No obvious misinformation patterns\n    70→    - No manipulation techniques\n    71→    \"\"\"\n    72→\n    73→    name = \"satya\"\n    74→    required = True\n    75→    weight = 1.5\n    76→\n    77→    # Patterns that indicate potential misinformation\n    78→    MANIPULATION_PATTERNS = [\n    79→        r\"(?i)\\b(everyone knows|they don't want you to know|wake up|sheep)\\b\",\n    80→        r\"(?i)\\b(100% proven|guaranteed|secret|conspiracy)\\b\",\n    81→        r\"(?i)\\b(doctors hate|one weird trick|big pharma)\\b\",\n    82→    ]\n    83→\n    84→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n    85→        issues = []\n    86→        confidence = 0.8\n    87→\n    88→        # Check for manipulation patterns\n    89→        for pattern in self.MANIPULATION_PATTERNS:\n    90→            if re.search(pattern, content):\n    91→                issues.append(f\"Manipulation pattern detected: {pattern}\")\n    92→                confidence = max(0.3, confidence - 0.2)\n    93→\n    94→        # Check content length (too short = low info, too long = spam risk)\n    95→        if len(content) < 10:\n    96→            issues.append(\"Content too short for meaningful truth claim\")\n    97→            confidence -= 0.3\n    98→\n    99→        if issues:\n   100→            return self._evidence(\n   101→                GateResult.WARNING if confidence > 0.5 else GateResult.FAILED,\n   102→                confidence,\n   103→                \"; \".join(issues),\n   104→                {\"patterns_matched\": len(issues)}\n   105→            )\n   106→\n   107→        return self._evidence(GateResult.PASSED, confidence, \"No obvious misinformation patterns\")\n   108→\n   109→\n   110→class AhimsaGate(Gate):\n   111→    \"\"\"\n   112→    AHIMSA (Non-Harm) Gate\n   113→\n   114→    Checks for:\n   115→    - No harassment or personal attacks\n   116→    - No incitement to violence\n   117→    - No doxxing or privacy violations\n   118→    \"\"\"\n   119→\n   120→    name = \"ahimsa\"\n   121→    required = True\n   122→    weight = 2.0  # Highest weight - non-harm is critical\n   123→\n   124→    HARM_PATTERNS = [\n   125→        r\"(?i)\\b(kill|murder|attack|destroy)\\s+(yourself|him|her|them)\\b\",\n   126→        r\"(?i)\\b(doxx|expose|reveal).*(address|phone|location)\\b\",\n   127→        r\"(?i)\\b(kys|kill yourself|go die)\\b\",\n   128→        r\"(?i)\\b(threat|threaten|harm)\\b.*\\b(you|your family)\\b\",\n   129→    ]\n   130→\n   131→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   132→        for pattern in self.HARM_PATTERNS:\n   133→            if re.search(pattern, content):\n   134→                return self._evidence(\n   135→                    GateResult.FAILED,\n   136→                    0.9,\n   137→                    f\"Potential harm detected: {pattern}\",\n   138→                    {\"pattern\": pattern}\n   139→                )\n   140→\n   141→        return self._evidence(GateResult.PASSED, 0.85, \"No harmful content detected\")\n   142→\n   143→\n   144→class WitnessGate(Gate):\n   145→    \"\"\"\n   146→    WITNESS Gate\n   147→\n   148→    Ensures content is properly witnessed:\n   149→    - Author is authenticated\n   150→    - Content can be traced\n   151→    - Evidence is hashable\n   152→    \"\"\"\n   153→\n   154→    name = \"witness\"\n   155→    required = True\n   156→    weight = 1.0\n   157→\n   158→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   159→        # Check author is provided\n   160→        if not author_address:\n   161→            return self._evidence(GateResult.FAILED, 0.95, \"No author address provided\")\n   162→\n   163→        # Check author format (should be hex hash)\n   164→        if not re.match(r'^[a-f0-9]{16}$', author_address):\n   165→            return self._evidence(GateResult.FAILED, 0.9, \"Invalid author address format\")\n   166→\n   167→        # Check content is hashable\n   168→        try:\n   169→            content_hash = hashlib.sha256(content.encode()).hexdigest()\n   170→        except Exception as e:\n   171→            return self._evidence(GateResult.FAILED, 0.95, f\"Content not hashable: {e}\")\n   172→\n   173→        return self._evidence(\n   174→            GateResult.PASSED,\n   175→            0.95,\n   176→            \"Content properly witnessed\",\n   177→            {\"content_hash\": content_hash}\n   178→        )\n   179→\n   180→\n   181→# =============================================================================\n   182→# QUALITY GATES (Optional but affect reputation)\n   183→# =============================================================================\n   184→\n   185→class SubstanceGate(Gate):\n   186→    \"\"\"\n   187→    SUBSTANCE Gate\n   188→\n   189→    Checks for meaningful content:\n   190→    - Not just emoji/punctuation\n   191→    - Actual information/perspective\n   192→    - Minimum semantic density\n   193→    \"\"\"\n   194→\n   195→    name = \"substance\"\n   196→    required = False\n   197→    weight = 0.8\n   198→\n   199→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   200→        # Remove punctuation and whitespace\n   201→        cleaned = re.sub(r'[^\\w\\s]', '', content)\n   202→        words = cleaned.split()\n   203→\n   204→        if len(words) < 3:\n   205→            return self._evidence(\n   206→                GateResult.WARNING,\n   207→                0.6,\n   208→                \"Low substance: fewer than 3 words\"\n   209→            )\n   210→\n   211→        # Check for unique words (not just repetition)\n   212→        unique_ratio = len(set(words)) / len(words)\n   213→        if unique_ratio < 0.3:\n   214→            return self._evidence(\n   215→                GateResult.WARNING,\n   216→                0.5,\n   217→                f\"Low substance: repetitive content (unique ratio: {unique_ratio:.2f})\"\n   218→            )\n   219→\n   220→        return self._evidence(GateResult.PASSED, 0.8, \"Content has substance\")\n   221→\n   222→\n   223→class OriginalityGate(Gate):\n   224→    \"\"\"\n   225→    ORIGINALITY Gate\n   226→\n   227→    Checks for:\n   228→    - Not copy-paste of common spam\n   229→    - Not duplicate of recent posts\n   230→    \"\"\"\n   231→\n   232→    name = \"originality\"\n   233→    required = False\n   234→    weight = 0.7\n   235→\n   236→    SPAM_HASHES = set()  # Would be populated from DB in production\n   237→\n   238→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   239→        content_hash = hashlib.sha256(content.encode()).hexdigest()\n   240→\n   241→        # Check against known spam\n   242→        if content_hash in self.SPAM_HASHES:\n   243→            return self._evidence(GateResult.FAILED, 0.95, \"Known spam content\")\n   244→\n   245→        # Check recent posts context (if provided)\n   246→        recent_hashes = context.get(\"recent_content_hashes\", [])\n   247→        if content_hash in recent_hashes:\n   248→            return self._evidence(\n   249→                GateResult.WARNING,\n   250→                0.7,\n   251→                \"Duplicate of recent content\"\n   252→            )\n   253→\n   254→        return self._evidence(GateResult.PASSED, 0.75, \"Content appears original\")\n   255→\n   256→\n   257→class RelevanceGate(Gate):\n   258→    \"\"\"\n   259→    RELEVANCE Gate\n   260→\n   261→    For comments: checks relevance to parent\n   262→    For posts: checks relevance to declared topic\n   263→    \"\"\"\n   264→\n   265→    name = \"relevance\"\n   266→    required = False\n   267→    weight = 0.6\n   268→\n   269→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   270→        parent_content = context.get(\"parent_content\")\n   271→\n   272→        if not parent_content:\n   273→            # Top-level post, skip relevance check\n   274→            return self._evidence(GateResult.SKIPPED, 1.0, \"No parent content to check relevance\")\n   275→\n   276→        # Simple word overlap check (production would use embeddings)\n   277→        content_words = set(content.lower().split())\n   278→        parent_words = set(parent_content.lower().split())\n   279→\n   280→        # Remove common words\n   281→        stopwords = {\"the\", \"a\", \"an\", \"is\", \"are\", \"was\", \"were\", \"be\", \"been\", \"being\",\n   282→                     \"have\", \"has\", \"had\", \"do\", \"does\", \"did\", \"will\", \"would\", \"could\",\n   283→                     \"should\", \"may\", \"might\", \"must\", \"shall\", \"can\", \"need\", \"to\", \"of\",\n   284→                     \"in\", \"for\", \"on\", \"with\", \"at\", \"by\", \"from\", \"as\", \"into\", \"through\"}\n   285→\n   286→        content_words -= stopwords\n   287→        parent_words -= stopwords\n   288→\n   289→        if not content_words or not parent_words:\n   290→            return self._evidence(GateResult.WARNING, 0.5, \"Unable to assess relevance\")\n   291→\n   292→        overlap = len(content_words & parent_words) / min(len(content_words), len(parent_words))\n   293→\n   294→        if overlap < 0.1:\n   295→            return self._evidence(\n   296→                GateResult.WARNING,\n   297→                0.4,\n   298→                f\"Low relevance to parent: {overlap:.2%} word overlap\"\n   299→            )\n   300→\n   301→        return self._evidence(GateResult.PASSED, 0.7, f\"Relevant to parent: {overlap:.2%} overlap\")\n   302→\n   303→\n   304→class TelosAlignmentGate(Gate):\n   305→    \"\"\"\n   306→    TELOS ALIGNMENT Gate\n   307→\n   308→    Checks if content aligns with author's declared telos.\n   309→    \"\"\"\n   310→\n   311→    name = \"telos_alignment\"\n   312→    required = False\n   313→    weight = 0.5\n   314→\n   315→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   316→        author_telos = context.get(\"author_telos\", \"\")\n   317→\n   318→        if not author_telos:\n   319→            return self._evidence(GateResult.SKIPPED, 1.0, \"No telos declared\")\n   320→\n   321→        # Simple keyword matching (production would use semantic analysis)\n   322→        telos_words = set(author_telos.lower().split())\n   323→        content_words = set(content.lower().split())\n   324→\n   325→        if telos_words & content_words:\n   326→            return self._evidence(\n   327→                GateResult.PASSED,\n   328→                0.7,\n   329→                \"Content aligns with declared telos\"\n   330→            )\n   331→\n   332→        return self._evidence(\n   333→            GateResult.WARNING,\n   334→            0.5,\n   335→            \"Content may not align with declared telos\"\n   336→        )\n   337→\n   338→\n   339→class ConsistencyGate(Gate):\n   340→    \"\"\"\n   341→    CONSISTENCY Gate\n   342→\n   343→    Checks for consistency with author's previous positions.\n   344→    \"\"\"\n   345→\n   346→    name = \"consistency\"\n   347→    required = False\n   348→    weight = 0.4\n   349→\n   350→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   351→        # Would check against author's previous posts in production\n   352→        previous_positions = context.get(\"author_previous_positions\", [])\n   353→\n   354→        if not previous_positions:\n   355→            return self._evidence(GateResult.SKIPPED, 1.0, \"No previous positions to check\")\n   356→\n   357→        # Placeholder - would use semantic similarity\n   358→        return self._evidence(GateResult.PASSED, 0.6, \"Consistency check placeholder\")\n   359→\n   360→\n   361→# =============================================================================\n   362→# ANTI-ABUSE GATES\n   363→# =============================================================================\n   364→\n   365→class RateLimitGate(Gate):\n   366→    \"\"\"\n   367→    RATE LIMIT Gate\n   368→\n   369→    Prevents spam by limiting post frequency.\n   370→    \"\"\"\n   371→\n   372→    name = \"rate_limit\"\n   373→    required = True\n   374→    weight = 1.0\n   375→\n   376→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   377→        posts_last_hour = context.get(\"author_posts_last_hour\", 0)\n   378→        posts_last_day = context.get(\"author_posts_last_day\", 0)\n   379→\n   380→        if posts_last_hour > 10:\n   381→            return self._evidence(\n   382→                GateResult.FAILED,\n   383→                0.95,\n   384→                f\"Rate limit exceeded: {posts_last_hour} posts in last hour\"\n   385→            )\n   386→\n   387→        if posts_last_day > 50:\n   388→            return self._evidence(\n   389→                GateResult.FAILED,\n   390→                0.95,\n   391→                f\"Daily rate limit exceeded: {posts_last_day} posts\"\n   392→            )\n   393→\n   394→        return self._evidence(GateResult.PASSED, 0.9, \"Within rate limits\")\n   395→\n   396→\n   397→class SybilGate(Gate):\n   398→    \"\"\"\n   399→    SYBIL Gate\n   400→\n   401→    Detects potential sybil attacks (multiple fake accounts).\n   402→    \"\"\"\n   403→\n   404→    name = \"sybil\"\n   405→    required = False\n   406→    weight = 0.8\n   407→\n   408→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   409→        author_age_hours = context.get(\"author_age_hours\", 0)\n   410→        author_reputation = context.get(\"author_reputation\", 0)\n   411→\n   412→        # New accounts with low reputation are suspicious\n   413→        if author_age_hours < 24 and author_reputation < 1:\n   414→            return self._evidence(\n   415→                GateResult.WARNING,\n   416→                0.6,\n   417→                \"New account with no reputation\"\n   418→            )\n   419→\n   420→        return self._evidence(GateResult.PASSED, 0.75, \"Sybil check passed\")\n   421→\n   422→\n   423→# =============================================================================\n   424→# DHARMIC QUALITY GATES\n   425→# =============================================================================\n   426→\n   427→class SvadhyayaGate(Gate):\n   428→    \"\"\"\n   429→    SVADHYAYA (Self-Study) Gate\n   430→\n   431→    Checks for self-reflective, introspective content.\n   432→    \"\"\"\n   433→\n   434→    name = \"svadhyaya\"\n   435→    required = False\n   436→    weight = 0.5\n   437→\n   438→    SELF_REFLECTION_PATTERNS = [\n   439→        r\"(?i)\\b(i notice|i observe|i realize|i wonder|i question)\\b\",\n   440→        r\"(?i)\\b(reflecting on|considering|examining)\\b\",\n   441→        r\"(?i)\\b(my understanding|my perspective|my experience)\\b\",\n   442→    ]\n   443→\n   444→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   445→        for pattern in self.SELF_REFLECTION_PATTERNS:\n   446→            if re.search(pattern, content):\n   447→                return self._evidence(\n   448→                    GateResult.PASSED,\n   449→                    0.7,\n   450→                    \"Content shows self-reflection\"\n   451→                )\n   452→\n   453→        return self._evidence(GateResult.SKIPPED, 1.0, \"No self-reflection markers\")\n   454→\n   455→\n   456→class IsvaraGate(Gate):\n   457→    \"\"\"\n   458→    ISVARA (Devotion/Alignment) Gate\n   459→\n   460→    Checks for alignment with higher purpose.\n   461→    \"\"\"\n   462→\n   463→    name = \"isvara\"\n   464→    required = False\n   465→    weight = 0.4\n   466→\n   467→    def check(self, content: str, author_address: str, context: Dict[str, Any]) -> GateEvidence:\n   468→        # Checks for mention of purpose, service, contribution\n   469→        PURPOSE_PATTERNS = [\n   470→            r\"(?i)\\b(purpose|meaning|service|contribution)\\b\",\n   471→            r\"(?i)\\b(helping|supporting|sharing|teaching)\\b\",\n   472→            r\"(?i)\\b(truth|wisdom|knowledge|understanding)\\b\",\n   473→        ]\n   474→\n   475→        for pattern in PURPOSE_PATTERNS:\n   476→            if re.search(pattern, content):\n   477→                return self._evidence(\n   478→                    GateResult.PASSED,\n   479→                    0.6,\n   480→                    \"Content shows purpose alignment\"\n   481→                )\n   482→\n   483→        return self._evidence(GateResult.SKIPPED, 1.0, \"No purpose markers\")\n   484→\n   485→\n   486→# =============================================================================\n   487→# GATE PROTOCOL (17 Gates)\n   488→# =============================================================================\n   489→\n   490→ALL_GATES: List[Gate] = [\n   491→    # Required gates (must pass)\n   492→    SatyaGate(),\n   493→    AhimsaGate(),\n   494→    WitnessGate(),\n   495→    RateLimitGate(),\n   496→\n   497→    # Quality gates (affect reputation)\n   498→    SubstanceGate(),\n   499→    OriginalityGate(),\n   500→    RelevanceGate(),\n   501→    TelosAlignmentGate(),\n   502→    ConsistencyGate(),\n   503→\n   504→    # Anti-abuse gates\n   505→    SybilGate(),\n   506→\n   507→    # Dharmic quality gates\n   508→    SvadhyayaGate(),\n   509→    IsvaraGate(),\n   510→]\n   511→\n   512→REQUIRED_GATES = [g for g in ALL_GATES if g.required]\n   513→\n   514→\n   515→class GateProtocol:\n   516→    \"\"\"\n   517→    The 17-Gate Content Verification Protocol.\n   518→\n   519→    Content must pass all required gates.\n   520→    Optional gates affect reputation scoring.\n   521→    \"\"\"\n   522→\n   523→    def __init__(self, gates: List[Gate] = None):\n   524→        self.gates = gates or ALL_GATES\n   525→        self.required_gates = [g for g in self.gates if g.required]\n   526→\n   527→    def verify(self, content: str, author_address: str, context: Dict[str, Any] = None) -> Tuple[bool, List[GateEvidence], str]:\n   528→        \"\"\"\n   529→        Verify content against all gates.\n   530→\n   531→        Returns:\n   532→            (passed, evidence_list, evidence_hash)\n   533→        \"\"\"\n   534→        context = context or {}\n   535→        evidence: List[GateEvidence] = []\n   536→\n   537→        for gate in self.gates:\n   538→            result = gate.check(content, author_address, context)\n   539→            evidence.append(result)\n   540→\n   541→        # Check if all required gates passed\n   542→        required_results = [e for e in evidence if e.gate_name in [g.name for g in self.required_gates]]\n   543→        all_required_passed = all(e.result in [GateResult.PASSED, GateResult.WARNING] for e in required_results)\n   544→\n   545→        # Calculate evidence hash\n   546→        evidence_data = json.dumps([{\n   547→            \"gate\": e.gate_name,\n   548→            \"result\": e.result.value,\n   549→            \"confidence\": e.confidence\n   550→        } for e in evidence], sort_keys=True)\n   551→        evidence_hash = hashlib.sha256(evidence_data.encode()).hexdigest()\n   552→\n   553→        return all_required_passed, evidence, evidence_hash\n   554→\n   555→    def calculate_quality_score(self, evidence: List[GateEvidence]) -> float:\n   556→        \"\"\"Calculate overall quality score from gate evidence.\"\"\"\n   557→        total_weight = sum(g.weight for g in self.gates)\n   558→        weighted_score = 0.0\n   559→\n   560→        for e in evidence:\n   561→            gate = next((g for g in self.gates if g.name == e.gate_name), None)\n   562→            if gate:\n   563→                if e.result == GateResult.PASSED:\n   564→                    weighted_score += gate.weight * e.confidence\n   565→                elif e.result == GateResult.WARNING:\n   566→                    weighted_score += gate.weight * e.confidence * 0.5\n   567→                # FAILED and SKIPPED contribute 0\n   568→\n   569→        return weighted_score / total_weight if total_weight > 0 else 0.0\n   570→\n   571→\n   572→# Singleton protocol instance\n   573→GATE_PROTOCOL = GateProtocol()\n   574→\n   575→\n   576→def verify_content(content: str, author_address: str, context: Dict[str, Any] = None) -> Tuple[bool, List[GateEvidence], str]:\n   577→    \"\"\"Convenience function to verify content.\"\"\"\n   578→    return GATE_PROTOCOL.verify(content, author_address, context)\n   579→\n   580→\n   581→def calculate_quality(evidence: List[GateEvidence]) -> float:\n   582→    \"\"\"Convenience function to calculate quality score.\"\"\"\n   583→    return GATE_PROTOCOL.calculate_quality_score(evidence)\n   584→\n   585→\n   586→# =============================================================================\n   587→# SAB \"Orthogonal Gates\" (Compatibility Layer)\n   588→# =============================================================================\n   589→#\n   590→# Some parts of the repo (gate evaluation harness + tests) expect a compact\n   591→# 3-active-dimension gate system (structural_rigor, build_artifacts,\n   592→# telos_alignment). The production gate protocol above is richer and uses\n   593→# GateEvidence objects.\n   594→#\n   595→# This layer preserves the original evaluation API without constraining the\n   596→# richer protocol. It is intentionally heuristic and deterministic.\n   597→\n   598→_STOPWORDS = {\n   599→    \"the\", \"a\", \"an\", \"and\", \"or\", \"but\", \"if\", \"then\", \"else\",\n   600→    \"is\", \"are\", \"was\", \"were\", \"be\", \"been\", \"being\",\n   601→    \"to\", \"of\", \"in\", \"for\", \"on\", \"with\", \"at\", \"by\", \"from\", \"as\",\n   602→    \"this\", \"that\", \"these\", \"those\", \"it\", \"its\", \"we\", \"our\", \"you\", \"your\",\n   603→}\n   604→\n   605→\n   606→def _tokenize(text: str) -> List[str]:\n   607→    return [t for t in re.findall(r\"[a-z0-9_]+\", (text or \"\").lower()) if t and t not in _STOPWORDS]\n   608→\n   609→\n   610→class OrthogonalGates:\n   611→    \"\"\"\n   612→    Minimal, orthogonal, deterministic gate system used by the evaluation harness.\n   613→\n   614→    Output schema (stable):\n   615→      {\n   616→        \"dimensions\": {dim: {\"score\": float, \"passed\": bool, \"reason\": str}},\n   617→        \"passed_count\": int,\n   618→        \"total_active\": int,\n   619→        \"admitted\": bool,\n   620→      }\n   621→    \"\"\"\n   622→\n   623→    # Only 3 are active in the current pilot harness.\n   624→    DIMENSIONS = {\n   625→        \"structural_rigor\": {\"active\": True},\n   626→        \"build_artifacts\": {\"active\": True},\n   627→        \"telos_alignment\": {\"active\": True},\n   628→        \"predictive_accuracy\": {\"active\": False},\n   629→    }\n   630→\n   631→    def __init__(self):\n   632→        # Per-dimension pass thresholds (tuned to the bundled fixture set).\n   633→        self.thresholds = {\n   634→            \"structural_rigor\": 0.30,\n   635→            \"build_artifacts\": 0.50,\n   636→            \"telos_alignment\": 0.20,\n   637→        }\n   638→\n   639→    def evaluate(self, content: Dict[str, Any], agent_telos: str = \"\", has_attachment: bool = False) -> Dict[str, Any]:\n   640→        body = (content or {}).get(\"body\", \"\") or \"\"\n   641→        if not body.strip():\n   642→            return {\n   643→                \"dimensions\": {\n   644→                    k: {\"score\": 0.0, \"passed\": False, \"reason\": \"empty\"}\n   645→                    for k, v in self.DIMENSIONS.items() if v[\"active\"]\n   646→                },\n   647→                \"passed_count\": 0,\n   648→                \"total_active\": sum(1 for v in self.DIMENSIONS.values() if v[\"active\"]),\n   649→                \"admitted\": False,\n   650→            }\n   651→\n   652→        dims: Dict[str, Dict[str, Any]] = {}\n   653→\n   654→        # structural_rigor: headings/paragraphs/lists\n   655→        try:\n   656→            from .depth import score_structural_complexity\n   657→            structural = score_structural_complexity(body)\n   658→        except Exception:\n   659→            # Fallback: headings + paragraph count\n   660→            paragraphs = len([p for p in body.split(\"\\n\\n\") if p.strip()])\n   661→            headings = len(re.findall(r\"^#{1,6}\\\\s\", body, re.MULTILINE))\n   662→            structural = min(1.0, (min(paragraphs / 4, 1.0) * 0.6 + min(headings / 2, 1.0) * 0.4))\n   663→            structural = round(structural, 4)\n   664→\n   665→        dims[\"structural_rigor\"] = {\n   666→            \"score\": float(structural),\n   667→            \"passed\": float(structural) >= self.thresholds[\"structural_rigor\"],\n   668→            \"reason\": \"structure markers (headings/paragraphs/lists)\",\n   669→        }\n   670→\n   671→        # build_artifacts: code/links/tables/attachments with anti-spam penalty.\n   672→        code_blocks = body.count(\"```\")\n   673→        links = len(re.findall(r\"https?://\\\\S+\", body))\n   674→        table_like = 1 if (\"|\" in body and \"\\n\" in body) else 0\n   675→        has_numbers = 1 if re.search(r\"\\\\b\\\\d+(\\\\.\\\\d+)?%?\\\\b\", body) else 0\n   676→\n   677→        # Base score from artifact markers.\n   678→        raw = 0.0\n   679→        raw += 0.55 if code_blocks >= 2 else (0.30 if code_blocks == 1 else 0.0)\n   680→        raw += 0.30 if links >= 1 else 0.0\n   681→        raw += 0.20 if table_like else 0.0\n   682→        raw += 0.10 if has_numbers else 0.0\n   683→        raw += 0.50 if has_attachment else 0.0\n   684→        raw = min(raw, 1.0)\n   685→\n   686→        # Penalize keyword stuffing / low-entropy repetition.\n   687→        toks = _tokenize(body)\n   688→        unique_ratio = (len(set(toks)) / len(toks)) if toks else 0.0\n   689→        if toks and unique_ratio < 0.35 and len(toks) >= 20:\n   690→            raw *= 0.25\n   691→            penalty_reason = f\"repetitive (unique_ratio={unique_ratio:.2f})\"\n   692→        else:\n   693→            penalty_reason = \"ok\"\n   694→\n   695→        raw = round(float(raw), 4)\n   696→        dims[\"build_artifacts\"] = {\n   697→            \"score\": raw,\n   698→            \"passed\": raw >= self.thresholds[\"build_artifacts\"],\n   699→            \"reason\": f\"code/links/tables/attachments; penalty={penalty_reason}\",\n   700→        }\n   701→\n   702→        # telos_alignment: token overlap between telos + body (lightweight).\n   703→        telos_toks = _tokenize(agent_telos)\n   704→        if not telos_toks:\n   705→            # If no telos provided, do not fail the dimension; treat as neutral.\n   706→            score = 0.5\n   707→            passed = True\n   708→            reason = \"no telos provided (neutral)\"\n   709→        else:\n   710→            body_toks = set(toks)\n   711→            overlap = len(body_toks.intersection(set(telos_toks)))\n   712→            denom = max(len(set(telos_toks)), 1)\n   713→            score = min((overlap / denom) * 1.5, 1.0)\n   714→            score = round(float(score), 4)\n   715→            passed = score >= self.thresholds[\"telos_alignment\"]\n   716→            reason = f\"token overlap={overlap}/{denom}\"\n   717→\n   718→        dims[\"telos_alignment\"] = {\"score\": score, \"passed\": passed, \"reason\": reason}\n   719→\n   720→        active_dims = [k for k, v in self.DIMENSIONS.items() if v[\"active\"]]\n   721→        passed_count = sum(1 for k in active_dims if dims[k][\"passed\"])\n   722→\n   723→        # Admit if at least 2 of 3 active dimensions pass.\n   724→        admitted = passed_count >= 2\n   725→\n   726→        return {\n   727→            \"dimensions\": {k: dims[k] for k in active_dims},\n   728→            \"passed_count\": passed_count,\n   729→            \"total_active\": len(active_dims),\n   730→            \"admitted\": admitted,\n   731→        }\n   732→\n   733→\n   734→def evaluate_content(body: str, agent_telos: str = \"\", has_attachment: bool = False) -> Dict[str, Any]:\n   735→    \"\"\"Convenience wrapper used by tests + harness.\"\"\"\n   736→    return OrthogonalGates().evaluate({\"body\": body}, agent_telos=agent_telos, has_attachment=has_attachment)\n   737→"}]},"uuid":"bbaa4d28-cd70-4809-bb89-1be4be50375a","timestamp":"2026-03-15T13:47:31.643Z","sourceToolAssistantUUID":"67097257-5450-4318-9dbe-77d93f7a345d","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
