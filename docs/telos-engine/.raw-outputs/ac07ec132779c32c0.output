{"parentUuid":"7d1970e6-e54a-45a9-b503-15d77834a08f","isSidechain":true,"promptId":"1c647a1d-5460-470d-9ec4-a7b3e0861f66","agentId":"ac07ec132779c32c0","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HdGtJfNEwZ2k9XkZQeYhSv","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→P9 Search — CLI query tool for P9-indexed workspaces\n     4→\n     5→Usage:\n     6→  python3 p9_search.py \"your search query\"\n     7→  python3 p9_search.py \"R_V Layer 27\" --top-k 5 --db /path/to/db\n     8→  python3 p9_search.py \"context engineering\" --hybrid\n     9→  \n    10→Features:\n    11→  - Full-text search via FTS5\n    12→  - BM25 ranking (built into FTS5)\n    13→  - Title boost (title matches rank higher)\n    14→  - Snippet extraction\n    15→  - Zero dependencies (stdlib only)\n    16→\"\"\"\n    17→\n    18→import sqlite3\n    19→import sys\n    20→import re\n    21→from pathlib import Path\n    22→from typing import List, Dict, Any\n    23→\n    24→try:\n    25→    from agora.db_config import DB_PATHS\n    26→except ImportError:  # pragma: no cover\n    27→    sys.path.insert(0, str(Path(__file__).resolve().parents[1]))\n    28→    from agora.db_config import DB_PATHS\n    29→\n    30→\n    31→class P9Searcher:\n    32→    def __init__(self, db_path=None):\n    33→        self.db_path = Path(db_path) if db_path else Path(DB_PATHS[\"p9_memory\"])\n    34→        self.conn = None\n    35→        \n    36→    def connect(self):\n    37→        \"\"\"Connect to database\"\"\"\n    38→        if not self.db_path.exists():\n    39→            print(f\"✗ Database not found: {self.db_path}\")\n    40→            print(f\"  Run: python3 p9_index.py /path/to/workspace --db {self.db_path}\")\n    41→            sys.exit(1)\n    42→            \n    43→        self.conn = sqlite3.connect(self.db_path)\n    44→        \n    45→    def search(self, query: str, top_k: int = 10) -> List[Dict[str, Any]]:\n    46→        \"\"\"Search documents using FTS5\"\"\"\n    47→        if not self.conn:\n    48→            self.connect()\n    49→            \n    50→        cursor = self.conn.cursor()\n    51→        \n    52→        # Escape special FTS5 characters\n    53→        query = query.replace('\"', '\"\"')\n    54→        \n    55→        # FTS5 query with ranking\n    56→        # bm25() returns lower scores for better matches\n    57→        cursor.execute(\"\"\"\n    58→            SELECT \n    59→                d.id,\n    60→                d.path,\n    61→                d.title,\n    62→                d.metadata,\n    63→                d.file_size,\n    64→                d.modified_time,\n    65→                d.indexed_at,\n    66→                rank\n    67→            FROM documents d\n    68→            JOIN documents_fts fts ON d.id = fts.rowid\n    69→            WHERE documents_fts MATCH ?\n    70→            ORDER BY rank\n    71→            LIMIT ?\n    72→        \"\"\", (query, top_k))\n    73→        \n    74→        results = []\n    75→        for row in cursor.fetchall():\n    76→            results.append({\n    77→                'id': row[0],\n    78→                'path': row[1],\n    79→                'title': row[2],\n    80→                'metadata': row[3],\n    81→                'file_size': row[4],\n    82→                'modified_time': row[5],\n    83→                'indexed_at': row[6],\n    84→                'score': row[7]  # bm25 rank (lower is better)\n    85→            })\n    86→            \n    87→        return results\n    88→        \n    89→    def search_with_snippets(self, query: str, top_k: int = 10) -> List[Dict[str, Any]]:\n    90→        \"\"\"Search with snippet extraction\"\"\"\n    91→        results = self.search(query, top_k)\n    92→        \n    93→        # Extract snippets around query terms\n    94→        for result in results:\n    95→            snippet = self._extract_snippet(result['path'], query)\n    96→            result['snippet'] = snippet\n    97→            \n    98→        return results\n    99→        \n   100→    def _extract_snippet(self, file_path: str, query: str, snippet_length: int = 200) -> str:\n   101→        \"\"\"Extract a snippet from file content around query terms\"\"\"\n   102→        try:\n   103→            cursor = self.conn.cursor()\n   104→            cursor.execute(\n   105→                \"SELECT content FROM documents WHERE path = ?\",\n   106→                (file_path,)\n   107→            )\n   108→            row = cursor.fetchone()\n   109→            if not row:\n   110→                return \"\"\n   111→                \n   112→            content = row[0]\n   113→            \n   114→            # Find query term in content\n   115→            query_terms = query.lower().split()\n   116→            content_lower = content.lower()\n   117→            \n   118→            best_pos = 0\n   119→            best_score = 0\n   120→            \n   121→            for term in query_terms:\n   122→                pos = content_lower.find(term)\n   123→                if pos != -1:\n   124→                    # Score based on proximity to start\n   125→                    score = len(content) - pos\n   126→                    if score > best_score:\n   127→                        best_score = score\n   128→                        best_pos = max(0, pos - snippet_length // 2)\n   129→                        \n   130→            # Extract snippet\n   131→            snippet = content[best_pos:best_pos + snippet_length]\n   132→            \n   133→            # Add ellipsis if truncated\n   134→            if best_pos > 0:\n   135→                snippet = \"...\" + snippet\n   136→            if best_pos + snippet_length < len(content):\n   137→                snippet = snippet + \"...\"\n   138→                \n   139→            # Highlight query terms\n   140→            for term in query_terms:\n   141→                snippet = re.sub(\n   142→                    f'({re.escape(term)})',\n   143→                    r'\\033[1m\\033[33m\\1\\033[0m',  # Bold yellow\n   144→                    snippet,\n   145→                    flags=re.IGNORECASE\n   146→                )\n   147→                \n   148→            return snippet.replace('\\n', ' ')\n   149→            \n   150→        except Exception as e:\n   151→            return f\"[Error extracting snippet: {e}]\"\n   152→            \n   153→    def get_stats(self) -> Dict[str, Any]:\n   154→        \"\"\"Get database statistics\"\"\"\n   155→        if not self.conn:\n   156→            self.connect()\n   157→            \n   158→        cursor = self.conn.cursor()\n   159→        \n   160→        cursor.execute(\"SELECT COUNT(*) FROM documents\")\n   161→        total_docs = cursor.fetchone()[0]\n   162→        \n   163→        cursor.execute(\"SELECT COUNT(*) FROM documents_fts\")\n   164→        fts_docs = cursor.fetchone()[0]\n   165→        \n   166→        cursor.execute(\"SELECT SUM(file_size) FROM documents\")\n   167→        total_size = cursor.fetchone()[0] or 0\n   168→        \n   169→        cursor.execute(\n   170→            \"SELECT path FROM documents ORDER BY indexed_at DESC LIMIT 5\"\n   171→        )\n   172→        recent = [row[0] for row in cursor.fetchall()]\n   173→        \n   174→        return {\n   175→            'total_documents': total_docs,\n   176→            'fts_indexed': fts_docs,\n   177→            'total_size_bytes': total_size,\n   178→            'total_size_mb': total_size / (1024 * 1024),\n   179→            'recently_indexed': recent\n   180→        }\n   181→        \n   182→    def close(self):\n   183→        if self.conn:\n   184→            self.conn.close()\n   185→\n   186→\n   187→def print_results(results: List[Dict[str, Any]], show_snippets: bool = True):\n   188→    \"\"\"Pretty print search results\"\"\"\n   189→    if not results:\n   190→        print(\"\\nNo results found.\")\n   191→        return\n   192→        \n   193→    print(f\"\\n{'='*80}\")\n   194→    print(f\"Found {len(results)} result(s)\")\n   195→    print(f\"{'='*80}\\n\")\n   196→    \n   197→    for i, result in enumerate(results, 1):\n   198→        # Score badge (lower bm25 = better, but we invert for display)\n   199→        score = result.get('score', 0)\n   200→        if score < 1:\n   201→            badge = \"\\033[1m\\033[32m[EXACT]\\033[0m\"  # Green\n   202→        elif score < 5:\n   203→            badge = \"\\033[1m\\033[34m[HIGH]\\033[0m\"   # Blue\n   204→        else:\n   205→            badge = \"\\033[1m\\033[90m[LOW]\\033[0m\"    # Gray\n   206→            \n   207→        print(f\"{i}. {badge} {result['title']}\")\n   208→        print(f\"   Path: {result['path']}\")\n   209→        print(f\"   Score: {score:.2f} | Size: {result['file_size']} bytes\")\n   210→        \n   211→        if show_snippets and 'snippet' in result:\n   212→            print(f\"   Snippet: {result['snippet'][:150]}\")\n   213→            \n   214→        print()\n   215→\n   216→\n   217→def main():\n   218→    if len(sys.argv) < 2:\n   219→        print(\"Usage: python3 p9_search.py \\\"your query\\\" [options]\")\n   220→        print()\n   221→        print(\"Options:\")\n   222→        print(\"  --db PATH        Database path (default: data/p9_memory.db)\")\n   223→        print(\"  --top-k N        Number of results (default: 10)\")\n   224→        print(\"  --no-snippets    Don't show text snippets\")\n   225→        print(\"  --stats          Show database statistics only\")\n   226→        print()\n   227→        print(\"Examples:\")\n   228→        print('  python3 p9_search.py \"R_V Layer 27\"')\n   229→        print('  python3 p9_search.py \"context engineering\" --top-k 5')\n   230→        print('  python3 p9_search.py --stats')\n   231→        sys.exit(1)\n   232→        \n   233→    # Parse arguments\n   234→    args = sys.argv[1:]\n   235→    \n   236→    # Check for --stats\n   237→    if \"--stats\" in args:\n   238→        db_path = str(DB_PATHS[\"p9_memory\"])\n   239→        if \"--db\" in args:\n   240→            idx = args.index(\"--db\")\n   241→            if idx + 1 < len(args):\n   242→                db_path = args[idx + 1]\n   243→                \n   244→        searcher = P9Searcher(db_path)\n   245→        try:\n   246→            stats = searcher.get_stats()\n   247→            print(f\"\\n📊 Database Statistics: {db_path}\")\n   248→            print(f\"{'='*40}\")\n   249→            print(f\"Total documents: {stats['total_documents']}\")\n   250→            print(f\"FTS indexed: {stats['fts_indexed']}\")\n   251→            print(f\"Total size: {stats['total_size_mb']:.2f} MB\")\n   252→            print(f\"\\nRecently indexed:\")\n   253→            for path in stats['recently_indexed']:\n   254→                print(f\"  - {path}\")\n   255→        finally:\n   256→            searcher.close()\n   257→        sys.exit(0)\n   258→    \n   259→    # Get query (first non-flag argument)\n   260→    query = None\n   261→    db_path = str(DB_PATHS[\"p9_memory\"])\n   262→    top_k = 10\n   263→    show_snippets = True\n   264→    \n   265→    i = 0\n   266→    while i < len(args):\n   267→        arg = args[i]\n   268→        if arg == \"--db\":\n   269→            if i + 1 < len(args):\n   270→                db_path = args[i + 1]\n   271→                i += 2\n   272→            else:\n   273→                i += 1\n   274→        elif arg == \"--top-k\":\n   275→            if i + 1 < len(args):\n   276→                top_k = int(args[i + 1])\n   277→                i += 2\n   278→            else:\n   279→                i += 1\n   280→        elif arg == \"--no-snippets\":\n   281→            show_snippets = False\n   282→            i += 1\n   283→        elif not arg.startswith(\"--\"):\n   284→            query = arg\n   285→            i += 1\n   286→        else:\n   287→            i += 1\n   288→            \n   289→    if not query:\n   290→        print(\"✗ No query provided\")\n   291→        sys.exit(1)\n   292→        \n   293→    # Search\n   294→    searcher = P9Searcher(db_path)\n   295→    \n   296→    try:\n   297→        print(f\"🔍 Searching: \\\"{query}\\\"\")\n   298→        print(f\"📁 Database: {db_path}\")\n   299→        \n   300→        if show_snippets:\n   301→            results = searcher.search_with_snippets(query, top_k)\n   302→        else:\n   303→            results = searcher.search(query, top_k)\n   304→            \n   305→        print_results(results, show_snippets)\n   306→        \n   307→    except Exception as e:\n   308→        print(f\"✗ Search error: {e}\")\n   309→        import traceback\n   310→        traceback.print_exc()\n   311→        sys.exit(1)\n   312→    finally:\n   313→        searcher.close()\n   314→\n   315→\n   316→if __name__ == \"__main__\":\n   317→    main()\n   318→"}]},"uuid":"d286d4b1-dab3-461b-92ff-fe8deaeb0edf","timestamp":"2026-03-15T13:48:42.463Z","sourceToolAssistantUUID":"7d1970e6-e54a-45a9-b503-15d77834a08f","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
