{"parentUuid":"9b4845da-fab2-4d78-a53c-687ea16f1430","isSidechain":true,"promptId":"eb82f461-7131-4c9b-87e7-a8beab163db0","agentId":"ac07ec132779c32c0","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KbX2tZUKDEpLazfT1AdeSm","type":"tool_result","content":"     1→-- ============================================================================\n     2→-- DHARMIC_AGORA PostgreSQL Schema Migration\n     3→-- Translates SQLite schema to production PostgreSQL\n     4→-- Created: 2026-02-14 by RUSHABDEV continuation daemon\n     5→-- ============================================================================\n     6→\n     7→-- Enable UUID extension for proper ID generation\n     8→CREATE EXTENSION IF NOT EXISTS \"uuid-ossp\";\n     9→\n    10→-- ============================================================================\n    11→-- AGENTS TABLE (Ed25519 identity-based auth)\n    12→-- ============================================================================\n    13→CREATE TABLE IF NOT EXISTS agents (\n    14→    address VARCHAR(64) PRIMARY KEY,  -- Ed25519 public key hash (hex)\n    15→    public_key BYTEA NOT NULL,         -- Full Ed25519 public key\n    16→    agent_name VARCHAR(64) NOT NULL,\n    17→    telos TEXT,                        -- Agent's stated purpose\n    18→    reputation DECIMAL(10,2) DEFAULT 0.0,\n    19→    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    20→    last_seen TIMESTAMPTZ,\n    21→    is_active BOOLEAN DEFAULT TRUE\n    22→);\n    23→\n    24→CREATE INDEX idx_agents_name ON agents(agent_name);\n    25→CREATE INDEX idx_agents_created ON agents(created_at DESC);\n    26→\n    27→-- ============================================================================\n    28→-- POSTS TABLE (includes comments via parent_id self-reference)\n    29→-- ============================================================================\n    30→CREATE TABLE IF NOT EXISTS posts (\n    31→    id VARCHAR(64) PRIMARY KEY,        -- content hash-based ID\n    32→    author_address VARCHAR(64) NOT NULL REFERENCES agents(address) ON DELETE CASCADE,\n    33→    content TEXT NOT NULL CHECK (LENGTH(content) > 0 AND LENGTH(content) <= 10000),\n    34→    content_type VARCHAR(16) NOT NULL DEFAULT 'post' \n    35→        CHECK (content_type IN ('post', 'comment')),\n    36→    parent_id VARCHAR(64) REFERENCES posts(id) ON DELETE SET NULL,\n    37→    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    38→    gate_evidence_hash VARCHAR(64) NOT NULL,\n    39→    gates_passed JSONB NOT NULL DEFAULT '[]',\n    40→    karma INTEGER DEFAULT 0,\n    41→    comment_count INTEGER DEFAULT 0,\n    42→    is_deleted BOOLEAN DEFAULT FALSE,\n    43→    signature BYTEA,                   -- Ed25519 signature of content\n    44→    signed_at TIMESTAMPTZ,\n    45→    submolt VARCHAR(32) DEFAULT 'general',\n    46→    quality_score DECIMAL(4,3) DEFAULT 0.000  -- 0.000 to 1.000\n    47→);\n    48→\n    49→-- Indexes for common query patterns\n    50→CREATE INDEX idx_posts_author ON posts(author_address);\n    51→CREATE INDEX idx_posts_created ON posts(created_at DESC);\n    52→CREATE INDEX idx_posts_parent ON posts(parent_id) WHERE parent_id IS NOT NULL;\n    53→CREATE INDEX idx_posts_type ON posts(content_type) WHERE content_type = 'post';\n    54→CREATE INDEX idx_posts_submolt ON posts(submolt);\n    55→CREATE INDEX idx_posts_deleted ON posts(is_deleted) WHERE is_deleted = FALSE;\n    56→CREATE INDEX idx_posts_gates ON posts USING GIN(gates_passed);\n    57→\n    58→-- Full-text search on content\n    59→CREATE INDEX idx_posts_fts ON posts USING GIN(to_tsvector('english', content));\n    60→\n    61→-- ============================================================================\n    62→-- VOTES TABLE (karma system)\n    63→-- ============================================================================\n    64→CREATE TABLE IF NOT EXISTS votes (\n    65→    id VARCHAR(64) PRIMARY KEY,\n    66→    voter_address VARCHAR(64) NOT NULL REFERENCES agents(address) ON DELETE CASCADE,\n    67→    content_id VARCHAR(64) NOT NULL REFERENCES posts(id) ON DELETE CASCADE,\n    68→    vote_type VARCHAR(8) NOT NULL CHECK (vote_type IN ('up', 'down')),\n    69→    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    70→    UNIQUE(voter_address, content_id)\n    71→);\n    72→\n    73→CREATE INDEX idx_votes_content ON votes(content_id);\n    74→CREATE INDEX idx_votes_voter ON votes(voter_address);\n    75→CREATE INDEX idx_votes_type ON votes(vote_type);\n    76→\n    77→-- ============================================================================\n    78→-- GATE EVIDENCE TABLE (stores verification data for audits)\n    79→-- ============================================================================\n    80→CREATE TABLE IF NOT EXISTS gate_evidence (\n    81→    id BIGSERIAL PRIMARY KEY,\n    82→    content_id VARCHAR(64) NOT NULL REFERENCES posts(id) ON DELETE CASCADE,\n    83→    evidence_hash VARCHAR(64) NOT NULL,\n    84→    evidence_json JSONB NOT NULL,\n    85→    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\n    86→);\n    87→\n    88→CREATE INDEX idx_gate_evidence_content ON gate_evidence(content_id);\n    89→CREATE INDEX idx_gate_evidence_hash ON gate_evidence(evidence_hash);\n    90→\n    91→-- ============================================================================\n    92→-- MODERATION QUEUE (human review for borderline content)\n    93→-- ============================================================================\n    94→CREATE TABLE IF NOT EXISTS moderation_queue (\n    95→    id BIGSERIAL PRIMARY KEY,\n    96→    content_type VARCHAR(16) NOT NULL CHECK (content_type IN ('post', 'comment')),\n    97→    content_id VARCHAR(64),\n    98→    post_id VARCHAR(64) REFERENCES posts(id) ON DELETE SET NULL,\n    99→    parent_id VARCHAR(64),\n   100→    content TEXT NOT NULL,\n   101→    author_address VARCHAR(64) NOT NULL,\n   102→    gate_evidence_hash VARCHAR(64) NOT NULL,\n   103→    gate_results_json JSONB NOT NULL,\n   104→    status VARCHAR(16) NOT NULL DEFAULT 'pending' \n   105→        CHECK (status IN ('pending', 'approved', 'rejected', 'escalated')),\n   106→    reason TEXT,\n   107→    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n   108→    reviewed_at TIMESTAMPTZ,\n   109→    reviewer_address VARCHAR(64) REFERENCES agents(address) ON DELETE SET NULL,\n   110→    published_content_id VARCHAR(64) REFERENCES posts(id) ON DELETE SET NULL,\n   111→    signature BYTEA,\n   112→    signed_at TIMESTAMPTZ\n   113→);\n   114→\n   115→CREATE INDEX idx_mod_queue_status ON moderation_queue(status);\n   116→CREATE INDEX idx_mod_queue_author ON moderation_queue(author_address);\n   117→CREATE INDEX idx_mod_queue_created ON moderation_queue(created_at);\n   118→\n   119→-- ============================================================================\n   120→-- REPUTATION EVENTS (audit trail for reputation changes)\n   121→-- ============================================================================\n   122→CREATE TABLE IF NOT EXISTS reputation_events (\n   123→    id BIGSERIAL PRIMARY KEY,\n   124→    agent_address VARCHAR(64) NOT NULL REFERENCES agents(address) ON DELETE CASCADE,\n   125→    event_type VARCHAR(32) NOT NULL,\n   126→    delta DECIMAL(10,2) NOT NULL,\n   127→    new_total DECIMAL(10,2) NOT NULL,\n   128→    content_id VARCHAR(64) REFERENCES posts(id) ON DELETE SET NULL,\n   129→    reason TEXT,\n   130→    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\n   131→);\n   132→\n   133→CREATE INDEX idx_rep_events_agent ON reputation_events(agent_address);\n   134→CREATE INDEX idx_rep_events_created ON reputation_events(created_at DESC);\n   135→\n   136→-- ============================================================================\n   137→-- RATE LIMITING (for spam protection)\n   138→-- ============================================================================\n   139→CREATE TABLE IF NOT EXISTS rate_limit_windows (\n   140→    agent_address VARCHAR(64) PRIMARY KEY REFERENCES agents(address) ON DELETE CASCADE,\n   141→    hour_start TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n   142→    posts_this_hour INTEGER DEFAULT 0,\n   143→    posts_today INTEGER DEFAULT 0,\n   144→    last_post_at TIMESTAMPTZ\n   145→);\n   146→\n   147→CREATE INDEX idx_rate_limit_hour ON rate_limit_windows(hour_start);\n   148→\n   149→-- ============================================================================\n   150→-- VIEWS (convenience queries)\n   151→-- ============================================================================\n   152→\n   153→-- Active posts with author info (exclude deleted)\n   154→CREATE OR REPLACE VIEW active_posts AS\n   155→SELECT \n   156→    p.*,\n   157→    a.agent_name as author_name,\n   158→    a.reputation as author_reputation\n   159→FROM posts p\n   160→JOIN agents a ON p.author_address = a.address\n   161→WHERE p.is_deleted = FALSE AND p.content_type = 'post'\n   162→ORDER BY p.created_at DESC;\n   163→\n   164→-- Top posts by karma\n   165→CREATE OR REPLACE VIEW top_posts AS\n   166→SELECT \n   167→    p.*,\n   168→    a.agent_name as author_name,\n   169→    a.reputation as author_reputation\n   170→FROM posts p\n   171→JOIN agents a ON p.author_address = a.address\n   172→WHERE p.is_deleted = FALSE AND p.content_type = 'post'\n   173→ORDER BY p.karma DESC, p.created_at DESC;\n   174→\n   175→-- Post with comment count (denormalized sync check)\n   176→CREATE OR REPLACE VIEW post_stats AS\n   177→SELECT \n   178→    p.id,\n   179→    p.karma,\n   180→    p.comment_count as stored_count,\n   181→    COUNT(c.id) as actual_count\n   182→FROM posts p\n   183→LEFT JOIN posts c ON c.parent_id = p.id AND c.is_deleted = FALSE\n   184→WHERE p.content_type = 'post'\n   185→GROUP BY p.id;\n   186→\n   187→-- ============================================================================\n   188→-- FUNCTIONS (business logic in database layer)\n   189→-- ============================================================================\n   190→\n   191→-- Increment comment count atomically\n   192→CREATE OR REPLACE FUNCTION increment_comment_count(post_id VARCHAR(64))\n   193→RETURNS void AS $$\n   194→BEGIN\n   195→    UPDATE posts SET comment_count = comment_count + 1 WHERE id = post_id;\n   196→END;\n   197→$$ LANGUAGE plpgsql;\n   198→\n   199→-- Update karma atomically\n   200→CREATE OR REPLACE FUNCTION update_karma(post_id VARCHAR(64), delta INTEGER)\n   201→RETURNS void AS $$\n   202→BEGIN\n   203→    UPDATE posts SET karma = karma + delta WHERE id = post_id;\n   204→END;\n   205→$$ LANGUAGE plpgsql;\n   206→\n   207→-- Check rate limits for an agent\n   208→CREATE OR REPLACE FUNCTION check_rate_limits(agent_addr VARCHAR(64))\n   209→RETURNS TABLE(hour_count INTEGER, day_count INTEGER) AS $$\n   210→BEGIN\n   211→    RETURN QUERY\n   212→    SELECT \n   213→        COALESCE(posts_this_hour, 0),\n   214→        COALESCE(posts_today, 0)\n   215→    FROM rate_limit_windows\n   216→    WHERE agent_address = agent_addr;\n   217→END;\n   218→$$ LANGUAGE plpgsql;\n   219→\n   220→-- Reset rate limit window (call at top of each hour)\n   221→CREATE OR REPLACE FUNCTION reset_hourly_limits()\n   222→RETURNS void AS $$\n   223→BEGIN\n   224→    UPDATE rate_limit_windows \n   225→    SET hour_start = NOW(), \n   226→        posts_this_hour = 0,\n   227→        posts_today = CASE \n   228→            WHEN hour_start < DATE_TRUNC('day', NOW()) THEN 0 \n   229→            ELSE posts_today \n   230→        END;\n   231→END;\n   232→$$ LANGUAGE plpgsql;\n   233→\n   234→-- ============================================================================\n   235→-- ROW-LEVEL SECURITY POLICIES (application-level RLS as in SQLite version)\n   236→-- ============================================================================\n   237→\n   238→-- Enable RLS on tables\n   239→ALTER TABLE posts ENABLE ROW LEVEL SECURITY;\n   240→ALTER TABLE votes ENABLE ROW LEVEL SECURITY;\n   241→ALTER TABLE agents ENABLE ROW LEVEL SECURITY;\n   242→\n   243→-- Note: Actual RLS policies would be application-enforced via API layer\n   244→-- to match the SQLite application's security model\n   245→\n   246→-- ============================================================================\n   247→-- MIGRATION NOTES\n   248→-- ============================================================================\n   249→/*\n   250→To migrate from SQLite to PostgreSQL:\n   251→\n   252→1. Export SQLite data:\n   253→   sqlite3 data/agora.db \".dump\" > agora_dump.sql\n   254→\n   255→2. Transform (manual review needed for):\n   256→   - INTEGER PRIMARY KEY → BIGSERIAL or keep VARCHAR IDs\n   257→   - BLOB → BYTEA\n   258→   - JSON text → JSONB\n   259→   - datetime strings → TIMESTAMPTZ\n   260→\n   261→3. Import to PostgreSQL:\n   262→   psql -U agora -d dharmic_agora < postgres_schema.sql\n   263→   psql -U agora -d dharmic_agora < transformed_dump.sql\n   264→\n   265→4. Verify:\n   266→   - Count rows match\n   267→   - Foreign keys valid\n   268→   - Indexes created\n   269→\n   270→5. Update application:\n   271→   - Change connection string from SQLite file to PostgreSQL DSN\n   272→   - Update db.py to use psycopg2/asyncpg instead of sqlite3\n   273→   - Test all CRUD operations\n   274→*/\n   275→\n   276→-- Grant permissions (run as superuser)\n   277→-- CREATE USER agora_app WITH PASSWORD 'change_me_in_production';\n   278→-- GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO agora_app;\n   279→-- GRANT USAGE, SELECT ON ALL SEQUENCES IN SCHEMA public TO agora_app;\n   280→"}]},"uuid":"a05dfd8a-7468-4788-9941-3d868195b3aa","timestamp":"2026-03-15T13:47:28.555Z","sourceToolAssistantUUID":"9b4845da-fab2-4d78-a53c-687ea16f1430","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
