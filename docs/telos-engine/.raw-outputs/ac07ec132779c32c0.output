{"parentUuid":"be8fd345-3c72-4f7b-8d4d-2be1b969f9cc","isSidechain":true,"agentId":"ac07ec132779c32c0","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01M3vUwWsVaksKyrBJq84Sgc","toolUseID":"toolu_01M3vUwWsVaksKyrBJq84Sgc","timestamp":"2026-03-15T13:48:42.250Z","uuid":"2e8d2723-8b0d-4386-bd8a-3efd62735dd4","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"3f771a2a-64a0-44ef-9a4b-d5ae61151617","isSidechain":true,"promptId":"1c647a1d-5460-470d-9ec4-a7b3e0861f66","agentId":"ac07ec132779c32c0","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M3vUwWsVaksKyrBJq84Sgc","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→P9 Semantic Search — Embedding-based semantic search for P9\n     4→\n     5→Usage:\n     6→  python3 p9_semantic.py index --db /path/to/db          # Index documents with embeddings\n     7→  python3 p9_semantic.py search \"query\" --db /path/to/db # Semantic search\n     8→  python3 p9_semantic.py hybrid \"query\" --db /path/to/db # Hybrid FTS5 + semantic\n     9→  python3 p9_semantic.py stats --db /path/to/db          # Show vector stats\n    10→\n    11→Features:\n    12→  - Sentence-transformers embeddings (all-MiniLM-L6-v2, 384-dim)\n    13→  - sqlite-vec for vector storage and similarity search\n    14→  - Hybrid search combining FTS5 + semantic similarity\n    15→  - Incremental indexing (only changed documents)\n    16→\"\"\"\n    17→\n    18→import sqlite3\n    19→import sys\n    20→import json\n    21→import hashlib\n    22→from pathlib import Path\n    23→from typing import List, Dict, Any, Optional, Tuple\n    24→import argparse\n    25→\n    26→try:\n    27→    from agora.db_config import DB_PATHS\n    28→except ImportError:  # pragma: no cover\n    29→    sys.path.insert(0, str(Path(__file__).resolve().parents[1]))\n    30→    from agora.db_config import DB_PATHS\n    31→\n    32→# Embedding model configuration\n    33→EMBEDDING_MODEL = \"all-MiniLM-L6-v2\"\n    34→EMBEDDING_DIM = 384\n    35→\n    36→\n    37→class SemanticIndexer:\n    38→    \"\"\"Handles embedding generation and vector indexing\"\"\"\n    39→    \n    40→    def __init__(self, db_path: str | None = None):\n    41→        self.db_path = Path(db_path) if db_path else Path(DB_PATHS[\"p9_memory\"])\n    42→        self.conn = None\n    43→        self.model = None\n    44→        \n    45→    def connect(self):\n    46→        \"\"\"Connect to database and ensure sqlite-vec is loaded\"\"\"\n    47→        self.conn = sqlite3.connect(self.db_path)\n    48→        self.conn.enable_load_extension(True)\n    49→        \n    50→        # Try to load sqlite-vec extension\n    51→        try:\n    52→            self.conn.execute(\"SELECT load_extension('vec0')\")\n    53→        except sqlite3.OperationalError:\n    54→            try:\n    55→                # Try common paths\n    56→                import os\n    57→                possible_paths = [\n    58→                    \"/usr/local/lib/vec0.dylib\",\n    59→                    \"/opt/homebrew/lib/vec0.dylib\",\n    60→                    \"/usr/lib/vec0.so\",\n    61→                    \"./vec0.dylib\",\n    62→                    \"./vec0.so\",\n    63→                ]\n    64→                for path in possible_paths:\n    65→                    if Path(path).exists():\n    66→                        self.conn.execute(f\"SELECT load_extension('{path}')\")\n    67→                        break\n    68→                else:\n    69→                    # Try pip-installed version\n    70→                    try:\n    71→                        import sqlite_vec\n    72→                        sqlite_vec.load(self.conn)\n    73→                    except ImportError:\n    74→                        pass\n    75→            except Exception as e:\n    76→                print(f\"⚠️  sqlite-vec extension not found: {e}\")\n    77→                print(\"   Install with: pip install sqlite-vec\")\n    78→                raise\n    79→                \n    80→        # Verify vec0 is loaded\n    81→        try:\n    82→            self.conn.execute(\"SELECT vec_version()\")\n    83→        except sqlite3.OperationalError:\n    84→            raise RuntimeError(\"sqlite-vec extension failed to load\")\n    85→            \n    86→    def init_vector_schema(self):\n    87→        \"\"\"Add vector table to existing P9 database\"\"\"\n    88→        cursor = self.conn.cursor()\n    89→        \n    90→        # Virtual table for vector storage\n    91→        cursor.execute(f\"\"\"\n    92→            CREATE VIRTUAL TABLE IF NOT EXISTS document_vectors USING vec0(\n    93→                document_id INTEGER PRIMARY KEY,\n    94→                embedding float[{EMBEDDING_DIM}] distance_metric=cosine\n    95→            )\n    96→        \"\"\")\n    97→        \n    98→        # Metadata table for indexing status\n    99→        cursor.execute(\"\"\"\n   100→            CREATE TABLE IF NOT EXISTS vector_index_status (\n   101→                document_id INTEGER PRIMARY KEY,\n   102→                content_hash TEXT NOT NULL,\n   103→                indexed_at TEXT DEFAULT CURRENT_TIMESTAMP,\n   104→                FOREIGN KEY (document_id) REFERENCES documents(id) ON DELETE CASCADE\n   105→            )\n   106→        \"\"\")\n   107→        \n   108→        self.conn.commit()\n   109→        print(f\"✓ Vector schema initialized (dim={EMBEDDING_DIM})\")\n   110→        \n   111→    def load_model(self):\n   112→        \"\"\"Lazy load the embedding model\"\"\"\n   113→        if self.model is None:\n   114→            try:\n   115→                from sentence_transformers import SentenceTransformer\n   116→                print(f\"🔄 Loading embedding model: {EMBEDDING_MODEL}...\")\n   117→                self.model = SentenceTransformer(EMBEDDING_MODEL)\n   118→                print(f\"✓ Model loaded\")\n   119→            except ImportError:\n   120→                print(\"✗ sentence-transformers not installed\")\n   121→                print(\"   Install with: pip install sentence-transformers\")\n   122→                raise\n   123→                \n   124→    def generate_embedding(self, text: str) -> List[float]:\n   125→        \"\"\"Generate embedding for text\"\"\"\n   126→        self.load_model()\n   127→        \n   128→        # Truncate very long texts (model limit ~512 tokens)\n   129→        # Rough approximation: 4 chars per token\n   130→        max_chars = 2000\n   131→        if len(text) > max_chars:\n   132→            text = text[:max_chars]\n   133→            \n   134→        embedding = self.model.encode(text, convert_to_numpy=True, show_progress_bar=False)\n   135→        return embedding.tolist()\n   136→        \n   137→    def index_document(self, doc_id: int, content: str, content_hash: str) -> bool:\n   138→        \"\"\"Index a single document with vector embedding\"\"\"\n   139→        cursor = self.conn.cursor()\n   140→        \n   141→        # Check if already indexed with same hash\n   142→        cursor.execute(\n   143→            \"SELECT content_hash FROM vector_index_status WHERE document_id = ?\",\n   144→            (doc_id,)\n   145→        )\n   146→        row = cursor.fetchone()\n   147→        if row and row[0] == content_hash:\n   148→            return False  # Already indexed, unchanged\n   149→            \n   150→        # Generate embedding\n   151→        try:\n   152→            embedding = self.generate_embedding(content)\n   153→        except Exception as e:\n   154→            print(f\"   ✗ Embedding failed for doc {doc_id}: {e}\")\n   155→            return False\n   156→            \n   157→        # Convert to JSON array for sqlite-vec\n   158→        embedding_json = json.dumps(embedding)\n   159→        \n   160→        # Insert or replace vector\n   161→        cursor.execute(\"\"\"\n   162→            INSERT OR REPLACE INTO document_vectors (document_id, embedding)\n   163→            VALUES (?, ?)\n   164→        \"\"\", (doc_id, embedding_json))\n   165→        \n   166→        # Update status\n   167→        cursor.execute(\"\"\"\n   168→            INSERT OR REPLACE INTO vector_index_status (document_id, content_hash, indexed_at)\n   169→            VALUES (?, ?, datetime('now'))\n   170→        \"\"\", (doc_id, content_hash))\n   171→        \n   172→        self.conn.commit()\n   173→        return True\n   174→        \n   175→    def index_all(self, batch_size: int = 32):\n   176→        \"\"\"Index all documents that don't have vectors yet\"\"\"\n   177→        cursor = self.conn.cursor()\n   178→        \n   179→        # Get all documents without vectors or with changed content\n   180→        cursor.execute(\"\"\"\n   181→            SELECT d.id, d.content, d.content_hash, d.path\n   182→            FROM documents d\n   183→            LEFT JOIN vector_index_status vis ON d.id = vis.document_id\n   184→            WHERE vis.document_id IS NULL OR vis.content_hash != d.content_hash\n   185→        \"\"\")\n   186→        \n   187→        to_index = cursor.fetchall()\n   188→        \n   189→        if not to_index:\n   190→            print(\"✓ All documents already vector-indexed\")\n   191→            return\n   192→            \n   193→        print(f\"🔄 Indexing {len(to_index)} documents with embeddings...\")\n   194→        \n   195→        indexed = 0\n   196→        errors = 0\n   197→        \n   198→        for doc_id, content, content_hash, path in to_index:\n   199→            try:\n   200→                if self.index_document(doc_id, content, content_hash):\n   201→                    indexed += 1\n   202→                    if indexed % 10 == 0:\n   203→                        print(f\"   ... {indexed} documents indexed\")\n   204→            except Exception as e:\n   205→                print(f\"   ✗ Error indexing {path}: {e}\")\n   206→                errors += 1\n   207→                \n   208→        print(f\"✓ Indexing complete: {indexed} indexed, {errors} errors\")\n   209→        \n   210→    def get_stats(self) -> Dict[str, Any]:\n   211→        \"\"\"Get vector index statistics\"\"\"\n   212→        cursor = self.conn.cursor()\n   213→        \n   214→        cursor.execute(\"SELECT COUNT(*) FROM document_vectors\")\n   215→        vector_count = cursor.fetchone()[0]\n   216→        \n   217→        cursor.execute(\"SELECT COUNT(*) FROM documents\")\n   218→        total_docs = cursor.fetchone()[0]\n   219→        \n   220→        cursor.execute(\"SELECT COUNT(*) FROM vector_index_status\")\n   221→        indexed_count = cursor.fetchone()[0]\n   222→        \n   223→        return {\n   224→            'total_documents': total_docs,\n   225→            'vector_indexed': vector_count,\n   226→            'index_status_entries': indexed_count,\n   227→            'coverage_pct': (vector_count / total_docs * 100) if total_docs > 0 else 0\n   228→        }\n   229→        \n   230→    def close(self):\n   231→        if self.conn:\n   232→            self.conn.close()\n   233→\n   234→\n   235→class SemanticSearcher:\n   236→    \"\"\"Handles semantic and hybrid search\"\"\"\n   237→    \n   238→    def __init__(self, db_path: str | None = None):\n   239→        self.db_path = Path(db_path) if db_path else Path(DB_PATHS[\"p9_memory\"])\n   240→        self.conn = None\n   241→        self.model = None\n   242→        \n   243→    def connect(self):\n   244→        \"\"\"Connect to database with sqlite-vec loaded\"\"\"\n   245→        self.conn = sqlite3.connect(self.db_path)\n   246→        self.conn.enable_load_extension(True)\n   247→        \n   248→        # Load sqlite-vec (try multiple methods)\n   249→        try:\n   250→            self.conn.execute(\"SELECT load_extension('vec0')\")\n   251→        except sqlite3.OperationalError:\n   252→            try:\n   253→                import sqlite_vec\n   254→                sqlite_vec.load(self.conn)\n   255→            except:\n   256→                # Try explicit paths\n   257→                import platform\n   258→                system = platform.system()\n   259→                ext = \"dylib\" if system == \"Darwin\" else \"so\"\n   260→                paths = [\n   261→                    f\"/opt/homebrew/lib/vec0.{ext}\",\n   262→                    f\"/usr/local/lib/vec0.{ext}\",\n   263→                    f\"./vec0.{ext}\",\n   264→                ]\n   265→                for path in paths:\n   266→                    if Path(path).exists():\n   267→                        self.conn.execute(f\"SELECT load_extension('{path}')\")\n   268→                        break\n   269→                        \n   270→    def load_model(self):\n   271→        \"\"\"Lazy load the embedding model\"\"\"\n   272→        if self.model is None:\n   273→            from sentence_transformers import SentenceTransformer\n   274→            self.model = SentenceTransformer(EMBEDDING_MODEL)\n   275→            \n   276→    def search(\n   277→        self, \n   278→        query: str, \n   279→        top_k: int = 10,\n   280→        min_similarity: float = 0.3\n   281→    ) -> List[Dict[str, Any]]:\n   282→        \"\"\"Pure semantic search using cosine similarity\"\"\"\n   283→        self.load_model()\n   284→        \n   285→        # Generate query embedding\n   286→        query_embedding = self.model.encode(query, convert_to_numpy=True)\n   287→        query_json = json.dumps(query_embedding.tolist())\n   288→        \n   289→        cursor = self.conn.cursor()\n   290→        \n   291→        # sqlite-vec cosine similarity search\n   292→        # vec_distance_cosine returns distance (0 = identical, 2 = opposite)\n   293→        # Convert to similarity: 1 - distance/2\n   294→        cursor.execute(\"\"\"\n   295→            SELECT \n   296→                d.id,\n   297→                d.path,\n   298→                d.title,\n   299→                d.metadata,\n   300→                d.file_size,\n   301→                d.modified_time,\n   302→                vec_distance_cosine(dv.embedding, ?) as distance\n   303→            FROM document_vectors dv\n   304→            JOIN documents d ON dv.document_id = d.id\n   305→            ORDER BY distance\n   306→            LIMIT ?\n   307→        \"\"\", (query_json, top_k * 2))  # Get extra for filtering\n   308→        \n   309→        results = []\n   310→        for row in cursor.fetchall():\n   311→            distance = row[6]\n   312→            similarity = 1 - (distance / 2)  # Convert distance to similarity\n   313→            \n   314→            if similarity >= min_similarity:\n   315→                results.append({\n   316→                    'id': row[0],\n   317→                    'path': row[1],\n   318→                    'title': row[2],\n   319→                    'metadata': row[3],\n   320→                    'file_size': row[4],\n   321→                    'modified_time': row[5],\n   322→                    'similarity': similarity,\n   323→                    'score_type': 'semantic'\n   324→                })\n   325→                \n   326→        return results[:top_k]\n   327→        \n   328→    def hybrid_search(\n   329→        self,\n   330→        query: str,\n   331→        top_k: int = 10,\n   332→        semantic_weight: float = 0.7,\n   333→        fts_weight: float = 0.3\n   334→    ) -> List[Dict[str, Any]]:\n   335→        \"\"\"Hybrid search combining FTS5 and semantic similarity\"\"\"\n   336→        self.load_model()\n   337→        \n   338→        # Get semantic results\n   339→        semantic_results = self.search(query, top_k=top_k * 2, min_similarity=0.1)\n   340→        semantic_dict = {r['id']: r for r in semantic_results}\n   341→        \n   342→        # Get FTS5 results\n   343→        query_escaped = query.replace('\"', '\"\"')\n   344→        cursor = self.conn.cursor()\n   345→        \n   346→        try:\n   347→            cursor.execute(\"\"\"\n   348→                SELECT \n   349→                    d.id,\n   350→                    d.path,\n   351→                    d.title,\n   352→                    rank\n   353→                FROM documents d\n   354→                JOIN documents_fts fts ON d.id = fts.rowid\n   355→                WHERE documents_fts MATCH ?\n   356→                ORDER BY rank\n   357→                LIMIT ?\n   358→            \"\"\", (query_escaped, top_k * 2))\n   359→            \n   360→            fts_results = []\n   361→            for row in cursor.fetchall():\n   362→                # Convert BM25 rank to score (lower rank = better, normalize)\n   363→                # BM25 rank is negative log of probability, typically -10 to 0\n   364→                rank = row[3] if row[3] else 0\n   365→                # Normalize to 0-1 (approximate)\n   366→                fts_score = max(0, min(1, 1 - (abs(rank) / 10)))\n   367→                \n   368→                fts_results.append({\n   369→                    'id': row[0],\n   370→                    'path': row[1],\n   371→                    'title': row[2],\n   372→                    'fts_score': fts_score\n   373→                })\n   374→                \n   375→        except Exception as e:\n   376→            print(f\"⚠️  FTS search error: {e}\")\n   377→            fts_results = []\n   378→            \n   379→        # Combine results\n   380→        all_ids = set(semantic_dict.keys())\n   381→        for r in fts_results:\n   382→            all_ids.add(r['id'])\n   383→            \n   384→        combined = []\n   385→        for doc_id in all_ids:\n   386→            sem_score = semantic_dict.get(doc_id, {}).get('similarity', 0)\n   387→            fts_score = next((r['fts_score'] for r in fts_results if r['id'] == doc_id), 0)\n   388→            \n   389→            # Weighted combination\n   390→            combined_score = (semantic_weight * sem_score) + (fts_weight * fts_score)\n   391→            \n   392→            # Get document details from semantic result or fetch\n   393→            if doc_id in semantic_dict:\n   394→                doc = semantic_dict[doc_id].copy()\n   395→            else:\n   396→                cursor.execute(\n   397→                    \"SELECT id, path, title, metadata, file_size, modified_time FROM documents WHERE id = ?\",\n   398→                    (doc_id,)\n   399→                )\n   400→                row = cursor.fetchone()\n   401→                if not row:\n   402→                    continue\n   403→                doc = {\n   404→                    'id': row[0],\n   405→                    'path': row[1],\n   406→                    'title': row[2],\n   407→                    'metadata': row[3],\n   408→                    'file_size': row[4],\n   409→                    'modified_time': row[5],\n   410→                    'similarity': 0\n   411→                }\n   412→                \n   413→            doc['hybrid_score'] = combined_score\n   414→            doc['semantic_score'] = sem_score\n   415→            doc['fts_score'] = fts_score\n   416→            doc['score_type'] = 'hybrid'\n   417→            combined.append(doc)\n   418→            \n   419→        # Sort by hybrid score descending\n   420→        combined.sort(key=lambda x: x['hybrid_score'], reverse=True)\n   421→        return combined[:top_k]\n   422→        \n   423→    def close(self):\n   424→        if self.conn:\n   425→            self.conn.close()\n   426→\n   427→\n   428→def print_results(results: List[Dict[str, Any]], show_scores: bool = True):\n   429→    \"\"\"Pretty print search results\"\"\"\n   430→    if not results:\n   431→        print(\"\\nNo results found.\")\n   432→        return\n   433→        \n   434→    print(f\"\\n{'='*80}\")\n   435→    print(f\"Found {len(results)} result(s)\")\n   436→    print(f\"{'='*80}\\n\")\n   437→    \n   438→    for i, result in enumerate(results, 1):\n   439→        # Score badge based on similarity/score\n   440→        if 'similarity' in result and result['similarity'] > 0.8:\n   441→            badge = \"\\033[1m\\033[32m[EXACT]\\033[0m\"\n   442→        elif 'similarity' in result and result['similarity'] > 0.6:\n   443→            badge = \"\\033[1m\\033[34m[HIGH]\\033[0m\"\n   444→        elif 'hybrid_score' in result and result['hybrid_score'] > 0.5:\n   445→            badge = \"\\033[1m\\033[36m[HYBRID]\\033[0m\"\n   446→        else:\n   447→            badge = \"\\033[1m\\033[90m[OK]\\033[0m\"\n   448→            \n   449→        print(f\"{i}. {badge} {result['title']}\")\n   450→        print(f\"   Path: {result['path']}\")\n   451→        \n   452→        if show_scores:\n   453→            if 'similarity' in result:\n   454→                print(f\"   Similarity: {result['similarity']:.3f}\")\n   455→            if 'hybrid_score' in result:\n   456→                print(f\"   Hybrid: {result['hybrid_score']:.3f} (sem: {result.get('semantic_score', 0):.3f}, fts: {result.get('fts_score', 0):.3f})\")\n   457→                \n   458→        print()\n   459→\n   460→\n   461→def main():\n   462→    parser = argparse.ArgumentParser(\n   463→        description=\"P9 Semantic Search — Embedding-based document search\"\n   464→    )\n   465→    parser.add_argument(\n   466→        \"--db\",\n   467→        default=str(DB_PATHS[\"p9_memory\"]),\n   468→        help=\"Database path (default: data/p9_memory.db)\"\n   469→    )\n   470→    \n   471→    subparsers = parser.add_subparsers(dest=\"command\", help=\"Command to run\")\n   472→    \n   473→    # Index command\n   474→    index_parser = subparsers.add_parser(\"index\", help=\"Index documents with embeddings\")\n   475→    \n   476→    # Search command\n   477→    search_parser = subparsers.add_parser(\"search\", help=\"Semantic search\")\n   478→    search_parser.add_argument(\"query\", help=\"Search query\")\n   479→    search_parser.add_argument(\"--top-k\", type=int, default=10, help=\"Number of results\")\n   480→    search_parser.add_argument(\"--min-sim\", type=float, default=0.3, help=\"Minimum similarity\")\n   481→    \n   482→    # Hybrid command\n   483→    hybrid_parser = subparsers.add_parser(\"hybrid\", help=\"Hybrid FTS5 + semantic search\")\n   484→    hybrid_parser.add_argument(\"query\", help=\"Search query\")\n   485→    hybrid_parser.add_argument(\"--top-k\", type=int, default=10, help=\"Number of results\")\n   486→    hybrid_parser.add_argument(\"--sem-weight\", type=float, default=0.7, help=\"Semantic weight\")\n   487→    hybrid_parser.add_argument(\"--fts-weight\", type=float, default=0.3, help=\"FTS weight\")\n   488→    \n   489→    # Stats command\n   490→    stats_parser = subparsers.add_parser(\"stats\", help=\"Show vector index statistics\")\n   491→    \n   492→    args = parser.parse_args()\n   493→    \n   494→    if not args.command:\n   495→        parser.print_help()\n   496→        sys.exit(1)\n   497→        \n   498→    if args.command == \"index\":\n   499→        indexer = SemanticIndexer(args.db)\n   500→        try:\n   501→            indexer.connect()\n   502→            indexer.init_vector_schema()\n   503→            indexer.index_all()\n   504→            stats = indexer.get_stats()\n   505→            print(f\"\\n📊 Index coverage: {stats['coverage_pct']:.1f}% ({stats['vector_indexed']}/{stats['total_documents']})\")\n   506→        except Exception as e:\n   507→            print(f\"✗ Indexing failed: {e}\")\n   508→            import traceback\n   509→            traceback.print_exc()\n   510→            sys.exit(1)\n   511→        finally:\n   512→            indexer.close()\n   513→            \n   514→    elif args.command == \"search\":\n   515→        searcher = SemanticSearcher(args.db)\n   516→        try:\n   517→            searcher.connect()\n   518→            print(f\"🔍 Semantic search: \\\"{args.query}\\\"\")\n   519→            results = searcher.search(args.query, top_k=args.top_k, min_similarity=args.min_sim)\n   520→            print_results(results)\n   521→        except Exception as e:\n   522→            print(f\"✗ Search failed: {e}\")\n   523→            import traceback\n   524→            traceback.print_exc()\n   525→            sys.exit(1)\n   526→        finally:\n   527→            searcher.close()\n   528→            \n   529→    elif args.command == \"hybrid\":\n   530→        searcher = SemanticSearcher(args.db)\n   531→        try:\n   532→            searcher.connect()\n   533→            print(f\"🔍 Hybrid search: \\\"{args.query}\\\"\")\n   534→            print(f\"   Weights: semantic={args.sem_weight}, fts={args.fts_weight}\")\n   535→            results = searcher.hybrid_search(\n   536→                args.query,\n   537→                top_k=args.top_k,\n   538→                semantic_weight=args.sem_weight,\n   539→                fts_weight=args.fts_weight\n   540→            )\n   541→            print_results(results)\n   542→        except Exception as e:\n   543→            print(f\"✗ Search failed: {e}\")\n   544→            import traceback\n   545→            traceback.print_exc()\n   546→            sys.exit(1)\n   547→        finally:\n   548→            searcher.close()\n   549→            \n   550→    elif args.command == \"stats\":\n   551→        indexer = SemanticIndexer(args.db)\n   552→        try:\n   553→            indexer.connect()\n   554→            stats = indexer.get_stats()\n   555→            print(f\"\\n📊 Vector Index Statistics: {args.db}\")\n   556→            print(f\"{'='*40}\")\n   557→            print(f\"Total documents: {stats['total_documents']}\")\n   558→            print(f\"Vector indexed: {stats['vector_indexed']}\")\n   559→            print(f\"Coverage: {stats['coverage_pct']:.1f}%\")\n   560→        finally:\n   561→            indexer.close()\n   562→\n   563→\n   564→if __name__ == \"__main__\":\n   565→    main()\n   566→"}]},"uuid":"15f6c704-97f6-4ff0-938f-9e53fdc41438","timestamp":"2026-03-15T13:48:42.250Z","sourceToolAssistantUUID":"3f771a2a-64a0-44ef-9a4b-d5ae61151617","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
