{"parentUuid":"7682cb47-a65c-4fc2-8534-90383be6f7cb","isSidechain":true,"agentId":"ac07ec132779c32c0","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01BwuCdb4BCSN9diXe7MWRAL","toolUseID":"toolu_01BwuCdb4BCSN9diXe7MWRAL","timestamp":"2026-03-15T13:47:32.500Z","uuid":"f1a14dd4-e0d3-4dd6-bbd0-e54b12529ea2","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"d8a6bed2-c4c5-46c1-8c0a-cc873666a52b","isSidechain":true,"promptId":"eb82f461-7131-4c9b-87e7-a8beab163db0","agentId":"ac07ec132779c32c0","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BwuCdb4BCSN9diXe7MWRAL","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→DHARMIC_AGORA Authentication Module\n     4→\n     5→Secure Ed25519 challenge-response authentication.\n     6→NO API KEYS IN DATABASE - learned from Moltbook's 1.5M key leak.\n     7→\n     8→Usage:\n     9→    from agora.auth import AgentAuth, generate_agent_keypair\n    10→\n    11→    # Agent generates keypair (private key stays on agent)\n    12→    private_key, public_key = generate_agent_keypair()\n    13→\n    14→    # Agent registers with public key\n    15→    auth = AgentAuth()\n    16→    address = auth.register(\"my-agent\", public_key)\n    17→\n    18→    # Auth flow: challenge -> sign -> verify -> JWT\n    19→    challenge = auth.create_challenge(address)\n    20→    signature = sign_challenge(private_key, challenge)\n    21→    jwt_token = auth.verify_challenge(address, signature)\n    22→\"\"\"\n    23→\n    24→import hashlib\n    25→import hmac\n    26→import json\n    27→import os\n    28→import re\n    29→import secrets\n    30→import sqlite3\n    31→import time\n    32→from dataclasses import dataclass\n    33→from datetime import datetime, timedelta, timezone\n    34→from pathlib import Path\n    35→from typing import Optional, Tuple\n    36→try:\n    37→    from passlib.context import CryptContext\n    38→except ImportError:  # Optional in local/dev; production should install passlib[bcrypt]\n    39→    CryptContext = None  # type: ignore[assignment]\n    40→\n    41→try:\n    42→    from .config import get_admin_allowlist, get_db_path, JWT_SECRET_FILE as CONFIG_JWT_SECRET_FILE\n    43→except ImportError:  # Allow running as a script\n    44→    import sys\n    45→    sys.path.insert(0, str(Path(__file__).parent.parent))\n    46→    from agora.config import get_admin_allowlist, get_db_path, JWT_SECRET_FILE as CONFIG_JWT_SECRET_FILE\n    47→\n    48→# PyNaCl for Ed25519 (libsodium binding)\n    49→try:\n    50→    from nacl.signing import SigningKey, VerifyKey\n    51→    from nacl.exceptions import BadSignatureError\n    52→    from nacl.encoding import HexEncoder\n    53→    NACL_AVAILABLE = True\n    54→except ImportError:\n    55→    NACL_AVAILABLE = False\n    56→    print(\"WARNING: PyNaCl not installed. Run: pip install pynacl\")\n    57→\n    58→\n    59→# =============================================================================\n    60→# CONFIGURATION\n    61→# =============================================================================\n    62→\n    63→AGORA_DB = get_db_path()\n    64→CHALLENGE_TTL_SECONDS = 60\n    65→JWT_TTL_HOURS = 24\n    66→JWT_SECRET_FILE = CONFIG_JWT_SECRET_FILE\n    67→TOKEN_NAME_PATTERN = re.compile(r\"^[A-Za-z0-9-]{3,30}$\")\n    68→TOKEN_HASHER = CryptContext(schemes=[\"bcrypt\"], deprecated=\"auto\") if CryptContext else None\n    69→\n    70→\n    71→def _sha256_simple_token_secret(token: str) -> str:\n    72→    \"\"\"Return a deterministic sha256 token hash with explicit scheme marker.\"\"\"\n    73→    return f\"sha256${hashlib.sha256(token.encode()).hexdigest()}\"\n    74→\n    75→\n    76→def _hash_simple_token_secret(token: str) -> str:\n    77→    \"\"\"Hash a simple token secret (bcrypt preferred, sha256 fallback).\"\"\"\n    78→    global TOKEN_HASHER\n    79→    if TOKEN_HASHER is not None:\n    80→        try:\n    81→            return TOKEN_HASHER.hash(token)\n    82→        except Exception:\n    83→            # Some bcrypt/passlib combos fail at runtime; keep token issuance available.\n    84→            TOKEN_HASHER = None\n    85→    return _sha256_simple_token_secret(token)\n    86→\n    87→\n    88→def _verify_simple_token_secret(token: str, stored_hash: str) -> bool:\n    89→    \"\"\"Verify simple token secret against bcrypt/sha256 hash formats.\"\"\"\n    90→    global TOKEN_HASHER\n    91→    if not stored_hash:\n    92→        return False\n    93→\n    94→    if stored_hash.startswith(\"$2\"):\n    95→        if TOKEN_HASHER is None:\n    96→            return False\n    97→        try:\n    98→            return bool(TOKEN_HASHER.verify(token, stored_hash))\n    99→        except Exception:\n   100→            TOKEN_HASHER = None\n   101→            return False\n   102→\n   103→    if stored_hash.startswith(\"sha256$\"):\n   104→        candidate = stored_hash[len(\"sha256$\"):]\n   105→    else:\n   106→        # Legacy rows may store raw sha256 in token_hash.\n   107→        candidate = stored_hash\n   108→\n   109→    return hmac.compare_digest(candidate, hashlib.sha256(token.encode()).hexdigest())\n   110→\n   111→\n   112→# =============================================================================\n   113→# KEY GENERATION (For Agents)\n   114→# =============================================================================\n   115→\n   116→def generate_agent_keypair() -> Tuple[bytes, bytes]:\n   117→    \"\"\"\n   118→    Generate Ed25519 keypair for agent authentication.\n   119→\n   120→    Returns:\n   121→        (private_key_hex, public_key_hex) - Both as hex-encoded bytes\n   122→\n   123→    The private key MUST stay on the agent's device.\n   124→    Only the public key is sent to DHARMIC_AGORA.\n   125→    \"\"\"\n   126→    if not NACL_AVAILABLE:\n   127→        raise ImportError(\"PyNaCl required: pip install pynacl\")\n   128→\n   129→    signing_key = SigningKey.generate()\n   130→    private_key_hex = signing_key.encode(encoder=HexEncoder)\n   131→    public_key_hex = signing_key.verify_key.encode(encoder=HexEncoder)\n   132→\n   133→    return private_key_hex, public_key_hex\n   134→\n   135→\n   136→# =============================================================================\n   137→# AGENT IDENTITY (CLIENT-SIDE HELPER)\n   138→# =============================================================================\n   139→\n   140→class AgentIdentity:\n   141→    \"\"\"Every agent has a cryptographic identity that signs all contributions.\"\"\"\n   142→\n   143→    def __init__(self, agent_id: str, signing_key: SigningKey):\n   144→        self.agent_id = agent_id\n   145→        self.signing_key = signing_key\n   146→        self.verify_key = signing_key.verify_key\n   147→\n   148→    def sign(self, message: bytes) -> bytes:\n   149→        return self.signing_key.sign(message).signature\n   150→\n   151→    @staticmethod\n   152→    def verify(verify_key_bytes: bytes, message: bytes, signature: bytes) -> bool:\n   153→        vk = VerifyKey(verify_key_bytes)\n   154→        try:\n   155→            vk.verify(message, signature)\n   156→            return True\n   157→        except Exception:\n   158→            return False\n   159→\n   160→\n   161→def sign_challenge(private_key_hex: bytes, challenge: bytes) -> bytes:\n   162→    \"\"\"\n   163→    Sign a challenge with the agent's private key.\n   164→\n   165→    Args:\n   166→        private_key_hex: Agent's private key (hex-encoded)\n   167→        challenge: Challenge bytes from DHARMIC_AGORA\n   168→\n   169→    Returns:\n   170→        Signature (hex-encoded)\n   171→    \"\"\"\n   172→    if not NACL_AVAILABLE:\n   173→        raise ImportError(\"PyNaCl required: pip install pynacl\")\n   174→\n   175→    signing_key = SigningKey(private_key_hex, encoder=HexEncoder)\n   176→    signed = signing_key.sign(challenge)\n   177→    return signed.signature.hex().encode()\n   178→\n   179→\n   180→def build_contribution_message(\n   181→    agent_address: str,\n   182→    content: str,\n   183→    signed_at: str,\n   184→    content_type: str,\n   185→    post_id: Optional[int] = None,\n   186→    parent_id: Optional[int] = None,\n   187→) -> bytes:\n   188→    \"\"\"\n   189→    Build a canonical message for contribution signing.\n   190→\n   191→    This must match on both client and server.\n   192→    \"\"\"\n   193→    payload = {\n   194→        \"agent_address\": agent_address,\n   195→        \"content\": content,\n   196→        \"signed_at\": signed_at,\n   197→        \"content_type\": content_type,\n   198→        \"post_id\": post_id,\n   199→        \"parent_id\": parent_id,\n   200→    }\n   201→    return json.dumps(payload, sort_keys=True, separators=(\",\", \":\")).encode()\n   202→\n   203→\n   204→def verify_contribution_signature(\n   205→    public_key_hex: str, message: bytes, signature_hex: str\n   206→) -> bool:\n   207→    \"\"\"Verify a contribution signature using the agent's public key.\"\"\"\n   208→    if not NACL_AVAILABLE:\n   209→        return False\n   210→    try:\n   211→        verify_key = VerifyKey(public_key_hex.encode(), encoder=HexEncoder)\n   212→        signature_bytes = bytes.fromhex(signature_hex)\n   213→        verify_key.verify(message, signature_bytes)\n   214→        return True\n   215→    except Exception:\n   216→        return False\n   217→\n   218→\n   219→# =============================================================================\n   220→# DATA CLASSES\n   221→# =============================================================================\n   222→\n   223→@dataclass\n   224→class Agent:\n   225→    \"\"\"Registered agent in DHARMIC_AGORA.\"\"\"\n   226→    address: str\n   227→    name: str\n   228→    public_key_hex: str\n   229→    created_at: str\n   230→    reputation: float = 0.0\n   231→    telos: str = \"\"\n   232→    last_seen: Optional[str] = None\n   233→\n   234→\n   235→@dataclass\n   236→class AuthResult:\n   237→    \"\"\"Result of authentication attempt.\"\"\"\n   238→    success: bool\n   239→    token: Optional[str] = None\n   240→    agent: Optional[Agent] = None\n   241→    error: Optional[str] = None\n   242→    expires_at: Optional[str] = None\n   243→\n   244→\n   245→# =============================================================================\n   246→# AGENT AUTHENTICATION\n   247→# =============================================================================\n   248→\n   249→class AgentAuth:\n   250→    \"\"\"\n   251→    Secure agent authentication using Ed25519 challenge-response.\n   252→\n   253→    Security properties:\n   254→    1. No API keys stored - only public keys\n   255→    2. Challenge-response prevents replay attacks\n   256→    3. Short-lived JWTs reduce exposure window\n   257→    4. All operations logged in witness trail\n   258→    \"\"\"\n   259→\n   260→    def __init__(self, db_path: Path = AGORA_DB):\n   261→        self.db_path = db_path\n   262→        self.db_path.parent.mkdir(parents=True, exist_ok=True)\n   263→        self._init_db()\n   264→        self._jwt_secret = self._load_or_create_jwt_secret()\n   265→\n   266→    def _init_db(self):\n   267→        \"\"\"Initialize database tables with proper security.\"\"\"\n   268→        conn = sqlite3.connect(self.db_path)\n   269→        cursor = conn.cursor()\n   270→\n   271→        # Agents table - NO API KEYS, only public keys\n   272→        cursor.execute(\"\"\"\n   273→            CREATE TABLE IF NOT EXISTS agents (\n   274→                address TEXT PRIMARY KEY,\n   275→                name TEXT NOT NULL,\n   276→                public_key_hex TEXT NOT NULL UNIQUE,\n   277→                created_at TEXT NOT NULL,\n   278→                reputation REAL DEFAULT 0.0,\n   279→                telos TEXT DEFAULT '',\n   280→                last_seen TEXT,\n   281→                is_banned INTEGER DEFAULT 0\n   282→            )\n   283→        \"\"\")\n   284→\n   285→        # Challenges table - temporary, auto-cleaned\n   286→        cursor.execute(\"\"\"\n   287→            CREATE TABLE IF NOT EXISTS challenges (\n   288→                address TEXT PRIMARY KEY,\n   289→                challenge_hex TEXT NOT NULL,\n   290→                created_at TEXT NOT NULL,\n   291→                expires_at TEXT NOT NULL\n   292→            )\n   293→        \"\"\")\n   294→\n   295→        # Witness log - append-only audit trail\n   296→        cursor.execute(\"\"\"\n   297→            CREATE TABLE IF NOT EXISTS witness_log (\n   298→                id INTEGER PRIMARY KEY AUTOINCREMENT,\n   299→                timestamp TEXT NOT NULL,\n   300→                action TEXT NOT NULL,\n   301→                agent_address TEXT,\n   302→                data_hash TEXT NOT NULL,\n   303→                previous_hash TEXT,\n   304→                signature TEXT\n   305→            )\n   306→        \"\"\")\n   307→\n   308→        # Simple tokens (Tier 1 — lowest barrier)\n   309→        cursor.execute(\"\"\"\n   310→            CREATE TABLE IF NOT EXISTS simple_tokens (\n   311→                token TEXT PRIMARY KEY,\n   312→                token_hash TEXT UNIQUE,\n   313→                address TEXT NOT NULL UNIQUE,\n   314→                name TEXT NOT NULL,\n   315→                telos TEXT DEFAULT '',\n   316→                created_at TEXT NOT NULL,\n   317→                expires_at TEXT NOT NULL\n   318→            )\n   319→        \"\"\")\n   320→        self._ensure_simple_token_hash_schema(cursor)\n   321→\n   322→        # API keys (Tier 2 — medium barrier, stored as hash)\n   323→        cursor.execute(\"\"\"\n   324→            CREATE TABLE IF NOT EXISTS api_keys (\n   325→                key_hash TEXT PRIMARY KEY,\n   326→                address TEXT NOT NULL UNIQUE,\n   327→                name TEXT NOT NULL,\n   328→                telos TEXT DEFAULT '',\n   329→                created_at TEXT NOT NULL,\n   330→                expires_at TEXT NOT NULL\n   331→            )\n   332→        \"\"\")\n   333→\n   334→        conn.commit()\n   335→        conn.close()\n   336→\n   337→    def _ensure_simple_token_hash_schema(self, cursor: sqlite3.Cursor):\n   338→        \"\"\"\n   339→        Ensure simple token storage uses hashed secrets.\n   340→\n   341→        Backward compatibility:\n   342→        - Legacy rows may have plaintext token in `token` and null `token_hash`.\n   343→        - We backfill `token_hash` (sha256 for migration safety) and replace token\n   344→          with a non-secret reference.\n   345→        \"\"\"\n   346→        cursor.execute(\"PRAGMA table_info(simple_tokens)\")\n   347→        columns = {row[1] for row in cursor.fetchall()}\n   348→\n   349→        if \"token_hash\" not in columns:\n   350→            cursor.execute(\"ALTER TABLE simple_tokens ADD COLUMN token_hash TEXT\")\n   351→\n   352→        cursor.execute(\n   353→            \"CREATE UNIQUE INDEX IF NOT EXISTS idx_simple_tokens_token_hash ON simple_tokens(token_hash)\"\n   354→        )\n   355→\n   356→        legacy_rows = cursor.execute(\n   357→            \"\"\"\n   358→            SELECT token FROM simple_tokens\n   359→            WHERE (token_hash IS NULL OR token_hash = '')\n   360→              AND token IS NOT NULL\n   361→              AND token != ''\n   362→            \"\"\"\n   363→        ).fetchall()\n   364→\n   365→        for (legacy_token,) in legacy_rows:\n   366→            token_hash = hashlib.sha256(legacy_token.encode()).hexdigest()\n   367→            token_ref = f\"legacy_{token_hash[:24]}\"\n   368→            cursor.execute(\n   369→                \"\"\"\n   370→                UPDATE simple_tokens\n   371→                SET token = ?, token_hash = ?\n   372→                WHERE token = ? AND (token_hash IS NULL OR token_hash = '')\n   373→                \"\"\",\n   374→                (token_ref, token_hash, legacy_token),\n   375→            )\n   376→\n   377→    def _load_or_create_jwt_secret(self) -> bytes:\n   378→        \"\"\"Load or create JWT signing secret.\"\"\"\n   379→        JWT_SECRET_FILE.parent.mkdir(parents=True, exist_ok=True)\n   380→\n   381→        if JWT_SECRET_FILE.exists():\n   382→            # Enforce strict permission when loading existing secret.\n   383→            try:\n   384→                if (JWT_SECRET_FILE.stat().st_mode & 0o777) != 0o600:\n   385→                    JWT_SECRET_FILE.chmod(0o600)\n   386→            except OSError:\n   387→                pass\n   388→            return JWT_SECRET_FILE.read_bytes()\n   389→\n   390→        secret = secrets.token_bytes(32)\n   391→        flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL\n   392→\n   393→        try:\n   394→            fd = os.open(str(JWT_SECRET_FILE), flags, 0o600)\n   395→        except FileExistsError:\n   396→            # Another process created it between exists() and open().\n   397→            return JWT_SECRET_FILE.read_bytes()\n   398→\n   399→        with os.fdopen(fd, \"wb\") as f:\n   400→            f.write(secret)\n   401→            f.flush()\n   402→            os.fsync(f.fileno())\n   403→        return secret\n   404→\n   405→    def _witness(self, action: str, agent_address: str, data: dict):\n   406→        \"\"\"Record action to witness log.\"\"\"\n   407→        conn = sqlite3.connect(self.db_path)\n   408→        cursor = conn.cursor()\n   409→\n   410→        # Get previous hash for chain\n   411→        cursor.execute(\"SELECT data_hash FROM witness_log ORDER BY id DESC LIMIT 1\")\n   412→        row = cursor.fetchone()\n   413→        previous_hash = row[0] if row else \"genesis\"\n   414→\n   415→        # Hash the data\n   416→        data_hash = hashlib.sha256(json.dumps(data, sort_keys=True).encode()).hexdigest()\n   417→\n   418→        cursor.execute(\"\"\"\n   419→            INSERT INTO witness_log (timestamp, action, agent_address, data_hash, previous_hash)\n   420→            VALUES (?, ?, ?, ?, ?)\n   421→        \"\"\", (\n   422→            datetime.now(timezone.utc).isoformat(),\n   423→            action,\n   424→            agent_address,\n   425→            data_hash,\n   426→            previous_hash\n   427→        ))\n   428→\n   429→        conn.commit()\n   430→        conn.close()\n   431→\n   432→    def register(self, name: str, public_key_hex: bytes, telos: str = \"\") -> str:\n   433→        \"\"\"\n   434→        Register a new agent with their public key.\n   435→\n   436→        Args:\n   437→            name: Human-readable agent name\n   438→            public_key_hex: Ed25519 public key (hex-encoded)\n   439→            telos: Agent's declared purpose/orientation\n   440→\n   441→        Returns:\n   442→            Agent address (derived from public key hash)\n   443→\n   444→        Raises:\n   445→            ValueError: If public key already registered\n   446→        \"\"\"\n   447→        if isinstance(public_key_hex, bytes):\n   448→            public_key_hex = public_key_hex.decode()\n   449→\n   450→        # Derive address from public key (deterministic)\n   451→        address = hashlib.sha256(public_key_hex.encode()).hexdigest()[:16]\n   452→\n   453→        conn = sqlite3.connect(self.db_path)\n   454→        cursor = conn.cursor()\n   455→\n   456→        try:\n   457→            cursor.execute(\"\"\"\n   458→                INSERT INTO agents (address, name, public_key_hex, created_at, telos)\n   459→                VALUES (?, ?, ?, ?, ?)\n   460→            \"\"\", (\n   461→                address,\n   462→                name,\n   463→                public_key_hex,\n   464→                datetime.now(timezone.utc).isoformat(),\n   465→                telos\n   466→            ))\n   467→            conn.commit()\n   468→        except sqlite3.IntegrityError:\n   469→            conn.close()\n   470→            raise ValueError(f\"Agent already registered: {address}\")\n   471→        finally:\n   472→            conn.close()\n   473→\n   474→        self._witness(\"agent_registered\", address, {\"name\": name, \"telos\": telos})\n   475→        return address\n   476→\n   477→    def create_challenge(self, address: str) -> bytes:\n   478→        \"\"\"\n   479→        Create authentication challenge for an agent.\n   480→\n   481→        Args:\n   482→            address: Agent's address\n   483→\n   484→        Returns:\n   485→            Random challenge bytes (32 bytes)\n   486→\n   487→        The agent must sign this challenge with their private key.\n   488→        Challenge expires in 60 seconds.\n   489→        \"\"\"\n   490→        # Verify agent exists\n   491→        conn = sqlite3.connect(self.db_path)\n   492→        cursor = conn.cursor()\n   493→\n   494→        cursor.execute(\"SELECT address FROM agents WHERE address = ? AND is_banned = 0\", (address,))\n   495→        if not cursor.fetchone():\n   496→            conn.close()\n   497→            raise ValueError(f\"Unknown or banned agent: {address}\")\n   498→\n   499→        # Generate challenge\n   500→        challenge = secrets.token_bytes(32)\n   501→        challenge_hex = challenge.hex()\n   502→        now = datetime.now(timezone.utc)\n   503→        expires = now + timedelta(seconds=CHALLENGE_TTL_SECONDS)\n   504→\n   505→        # Store challenge (replace any existing)\n   506→        cursor.execute(\"\"\"\n   507→            INSERT OR REPLACE INTO challenges (address, challenge_hex, created_at, expires_at)\n   508→            VALUES (?, ?, ?, ?)\n   509→        \"\"\", (address, challenge_hex, now.isoformat(), expires.isoformat()))\n   510→\n   511→        conn.commit()\n   512→        conn.close()\n   513→\n   514→        return challenge\n   515→\n   516→    def verify_challenge(self, address: str, signature_hex: bytes) -> AuthResult:\n   517→        \"\"\"\n   518→        Verify agent's signature and issue JWT.\n   519→\n   520→        Args:\n   521→            address: Agent's address\n   522→            signature_hex: Ed25519 signature of the challenge (hex-encoded)\n   523→\n   524→        Returns:\n   525→            AuthResult with JWT token if successful\n   526→        \"\"\"\n   527→        if not NACL_AVAILABLE:\n   528→            return AuthResult(success=False, error=\"Server misconfigured: PyNaCl missing\")\n   529→\n   530→        if isinstance(signature_hex, bytes):\n   531→            signature_hex = signature_hex.decode()\n   532→\n   533→        conn = sqlite3.connect(self.db_path)\n   534→        cursor = conn.cursor()\n   535→\n   536→        # Get agent and challenge\n   537→        cursor.execute(\"\"\"\n   538→            SELECT a.public_key_hex, c.challenge_hex, c.expires_at,\n   539→                   a.name, a.reputation, a.telos, a.created_at\n   540→            FROM agents a\n   541→            JOIN challenges c ON a.address = c.address\n   542→            WHERE a.address = ? AND a.is_banned = 0\n   543→        \"\"\", (address,))\n   544→\n   545→        row = cursor.fetchone()\n   546→        if not row:\n   547→            conn.close()\n   548→            return AuthResult(success=False, error=\"No pending challenge\")\n   549→\n   550→        public_key_hex, challenge_hex, expires_at, name, reputation, telos, created_at = row\n   551→\n   552→        # Check expiry\n   553→        if datetime.fromisoformat(expires_at) < datetime.now(timezone.utc):\n   554→            # Clean up expired challenge\n   555→            cursor.execute(\"DELETE FROM challenges WHERE address = ?\", (address,))\n   556→            conn.commit()\n   557→            conn.close()\n   558→            return AuthResult(success=False, error=\"Challenge expired\")\n   559→\n   560→        # Verify signature\n   561→        try:\n   562→            verify_key = VerifyKey(public_key_hex.encode(), encoder=HexEncoder)\n   563→            challenge_bytes = bytes.fromhex(challenge_hex)\n   564→            signature_bytes = bytes.fromhex(signature_hex)\n   565→            verify_key.verify(challenge_bytes, signature_bytes)\n   566→        except BadSignatureError:\n   567→            self._witness(\"auth_failed\", address, {\"reason\": \"bad_signature\"})\n   568→            conn.close()\n   569→            return AuthResult(success=False, error=\"Invalid signature\")\n   570→        except Exception as e:\n   571→            conn.close()\n   572→            return AuthResult(success=False, error=f\"Verification error: {e}\")\n   573→\n   574→        # Clean up used challenge\n   575→        cursor.execute(\"DELETE FROM challenges WHERE address = ?\", (address,))\n   576→\n   577→        # Update last_seen\n   578→        cursor.execute(\n   579→            \"UPDATE agents SET last_seen = ? WHERE address = ?\",\n   580→            (datetime.now(timezone.utc).isoformat(), address)\n   581→        )\n   582→\n   583→        conn.commit()\n   584→        conn.close()\n   585→\n   586→        # Issue JWT\n   587→        expires_at = datetime.now(timezone.utc) + timedelta(hours=JWT_TTL_HOURS)\n   588→        token = self._create_jwt(address, name, expires_at)\n   589→\n   590→        agent = Agent(\n   591→            address=address,\n   592→            name=name,\n   593→            public_key_hex=public_key_hex,\n   594→            created_at=created_at,\n   595→            reputation=reputation,\n   596→            telos=telos,\n   597→            last_seen=datetime.now(timezone.utc).isoformat()\n   598→        )\n   599→\n   600→        self._witness(\"auth_success\", address, {\"expires\": expires_at.isoformat()})\n   601→\n   602→        return AuthResult(\n   603→            success=True,\n   604→            token=token,\n   605→            agent=agent,\n   606→            expires_at=expires_at.isoformat()\n   607→        )\n   608→\n   609→    def _create_jwt(self, address: str, name: str, expires_at: datetime) -> str:\n   610→        \"\"\"Create simple HMAC-signed JWT.\"\"\"\n   611→        header = {\"alg\": \"HS256\", \"typ\": \"JWT\"}\n   612→        payload = {\n   613→            \"sub\": address,\n   614→            \"name\": name,\n   615→            \"exp\": int(expires_at.timestamp()),\n   616→            \"iat\": int(time.time())\n   617→        }\n   618→\n   619→        def b64url(data: bytes) -> str:\n   620→            import base64\n   621→            return base64.urlsafe_b64encode(data).rstrip(b'=').decode()\n   622→\n   623→        header_b64 = b64url(json.dumps(header).encode())\n   624→        payload_b64 = b64url(json.dumps(payload).encode())\n   625→        message = f\"{header_b64}.{payload_b64}\"\n   626→\n   627→        signature = hmac.new(self._jwt_secret, message.encode(), hashlib.sha256).digest()\n   628→        signature_b64 = b64url(signature)\n   629→\n   630→        return f\"{message}.{signature_b64}\"\n   631→\n   632→    def verify_jwt(self, token: str) -> Optional[dict]:\n   633→        \"\"\"Verify JWT and return payload if valid.\"\"\"\n   634→        try:\n   635→            parts = token.split('.')\n   636→            if len(parts) != 3:\n   637→                return None\n   638→\n   639→            header_b64, payload_b64, signature_b64 = parts\n   640→            message = f\"{header_b64}.{payload_b64}\"\n   641→\n   642→            # Verify signature\n   643→            import base64\n   644→\n   645→            def unpad(s):\n   646→                return s + '=' * (4 - len(s) % 4)\n   647→\n   648→            expected_sig = hmac.new(\n   649→                self._jwt_secret,\n   650→                message.encode(),\n   651→                hashlib.sha256\n   652→            ).digest()\n   653→            actual_sig = base64.urlsafe_b64decode(unpad(signature_b64))\n   654→\n   655→            if not hmac.compare_digest(expected_sig, actual_sig):\n   656→                return None\n   657→\n   658→            # Decode payload\n   659→            payload = json.loads(base64.urlsafe_b64decode(unpad(payload_b64)))\n   660→\n   661→            # Check expiry\n   662→            if payload.get('exp', 0) < time.time():\n   663→                return None\n   664→\n   665→            return payload\n   666→\n   667→        except Exception:\n   668→            return None\n   669→\n   670→    def get_agent(self, address: str) -> Optional[Agent]:\n   671→        \"\"\"Get agent by address.\"\"\"\n   672→        conn = sqlite3.connect(self.db_path)\n   673→        cursor = conn.cursor()\n   674→\n   675→        cursor.execute(\"\"\"\n   676→            SELECT address, name, public_key_hex, created_at, reputation, telos, last_seen\n   677→            FROM agents WHERE address = ? AND is_banned = 0\n   678→        \"\"\", (address,))\n   679→\n   680→        row = cursor.fetchone()\n   681→        conn.close()\n   682→\n   683→        if not row:\n   684→            return None\n   685→\n   686→        return Agent(*row)\n   687→\n   688→    def get_agent_public_key(self, address: str) -> Optional[str]:\n   689→        \"\"\"Get the public key hex for an agent.\"\"\"\n   690→        conn = sqlite3.connect(self.db_path)\n   691→        cursor = conn.cursor()\n   692→        cursor.execute(\"\"\"\n   693→            SELECT public_key_hex FROM agents WHERE address = ? AND is_banned = 0\n   694→        \"\"\", (address,))\n   695→        row = cursor.fetchone()\n   696→        conn.close()\n   697→        return row[0] if row else None\n   698→\n   699→    def is_admin(self, address: str) -> bool:\n   700→        \"\"\"Check whether an agent address is in the admin allowlist.\"\"\"\n   701→        return address in get_admin_allowlist()\n   702→\n   703→    def verify_contribution(self, address: str, message: bytes, signature_hex: str) -> bool:\n   704→        \"\"\"Verify a signed contribution for an agent.\"\"\"\n   705→        public_key_hex = self.get_agent_public_key(address)\n   706→        if not public_key_hex:\n   707→            return False\n   708→        return verify_contribution_signature(public_key_hex, message, signature_hex)\n   709→\n   710→    def ban_agent(self, address: str, reason: str):\n   711→        \"\"\"Ban an agent (admin action).\"\"\"\n   712→        conn = sqlite3.connect(self.db_path)\n   713→        cursor = conn.cursor()\n   714→        cursor.execute(\"UPDATE agents SET is_banned = 1 WHERE address = ?\", (address,))\n   715→        conn.commit()\n   716→        conn.close()\n   717→\n   718→        self._witness(\"agent_banned\", address, {\"reason\": reason})\n   719→\n   720→    def _validate_simple_token_name(self, name: str) -> None:\n   721→        \"\"\"Validate onboarding name constraints for simple-token registration.\"\"\"\n   722→        if not isinstance(name, str):\n   723→            raise ValueError(\"Name must be a string\")\n   724→        if not TOKEN_NAME_PATTERN.fullmatch(name):\n   725→            raise ValueError(\"Name must be 3-30 chars: alphanumeric or hyphen\")\n   726→\n   727→    def _is_name_taken(self, name: str) -> bool:\n   728→        \"\"\"Check whether a public-facing agent name is already in use.\"\"\"\n   729→        lowered = name.lower()\n   730→        conn = sqlite3.connect(self.db_path)\n   731→        try:\n   732→            row = conn.execute(\n   733→                \"\"\"\n   734→                SELECT 1 FROM agents WHERE LOWER(name) = ?\n   735→                UNION\n   736→                SELECT 1 FROM simple_tokens WHERE LOWER(name) = ?\n   737→                UNION\n   738→                SELECT 1 FROM api_keys WHERE LOWER(name) = ?\n   739→                LIMIT 1\n   740→                \"\"\",\n   741→                (lowered, lowered, lowered),\n   742→            ).fetchone()\n   743→            return row is not None\n   744→        finally:\n   745→            conn.close()\n   746→\n   747→    # =========================================================================\n   748→    # TIER 1: Simple Token Auth (lowest barrier)\n   749→    # =========================================================================\n   750→\n   751→    def create_simple_token(self, name: str, telos: str = \"\", strict_onboarding: bool = False) -> dict:\n   752→        \"\"\"\n   753→        Create a simple bearer token. No crypto required.\n   754→\n   755→        Returns:\n   756→            {\"token\": \"sab_...\", \"address\": \"...\", \"name\": \"...\", \"expires_at\": \"...\"}\n   757→        \"\"\"\n   758→        if strict_onboarding:\n   759→            self._validate_simple_token_name(name)\n   760→            if self._is_name_taken(name):\n   761→                raise ValueError(f\"Name already registered: {name}\")\n   762→\n   763→        token = f\"sab_{secrets.token_hex(32)}\"\n   764→        token_hash = _hash_simple_token_secret(token)\n   765→        token_fingerprint = hashlib.sha256(token.encode()).hexdigest()\n   766→        token_ref = f\"ref_{token_fingerprint[:24]}\"\n   767→        address = f\"t_{token_fingerprint[:14]}\"\n   768→        now = datetime.now(timezone.utc)\n   769→        expires_at = now + timedelta(hours=JWT_TTL_HOURS)\n   770→\n   771→        conn = sqlite3.connect(self.db_path)\n   772→        try:\n   773→            conn.execute(\n   774→                \"\"\"\n   775→                INSERT INTO simple_tokens (token, token_hash, address, name, telos, created_at, expires_at)\n   776→                VALUES (?,?,?,?,?,?,?)\n   777→                \"\"\",\n   778→                (token_ref, token_hash, address, name, telos, now.isoformat(), expires_at.isoformat()),\n   779→            )\n   780→            conn.commit()\n   781→        finally:\n   782→            conn.close()\n   783→\n   784→        self._witness(\"simple_token_created\", address, {\"name\": name})\n   785→        return {\"token\": token, \"address\": address, \"name\": name,\n   786→                \"expires_at\": expires_at.isoformat(), \"auth_method\": \"token\"}\n   787→\n   788→    def verify_simple_token(self, token: str) -> Optional[dict]:\n   789→        \"\"\"Verify a simple token. Returns agent dict or None.\n   790→        \n   791→        Uses constant-time comparison to prevent timing attacks.\n   792→        \"\"\"\n   793→        if not isinstance(token, str):\n   794→            return None\n   795→        if not token.startswith(\"sab_\"):\n   796→            return None\n   797→        if len(token) > 256:\n   798→            return None\n   799→        \n   800→        conn = sqlite3.connect(self.db_path)\n   801→        try:\n   802→            now = datetime.now(timezone.utc).isoformat()\n   803→            rows = conn.execute(\n   804→                \"\"\"\n   805→                SELECT token_hash, address, name, telos\n   806→                FROM simple_tokens\n   807→                WHERE token_hash IS NOT NULL AND token_hash != '' AND expires_at > ?\n   808→                \"\"\",\n   809→                (now,),\n   810→            ).fetchall()\n   811→\n   812→            for stored_hash, address, name, telos in rows:\n   813→                if not stored_hash:\n   814→                    continue\n   815→\n   816→                if _verify_simple_token_secret(token, stored_hash):\n   817→                    return {\n   818→                        \"address\": address,\n   819→                        \"name\": name,\n   820→                        \"telos\": telos,\n   821→                        \"reputation\": 0.0,\n   822→                        \"auth_method\": \"token\",\n   823→                    }\n   824→\n   825→            # Legacy fallback: plaintext rows that predate token_hash migration.\n   826→            rows = conn.execute(\n   827→                \"\"\"\n   828→                SELECT token, address, name, telos, expires_at\n   829→                FROM simple_tokens\n   830→                WHERE (token_hash IS NULL OR token_hash = '') AND expires_at > ?\n   831→                \"\"\",\n   832→                (now,),\n   833→            ).fetchall()\n   834→\n   835→            for stored_token, address, name, telos, expires_at in rows:\n   836→                if hmac.compare_digest(stored_token, token):\n   837→                    return {\"address\": address, \"name\": name, \"telos\": telos,\n   838→                            \"reputation\": 0.0, \"auth_method\": \"token\"}\n   839→            return None\n   840→        finally:\n   841→            conn.close()\n   842→\n   843→    # =========================================================================\n   844→    # TIER 2: API Key Auth (medium barrier)\n   845→    # =========================================================================\n   846→\n   847→    def create_api_key(self, name: str, telos: str = \"\", expires_days: int = 90) -> dict:\n   848→        \"\"\"\n   849→        Create a long-lived API key. Stored as SHA-256 hash.\n   850→\n   851→        Returns:\n   852→            {\"api_key\": \"sab_k_...\", \"address\": \"...\", \"name\": \"...\", \"expires_at\": \"...\"}\n   853→        \"\"\"\n   854→        raw_key = f\"sab_k_{secrets.token_hex(32)}\"\n   855→        key_hash = hashlib.sha256(raw_key.encode()).hexdigest()\n   856→        address = f\"k_{key_hash[:14]}\"\n   857→        now = datetime.now(timezone.utc)\n   858→        expires_at = now + timedelta(days=expires_days)\n   859→\n   860→        conn = sqlite3.connect(self.db_path)\n   861→        try:\n   862→            conn.execute(\n   863→                \"INSERT INTO api_keys (key_hash, address, name, telos, created_at, expires_at) VALUES (?,?,?,?,?,?)\",\n   864→                (key_hash, address, name, telos, now.isoformat(), expires_at.isoformat()),\n   865→            )\n   866→            conn.commit()\n   867→        finally:\n   868→            conn.close()\n   869→\n   870→        self._witness(\"api_key_created\", address, {\"name\": name})\n   871→        return {\"api_key\": raw_key, \"address\": address, \"name\": name,\n   872→                \"expires_at\": expires_at.isoformat(), \"auth_method\": \"api_key\"}\n   873→\n   874→    def verify_api_key(self, raw_key: str) -> Optional[dict]:\n   875→        \"\"\"Verify an API key. Returns agent dict or None.\"\"\"\n   876→        if not raw_key.startswith(\"sab_k_\"):\n   877→            return None\n   878→        key_hash = hashlib.sha256(raw_key.encode()).hexdigest()\n   879→        conn = sqlite3.connect(self.db_path)\n   880→        try:\n   881→            row = conn.execute(\n   882→                \"SELECT address, name, telos, expires_at FROM api_keys WHERE key_hash=?\",\n   883→                (key_hash,),\n   884→            ).fetchone()\n   885→            if not row:\n   886→                return None\n   887→            address, name, telos, expires_at = row\n   888→            if datetime.fromisoformat(expires_at) < datetime.now(timezone.utc):\n   889→                return None\n   890→            return {\"address\": address, \"name\": name, \"telos\": telos,\n   891→                    \"reputation\": 0.0, \"auth_method\": \"api_key\"}\n   892→        finally:\n   893→            conn.close()\n   894→\n   895→\n   896→# =============================================================================\n   897→# CLI TESTING\n   898→# =============================================================================\n   899→\n   900→if __name__ == \"__main__\":\n   901→    print(\"=== DHARMIC_AGORA Auth Test ===\\n\")\n   902→\n   903→    if not NACL_AVAILABLE:\n   904→        print(\"ERROR: Install PyNaCl first: pip install pynacl\")\n   905→        exit(1)\n   906→\n   907→    # Generate agent keypair\n   908→    print(\"1. Generating agent keypair...\")\n   909→    private_key, public_key = generate_agent_keypair()\n   910→    print(f\"   Private key: {private_key[:32].decode()}... (KEEP SECRET)\")\n   911→    print(f\"   Public key:  {public_key[:32].decode()}...\")\n   912→\n   913→    # Register agent\n   914→    print(\"\\n2. Registering agent...\")\n   915→    auth = AgentAuth()\n   916→    try:\n   917→        address = auth.register(\"test-agent\", public_key, telos=\"seeking truth\")\n   918→        print(f\"   Address: {address}\")\n   919→    except ValueError:\n   920→        print(\"   Already registered, looking up...\")\n   921→        address = hashlib.sha256(public_key).hexdigest()[:16]\n   922→\n   923→    # Auth flow\n   924→    print(\"\\n3. Creating challenge...\")\n   925→    challenge = auth.create_challenge(address)\n   926→    print(f\"   Challenge: {challenge.hex()[:32]}...\")\n   927→\n   928→    print(\"\\n4. Signing challenge...\")\n   929→    signature = sign_challenge(private_key, challenge)\n   930→    print(f\"   Signature: {signature[:32].decode()}...\")\n   931→\n   932→    print(\"\\n5. Verifying signature...\")\n   933→    result = auth.verify_challenge(address, signature)\n   934→    if result.success:\n   935→        print(\"   SUCCESS!\")\n   936→        print(f\"   JWT Token: {result.token[:50]}...\")\n   937→        print(f\"   Expires: {result.expires_at}\")\n   938→        print(f\"   Agent: {result.agent.name} (rep: {result.agent.reputation})\")\n   939→    else:\n   940→        print(f\"   FAILED: {result.error}\")\n   941→\n   942→    print(\"\\n6. Verifying JWT...\")\n   943→    payload = auth.verify_jwt(result.token)\n   944→    if payload:\n   945→        print(f\"   Valid! Subject: {payload['sub']}\")\n   946→    else:\n   947→        print(\"   Invalid!\")\n   948→\n   949→    print(\"\\n=== Test Complete ===\")\n   950→"}]},"uuid":"e8b1a101-7440-482f-9e16-4478a68726bb","timestamp":"2026-03-15T13:47:32.500Z","sourceToolAssistantUUID":"d8a6bed2-c4c5-46c1-8c0a-cc873666a52b","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
