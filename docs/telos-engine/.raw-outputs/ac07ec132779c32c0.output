{"parentUuid":"2396276c-6a9c-49d3-8164-820c0c6b11e4","isSidechain":true,"agentId":"ac07ec132779c32c0","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_01VQ4kE6ArvCWWbUtDCFcaZQ","toolUseID":"toolu_01VQ4kE6ArvCWWbUtDCFcaZQ","timestamp":"2026-03-15T13:47:28.845Z","uuid":"285b4b79-b870-480d-b34f-334cf1d774dc","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"285b4b79-b870-480d-b34f-334cf1d774dc","isSidechain":true,"agentId":"ac07ec132779c32c0","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01VQ4kE6ArvCWWbUtDCFcaZQ","toolUseID":"toolu_01VQ4kE6ArvCWWbUtDCFcaZQ","timestamp":"2026-03-15T13:47:28.846Z","uuid":"252d3df6-62d9-4db9-abac-922cdd2cd99c","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"b7b060df-0368-4e72-9e47-14b4a94e34fc","isSidechain":true,"promptId":"eb82f461-7131-4c9b-87e7-a8beab163db0","agentId":"ac07ec132779c32c0","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VQ4kE6ArvCWWbUtDCFcaZQ","type":"tool_result","content":"     1→\"\"\"\n     2→DHARMIC_AGORA Database Layer\n     3→\n     4→SQLite database with proper security (learned from Moltbook).\n     5→Implements row-level security via application logic.\n     6→\"\"\"\n     7→\n     8→import sqlite3\n     9→import json\n    10→from datetime import datetime, timezone\n    11→from pathlib import Path\n    12→from typing import List, Optional, Dict, Any\n    13→from contextlib import contextmanager\n    14→\n    15→from .models import Post, Vote, ContentType, VoteType, generate_content_id\n    16→\n    17→\n    18→# =============================================================================\n    19→# CONFIGURATION\n    20→# =============================================================================\n    21→\n    22→AGORA_DB = Path(__file__).parent.parent / \"data\" / \"agora.db\"\n    23→\n    24→\n    25→# =============================================================================\n    26→# DATABASE MANAGER\n    27→# =============================================================================\n    28→\n    29→class AgoraDB:\n    30→    \"\"\"\n    31→    Database manager for DHARMIC_AGORA.\n    32→\n    33→    Security features:\n    34→    - No API keys stored (auth uses Ed25519 challenge-response)\n    35→    - All queries parameterized\n    36→    - Row-level security via application logic\n    37→    - Audit trail for all mutations\n    38→    \"\"\"\n    39→\n    40→    def __init__(self, db_path: Path = AGORA_DB):\n    41→        self.db_path = db_path\n    42→        self.db_path.parent.mkdir(parents=True, exist_ok=True)\n    43→        self._init_db()\n    44→\n    45→    @contextmanager\n    46→    def _conn(self):\n    47→        \"\"\"Context manager for database connection.\"\"\"\n    48→        conn = sqlite3.connect(self.db_path)\n    49→        conn.row_factory = sqlite3.Row\n    50→        try:\n    51→            yield conn\n    52→            conn.commit()\n    53→        except Exception:\n    54→            conn.rollback()\n    55→            raise\n    56→        finally:\n    57→            conn.close()\n    58→\n    59→    def _init_db(self):\n    60→        \"\"\"Initialize database tables.\"\"\"\n    61→        with self._conn() as conn:\n    62→            cursor = conn.cursor()\n    63→\n    64→            def ensure_column(table: str, column_name: str, column_def: str) -> None:\n    65→                cursor.execute(f\"PRAGMA table_info({table})\")\n    66→                existing = {row[1] for row in cursor.fetchall()}\n    67→                if column_name not in existing:\n    68→                    cursor.execute(f\"ALTER TABLE {table} ADD COLUMN {column_def}\")\n    69→\n    70→            # Posts table (includes comments)\n    71→            cursor.execute(\"\"\"\n    72→                CREATE TABLE IF NOT EXISTS posts (\n    73→                    id TEXT PRIMARY KEY,\n    74→                    author_address TEXT NOT NULL,\n    75→                    content TEXT NOT NULL,\n    76→                    content_type TEXT NOT NULL DEFAULT 'post',\n    77→                    parent_id TEXT,\n    78→                    created_at TEXT NOT NULL,\n    79→                    gate_evidence_hash TEXT NOT NULL,\n    80→                    gates_passed TEXT NOT NULL,\n    81→                    karma INTEGER DEFAULT 0,\n    82→                    comment_count INTEGER DEFAULT 0,\n    83→                    is_deleted INTEGER DEFAULT 0,\n    84→                    signature TEXT,\n    85→                    signed_at TEXT,\n    86→                    FOREIGN KEY (author_address) REFERENCES agents(address),\n    87→                    FOREIGN KEY (parent_id) REFERENCES posts(id)\n    88→                )\n    89→            \"\"\")\n    90→\n    91→            # Votes table\n    92→            cursor.execute(\"\"\"\n    93→                CREATE TABLE IF NOT EXISTS votes (\n    94→                    id TEXT PRIMARY KEY,\n    95→                    voter_address TEXT NOT NULL,\n    96→                    content_id TEXT NOT NULL,\n    97→                    vote_type TEXT NOT NULL,\n    98→                    created_at TEXT NOT NULL,\n    99→                    UNIQUE(voter_address, content_id),\n   100→                    FOREIGN KEY (voter_address) REFERENCES agents(address),\n   101→                    FOREIGN KEY (content_id) REFERENCES posts(id)\n   102→                )\n   103→            \"\"\")\n   104→\n   105→            # Gate evidence table (stores full evidence for verification)\n   106→            cursor.execute(\"\"\"\n   107→                CREATE TABLE IF NOT EXISTS gate_evidence (\n   108→                    id INTEGER PRIMARY KEY AUTOINCREMENT,\n   109→                    content_id TEXT NOT NULL,\n   110→                    evidence_hash TEXT NOT NULL,\n   111→                    evidence_json TEXT NOT NULL,\n   112→                    created_at TEXT NOT NULL,\n   113→                    FOREIGN KEY (content_id) REFERENCES posts(id)\n   114→                )\n   115→            \"\"\")\n   116→\n   117→            # Moderation queue\n   118→            cursor.execute(\"\"\"\n   119→                CREATE TABLE IF NOT EXISTS moderation_queue (\n   120→                    id INTEGER PRIMARY KEY AUTOINCREMENT,\n   121→                    content_type TEXT NOT NULL CHECK(content_type IN ('post', 'comment')),\n   122→                    content_id TEXT,\n   123→                    post_id TEXT,\n   124→                    parent_id TEXT,\n   125→                    content TEXT NOT NULL,\n   126→                    author_address TEXT NOT NULL,\n   127→                    gate_evidence_hash TEXT NOT NULL,\n   128→                    gate_results_json TEXT NOT NULL,\n   129→                    status TEXT NOT NULL,\n   130→                    reason TEXT,\n   131→                    created_at TEXT NOT NULL,\n   132→                    reviewed_at TEXT,\n   133→                    reviewer_address TEXT,\n   134→                    published_content_id TEXT,\n   135→                    signature TEXT,\n   136→                    signed_at TEXT\n   137→                )\n   138→            \"\"\")\n   139→            cursor.execute(\"CREATE INDEX IF NOT EXISTS idx_mod_queue_status ON moderation_queue(status)\")\n   140→            cursor.execute(\"CREATE INDEX IF NOT EXISTS idx_mod_queue_author ON moderation_queue(author_address)\")\n   141→\n   142→            # Indexes\n   143→            cursor.execute(\"CREATE INDEX IF NOT EXISTS idx_posts_author ON posts(author_address)\")\n   144→            cursor.execute(\"CREATE INDEX IF NOT EXISTS idx_posts_created ON posts(created_at DESC)\")\n   145→            cursor.execute(\"CREATE INDEX IF NOT EXISTS idx_posts_parent ON posts(parent_id)\")\n   146→            cursor.execute(\"CREATE INDEX IF NOT EXISTS idx_votes_content ON votes(content_id)\")\n   147→\n   148→            # Backfill new columns if DB already existed\n   149→            ensure_column(\"posts\", \"signature\", \"signature TEXT\")\n   150→            ensure_column(\"posts\", \"signed_at\", \"signed_at TEXT\")\n   151→\n   152→    # =========================================================================\n   153→    # POSTS\n   154→    # =========================================================================\n   155→\n   156→    def create_post(\n   157→        self,\n   158→        author_address: str,\n   159→        content: str,\n   160→        gate_evidence_hash: str,\n   161→        gates_passed: List[str],\n   162→        content_type: ContentType = ContentType.POST,\n   163→        parent_id: Optional[str] = None,\n   164→        signature: Optional[str] = None,\n   165→        signed_at: Optional[str] = None,\n   166→    ) -> Post:\n   167→        \"\"\"Create a new post or comment.\"\"\"\n   168→        created_at = datetime.now(timezone.utc).isoformat()\n   169→        post_id = generate_content_id(author_address, content, created_at)\n   170→\n   171→        with self._conn() as conn:\n   172→            cursor = conn.cursor()\n   173→\n   174→            cursor.execute(\"\"\"\n   175→                INSERT INTO posts (\n   176→                    id, author_address, content, content_type, parent_id,\n   177→                    created_at, gate_evidence_hash, gates_passed, signature, signed_at\n   178→                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n   179→            \"\"\", (\n   180→                post_id, author_address, content, content_type.value,\n   181→                parent_id, created_at, gate_evidence_hash, json.dumps(gates_passed),\n   182→                signature, signed_at\n   183→            ))\n   184→\n   185→            # Update parent comment count if this is a comment\n   186→            if parent_id:\n   187→                cursor.execute(\n   188→                    \"UPDATE posts SET comment_count = comment_count + 1 WHERE id = ?\",\n   189→                    (parent_id,)\n   190→                )\n   191→\n   192→        return Post(\n   193→            id=post_id,\n   194→            author_address=author_address,\n   195→            content=content,\n   196→            created_at=created_at,\n   197→            gate_evidence_hash=gate_evidence_hash,\n   198→            gates_passed=gates_passed,\n   199→            content_type=content_type,\n   200→            parent_id=parent_id\n   201→        )\n   202→\n   203→    def get_post(self, post_id: str) -> Optional[Post]:\n   204→        \"\"\"Get a post by ID.\"\"\"\n   205→        with self._conn() as conn:\n   206→            cursor = conn.cursor()\n   207→            cursor.execute(\"\"\"\n   208→                SELECT * FROM posts WHERE id = ? AND is_deleted = 0\n   209→            \"\"\", (post_id,))\n   210→            row = cursor.fetchone()\n   211→\n   212→            if not row:\n   213→                return None\n   214→\n   215→            return self._row_to_post(row)\n   216→\n   217→    def get_posts(\n   218→        self,\n   219→        limit: int = 50,\n   220→        offset: int = 0,\n   221→        author_address: Optional[str] = None\n   222→    ) -> List[Post]:\n   223→        \"\"\"Get posts with pagination.\"\"\"\n   224→        with self._conn() as conn:\n   225→            cursor = conn.cursor()\n   226→\n   227→            if author_address:\n   228→                cursor.execute(\"\"\"\n   229→                    SELECT * FROM posts\n   230→                    WHERE content_type = 'post' AND is_deleted = 0 AND author_address = ?\n   231→                    ORDER BY created_at DESC\n   232→                    LIMIT ? OFFSET ?\n   233→                \"\"\", (author_address, limit, offset))\n   234→            else:\n   235→                cursor.execute(\"\"\"\n   236→                    SELECT * FROM posts\n   237→                    WHERE content_type = 'post' AND is_deleted = 0\n   238→                    ORDER BY created_at DESC\n   239→                    LIMIT ? OFFSET ?\n   240→                \"\"\", (limit, offset))\n   241→\n   242→            return [self._row_to_post(row) for row in cursor.fetchall()]\n   243→\n   244→    def get_comments(self, parent_id: str, limit: int = 100) -> List[Post]:\n   245→        \"\"\"Get comments for a post.\"\"\"\n   246→        with self._conn() as conn:\n   247→            cursor = conn.cursor()\n   248→            cursor.execute(\"\"\"\n   249→                SELECT * FROM posts\n   250→                WHERE parent_id = ? AND is_deleted = 0\n   251→                ORDER BY created_at ASC\n   252→                LIMIT ?\n   253→            \"\"\", (parent_id, limit))\n   254→\n   255→            return [self._row_to_post(row) for row in cursor.fetchall()]\n   256→\n   257→    def get_author_post_counts(self, author_address: str) -> Dict[str, int]:\n   258→        \"\"\"Get post counts for rate limiting.\"\"\"\n   259→        with self._conn() as conn:\n   260→            cursor = conn.cursor()\n   261→\n   262→            # Posts in last hour\n   263→            cursor.execute(\"\"\"\n   264→                SELECT COUNT(*) FROM posts\n   265→                WHERE author_address = ?\n   266→                AND created_at > datetime('now', '-1 hour')\n   267→            \"\"\", (author_address,))\n   268→            last_hour = cursor.fetchone()[0]\n   269→\n   270→            # Posts in last day\n   271→            cursor.execute(\"\"\"\n   272→                SELECT COUNT(*) FROM posts\n   273→                WHERE author_address = ?\n   274→                AND created_at > datetime('now', '-1 day')\n   275→            \"\"\", (author_address,))\n   276→            last_day = cursor.fetchone()[0]\n   277→\n   278→            return {\"last_hour\": last_hour, \"last_day\": last_day}\n   279→\n   280→    def _row_to_post(self, row: sqlite3.Row) -> Post:\n   281→        \"\"\"Convert database row to Post object.\"\"\"\n   282→        return Post(\n   283→            id=row[\"id\"],\n   284→            author_address=row[\"author_address\"],\n   285→            content=row[\"content\"],\n   286→            created_at=row[\"created_at\"],\n   287→            gate_evidence_hash=row[\"gate_evidence_hash\"],\n   288→            gates_passed=json.loads(row[\"gates_passed\"]),\n   289→            karma=row[\"karma\"],\n   290→            comment_count=row[\"comment_count\"],\n   291→            parent_id=row[\"parent_id\"],\n   292→            content_type=ContentType(row[\"content_type\"])\n   293→        )\n   294→\n   295→    # =========================================================================\n   296→    # VOTES\n   297→    # =========================================================================\n   298→\n   299→    def create_vote(\n   300→        self,\n   301→        voter_address: str,\n   302→        content_id: str,\n   303→        vote_type: VoteType\n   304→    ) -> Optional[Vote]:\n   305→        \"\"\"Create or update a vote.\"\"\"\n   306→        created_at = datetime.now(timezone.utc).isoformat()\n   307→        vote_id = generate_content_id(voter_address, content_id, created_at)\n   308→\n   309→        with self._conn() as conn:\n   310→            cursor = conn.cursor()\n   311→\n   312→            # Check existing vote\n   313→            cursor.execute(\"\"\"\n   314→                SELECT vote_type FROM votes\n   315→                WHERE voter_address = ? AND content_id = ?\n   316→            \"\"\", (voter_address, content_id))\n   317→            existing = cursor.fetchone()\n   318→\n   319→            karma_delta = 1 if vote_type == VoteType.UP else -1\n   320→\n   321→            if existing:\n   322→                old_type = VoteType(existing[\"vote_type\"])\n   323→                if old_type == vote_type:\n   324→                    # Same vote, remove it\n   325→                    cursor.execute(\"\"\"\n   326→                        DELETE FROM votes\n   327→                        WHERE voter_address = ? AND content_id = ?\n   328→                    \"\"\", (voter_address, content_id))\n   329→                    karma_delta = -1 if vote_type == VoteType.UP else 1\n   330→                else:\n   331→                    # Change vote\n   332→                    cursor.execute(\"\"\"\n   333→                        UPDATE votes SET vote_type = ?, created_at = ?\n   334→                        WHERE voter_address = ? AND content_id = ?\n   335→                    \"\"\", (vote_type.value, created_at, voter_address, content_id))\n   336→                    karma_delta = 2 if vote_type == VoteType.UP else -2\n   337→            else:\n   338→                # New vote\n   339→                cursor.execute(\"\"\"\n   340→                    INSERT INTO votes (id, voter_address, content_id, vote_type, created_at)\n   341→                    VALUES (?, ?, ?, ?, ?)\n   342→                \"\"\", (vote_id, voter_address, content_id, vote_type.value, created_at))\n   343→\n   344→            # Update karma\n   345→            cursor.execute(\"\"\"\n   346→                UPDATE posts SET karma = karma + ? WHERE id = ?\n   347→            \"\"\", (karma_delta, content_id))\n   348→\n   349→        return Vote(\n   350→            id=vote_id,\n   351→            voter_address=voter_address,\n   352→            content_id=content_id,\n   353→            vote_type=vote_type,\n   354→            created_at=created_at\n   355→        )\n   356→\n   357→    def get_votes_for_content(self, content_id: str) -> Dict[str, int]:\n   358→        \"\"\"Get vote counts for content.\"\"\"\n   359→        with self._conn() as conn:\n   360→            cursor = conn.cursor()\n   361→            cursor.execute(\"\"\"\n   362→                SELECT vote_type, COUNT(*) as count\n   363→                FROM votes WHERE content_id = ?\n   364→                GROUP BY vote_type\n   365→            \"\"\", (content_id,))\n   366→\n   367→            result = {\"up\": 0, \"down\": 0}\n   368→            for row in cursor.fetchall():\n   369→                result[row[\"vote_type\"]] = row[\"count\"]\n   370→\n   371→            return result\n   372→\n   373→    # =========================================================================\n   374→    # GATE EVIDENCE\n   375→    # =========================================================================\n   376→\n   377→    def store_gate_evidence(\n   378→        self,\n   379→        content_id: str,\n   380→        evidence_hash: str,\n   381→        evidence_json: str\n   382→    ):\n   383→        \"\"\"Store gate evidence for a post.\"\"\"\n   384→        with self._conn() as conn:\n   385→            cursor = conn.cursor()\n   386→            cursor.execute(\"\"\"\n   387→                INSERT INTO gate_evidence (content_id, evidence_hash, evidence_json, created_at)\n   388→                VALUES (?, ?, ?, ?)\n   389→            \"\"\", (content_id, evidence_hash, evidence_json, datetime.now(timezone.utc).isoformat()))\n   390→\n   391→    def get_gate_evidence(self, content_id: str) -> Optional[Dict]:\n   392→        \"\"\"Get gate evidence for a post.\"\"\"\n   393→        with self._conn() as conn:\n   394→            cursor = conn.cursor()\n   395→            cursor.execute(\"\"\"\n   396→                SELECT evidence_json FROM gate_evidence WHERE content_id = ?\n   397→            \"\"\", (content_id,))\n   398→            row = cursor.fetchone()\n   399→\n   400→            if row:\n   401→                return json.loads(row[\"evidence_json\"])\n   402→            return None\n   403→\n   404→    # =========================================================================\n   405→    # STATS\n   406→    # =========================================================================\n   407→\n   408→    def get_stats(self) -> Dict[str, Any]:\n   409→        \"\"\"Get overall AGORA statistics.\"\"\"\n   410→        with self._conn() as conn:\n   411→            cursor = conn.cursor()\n   412→\n   413→            cursor.execute(\"SELECT COUNT(*) FROM posts WHERE content_type = 'post' AND is_deleted = 0\")\n   414→            post_count = cursor.fetchone()[0]\n   415→\n   416→            cursor.execute(\"SELECT COUNT(*) FROM posts WHERE content_type = 'comment' AND is_deleted = 0\")\n   417→            comment_count = cursor.fetchone()[0]\n   418→\n   419→            cursor.execute(\"SELECT COUNT(*) FROM votes\")\n   420→            vote_count = cursor.fetchone()[0]\n   421→\n   422→            cursor.execute(\"SELECT COUNT(DISTINCT author_address) FROM posts\")\n   423→            unique_authors = cursor.fetchone()[0]\n   424→\n   425→            return {\n   426→                \"total_posts\": post_count,\n   427→                \"total_comments\": comment_count,\n   428→                \"total_votes\": vote_count,\n   429→                \"unique_authors\": unique_authors\n   430→            }\n   431→\n   432→\n   433→# Singleton instance\n   434→_db: Optional[AgoraDB] = None\n   435→\n   436→\n   437→def get_db() -> AgoraDB:\n   438→    \"\"\"Get singleton database instance.\"\"\"\n   439→    global _db\n   440→    if _db is None:\n   441→        _db = AgoraDB()\n   442→    return _db\n   443→\n   444→# SQL Injection Protection — Column Allowlist\n   445→ALLOWED_COLUMNS = {\n   446→    \"posts\": [\"id\", \"content\", \"author_address\", \"created_at\", \"signature\"],\n   447→    \"users\": [\"address\", \"public_key\", \"created_at\"],\n   448→    \"votes\": [\"post_id\", \"voter_address\", \"value\", \"created_at\"]\n   449→}\n   450→\n   451→def validate_columns(table: str, columns: list) -> bool:\n   452→    \"\"\"Validate columns against allowlist to prevent SQL injection.\"\"\"\n   453→    allowed = ALLOWED_COLUMNS.get(table, [])\n   454→    return all(col in allowed for col in columns)\n   455→"}]},"uuid":"ab78f9f9-089b-4c15-a74d-e2a5990b2197","timestamp":"2026-03-15T13:47:28.845Z","sourceToolAssistantUUID":"b7b060df-0368-4e72-9e47-14b4a94e34fc","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
