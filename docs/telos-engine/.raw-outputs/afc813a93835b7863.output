{"parentUuid":"c59a7c39-ff09-491b-a64e-545ab6ab648b","isSidechain":true,"agentId":"afc813a93835b7863","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_018zJpNuxPvt5ZQUwLeCMkQQ","toolUseID":"toolu_018zJpNuxPvt5ZQUwLeCMkQQ","timestamp":"2026-03-15T13:47:41.131Z","uuid":"9871ff5b-426e-466f-bd26-0ed4e6906378","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"6aae0416-fc40-48a6-a94f-dda88a2e3bbe","isSidechain":true,"promptId":"0fd463d9-b82e-40a5-90f7-91f9435b3a86","agentId":"afc813a93835b7863","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018zJpNuxPvt5ZQUwLeCMkQQ","type":"tool_result","content":"     1→\"\"\"Skill Composer -- DAG-based skill composition for complex tasks.\n     2→\n     3→Goes beyond simple parallel spawning: skills compose into dependency\n     4→graphs where the output of one step feeds as context into the next.\n     5→The natural flow is research -> build -> validate -> deploy, but\n     6→arbitrary DAGs are supported via explicit dependency declarations.\n     7→\n     8→Topologically sorted into parallel \"waves\" for execution: steps\n     9→within a wave have no inter-dependencies and run concurrently.\n    10→\"\"\"\n    11→\n    12→from __future__ import annotations\n    13→\n    14→import hashlib\n    15→import logging\n    16→from collections import defaultdict, deque\n    17→from datetime import datetime, timezone\n    18→from typing import TYPE_CHECKING\n    19→\n    20→from pydantic import BaseModel, Field\n    21→\n    22→if TYPE_CHECKING:\n    23→    from dharma_swarm.intent_router import IntentRouter\n    24→    from dharma_swarm.skills import SkillRegistry\n    25→\n    26→logger = logging.getLogger(__name__)\n    27→\n    28→# Maximum steps per plan -- matches agent fleet size cap.\n    29→MAX_STEPS = 7\n    30→\n    31→# Canonical phase ordering used by auto-compose.\n    32→_PHASE_KEYWORDS: dict[str, list[str]] = {\n    33→    \"research\": [\"scan\", \"research\", \"analyze\", \"explore\", \"discover\", \"read\", \"map\", \"investigate\"],\n    34→    \"build\": [\"build\", \"implement\", \"create\", \"write\", \"code\", \"develop\", \"fix\", \"patch\", \"refactor\"],\n    35→    \"validate\": [\"test\", \"validate\", \"verify\", \"check\", \"assert\", \"qa\"],\n    36→    \"deploy\": [\"deploy\", \"ship\", \"release\", \"publish\", \"push\"],\n    37→}\n    38→\n    39→_PHASE_ORDER = [\"research\", \"build\", \"validate\", \"deploy\"]\n    40→\n    41→\n    42→# -- Models ---------------------------------------------------------------\n    43→\n    44→\n    45→class SkillStep(BaseModel):\n    46→    \"\"\"A single step in a skill composition DAG.\"\"\"\n    47→\n    48→    skill_name: str\n    49→    task: str\n    50→    depends_on: list[str] = Field(default_factory=list)\n    51→    step_id: str = \"\"\n    52→    parallel_group: str = \"\"\n    53→    timeout: float = 300.0\n    54→    retry: int = 0\n    55→\n    56→\n    57→class HandoffArtifact(BaseModel):\n    58→    \"\"\"Typed output from a skill step, passed to downstream steps.\"\"\"\n    59→\n    60→    step_id: str\n    61→    skill_name: str\n    62→    artifact_type: str  # code_diff, analysis, test_results, context, plan\n    63→    content: str\n    64→    metadata: dict = Field(default_factory=dict)\n    65→    created_at: datetime = Field(default_factory=lambda: datetime.now(timezone.utc))\n    66→\n    67→\n    68→class CompositionPlan(BaseModel):\n    69→    \"\"\"A full DAG of skill steps for a complex task.\"\"\"\n    70→\n    71→    task: str\n    72→    steps: list[SkillStep] = Field(default_factory=list)\n    73→    artifacts: dict[str, HandoffArtifact] = Field(default_factory=dict)\n    74→    status: str = \"pending\"\n    75→\n    76→    # -- DAG queries -------------------------------------------------------\n    77→\n    78→    def execution_order(self) -> list[list[SkillStep]]:\n    79→        \"\"\"Topological sort into parallel waves.\n    80→\n    81→        Returns a list of waves. Each wave contains steps whose\n    82→        dependencies are fully satisfied by prior waves.\n    83→\n    84→        Raises:\n    85→            ValueError: If the dependency graph contains a cycle.\n    86→        \"\"\"\n    87→        step_map: dict[str, SkillStep] = {s.step_id: s for s in self.steps}\n    88→        in_degree: dict[str, int] = {s.step_id: 0 for s in self.steps}\n    89→        children: dict[str, list[str]] = defaultdict(list)\n    90→\n    91→        for step in self.steps:\n    92→            for dep in step.depends_on:\n    93→                if dep in step_map:\n    94→                    in_degree[step.step_id] += 1\n    95→                    children[dep].append(step.step_id)\n    96→\n    97→        waves: list[list[SkillStep]] = []\n    98→        remaining = set(in_degree.keys())\n    99→\n   100→        while remaining:"}]},"uuid":"bceb46bc-e58e-4397-8a57-984d33a416dc","timestamp":"2026-03-15T13:47:41.130Z","sourceToolAssistantUUID":"6aae0416-fc40-48a6-a94f-dda88a2e3bbe","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
