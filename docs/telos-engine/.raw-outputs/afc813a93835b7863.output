{"parentUuid":"3a717782-7b84-4408-99ae-7a3accb0edf3","isSidechain":true,"agentId":"afc813a93835b7863","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01Ay5LK6uPePYaA6xPwr6Ro8","toolUseID":"toolu_01Ay5LK6uPePYaA6xPwr6Ro8","timestamp":"2026-03-15T13:47:17.590Z","uuid":"bfd5ed59-372a-4713-9401-b5b2a4d59e3e","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"8b78113e-bc21-47cf-b5ba-f9e45adec344","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"afc813a93835b7863","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ay5LK6uPePYaA6xPwr6Ro8","type":"tool_result","content":"     1→\"\"\"Async LLM provider abstraction layer.\n     2→\n     3→Wraps Anthropic and OpenAI async clients with a router for dispatching\n     4→by provider type. Missing API keys are tolerated at import; only raised on use.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→import asyncio\n    10→from dataclasses import replace\n    11→from datetime import datetime, timezone\n    12→import inspect\n    13→import json\n    14→import os\n    15→import random\n    16→import time\n    17→from abc import ABC, abstractmethod\n    18→from collections.abc import AsyncIterator\n    19→from pathlib import Path\n    20→from typing import Any\n    21→\n    22→import httpx\n    23→\n    24→from dharma_swarm.models import LLMRequest, LLMResponse, ProviderType\n    25→from dharma_swarm.jikoku_instrumentation import jikoku_traced_provider  # type: ignore\n    26→from dharma_swarm.ollama_config import (\n    27→    OLLAMA_DEFAULT_CLOUD_MODEL,\n    28→    OLLAMA_DEFAULT_LOCAL_MODEL,\n    29→    OLLAMA_LOCAL_BASE_URL,\n    30→    build_ollama_headers,\n    31→    ollama_transport_mode,\n    32→    resolve_ollama_base_url,\n    33→    resolve_ollama_model,\n    34→)\n    35→from dharma_swarm.provider_policy import (\n    36→    ProviderPolicyRouter,\n    37→    ProviderRouteDecision,\n    38→    ProviderRouteRequest,\n    39→)\n    40→from dharma_swarm.router_retrospective import (\n    41→    RouteOutcomeRecord,\n    42→    build_route_retrospective,\n    43→)\n    44→from dharma_swarm.resilience import (\n    45→    CircuitBreakerRegistry,\n    46→    RetryPolicy,\n    47→    run_with_retry,\n    48→)\n    49→from dharma_swarm.router_v1 import (\n    50→    build_routing_signals,\n    51→    enrich_route_request,\n    52→    model_hint_for_provider,\n    53→)\n    54→from dharma_swarm.routing_memory import RoutingMemoryStore, build_task_signature\n    55→\n    56→\n    57→class LLMProvider(ABC):\n    58→    \"\"\"Abstract base for all LLM providers.\"\"\"\n    59→\n    60→    @abstractmethod\n    61→    async def complete(self, request: LLMRequest) -> LLMResponse:\n    62→        \"\"\"Send a completion request and return the full response.\"\"\"\n    63→\n    64→    @abstractmethod\n    65→    async def stream(self, request: LLMRequest) -> AsyncIterator[str]:\n    66→        \"\"\"Stream completion tokens as they arrive.\"\"\"\n    67→        yield  # type: ignore[misc]  # required for async generator signature\n    68→\n    69→\n    70→class AnthropicProvider(LLMProvider):\n    71→    \"\"\"Provider backed by the Anthropic Messages API.\"\"\"\n    72→\n    73→    def __init__(self, api_key: str | None = None) -> None:\n    74→        self._api_key = api_key or os.environ.get(\"ANTHROPIC_API_KEY\")\n    75→        self._client: Any = None\n    76→\n    77→    def _client_or_raise(self) -> Any:\n    78→        if self._client is not None:\n    79→            return self._client\n    80→        if not self._api_key:\n    81→            raise RuntimeError(\"ANTHROPIC_API_KEY not set\")\n    82→        try:\n    83→            from anthropic import AsyncAnthropic\n    84→        except ImportError as exc:\n    85→            raise ImportError(\"pip install anthropic\") from exc\n    86→        self._client = AsyncAnthropic(api_key=self._api_key)\n    87→        return self._client\n    88→\n    89→    @staticmethod\n    90→    def _strip_system(msgs: list[dict[str, str]]) -> list[dict[str, str]]:\n    91→        return [m for m in msgs if m.get(\"role\") != \"system\"]\n    92→\n    93→    @jikoku_traced_provider\n    94→    async def complete(self, request: LLMRequest) -> LLMResponse:\n    95→        client = self._client_or_raise()\n    96→        kwargs: dict[str, Any] = dict(\n    97→            model=request.model, max_tokens=request.max_tokens,\n    98→            temperature=request.temperature,\n    99→            messages=self._strip_system(request.messages),\n   100→        )"}]},"uuid":"f1021705-28e2-4774-9187-38b5c6b1224e","timestamp":"2026-03-15T13:47:17.590Z","sourceToolAssistantUUID":"8b78113e-bc21-47cf-b5ba-f9e45adec344","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
