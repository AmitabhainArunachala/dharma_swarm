{"parentUuid":"eb7ee8e7-3e93-4ba9-87d2-9ff6e81cd237","isSidechain":true,"agentId":"afc813a93835b7863","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01QKVKdwo4Letw7MX8Siu2Jh","toolUseID":"toolu_01QKVKdwo4Letw7MX8Siu2Jh","timestamp":"2026-03-15T13:47:22.490Z","uuid":"17e907fd-8e09-4c25-b349-b2d20975fecc","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"fc8f7932-e009-4f69-87e2-526341f8451f","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"afc813a93835b7863","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QKVKdwo4Letw7MX8Siu2Jh","type":"tool_result","content":"     1→\"\"\"Darwin Engine -- self-improvement orchestration loop.\n     2→\n     3→Coordinates the full evolution cycle: propose mutations, gate-check them,\n     4→evaluate fitness, archive results, and select parents for the next generation.\n     5→\n     6→Pipeline:\n     7→    PROPOSE -> GATE CHECK -> WRITE CODE -> TEST -> EVALUATE FITNESS -> ARCHIVE -> SELECT NEXT PARENT\n     8→\"\"\"\n     9→\n    10→from __future__ import annotations\n    11→\n    12→import asyncio\n    13→from collections import defaultdict\n    14→import hashlib\n    15→import logging\n    16→import re\n    17→import shutil\n    18→from tempfile import TemporaryDirectory\n    19→import time\n    20→from collections.abc import Callable\n    21→from enum import Enum\n    22→from pathlib import Path\n    23→from typing import Any, Optional\n    24→\n    25→from pydantic import BaseModel, Field, field_validator\n    26→\n    27→from dharma_swarm.archive import (\n    28→    ArchiveEntry,\n    29→    EvolutionArchive,\n    30→    FitnessScore,\n    31→    normalize_fitness_weights,\n    32→)\n    33→from dharma_swarm.convergence import ConvergenceConfig, ConvergenceDetector\n    34→from dharma_swarm.diff_applier import DiffApplier\n    35→from dharma_swarm.elegance import evaluate_elegance\n    36→from dharma_swarm.execution_profile import (\n    37→    EvidenceTier,\n    38→    ExecutionProfileRegistry,\n    39→    PromotionState,\n    40→    ResolvedExecutionProfile,\n    41→    derive_promotion_state,\n    42→)\n    43→from dharma_swarm.experiment_memory import ExperimentMemory, ExperimentMemorySnapshot\n    44→from dharma_swarm.experiment_log import ExperimentLog, ExperimentRecord\n    45→from dharma_swarm.fitness_predictor import FitnessPredictor, ProposalFeatures\n    46→from dharma_swarm.jikoku_instrumentation import jikoku_auto_span\n    47→from dharma_swarm.landscape import FitnessLandscapeMapper, LandscapeProbe\n    48→from dharma_swarm.models import GateDecision, GateResult, SandboxResult, _new_id, _utc_now\n    49→from dharma_swarm.router_retrospective import (\n    50→    DriftGuardDecision,\n    51→    DriftGuardThresholds,\n    52→    RouteOutcomeRecord,\n    53→    RouteRetrospectiveArtifact,\n    54→    build_route_policy_archive_entry,\n    55→    build_route_retrospective,\n    56→    evaluate_router_drift,\n    57→)\n    58→from dharma_swarm.selector import select_parent\n    59→from dharma_swarm.telos_gates import check_with_reflective_reroute\n    60→from dharma_swarm.traces import TraceEntry, TraceStore\n    61→from dharma_swarm.ucb_selector import UCBConfig, UCBParentSelector\n    62→\n    63→logger = logging.getLogger(__name__)\n    64→\n    65→\n    66→# ---------------------------------------------------------------------------\n    67→# Enums\n    68→# ---------------------------------------------------------------------------\n    69→\n    70→\n    71→class EvolutionStatus(str, Enum):\n    72→    \"\"\"Lifecycle status of an evolution proposal.\"\"\"\n    73→\n    74→    PENDING = \"pending\"\n    75→    REFLECTING = \"reflecting\"\n    76→    GATED = \"gated\"\n    77→    WRITING = \"writing\"\n    78→    TESTING = \"testing\"\n    79→    EVALUATED = \"evaluated\"\n    80→    ARCHIVED = \"archived\"\n    81→    REJECTED = \"rejected\"\n    82→\n    83→\n    84→# ---------------------------------------------------------------------------\n    85→# Data models\n    86→# ---------------------------------------------------------------------------\n    87→\n    88→\n    89→class Proposal(BaseModel):\n    90→    \"\"\"A proposed code change to be evaluated by the Darwin Engine.\"\"\"\n    91→\n    92→    id: str = Field(default_factory=_new_id)\n    93→    component: str\n    94→    change_type: str  # \"mutation\", \"crossover\", \"ablation\"\n    95→    description: str\n    96→    parent_id: Optional[str] = None\n    97→    spec_ref: str | None = None\n    98→    requirement_refs: list[str] = Field(default_factory=list)\n    99→    think_notes: str = \"\"\n   100→    diff: str = \"\"\n   101→    status: EvolutionStatus = EvolutionStatus.PENDING\n   102→    predicted_fitness: float = 0.0\n   103→    actual_fitness: Optional[FitnessScore] = None\n   104→    gate_decision: Optional[str] = None\n   105→    gate_reason: Optional[str] = None\n   106→    reflection_attempts: int = 0\n   107→    reflection_suggestions: list[str] = Field(default_factory=list)\n   108→    test_results: dict[str, Any] = Field(default_factory=dict)\n   109→    cycle_id: str | None = None\n   110→    execution_profile: str = \"default\"\n   111→    execution_matched_pattern: str | None = None\n   112→    execution_workspace: str | None = None\n   113→    execution_test_command: str | None = None\n   114→    execution_timeout: float | None = None\n   115→    execution_risk_level: str = \"medium\"\n   116→    execution_rollback_policy: str = \"revert_patch\"\n   117→    execution_expected_metrics: list[str] = Field(default_factory=list)\n   118→    evidence_tier: str = EvidenceTier.UNVALIDATED.value\n   119→    promotion_state: str = PromotionState.CANDIDATE.value\n   120→    experiment_id: str | None = None\n   121→    metadata: dict[str, Any] | None = None\n   122→\n   123→    @field_validator('component')\n   124→    @classmethod\n   125→    def validate_component_path(cls, v: str) -> str:\n   126→        \"\"\"Ensure component is a valid filesystem path.\"\"\"\n   127→        invalid_chars = ['<', '>', ':', '\"', '|', '?', '*']\n   128→        for char in invalid_chars:\n   129→            if char in v:\n   130→                raise ValueError(f\"Component contains invalid filesystem character '{char}'\")\n   131→        return v\n   132→\n   133→\n   134→class CycleResult(BaseModel):\n   135→    \"\"\"Summary of a single evolution cycle run.\"\"\"\n   136→\n   137→    cycle_id: str = Field(default_factory=_new_id)\n   138→    plan_id: str = \"\"\n   139→    proposals_submitted: int = 0\n   140→    proposals_gated: int = 0\n   141→    proposals_tested: int = 0\n   142→    proposals_archived: int = 0\n   143→    circuit_breakers_tripped: int = 0\n   144→    strategy_pivots: int = 0\n   145→    best_fitness: float = 0.0\n   146→    exploration_ratio: float = 0.0\n   147→    convergence_restart_triggered: bool = False\n   148→    restart_cycles_remaining: int = 0\n   149→    mutation_rate_applied: float = 0.0\n   150→    landscape_basin: str | None = None"}]},"uuid":"291d48ec-8eb1-4b56-8427-e4f8c28bdb69","timestamp":"2026-03-15T13:47:22.489Z","sourceToolAssistantUUID":"fc8f7932-e009-4f69-87e2-526341f8451f","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
