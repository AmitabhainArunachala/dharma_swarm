{"parentUuid":"b22bac44-7ec2-4255-9c5d-1fb853a4372b","isSidechain":true,"promptId":"eb82f461-7131-4c9b-87e7-a8beab163db0","agentId":"afc813a93835b7863","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XeGDMxyZks5dwmqLJp3QJv","type":"tool_result","content":"     1→\"\"\"Policy compiler for DHARMA SWARM.\n     2→\n     3→Compiles kernel principles and accepted claims into a unified Policy\n     4→that can evaluate actions against dharmic constraints. Immutable rules\n     5→(from the kernel) always override mutable rules (from the corpus).\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→from typing import Any, Literal\n    11→\n    12→from pydantic import BaseModel, Field\n    13→\n    14→from dharma_swarm.models import _utc_now\n    15→\n    16→\n    17→# ---------------------------------------------------------------------------\n    18→# Data Models\n    19→# ---------------------------------------------------------------------------\n    20→\n    21→EnforcementLevel = Literal[\"block\", \"warn\", \"log\", \"gate_human\"]\n    22→\n    23→_SEVERITY_TO_ENFORCEMENT: dict[str, EnforcementLevel] = {\n    24→    \"critical\": \"block\",\n    25→    \"high\": \"warn\",\n    26→    \"medium\": \"log\",\n    27→}\n    28→\n    29→\n    30→class PolicyRule(BaseModel):\n    31→    \"\"\"A single rule inside a compiled policy.\"\"\"\n    32→\n    33→    source: str\n    34→    rule_text: str\n    35→    weight: float = Field(ge=0.0, le=1.0)\n    36→    is_immutable: bool\n    37→    enforcement_level: EnforcementLevel\n    38→\n    39→\n    40→class PolicyDecision(BaseModel):\n    41→    \"\"\"Result of checking an action against a policy.\"\"\"\n    42→\n    43→    allowed: bool\n    44→    violated_rules: list[PolicyRule] = Field(default_factory=list)\n    45→    reason: str = \"\"\n    46→\n    47→\n    48→class Policy(BaseModel):\n    49→    \"\"\"A compiled set of rules ready for action evaluation.\"\"\"\n    50→\n    51→    rules: list[PolicyRule] = Field(default_factory=list)\n    52→    context: str = \"\"\n    53→    compiled_at: str = Field(default_factory=lambda: _utc_now().isoformat())\n    54→\n    55→    def get_immutable_rules(self) -> list[PolicyRule]:\n    56→        \"\"\"Return all immutable (kernel-derived) rules.\"\"\"\n    57→        return [r for r in self.rules if r.is_immutable]\n    58→\n    59→    def get_mutable_rules(self) -> list[PolicyRule]:\n    60→        \"\"\"Return all mutable (corpus-derived) rules.\"\"\"\n    61→        return [r for r in self.rules if not r.is_immutable]\n    62→\n    63→    def check_action(self, action: str, context: str = \"\") -> PolicyDecision:\n    64→        \"\"\"Evaluate an action string against all policy rules.\n    65→\n    66→        Matching is keyword-based: every word in the rule_text is checked\n    67→        against the combined action+context string (case-insensitive).\n    68→        A rule is considered matched if *all* its keywords appear.\n    69→\n    70→        Blocking logic:\n    71→        - Immutable rule with enforcement_level=\"block\" -> not allowed.\n    72→        - Mutable rule with enforcement_level=\"block\" and weight > 0.7 -> not allowed.\n    73→        \"\"\"\n    74→        combined = (action + \" \" + context).lower()\n    75→        violated: list[PolicyRule] = []\n    76→\n    77→        for rule in self.rules:\n    78→            keywords = rule.rule_text.lower().split()\n    79→            if all(kw in combined for kw in keywords):\n    80→                violated.append(rule)\n    81→\n    82→        blocked = False\n    83→        reasons: list[str] = []\n    84→\n    85→        for rule in violated:\n    86→            if rule.enforcement_level == \"block\":\n    87→                if rule.is_immutable:\n    88→                    blocked = True\n    89→                    reasons.append(\n    90→                        f\"immutable block: {rule.source}\"\n    91→                    )\n    92→                elif rule.weight > 0.7:\n    93→                    blocked = True\n    94→                    reasons.append(\n    95→                        f\"mutable block (weight={rule.weight}): {rule.source}\"\n    96→                    )\n    97→\n    98→        return PolicyDecision(\n    99→            allowed=not blocked,\n   100→            violated_rules=violated,\n   101→            reason=\"; \".join(reasons) if reasons else \"\",\n   102→        )\n   103→\n   104→\n   105→# ---------------------------------------------------------------------------\n   106→# Compiler\n   107→# ---------------------------------------------------------------------------\n   108→\n   109→\n   110→class PolicyCompiler:\n   111→    \"\"\"Stateless compiler that fuses kernel principles and corpus claims.\"\"\"\n   112→\n   113→    def compile(\n   114→        self,\n   115→        kernel_principles: dict[str, Any],\n   116→        accepted_claims: list[Any],\n   117→        context: str = \"\",\n   118→    ) -> Policy:\n   119→        \"\"\"Compile kernel principles and accepted claims into a Policy.\n   120→\n   121→        Args:\n   122→            kernel_principles: Mapping of name -> principle object. Each\n   123→                principle must expose ``name``, ``description``,\n   124→                ``formal_constraint``, and ``severity`` attributes.\n   125→            accepted_claims: List of claim objects. Each must expose\n   126→                ``id``, ``statement``, ``confidence``, and ``enforcement``\n   127→                attributes.\n   128→            context: Free-text description of what this policy is for.\n   129→\n   130→        Returns:\n   131→            A Policy with immutable rules (from kernel) sorted before\n   132→            mutable rules (from claims), ordered by weight descending\n   133→            within each group.\n   134→        \"\"\"\n   135→        immutable_rules: list[PolicyRule] = []\n   136→        mutable_rules: list[PolicyRule] = []\n   137→\n   138→        for name, principle in kernel_principles.items():\n   139→            severity: str = getattr(principle, \"severity\", \"medium\")\n   140→            enforcement = _SEVERITY_TO_ENFORCEMENT.get(severity, \"log\")\n   141→            rule = PolicyRule(\n   142→                source=f\"kernel:{name}\",\n   143→                rule_text=getattr(principle, \"formal_constraint\", \"\"),\n   144→                weight=1.0,\n   145→                is_immutable=True,\n   146→                enforcement_level=enforcement,\n   147→            )\n   148→            immutable_rules.append(rule)\n   149→\n   150→        for claim in accepted_claims:"}]},"uuid":"aca3208f-4315-40b0-85cb-aaa1d35ae481","timestamp":"2026-03-15T13:47:32.011Z","sourceToolAssistantUUID":"b22bac44-7ec2-4255-9c5d-1fb853a4372b","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
