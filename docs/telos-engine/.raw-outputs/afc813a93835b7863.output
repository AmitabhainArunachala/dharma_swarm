{"parentUuid":"f05b8cd3-0d71-4da3-812a-06bf2f53961f","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"afc813a93835b7863","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013Criu9414Kuaeu3QHa6qfA","type":"tool_result","content":"     1→\"\"\"Pydantic data models for DHARMA SWARM.\n     2→\n     3→All shared types, enums, and data structures used across the swarm system.\n     4→Every module imports from here — this is the schema contract.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→import uuid\n    10→from datetime import datetime, timezone\n    11→from enum import Enum\n    12→from typing import Any, Optional\n    13→\n    14→from pydantic import BaseModel, Field\n    15→\n    16→\n    17→# === Enums ===\n    18→\n    19→class TaskStatus(str, Enum):\n    20→    PENDING = \"pending\"\n    21→    ASSIGNED = \"assigned\"\n    22→    RUNNING = \"running\"\n    23→    COMPLETED = \"completed\"\n    24→    FAILED = \"failed\"\n    25→    CANCELLED = \"cancelled\"\n    26→\n    27→\n    28→class TaskPriority(str, Enum):\n    29→    LOW = \"low\"\n    30→    NORMAL = \"normal\"\n    31→    HIGH = \"high\"\n    32→    URGENT = \"urgent\"\n    33→\n    34→\n    35→class AgentStatus(str, Enum):\n    36→    IDLE = \"idle\"\n    37→    BUSY = \"busy\"\n    38→    STARTING = \"starting\"\n    39→    STOPPING = \"stopping\"\n    40→    DEAD = \"dead\"\n    41→\n    42→\n    43→class AgentRole(str, Enum):\n    44→    CODER = \"coder\"\n    45→    REVIEWER = \"reviewer\"\n    46→    RESEARCHER = \"researcher\"\n    47→    TESTER = \"tester\"\n    48→    ORCHESTRATOR = \"orchestrator\"\n    49→    GENERAL = \"general\"\n    50→    # PSMV cognitive roles (from 5-role agent briefings)\n    51→    CARTOGRAPHER = \"cartographer\"\n    52→    ARCHEOLOGIST = \"archeologist\"\n    53→    SURGEON = \"surgeon\"\n    54→    ARCHITECT = \"architect\"\n    55→    VALIDATOR = \"validator\"\n    56→    CONDUCTOR = \"conductor\"\n    57→\n    58→\n    59→class MessagePriority(str, Enum):\n    60→    LOW = \"low\"\n    61→    NORMAL = \"normal\"\n    62→    HIGH = \"high\"\n    63→    URGENT = \"urgent\"\n    64→\n    65→\n    66→class MessageStatus(str, Enum):\n    67→    UNREAD = \"unread\"\n    68→    READ = \"read\"\n    69→    ARCHIVED = \"archived\"\n    70→\n    71→\n    72→class GateTier(str, Enum):\n    73→    A = \"A\"  # Absolute block\n    74→    B = \"B\"  # Strong block\n    75→    C = \"C\"  # Advisory\n    76→\n    77→\n    78→class GateResult(str, Enum):\n    79→    PASS = \"PASS\"\n    80→    FAIL = \"FAIL\"\n    81→    WARN = \"WARN\"\n    82→\n    83→\n    84→class GateDecision(str, Enum):\n    85→    ALLOW = \"allow\"\n    86→    BLOCK = \"block\"\n    87→    REVIEW = \"review\"\n    88→\n    89→\n    90→class TopologyType(str, Enum):\n    91→    FAN_OUT = \"fan_out\"\n    92→    FAN_IN = \"fan_in\"\n    93→    PIPELINE = \"pipeline\"\n    94→    BROADCAST = \"broadcast\"\n    95→\n    96→\n    97→class MemoryLayer(str, Enum):\n    98→    IMMEDIATE = \"immediate\"\n    99→    SESSION = \"session\"\n   100→    DEVELOPMENT = \"development\""}]},"uuid":"43258e77-63d8-4016-a8a5-b3023c405fad","timestamp":"2026-03-15T13:47:16.949Z","sourceToolAssistantUUID":"f05b8cd3-0d71-4da3-812a-06bf2f53961f","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
