{"parentUuid":"a62eb8b5-6ad4-464f-8963-308069642668","isSidechain":true,"promptId":"0fd463d9-b82e-40a5-90f7-91f9435b3a86","agentId":"afc813a93835b7863","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dus1av6by77PHDiWTvstyW","type":"tool_result","content":"     1→\"\"\"Multi-layer context engine for dharma_swarm agents.\n     2→\n     3→Five layers, selected by role x thread x task:\n     4→\n     5→  L1 VISION    — PSMV crown jewels, Genome spec, ten_words, telos\n     6→  L2 RESEARCH  — CLAUDE1-9 (per thread), R_V data, experimental results\n     7→  L3 ENGINEER  — dgc-core code, dharma_swarm modules, test status, code map\n     8→  L4 OPS       — AGNI state, trishula inbox, manifest, shipped/pending\n     9→  L5 SWARM     — What other agents found this cycle (shared notes)\n    10→\n    11→Each role gets a different mix. Each thread shifts emphasis.\n    12→Context budget: ~30K chars max (fits in system prompt alongside v7 rules).\n    13→\"\"\"\n    14→\n    15→from __future__ import annotations\n    16→\n    17→import json\n    18→import sqlite3\n    19→import time\n    20→from datetime import timezone\n    21→from pathlib import Path\n    22→\n    23→from dharma_swarm.injection_scanner import scan_and_sanitize\n    24→\n    25→HOME = Path.home()\n    26→AGNI_WORKSPACE = HOME / \"agni-workspace\"\n    27→TRISHULA_INBOX = HOME / \"trishula\" / \"inbox\"\n    28→STATE_DIR = HOME / \".dharma\"\n    29→SHARED_DIR = STATE_DIR / \"shared\"\n    30→PSMV = HOME / \"Persistent-Semantic-Memory-Vault\"\n    31→\n    32→# ── File reading helper ──────────────────────────────────────────────\n    33→\n    34→def _read_file(path: Path, max_chars: int = 2000) -> str | None:\n    35→    \"\"\"Read a file, truncate if needed, scan for injection. Returns None if missing.\"\"\"\n    36→    if not path.exists():\n    37→        return None\n    38→    try:\n    39→        content = path.read_text()\n    40→        # Scan external files for prompt injection before inclusion\n    41→        content = scan_and_sanitize(content, path.name)\n    42→        if len(content) > max_chars:\n    43→            return content[:max_chars] + \"\\n... [truncated]\"\n    44→        return content\n    45→    except Exception:\n    46→        return None\n    47→\n    48→\n    49→def _read_head(path: Path, lines: int = 30) -> str | None:\n    50→    \"\"\"Read first N lines of a file.\"\"\"\n    51→    if not path.exists():\n    52→        return None\n    53→    try:\n    54→        with open(path) as f:\n    55→            return \"\".join(f.readline() for _ in range(lines))\n    56→    except Exception:\n    57→        return None\n    58→\n    59→\n    60→def _format_retrieval_line(hit) -> str:\n    61→    record = hit.record\n    62→    metadata = record.metadata\n    63→    source_kind = str(metadata.get(\"source_kind\", \"unknown\"))\n    64→    created_at = record.created_at\n    65→    if created_at.tzinfo is None:\n    66→        created_at = created_at.replace(tzinfo=timezone.utc)\n    67→    stamp = created_at.astimezone(timezone.utc).strftime(\"%Y-%m-%d %H:%MZ\")\n    68→\n    69→    if source_kind == \"note\":\n    70→        source_label = str(metadata.get(\"source_ref\") or metadata.get(\"source_path\") or \"note\")\n    71→        section = str(metadata.get(\"section_title\") or \"\")\n    72→        provenance = f\"{source_label} | {stamp}\"\n    73→        if section:\n    74→            provenance = f\"{provenance} | {section}\"\n    75→    else:\n    76→        event_type = str(metadata.get(\"event_type\") or \"event\")\n    77→        source = str(metadata.get(\"source\") or \"runtime\")\n    78→        provenance = f\"{event_type} @ {source} | {stamp}\"\n    79→\n    80→    snippet = record.text.replace(\"\\n\", \" \").strip()[:100]\n    81→    return f\"  [retrieval:{source_kind}] {provenance} | {snippet}\"\n    82→\n    83→\n    84→def _format_idea_line(shard) -> str:\n    85→    created_at = shard.created_at\n    86→    if created_at.tzinfo is None:\n    87→        created_at = created_at.replace(tzinfo=timezone.utc)\n    88→    stamp = created_at.astimezone(timezone.utc).strftime(\"%Y-%m-%d %H:%MZ\")\n    89→    return (\n    90→        f\"  [idea:{shard.state}] {shard.shard_kind} | \"\n    91→        f\"salience={shard.salience:.2f} | {stamp} | {shard.text[:140]}\"\n    92→    )\n    93→\n    94→\n    95→# ── L1: VISION — The meta-layer ─────────────────────────────────────\n    96→\n    97→# Crown jewels and specs to look for (first found wins)\n    98→_VISION_FILES = {\n    99→    \"ten_words\": [\n   100→        PSMV / \"SPONTANEOUS_PREACHING_PROTOCOL\" / \"crown_jewel_forge\" / \"approved\" / \"ten_words.md\",\n   101→        PSMV / \"CORE\" / \"ten_words.md\",\n   102→    ],\n   103→    \"genome_spec\": [\n   104→        PSMV / \"06-Multi-System-Coherence\" / \"DHARMA_GENOME_SPECIFICATION.md\",\n   105→        PSMV / \"CORE\" / \"DHARMA_GENOME_SPECIFICATION.md\",\n   106→    ],\n   107→    \"garden_daemon\": [\n   108→        PSMV / \"AGENT_EMERGENT_WORKSPACES\" / \"GARDEN_DAEMON_SPEC.md\",\n   109→    ],\n   110→    \"induction_v7\": [\n   111→        PSMV / \"AGENT_EMERGENT_WORKSPACES\" / \"INDUCTION_PROMPT_v7.md\",\n   112→    ],\n   113→    \"samaya_protocol\": [\n   114→        PSMV / \"08-Research-Documentation\" / \"theoretical-frameworks\" / \"MASTER_PROMPT_Samaya_Darwin-Godel_Machine.md\",\n   115→    ],\n   116→    \"lenia_godel\": [\n   117→        PSMV / \"CORE\" / \"LENIA_GODEL_DHARMA_IMPLEMENTATION_PLAN.md\",\n   118→    ],\n   119→    \"soul\": [\n   120→        AGNI_WORKSPACE / \"SOUL.md\",\n   121→    ],\n   122→    \"constitution\": [\n   123→        AGNI_WORKSPACE / \"CONSTITUTION.md\",\n   124→    ],\n   125→    \"north_star\": [\n   126→        AGNI_WORKSPACE / \"NORTH_STAR\" / \"90_DAY_COUNTER_ATTRACTOR.md\",\n   127→        AGNI_WORKSPACE / \"NORTH_STAR\" / \"SAB_500_YEAR_VISION.md\",\n   128→    ],\n   129→}\n   130→\n   131→\n   132→def read_vision(keys: list[str] | None = None, max_per_file: int = 1500) -> str:\n   133→    \"\"\"Read vision-layer documents. Specify keys or get defaults.\"\"\"\n   134→    target_keys = keys or [\"ten_words\", \"soul\", \"north_star\"]\n   135→    sections = [\"# Vision Layer\"]\n   136→    for key in target_keys:\n   137→        paths = _VISION_FILES.get(key, [])\n   138→        for p in paths:\n   139→            content = _read_file(p, max_chars=max_per_file)\n   140→            if content:\n   141→                sections.append(f\"\\n## {key} ({p.name})\\n{content}\")\n   142→                break\n   143→    return \"\\n\".join(sections) if len(sections) > 1 else \"\"\n   144→\n   145→\n   146→# ── L2: RESEARCH — Thread-specific knowledge ────────────────────────\n   147→\n   148→# CLAUDE files mapped to research threads\n   149→_THREAD_CLAUDE_FILES = {\n   150→    \"mechanistic\": [HOME / \"CLAUDE1.md\", HOME / \"CLAUDE5.md\", HOME / \"CLAUDE7.md\"],"}]},"uuid":"044a1c55-4f9e-4055-be87-d68f4aa10395","timestamp":"2026-03-15T13:47:40.493Z","sourceToolAssistantUUID":"a62eb8b5-6ad4-464f-8963-308069642668","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
