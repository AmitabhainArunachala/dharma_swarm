{"parentUuid":"314838dd-38aa-402f-8eb9-887cbf35936f","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a1f81fe877b9073d0","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012oeyDKQyWtSa5me4mMnG7g","type":"tool_result","content":"     1→\"\"\"\n     2→Jagat Kalyan — FastAPI Application\n     3→\n     4→AI-coordinated ecological restoration matching platform.\n     5→Connects AI companies' carbon budgets to community restoration projects.\n     6→\n     7→Run: python app.py\n     8→Or:  uvicorn app:app --reload\n     9→\"\"\"\n    10→\n    11→import os\n    12→import logging\n    13→from contextlib import asynccontextmanager\n    14→from datetime import datetime, timezone\n    15→\n    16→from fastapi import FastAPI, Depends, Request, Form, HTTPException\n    17→from fastapi.responses import HTMLResponse, RedirectResponse\n    18→from fastapi.staticfiles import StaticFiles\n    19→from fastapi.templating import Jinja2Templates\n    20→from sqlalchemy import func\n    21→from sqlalchemy.orm import Session\n    22→\n    23→from models import (\n    24→    init_db,\n    25→    get_db,\n    26→    Project,\n    27→    Funder,\n    28→    Match,\n    29→    Outcome,\n    30→    ProjectType,\n    31→    FunderType,\n    32→    VerificationStatus,\n    33→    MatchStatus,\n    34→)\n    35→from matching import generate_matches\n    36→from welfare_tons import calculate_welfare_tons\n    37→\n    38→logging.basicConfig(level=logging.INFO)\n    39→logger = logging.getLogger(__name__)\n    40→\n    41→\n    42→@asynccontextmanager\n    43→async def lifespan(app: FastAPI):\n    44→    init_db()\n    45→    logger.info(\"Jagat Kalyan database initialized.\")\n    46→    # Auto-seed if empty\n    47→    db = next(get_db())\n    48→    try:\n    49→        if db.query(Project).count() == 0:\n    50→            logger.info(\"Empty database detected. Running seed...\")\n    51→            from seed_data import seed\n    52→\n    53→            seed()\n    54→    finally:\n    55→        db.close()\n    56→    yield\n    57→\n    58→\n    59→app = FastAPI(title=\"Jagat Kalyan\", description=\"AI-Coordinated Ecological Restoration\", lifespan=lifespan)\n    60→\n    61→# Templates\n    62→templates = Jinja2Templates(directory=os.path.join(os.path.dirname(__file__), \"templates\"))\n    63→\n    64→# Static files (CSS)\n    65→static_dir = os.path.join(os.path.dirname(__file__), \"static\")\n    66→if os.path.isdir(static_dir):\n    67→    app.mount(\"/static\", StaticFiles(directory=static_dir), name=\"static\")\n    68→\n    69→\n    70→# --- Jinja2 Filters ---\n    71→\n    72→\n    73→def format_number(value):\n    74→    \"\"\"Format numbers with commas.\"\"\"\n    75→    if value is None:\n    76→        return \"0\"\n    77→    if isinstance(value, float):\n    78→        if value == int(value):\n    79→            return f\"{int(value):,}\"\n    80→        return f\"{value:,.1f}\""}]},"uuid":"3dcc8679-d2df-40ca-b6a9-7c087262f689","timestamp":"2026-03-15T14:17:29.428Z","sourceToolAssistantUUID":"314838dd-38aa-402f-8eb9-887cbf35936f","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
