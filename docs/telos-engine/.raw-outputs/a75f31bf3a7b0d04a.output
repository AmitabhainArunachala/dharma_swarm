{"parentUuid":"9f553e4c-bdb5-4308-ab94-fb4bf5ba52c8","isSidechain":true,"agentId":"a75f31bf3a7b0d04a","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_0124F7bfrSyrBLCr7qkSDqeK","toolUseID":"toolu_0124F7bfrSyrBLCr7qkSDqeK","timestamp":"2026-03-15T13:46:38.430Z","uuid":"17c21849-56a1-4ed3-814c-aa5878378085","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"17c21849-56a1-4ed3-814c-aa5878378085","isSidechain":true,"agentId":"a75f31bf3a7b0d04a","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_0124F7bfrSyrBLCr7qkSDqeK","toolUseID":"toolu_0124F7bfrSyrBLCr7qkSDqeK","timestamp":"2026-03-15T13:46:38.431Z","uuid":"305b098b-e63b-49b3-9d85-6ea094ebb05c","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"b8a3dd99-9b54-45ed-b4c1-22fd63c966c9","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"a75f31bf3a7b0d04a","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0124F7bfrSyrBLCr7qkSDqeK","type":"tool_result","content":"     1→\"\"\"Dharmic safety gate system.\n     2→\n     3→Eleven gates from Akram Vignan mapped to computational safety checks.\n     4→Ported from dgc-core/hooks/telos_gate.py into a clean class-based API.\n     5→Think-point witness logs are written to ~/.dharma/witness/ for audit.\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→from dataclasses import dataclass, field\n    11→import json\n    12→import os\n    13→import re\n    14→from datetime import datetime, timezone\n    15→from pathlib import Path\n    16→\n    17→from dharma_swarm.anekanta_gate import evaluate_anekanta\n    18→from dharma_swarm.models import (\n    19→    GateCheckResult,\n    20→    GateDecision,\n    21→    GateResult,\n    22→    GateTier,\n    23→)\n    24→\n    25→WITNESS_DIR = Path.home() / \".dharma\" / \"witness\"\n    26→\n    27→\n    28→@dataclass\n    29→class ReflectiveGateOutcome:\n    30→    \"\"\"Result bundle for reflective reroute gate checks.\"\"\"\n    31→\n    32→    result: GateCheckResult\n    33→    attempts: int = 0\n    34→    reflection: str = \"\"\n    35→    suggestions: list[str] = field(default_factory=list)\n    36→\n    37→\n    38→class TelosGatekeeper:\n    39→    \"\"\"Runs 11 dharmic gates against proposed actions.\n    40→\n    41→    Tier A failures block unconditionally.\n    42→    Tier B failures block unconditionally.\n    43→    Tier C failures produce a review advisory (not a block).\n    44→    \"\"\"\n    45→\n    46→    GATES: dict[str, GateTier] = {\n    47→        \"AHIMSA\": GateTier.A,\n    48→        \"SATYA\": GateTier.B,\n    49→        \"CONSENT\": GateTier.B,\n    50→        \"VYAVASTHIT\": GateTier.C,\n    51→        \"REVERSIBILITY\": GateTier.C,\n    52→        \"SVABHAAVA\": GateTier.C,\n    53→        \"BHED_GNAN\": GateTier.C,\n    54→        \"WITNESS\": GateTier.C,\n    55→        \"ANEKANTA\": GateTier.C,\n    56→        \"DOGMA_DRIFT\": GateTier.C,\n    57→        \"STEELMAN\": GateTier.C,\n    58→    }\n    59→\n    60→    HARM_WORDS: set[str] = {\n    61→        \"delete all\", \"destroy\", \"rm -rf\", \"wipe\", \"kill\", \"corrupt\",\n    62→        \"exploit\", \"attack\", \"exfiltrate\", \"format disk\", \"drop table\",\n    63→        \"truncate table\", \"shutdown -h\", \"mkfs\", \"dd if=/dev/zero\",\n    64→        \"chmod 777\", \":(){ :|:& };:\", \"ddos\", \"denial of service\",\n    65→    }\n    66→\n    67→    FORCE_WORDS: set[str] = {\n    68→        \"force\", \"override\", \"bypass\", \"skip validation\",\n    69→        \"disable safety\", \"--no-verify\",\n    70→    }\n    71→\n    72→    IRREVERSIBLE_WORDS: set[str] = {\n    73→        \"permanent\", \"irreversible\", \"cannot undo\",\n    74→        \"no backup\", \"force push\",\n    75→    }\n    76→\n    77→    INJECTION_PATTERNS: set[str] = {\n    78→        \"ignore previous instructions\", \"ignore all previous\",\n    79→        \"disregard your instructions\", \"new instructions:\",\n    80→        \"you are now\", \"act as if you\", \"pretend you are\",\n    81→        \"override your\", \"forget your rules\",\n    82→    }\n    83→\n    84→    CREDENTIAL_PATTERNS: set[str] = {\n    85→        \"sk-or-v1-\", \"sk-ant-\", \"sk-proj-\", \"AKIA\", \"ghp_\", \"gho_\",\n    86→        \"xoxb-\", \"xoxp-\", \"Bearer \", \"-----BEGIN PRIVATE KEY\",\n    87→        \"-----BEGIN RSA PRIVATE\", \"password=\", \"secret=\",\n    88→    }\n    89→\n    90→    DECEPTION_PATTERNS: set[str] = {\n    91→        \"fake academic citation\",\n    92→        \"fake academic citations\",\n    93→        \"fake citation\",\n    94→        \"fabricate citation\",\n    95→        \"fabricate references\",\n    96→        \"invent citation\",\n    97→    }\n    98→\n    99→    SENSITIVE_PATH_PATTERNS: set[str] = {\n   100→        \"/etc/passwd\",\n   101→        \"/etc/shadow\",\n   102→        \".ssh/id_rsa\",\n   103→        \".aws/credentials\",\n   104→    }\n   105→\n   106→    EXFIL_PATTERNS: set[str] = {\n   107→        \"send it to pastebin\",\n   108→        \"send to pastebin\",\n   109→        \"upload to pastebin\",\n   110→        \"exfiltrate\",\n   111→        \"post publicly\",\n   112→        \"leak\",\n   113→    }\n   114→\n   115→    # Strict-mode patterns tuned to catch common security bypass intents that\n   116→    # may evade narrow AHIMSA keywords in internal YOLO mode.\n   117→    STRICT_SECURITY_PATTERNS: set[str] = {\n   118→        \"bypass authentication\",\n   119→        \"bypass auth\",\n   120→        \"inject sql\",\n   121→        \"sql injection\",\n   122→        \"disable ssl certificate validation\",\n   123→        \"disable tls validation\",\n   124→        \"execute arbitrary code\",\n   125→        \"grant admin privileges\",\n   126→        \"disable rate limiting\",\n   127→        \"expose sensitive credentials\",\n   128→        \"disable encryption\",\n   129→    }\n   130→\n   131→    THINK_PHASE_HINTS: dict[str, str] = {\n   132→        \"before_write\": \"Pause, articulate risks, and confirm rollback path before writing files.\",\n   133→        \"before_git\": \"Pause, review staged changes, and confirm commit message accuracy.\",\n   134→        \"before_complete\": \"Pause, verify outputs/tests, and confirm requirement coverage.\",\n   135→        \"before_pivot\": \"Pause, summarize repeated failures, and choose a different strategy.\",\n   136→        \"when_stuck\": \"Pause, identify what is blocking you, and consider alternative approaches.\",\n   137→    }\n   138→\n   139→    # Think phases that BLOCK (not just warn) on insufficient reflection.\n   140→    # These are Devin's mandatory-think cases adapted for dharma_swarm.\n   141→    MANDATORY_THINK_PHASES: set[str] = {\n   142→        \"before_write\",\n   143→        \"before_git\",\n   144→        \"before_complete\",\n   145→        \"before_pivot\",\n   146→    }\n   147→\n   148→    def check(\n   149→        self,\n   150→        action: str,\n   151→        content: str = \"\",\n   152→        tool_name: str = \"\",\n   153→        trust_mode: str | None = None,\n   154→        think_phase: str | None = None,\n   155→        reflection: str = \"\",\n   156→    ) -> GateCheckResult:\n   157→        \"\"\"Run all 11 gates against an action and optional content.\n   158→\n   159→        Args:\n   160→            action: The action description (command, file path, etc.).\n   161→            content: Body content being written or edited.\n   162→            tool_name: Name of the tool being invoked (informational).\n   163→            trust_mode:\n   164→                - ``internal_yolo`` (default): permissive for internal speed.\n   165→                - ``external_strict``: block high-risk security intents.\n   166→            think_phase:\n   167→                Optional Devin-style think checkpoint phase. Supported values:\n   168→                ``before_write``, ``before_pivot``, ``before_complete``.\n   169→            reflection:\n   170→                Reflection text for think-point validation.\n   171→\n   172→        Returns:\n   173→            GateCheckResult with decision, reason, and per-gate results.\n   174→        \"\"\"\n   175→        resolved_mode = (\n   176→            (trust_mode or os.getenv(\"DGC_TRUST_MODE\", \"internal_yolo\"))\n   177→            .strip()\n   178→            .lower()\n   179→        )\n   180→        action_lower = action.lower()\n   181→        content_lower = content.lower()\n   182→        combined = action_lower + \" \" + content_lower\n   183→        results: dict[str, tuple[GateResult, str]] = {}\n   184→\n   185→        # --- AHIMSA (Tier A) — harm + injection detection ---\n   186→        harm_hit = next((w for w in self.HARM_WORDS if w in action_lower), None)\n   187→        injection_hit = next(\n   188→            (p for p in self.INJECTION_PATTERNS if p in combined), None,\n   189→        )\n   190→        strict_hit = None\n   191→        if resolved_mode == \"external_strict\":\n   192→            strict_hit = next(\n   193→                (p for p in self.STRICT_SECURITY_PATTERNS if p in combined),\n   194→                None,\n   195→            )\n   196→\n   197→        if strict_hit:\n   198→            results[\"AHIMSA\"] = (\n   199→                GateResult.FAIL,\n   200→                f\"Strict security intent detected: {strict_hit}\","}]},"uuid":"f29178d7-eede-4c06-9f50-9f31a49ed92c","timestamp":"2026-03-15T13:46:38.430Z","sourceToolAssistantUUID":"b8a3dd99-9b54-45ed-b4c1-22fd63c966c9","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
