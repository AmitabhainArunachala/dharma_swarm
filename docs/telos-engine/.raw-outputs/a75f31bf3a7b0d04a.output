{"parentUuid":"cb0bb311-d734-439d-a184-9ff046f5e77d","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"a75f31bf3a7b0d04a","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015MYDyQYFA2hb2vVC6HxSM3","type":"tool_result","content":"     1→\"\"\"Typed decision ontology and deterministic decision-quality scoring.\n     2→\n     3→This module models decisions as first-class objects with evidence, objections,\n     4→reviews, and outcome metrics. The scoring is intentionally deterministic and\n     5→artifact-backed so DGC can judge decision quality using structure, grounding,\n     6→and traceability instead of prose style alone.\n     7→\"\"\"\n     8→\n     9→from __future__ import annotations\n    10→\n    11→import uuid\n    12→from datetime import datetime, timezone\n    13→from enum import Enum\n    14→\n    15→from typing import Any\n    16→\n    17→from pydantic import BaseModel, Field\n    18→\n    19→from dharma_swarm.decision_router import DecisionInput\n    20→from dharma_swarm.steelman_gate import SteelmanCheck, check_steelman\n    21→\n    22→\n    23→def _utc_now() -> datetime:\n    24→    return datetime.now(timezone.utc)\n    25→\n    26→\n    27→def _new_id() -> str:\n    28→    return uuid.uuid4().hex[:12]\n    29→\n    30→\n    31→def _clamp01(value: float) -> float:\n    32→    return max(0.0, min(1.0, float(value)))\n    33→\n    34→\n    35→def _ratio(numerator: int, denominator: int) -> float:\n    36→    if denominator <= 0:\n    37→        return 0.0\n    38→    return _clamp01(numerator / denominator)\n    39→\n    40→\n    41→class DecisionState(str, Enum):\n    42→    DRAFT = \"draft\"\n    43→    PROPOSED = \"proposed\"\n    44→    APPROVED = \"approved\"\n    45→    EXECUTING = \"executing\"\n    46→    OBSERVED = \"observed\"\n    47→    CLOSED = \"closed\"\n    48→\n    49→\n    50→class EvidenceKind(str, Enum):\n    51→    PRIMARY_SOURCE = \"primary_source\"\n    52→    REPO_FACT = \"repo_fact\"\n    53→    TEST = \"test\"\n    54→    BENCHMARK = \"benchmark\"\n    55→    RUNTIME = \"runtime\"\n    56→    USER_CONSTRAINT = \"user_constraint\"\n    57→    MODEL_OUTPUT = \"model_output\"\n    58→\n    59→\n    60→class ChallengeSeverity(str, Enum):\n    61→    LOW = \"low\"\n    62→    MEDIUM = \"medium\"\n    63→    HIGH = \"high\"\n    64→    CRITICAL = \"critical\"\n    65→\n    66→\n    67→class ReviewVerdict(str, Enum):\n    68→    PASS = \"pass\"\n    69→    WARN = \"warn\"\n    70→    FAIL = \"fail\"\n    71→\n    72→\n    73→class DecisionQualityVerdict(str, Enum):\n    74→    FRAGILE = \"fragile\"\n    75→    DEFENSIBLE = \"defensible\"\n    76→    AUDIT_READY = \"audit_ready\"\n    77→\n    78→\n    79→class DecisionContext(BaseModel):\n    80→    mission: str\n    81→    owner: str\n    82→    time_horizon: str = \"\"\n    83→    domains: list[str] = Field(default_factory=list)\n    84→    constraints: list[str] = Field(default_factory=list)\n    85→    assumptions: list[str] = Field(default_factory=list)\n    86→    risk_score: float = Field(default=0.5, ge=0.0, le=1.0)\n    87→    uncertainty: float = Field(default=0.5, ge=0.0, le=1.0)\n    88→    novelty: float = Field(default=0.3, ge=0.0, le=1.0)\n    89→    urgency: float = Field(default=0.5, ge=0.0, le=1.0)\n    90→    expected_impact: float = Field(default=0.5, ge=0.0, le=1.0)\n    91→    reversible: bool = True\n    92→\n    93→\n    94→class DecisionOption(BaseModel):\n    95→    option_id: str = Field(default_factory=_new_id)\n    96→    title: str\n    97→    description: str = \"\"\n    98→    selected: bool = False\n    99→    tradeoffs: list[str] = Field(default_factory=list)\n   100→\n   101→\n   102→class DecisionClaim(BaseModel):\n   103→    claim_id: str = Field(default_factory=_new_id)\n   104→    text: str\n   105→    supports_option_id: str = \"\"\n   106→    evidence_refs: list[str] = Field(default_factory=list)\n   107→    confidence: float = Field(default=0.5, ge=0.0, le=1.0)\n   108→\n   109→\n   110→class DecisionEvidence(BaseModel):\n   111→    evidence_id: str = Field(default_factory=_new_id)\n   112→    kind: EvidenceKind\n   113→    summary: str\n   114→    source_uri: str = \"\"\n   115→    confidence: float = Field(default=0.5, ge=0.0, le=1.0)\n   116→    verified: bool = False\n   117→    provenance_refs: list[str] = Field(default_factory=list)\n   118→\n   119→\n   120→class DecisionChallenge(BaseModel):\n   121→    challenge_id: str = Field(default_factory=_new_id)\n   122→    summary: str\n   123→    severity: ChallengeSeverity = ChallengeSeverity.MEDIUM\n   124→    source_agent: str = \"\"\n   125→    addressed: bool = False\n   126→    response: str = \"\"\n   127→\n   128→\n   129→class DecisionMetric(BaseModel):\n   130→    name: str\n   131→    baseline: str = \"\"\n   132→    target: str = \"\"\n   133→    measurement_plan: str = \"\"\n   134→    owner: str = \"\"\n   135→\n   136→\n   137→class DecisionReview(BaseModel):\n   138→    reviewer: str\n   139→    role: str = \"\"\n   140→    verdict: ReviewVerdict = ReviewVerdict.WARN\n   141→    notes: str = \"\"\n   142→\n   143→\n   144→class DecisionQualityAssessment(BaseModel):\n   145→    decision_id: str\n   146→    overall_score: float\n   147→    structural_score: float\n   148→    evidence_score: float\n   149→    challenge_score: float\n   150→    traceability_score: float"}]},"uuid":"94b34df7-76ee-4c59-864a-7ba20565e2f4","timestamp":"2026-03-15T13:46:24.367Z","sourceToolAssistantUUID":"cb0bb311-d734-439d-a184-9ff046f5e77d","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
