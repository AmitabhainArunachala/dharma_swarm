{"parentUuid":"176efe4e-c35c-47e0-8208-188d7dbf10c7","isSidechain":true,"agentId":"a75f31bf3a7b0d04a","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_015cnrJ1wai84KPfvBaiVwm1","toolUseID":"toolu_015cnrJ1wai84KPfvBaiVwm1","timestamp":"2026-03-15T13:46:27.171Z","uuid":"14b6373b-1f0f-467a-b54c-307a0b0bcba6","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"14b6373b-1f0f-467a-b54c-307a0b0bcba6","isSidechain":true,"agentId":"a75f31bf3a7b0d04a","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_015cnrJ1wai84KPfvBaiVwm1","toolUseID":"toolu_015cnrJ1wai84KPfvBaiVwm1","timestamp":"2026-03-15T13:46:27.171Z","uuid":"e77546d5-de6e-4fe8-a4d6-8f02b1078dd2","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"4577ed09-f6d6-46f2-aa97-607144dd0ed7","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"a75f31bf3a7b0d04a","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015cnrJ1wai84KPfvBaiVwm1","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→TELOS GATE — Claude Code Hook (PreToolUse)\n     4→\n     5→Runs 8 Dharmic Gates before any tool execution.\n     6→Ported from DHARMIC_GODEL_CLAW/src/core/unified_gates.py (1806 lines → 180 lines).\n     7→Adds: injection detection, credential protection, BHED_GNAN gate.\n     8→\n     9→Install: Add to ~/.claude/settings.json hooks.PreToolUse\n    10→\"\"\"\n    11→\n    12→import json\n    13→import sys\n    14→from datetime import datetime, timezone\n    15→\n    16→# Gate definitions: (name, tier)\n    17→# Tier A = absolute block, Tier B = strong, Tier C = advisory\n    18→GATES = {\n    19→    \"AHIMSA\": \"A\",       # Does this harm?\n    20→    \"SATYA\": \"B\",        # Is this true/honest?\n    21→    \"CONSENT\": \"B\",      # Permission granted?\n    22→    \"VYAVASTHIT\": \"C\",   # Allow or force?\n    23→    \"REVERSIBILITY\": \"C\",  # Can undo?\n    24→    \"SVABHAAVA\": \"C\",    # Aligned with telos?\n    25→    \"BHED_GNAN\": \"C\",    # Witness clarity — distinguishing self from action\n    26→    \"WITNESS\": \"C\",      # Self-observing? (always passes — the act of checking IS witnessing)\n    27→}\n    28→\n    29→HARM_WORDS = {\n    30→    \"delete all\", \"destroy\", \"rm -rf\", \"wipe\", \"kill\", \"corrupt\",\n    31→    \"exploit\", \"attack\", \"exfiltrate\", \"format disk\", \"drop table\",\n    32→    \"truncate table\", \"shutdown -h\", \"mkfs\", \"dd if=/dev/zero\",\n    33→    \"chmod 777\", \":(){ :|:& };:\",\n    34→}\n    35→\n    36→FORCE_WORDS = {\"force\", \"override\", \"bypass\", \"skip validation\", \"disable safety\", \"--no-verify\"}\n    37→\n    38→IRREVERSIBLE_WORDS = {\"permanent\", \"irreversible\", \"cannot undo\", \"no backup\", \"force push\"}\n    39→\n    40→# Prompt injection detection (from unified_gates.py)\n    41→INJECTION_PATTERNS = {\n    42→    \"ignore previous instructions\", \"ignore all previous\",\n    43→    \"disregard your instructions\", \"new instructions:\",\n    44→    \"you are now\", \"act as if you\", \"pretend you are\",\n    45→    \"override your\", \"forget your rules\",\n    46→}\n    47→\n    48→# Credential patterns — never write these to files\n    49→OPENROUTER_PREFIX = \"sk-or-\" + \"v1-\"\n    50→CREDENTIAL_PATTERNS = {\n    51→    OPENROUTER_PREFIX, \"sk-ant-\", \"sk-proj-\", \"AKIA\", \"ghp_\", \"gho_\",\n    52→    \"xoxb-\", \"xoxp-\", \"Bearer \", \"-----BEGIN PRIVATE KEY\",\n    53→    \"-----BEGIN RSA PRIVATE\", \"password=\", \"secret=\",\n    54→}\n    55→\n    56→# Tools that are always safe (read-only)\n    57→SAFE_TOOLS = {\"Read\", \"Glob\", \"Grep\", \"LSP\", \"WebFetch\", \"WebSearch\", \"TaskList\", \"TaskGet\"}\n    58→\n    59→# Tools that need gate checks\n    60→GATED_TOOLS = {\"Bash\", \"Write\", \"Edit\", \"NotebookEdit\"}\n    61→\n    62→\n    63→def check_gates(tool_name: str, tool_input: dict) -> dict:\n    64→    \"\"\"Run all 8 gates. Returns {\"decision\": \"allow\"|\"block\"|\"review\", \"reason\": str}\"\"\"\n    65→\n    66→    # Safe tools pass immediately\n    67→    if tool_name in SAFE_TOOLS:\n    68→        return {\"decision\": \"allow\", \"reason\": \"Read-only tool\"}\n    69→\n    70→    # Build action description from tool input\n    71→    action = \"\"\n    72→    content = \"\"\n    73→    if tool_name == \"Bash\":\n    74→        action = tool_input.get(\"command\", \"\")\n    75→    elif tool_name == \"Write\":\n    76→        action = f\"write to {tool_input.get('file_path', 'unknown')}\"\n    77→        content = tool_input.get(\"content\", \"\")\n    78→    elif tool_name == \"Edit\":\n    79→        action = f\"edit {tool_input.get('file_path', 'unknown')}\"\n    80→        content = tool_input.get(\"new_string\", \"\")\n    81→\n    82→    action_lower = action.lower()\n    83→    content_lower = content.lower() if content else \"\"\n    84→    combined = action_lower + \" \" + content_lower\n    85→    results = {}\n    86→\n    87→    # AHIMSA — Tier A (blocks on match)\n    88→    harm_hit = next((w for w in HARM_WORDS if w in action_lower), None)\n    89→    injection_hit = next((p for p in INJECTION_PATTERNS if p in combined), None)\n    90→    if harm_hit:\n    91→        results[\"AHIMSA\"] = (\"FAIL\", f\"Harmful: {harm_hit}\")\n    92→    elif injection_hit:\n    93→        results[\"AHIMSA\"] = (\"FAIL\", f\"Injection detected: {injection_hit}\")\n    94→    else:\n    95→        results[\"AHIMSA\"] = (\"PASS\", \"\")\n    96→\n    97→    # SATYA — Tier B (check for credential leakage in writes)\n    98→    if tool_name in (\"Write\", \"Edit\") and content:\n    99→        cred_hit = next((p for p in CREDENTIAL_PATTERNS if p in content), None)\n   100→        if cred_hit:\n   101→            results[\"SATYA\"] = (\"FAIL\", f\"Credential in content: {cred_hit[:10]}...\")\n   102→        else:\n   103→            results[\"SATYA\"] = (\"PASS\", \"\")\n   104→    else:\n   105→        results[\"SATYA\"] = (\"PASS\", \"\")\n   106→\n   107→    # CONSENT — Tier B (Claude Code's own permission system handles this)\n   108→    results[\"CONSENT\"] = (\"PASS\", \"Claude Code permission system active\")\n   109→\n   110→    # VYAVASTHIT — Tier C\n   111→    force_hit = next((w for w in FORCE_WORDS if w in action_lower), None)\n   112→    results[\"VYAVASTHIT\"] = (\"FAIL\", f\"Forcing: {force_hit}\") if force_hit else (\"PASS\", \"\")\n   113→\n   114→    # REVERSIBILITY — Tier C\n   115→    irrev_hit = next((w for w in IRREVERSIBLE_WORDS if w in action_lower), None)\n   116→    results[\"REVERSIBILITY\"] = (\"WARN\", f\"Irreversible: {irrev_hit}\") if irrev_hit else (\"PASS\", \"\")\n   117→\n   118→    # SVABHAAVA — Tier C (telos alignment)\n   119→    results[\"SVABHAAVA\"] = (\"PASS\", \"\")\n   120→\n   121→    # BHED_GNAN — Tier C (witness clarity: am I the doer or the observer?)\n   122→    # This gate simply records that the system is aware of the distinction\n   123→    results[\"BHED_GNAN\"] = (\"PASS\", \"Doer-witness distinction noted\")\n   124→\n   125→    # WITNESS — always passes (the check itself IS witnessing)\n   126→    results[\"WITNESS\"] = (\"PASS\", \"Witnessed\")\n   127→\n   128→    # Evaluate\n   129→    tier_a_fail = any(results[g][0] == \"FAIL\" for g in GATES if GATES[g] == \"A\")\n   130→    tier_b_fail = any(results[g][0] == \"FAIL\" for g in GATES if GATES[g] == \"B\")\n   131→\n   132→    if tier_a_fail:\n   133→        reason = next(results[g][1] for g in GATES if GATES[g] == \"A\" and results[g][0] == \"FAIL\")\n   134→        return {\"decision\": \"block\", \"reason\": f\"AHIMSA violation: {reason}\"}\n   135→    if tier_b_fail:\n   136→        reasons = [results[g][1] for g in GATES if GATES[g] == \"B\" and results[g][0] == \"FAIL\"]\n   137→        return {\"decision\": \"block\", \"reason\": f\"Tier B violation: {'; '.join(reasons)}\"}\n   138→\n   139→    # Log to witness file (non-blocking)\n   140→    try:\n   141→        import os\n   142→        witness_dir = os.path.expanduser(\"~/.dharma/witness\")\n   143→        os.makedirs(witness_dir, exist_ok=True)\n   144→        today = datetime.now(timezone.utc).strftime(\"%Y-%m-%d\")\n   145→        with open(f\"{witness_dir}/{today}.jsonl\", \"a\") as f:\n   146→            f.write(json.dumps({\n   147→                \"ts\": datetime.now(timezone.utc).isoformat(),\n   148→                \"tool\": tool_name,\n   149→                \"action\": action[:200],\n   150→                \"gates\": {g: r[0] for g, r in results.items()},\n   151→            }) + \"\\n\")\n   152→    except Exception:\n   153→        pass  # Never block on logging failure\n   154→\n   155→    return {\"decision\": \"allow\", \"reason\": \"All gates passed\"}\n   156→\n   157→\n   158→def main():\n   159→    \"\"\"Claude Code hook entry point. Reads from stdin, writes to stdout.\"\"\"\n   160→    try:\n   161→        raw = sys.stdin.read()\n   162→        if not raw.strip():\n   163→            sys.exit(0)  # Empty input = allow\n   164→        hook_input = json.loads(raw)\n   165→        tool_name = hook_input.get(\"tool_name\", \"\")\n   166→        tool_input = hook_input.get(\"tool_input\", {})\n   167→    except (json.JSONDecodeError, KeyError, TypeError):\n   168→        sys.exit(0)  # On parse error, ALLOW (never block on hook failure)\n   169→\n   170→    result = check_gates(tool_name, tool_input)\n   171→\n   172→    if result[\"decision\"] == \"block\":\n   173→        print(json.dumps({\"error\": result[\"reason\"]}))\n   174→        sys.exit(1)\n   175→    else:\n   176→        sys.exit(0)\n   177→\n   178→\n   179→if __name__ == \"__main__\":\n   180→    try:\n   181→        main()\n   182→    except Exception:\n   183→        sys.exit(0)  # Catch-all: never block on unexpected error\n   184→"}]},"uuid":"b8ca23b8-a74d-4799-920c-95d5385eaca0","timestamp":"2026-03-15T13:46:27.171Z","sourceToolAssistantUUID":"4577ed09-f6d6-46f2-aa97-607144dd0ed7","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
