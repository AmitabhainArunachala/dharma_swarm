{"parentUuid":"ab60ae75-5645-4e55-897b-96e10842fc43","isSidechain":true,"agentId":"a75f31bf3a7b0d04a","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_012CaZWseDA45hTZkvBSSZ3X","toolUseID":"toolu_012CaZWseDA45hTZkvBSSZ3X","timestamp":"2026-03-15T13:46:24.141Z","uuid":"9fa65c8c-a167-462a-a09a-4bad8faf6d9b","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"915d33ab-1875-422c-b424-341d67133587","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"a75f31bf3a7b0d04a","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012CaZWseDA45hTZkvBSSZ3X","type":"tool_result","content":"   100→class PropertyDef(BaseModel):\n   101→    \"\"\"Schema for a single property on an ObjectType.\"\"\"\n   102→    name: str\n   103→    property_type: PropertyType\n   104→    required: bool = False\n   105→    default: Any = None\n   106→    description: str = \"\"\n   107→    enum_values: list[str] = Field(default_factory=list)\n   108→    ref_type: str = \"\"\n   109→    searchable: bool = False\n   110→    immutable: bool = False\n   111→\n   112→\n   113→class LinkDef(BaseModel):\n   114→    \"\"\"Schema for a relationship between two ObjectTypes.\n   115→\n   116→    Links are registered in BOTH directions. Defining\n   117→    'Task --assigned_to--> Agent' auto-registers the inverse\n   118→    'Agent --tasks--> Task'.\n   119→    \"\"\"\n   120→    name: str\n   121→    source_type: str\n   122→    target_type: str\n   123→    cardinality: LinkCardinality = LinkCardinality.MANY_TO_ONE\n   124→    required: bool = False\n   125→    inverse_name: str = \"\"\n   126→    description: str = \"\"\n   127→\n   128→\n   129→class ActionDef(BaseModel):\n   130→    \"\"\"Schema for a typed, transactional mutation.\n   131→\n   132→    Every mutation is an Action that commits atomically.\n   133→    No direct writes. No untyped side effects.\n   134→    Every action is auditable, reversible, and gated.\n   135→    \"\"\"\n   136→    name: str\n   137→    object_type: str\n   138→    description: str = \"\"\n   139→    input_params: dict[str, str] = Field(default_factory=dict)\n   140→    modifies: list[str] = Field(default_factory=list)\n   141→    creates: list[str] = Field(default_factory=list)\n   142→    requires_approval: bool = False\n   143→    telos_gates: list[str] = Field(default_factory=list)\n   144→    is_deterministic: bool = True\n   145→\n   146→\n   147→class SecurityPolicy(BaseModel):\n   148→    \"\"\"Per-ObjectType access control.\"\"\"\n   149→    read_roles: list[str] = Field(default_factory=lambda: [\"*\"])\n   150→    write_roles: list[str] = Field(default_factory=lambda: [\"*\"])\n   151→    create_roles: list[str] = Field(default_factory=lambda: [\"*\"])\n   152→    delete_roles: list[str] = Field(default_factory=lambda: [\"system\"])\n   153→    classification: SecurityLevel = SecurityLevel.INTERNAL\n   154→    field_restrictions: dict[str, list[str]] = Field(default_factory=dict)\n   155→    audit_all: bool = False\n   156→    telos_required: bool = False\n   157→\n   158→\n   159→class ObjectType(BaseModel):\n   160→    \"\"\"Schema for a class of entity in the dharma_swarm ontology.\"\"\"\n   161→    name: str\n   162→    description: str = \"\"\n   163→    properties: dict[str, PropertyDef] = Field(default_factory=dict)\n   164→    links: list[LinkDef] = Field(default_factory=list)\n   165→    actions: list[ActionDef] = Field(default_factory=list)\n   166→    security: SecurityPolicy = Field(default_factory=SecurityPolicy)\n   167→\n   168→    # Dharmic extensions\n   169→    telos_alignment: float = Field(default=0.5, ge=0.0, le=1.0)\n   170→    shakti_energy: ShaktiEnergy = ShaktiEnergy.MAHASARASWATI\n   171→    witness_quality: float = Field(default=0.5, ge=0.0, le=1.0)\n   172→\n   173→    # Schema metadata\n   174→    version: int = 1\n   175→    pydantic_model: str = \"\"\n   176→    storage_backend: str = \"jsonl\"\n   177→    icon: str = \"\"\n   178→\n   179→\n   180→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   181→# INSTANCES (What DOES exist)\n   182→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   183→\n   184→\n   185→class OntologyObj(BaseModel):\n   186→    \"\"\"A specific instance of an ObjectType.\"\"\"\n   187→    id: str = Field(default_factory=_new_id)\n   188→    type_name: str\n   189→    properties: dict[str, Any] = Field(default_factory=dict)\n   190→    created_at: datetime = Field(default_factory=_utc_now)\n   191→    created_by: str = \"system\"\n   192→    updated_at: datetime = Field(default_factory=_utc_now)\n   193→    version: int = 1\n   194→\n   195→\n   196→class Link(BaseModel):\n   197→    \"\"\"A specific relationship between two OntologyObjs.\"\"\"\n   198→    id: str = Field(default_factory=_new_id)\n   199→    link_name: str\n   200→    source_id: str\n   201→    source_type: str\n   202→    target_id: str\n   203→    target_type: str\n   204→    created_at: datetime = Field(default_factory=_utc_now)\n   205→    created_by: str = \"system\"\n   206→    metadata: dict[str, Any] = Field(default_factory=dict)\n   207→    witness_quality: float = Field(default=0.5, ge=0.0, le=1.0)\n   208→\n   209→\n   210→class ActionExecution(BaseModel):\n   211→    \"\"\"Audit record of an action being executed.\"\"\"\n   212→    id: str = Field(default_factory=_new_id)\n   213→    action_name: str\n   214→    object_id: str\n   215→    object_type: str\n   216→    input_params: dict[str, Any] = Field(default_factory=dict)\n   217→    result: str = \"pending\"\n   218→    gate_results: dict[str, str] = Field(default_factory=dict)\n   219→    executed_by: str = \"system\"\n   220→    executed_at: datetime = Field(default_factory=_utc_now)\n   221→    duration_ms: float = 0.0\n   222→    error: str = \"\"\n   223→    lineage_inputs: list[str] = Field(default_factory=list)\n   224→    lineage_outputs: list[str] = Field(default_factory=list)\n   225→\n   226→\n   227→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   228→# VALIDATION\n   229→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   230→\n   231→\n   232→def validate_object(obj: OntologyObj, obj_type: ObjectType) -> list[str]:\n   233→    \"\"\"Validate an OntologyObj against its ObjectType schema.\"\"\"\n   234→    errors: list[str] = []\n   235→    if obj.type_name != obj_type.name:\n   236→        errors.append(f\"type mismatch: '{obj.type_name}' vs '{obj_type.name}'\")\n   237→        return errors\n   238→\n   239→    for prop_name, prop_def in obj_type.properties.items():\n   240→        value = obj.properties.get(prop_name)\n   241→        if prop_def.required and value is None:\n   242→            errors.append(f\"missing required property: {prop_name}\")\n   243→            continue\n   244→        if value is None:\n   245→            continue\n   246→        if prop_def.property_type == PropertyType.ENUM and prop_def.enum_values:\n   247→            if str(value) not in prop_def.enum_values:\n   248→                errors.append(\n   249→                    f\"invalid enum '{prop_name}': \"\n   250→                    f\"'{value}' not in {prop_def.enum_values}\"\n   251→                )\n   252→        if prop_def.property_type == PropertyType.FLOAT:\n   253→            if not isinstance(value, (int, float)):\n   254→                errors.append(f\"'{prop_name}' must be numeric\")\n   255→        if prop_def.property_type == PropertyType.INTEGER:\n   256→            if not isinstance(value, int):\n   257→                errors.append(f\"'{prop_name}' must be integer\")\n   258→        if prop_def.property_type == PropertyType.BOOLEAN:\n   259→            if not isinstance(value, bool):\n   260→                errors.append(f\"'{prop_name}' must be boolean\")\n   261→    return errors\n   262→\n   263→\n   264→def validate_link(link: Link, link_def: LinkDef) -> list[str]:\n   265→    \"\"\"Validate a Link instance against its LinkDef schema.\"\"\"\n   266→    errors: list[str] = []\n   267→    if link.link_name != link_def.name:\n   268→        errors.append(f\"link name mismatch: '{link.link_name}' vs '{link_def.name}'\")\n   269→    if link.source_type != link_def.source_type:\n   270→        errors.append(f\"source type mismatch: '{link.source_type}' vs '{link_def.source_type}'\")\n   271→    if link.target_type != link_def.target_type:\n   272→        errors.append(f\"target type mismatch: '{link.target_type}' vs '{link_def.target_type}'\")\n   273→    return errors\n   274→\n   275→\n   276→def check_security(\n   277→    obj_type: ObjectType,\n   278→    agent_role: str,\n   279→    operation: str,\n   280→) -> tuple[bool, str]:\n   281→    \"\"\"Check if an agent role has permission for an operation.\"\"\"\n   282→    policy = obj_type.security\n   283→    role_map = {\n   284→        \"read\": policy.read_roles,\n   285→        \"write\": policy.write_roles,\n   286→        \"create\": policy.create_roles,\n   287→        \"delete\": policy.delete_roles,\n   288→    }\n   289→    allowed_roles = role_map.get(operation, [])\n   290→    if \"*\" in allowed_roles or agent_role in allowed_roles:\n   291→        return True, \"\"\n   292→    return False, f\"role '{agent_role}' denied {operation} on {obj_type.name}\"\n   293→\n   294→\n   295→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   296→# THE REGISTRY (The Brain)\n   297→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   298→\n   299→\n   300→class OntologyRegistry:\n   301→    \"\"\"Central registry of all object types, links, actions, and security.\n   302→\n   303→    This is the Palantir Ontology for dharma_swarm.\n   304→\n   305→    Usage::\n   306→\n   307→        registry = OntologyRegistry.create_dharma_registry()\n   308→        registry.get_type(\"Experiment\")\n   309→        registry.get_links_for(\"ResearchThread\")\n   310→        registry.schema_for_llm([\"Experiment\", \"KnowledgeArtifact\"])\n   311→    \"\"\"\n   312→\n   313→    def __init__(self) -> None:\n   314→        self._types: dict[str, ObjectType] = {}\n   315→        self._links: dict[str, LinkDef] = {}\n   316→        self._actions: dict[str, ActionDef] = {}\n   317→        self._objects: dict[str, OntologyObj] = {}\n   318→        self._link_instances: dict[str, Link] = {}\n   319→        self._action_log: list[ActionExecution] = []\n   320→\n   321→    # ── Registration ─────────────────────────────────────────────────\n   322→\n   323→    def register_type(self, obj_type: ObjectType) -> None:\n   324→        \"\"\"Register an ObjectType in the ontology.\"\"\"\n   325→        self._types[obj_type.name] = obj_type\n   326→        for link_def in obj_type.links:\n   327→            self.register_link(link_def)\n   328→        for action_def in obj_type.actions:\n   329→            self.register_action(action_def)\n   330→\n   331→    def register_link(self, link_def: LinkDef) -> None:\n   332→        \"\"\"Register a LinkDef. Auto-registers inverse if specified.\"\"\"\n   333→        key = f\"{link_def.source_type}.{link_def.name}\"\n   334→        self._links[key] = link_def\n   335→        if link_def.inverse_name:\n   336→            inverse_cardinality = {\n   337→                LinkCardinality.ONE_TO_ONE: LinkCardinality.ONE_TO_ONE,\n   338→                LinkCardinality.ONE_TO_MANY: LinkCardinality.MANY_TO_ONE,\n   339→                LinkCardinality.MANY_TO_ONE: LinkCardinality.ONE_TO_MANY,\n   340→                LinkCardinality.MANY_TO_MANY: LinkCardinality.MANY_TO_MANY,\n   341→            }[link_def.cardinality]\n   342→            inv_key = f\"{link_def.target_type}.{link_def.inverse_name}\"\n   343→            if inv_key not in self._links:\n   344→                self._links[inv_key] = LinkDef(\n   345→                    name=link_def.inverse_name,\n   346→                    source_type=link_def.target_type,\n   347→                    target_type=link_def.source_type,\n   348→                    cardinality=inverse_cardinality,\n   349→                    description=f\"Inverse of {link_def.name}\",\n   350→                )\n   351→\n   352→    def register_action(self, action_def: ActionDef) -> None:\n   353→        \"\"\"Register an ActionDef.\"\"\"\n   354→        key = f\"{action_def.object_type}.{action_def.name}\"\n   355→        self._actions[key] = action_def\n   356→\n   357→    # ── Querying ─────────────────────────────────────────────────────\n   358→\n   359→    def get_type(self, name: str) -> ObjectType | None:\n   360→        return self._types.get(name)\n   361→\n   362→    def get_types(self) -> list[ObjectType]:\n   363→        return list(self._types.values())\n   364→\n   365→    def type_names(self) -> list[str]:\n   366→        return sorted(self._types.keys())\n   367→\n   368→    def get_links_for(self, type_name: str) -> list[LinkDef]:\n   369→        \"\"\"Get all links where type_name is the source.\"\"\"\n   370→        prefix = f\"{type_name}.\"\n   371→        return [link for key, link in self._links.items() if key.startswith(prefix)]\n   372→\n   373→    def get_all_links_involving(self, type_name: str) -> list[LinkDef]:\n   374→        \"\"\"Get all links where type_name is source or target.\"\"\"\n   375→        return [\n   376→            link for link in self._links.values()\n   377→            if link.source_type == type_name or link.target_type == type_name\n   378→        ]\n   379→\n   380→    def get_actions_for(self, type_name: str) -> list[ActionDef]:\n   381→        prefix = f\"{type_name}.\"\n   382→        return [a for key, a in self._actions.items() if key.startswith(prefix)]\n   383→\n   384→    def get_link_def(self, source_type: str, link_name: str) -> LinkDef | None:\n   385→        return self._links.get(f\"{source_type}.{link_name}\")\n   386→\n   387→    def get_action_def(self, object_type: str, action_name: str) -> ActionDef | None:\n   388→        return self._actions.get(f\"{object_type}.{action_name}\")\n   389→\n   390→    # ── Object Operations ────────────────────────────────────────────\n   391→\n   392→    def create_object(\n   393→        self,\n   394→        type_name: str,\n   395→        properties: dict[str, Any],\n   396→        created_by: str = \"system\",\n   397→    ) -> tuple[OntologyObj | None, list[str]]:\n   398→        \"\"\"Create a new OntologyObj with validation.\"\"\"\n   399→        obj_type = self._types.get(type_name)"}]},"uuid":"375759ba-2563-4c95-976f-30c84511ce8a","timestamp":"2026-03-15T13:46:24.140Z","sourceToolAssistantUUID":"915d33ab-1875-422c-b424-341d67133587","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
