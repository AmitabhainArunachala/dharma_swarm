{"parentUuid":"d32f2e57-71aa-42e6-a20c-e8ef4642d924","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01KbMeBWi5KTS8VVwCZpzUum","toolUseID":"toolu_01KbMeBWi5KTS8VVwCZpzUum","timestamp":"2026-03-15T14:20:58.730Z","uuid":"0782e24e-3225-4c3f-afd2-b6ca354fd47c","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"804643cc-9235-4b22-80d9-5e64a44e015c","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49343f0463f23a8f","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KbMeBWi5KTS8VVwCZpzUum","type":"tool_result","content":"   100→        Returns:\n   101→            An ``IdentityState`` snapshot.\n   102→        \"\"\"\n   103→        gpr = await self._measure_gpr()\n   104→        bsi = await self._measure_bsi()\n   105→        rm = await self._measure_rm()\n   106→\n   107→        # S4 -> S5 feedback: threats boost RM weight\n   108→        if threat_boost:\n   109→            rm_weight = min(0.50, self.RM_WEIGHT + 0.15)\n   110→            gpr_weight = self.GPR_WEIGHT - 0.075\n   111→            bsi_weight = self.BSI_WEIGHT - 0.075\n   112→        else:\n   113→            gpr_weight = self.GPR_WEIGHT\n   114→            bsi_weight = self.BSI_WEIGHT\n   115→            rm_weight = self.RM_WEIGHT\n   116→\n   117→        tcs = gpr_weight * gpr + bsi_weight * bsi + rm_weight * rm\n   118→\n   119→        # Determine regime\n   120→        if tcs < self.CRITICAL_THRESHOLD:\n   121→            regime = \"critical\"\n   122→        elif tcs < self.DRIFT_THRESHOLD:\n   123→            regime = \"drifting\"\n   124→        else:\n   125→            regime = \"stable\"\n   126→\n   127→        # Issue correction if drifting\n   128→        correction_issued = False\n   129→        if regime in (\"drifting\", \"critical\"):\n   130→            correction_issued = self._issue_correction(tcs, gpr, bsi, rm)\n   131→\n   132→        state = IdentityState(\n   133→            tcs=round(tcs, 4),\n   134→            gpr=round(gpr, 4),\n   135→            bsi=round(bsi, 4),\n   136→            rm=round(rm, 4),\n   137→            regime=regime,\n   138→            correction_issued=correction_issued,\n   139→        )\n   140→        self._history.append(state)\n   141→        return state\n   142→\n   143→    @property\n   144→    def history(self) -> list[IdentityState]:\n   145→        \"\"\"Return a copy of all recorded states.\"\"\"\n   146→        return list(self._history)\n   147→\n   148→    @property\n   149→    def current_tcs(self) -> float:\n   150→        \"\"\"Return the most recent TCS, or 0.5 if no measurements taken.\"\"\"\n   151→        return self._history[-1].tcs if self._history else 0.5\n   152→\n   153→    # -- sub-metrics --------------------------------------------------------\n   154→\n   155→    async def _measure_gpr(self) -> float:\n   156→        \"\"\"Gate passage rate from witness logs.\n   157→\n   158→        Reads the 20 most-recent JSON files from\n   159→        ``<state_dir>/witness/`` and counts those whose ``decision``\n   160→        field is one of ``allow``, ``PASS``, or ``ALLOW``.\n   161→\n   162→        Returns:\n   163→            Float in [0.0, 1.0], defaulting to 0.5 when no data.\n   164→        \"\"\"\n   165→        witness_dir = self._state_dir / \"witness\"\n   166→        if not witness_dir.exists():\n   167→            return 0.5\n   168→\n   169→        try:\n   170→            log_files = sorted(\n   171→                witness_dir.glob(\"*.json\"),\n   172→                key=lambda p: p.stat().st_mtime,\n   173→                reverse=True,\n   174→            )[:20]\n   175→            if not log_files:\n   176→                return 0.5\n   177→\n   178→            total = 0\n   179→            passed = 0\n   180→            for lf in log_files:\n   181→                try:\n   182→                    data = json.loads(lf.read_text())\n   183→                    total += 1\n   184→                    decision = data.get(\"decision\", \"\")\n   185→                    if decision in (\"allow\", \"PASS\", \"ALLOW\"):\n   186→                        passed += 1\n   187→                except Exception:\n   188→                    continue\n   189→\n   190→            return passed / total if total > 0 else 0.5\n   191→        except Exception:\n   192→            return 0.5\n   193→\n   194→    async def _measure_bsi(self) -> float:\n   195→        \"\"\"Mean swabhaav_ratio from recent shared notes.\n   196→\n   197→        Imports :class:`~dharma_swarm.metrics.MetricsAnalyzer` lazily to\n   198→        avoid circular imports and analyses the 10 most-recent Markdown\n   199→        notes in ``<state_dir>/shared/``."}]},"uuid":"6d9e0fd1-6df9-4aae-82a9-5cd1c77e023a","timestamp":"2026-03-15T14:20:58.730Z","sourceToolAssistantUUID":"804643cc-9235-4b22-80d9-5e64a44e015c","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
