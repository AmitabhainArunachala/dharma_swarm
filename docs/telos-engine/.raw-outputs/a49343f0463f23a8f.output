{"parentUuid":"d8dddfb0-862d-4bf0-9dfc-4370d0c96e41","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01LQbJsDpWPJigp7jiYEM4u3","toolUseID":"toolu_01LQbJsDpWPJigp7jiYEM4u3","timestamp":"2026-03-15T14:20:42.093Z","uuid":"be4839a6-7d38-45c7-86e9-06bbf7de6435","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"562736f2-52e3-4fe8-b0da-f5ece1765fa1","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49343f0463f23a8f","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LQbJsDpWPJigp7jiYEM4u3","type":"tool_result","content":"     1→\"\"\"Universal Loop Engine — F(S) = S.\n     2→\n     3→The cascade engine runs any domain through the universal pattern:\n     4→  GENERATE → TEST → SCORE → GATE → eigenform check → MUTATE → SELECT → repeat\n     5→\n     6→Phase functions are resolved via importlib from string refs in LoopDomain.\n     7→Handles both sync and async callables.\n     8→\n     9→The META domain evolves LoopDomain configs themselves — the strange loop\n    10→where the system's configuration is a candidate for its own optimization.\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import asyncio\n    16→import importlib\n    17→import inspect\n    18→import logging\n    19→import time\n    20→from collections.abc import Callable\n    21→from typing import Any\n    22→\n    23→from dharma_swarm.checkpoint import (\n    24→    CheckpointStore,\n    25→    InterruptDecision,\n    26→    InterruptGate,\n    27→    InterruptRequest,\n    28→    LoopCheckpoint,\n    29→)\n    30→from dharma_swarm.models import LoopDomain, LoopResult\n    31→\n    32→logger = logging.getLogger(__name__)\n    33→\n    34→# Module-level singletons — shared across all engine runs\n    35→_checkpoint_store = CheckpointStore()\n    36→_interrupt_gate = InterruptGate()\n    37→\n    38→\n    39→# ---------------------------------------------------------------------------\n    40→# Domain registry\n    41→# ---------------------------------------------------------------------------\n    42→\n    43→_DOMAIN_MODULES: dict[str, str] = {\n    44→    \"code\": \"dharma_swarm.cascade_domains.code\",\n    45→    \"product\": \"dharma_swarm.cascade_domains.product\",\n    46→    \"skill\": \"dharma_swarm.cascade_domains.skill\",\n    47→    \"research\": \"dharma_swarm.cascade_domains.research\",\n    48→    \"meta\": \"dharma_swarm.cascade_domains.meta\",\n    49→}\n    50→\n    51→\n    52→def get_registered_domains() -> dict[str, LoopDomain]:\n    53→    \"\"\"Load all registered domain configs.\"\"\"\n    54→    domains: dict[str, LoopDomain] = {}\n    55→    for name, module_path in _DOMAIN_MODULES.items():\n    56→        try:\n    57→            mod = importlib.import_module(module_path)\n    58→            domains[name] = mod.get_domain()\n    59→        except Exception as e:\n    60→            logger.warning(\"Failed to load domain %s: %s\", name, e)\n    61→    return domains\n    62→\n    63→\n    64→# ---------------------------------------------------------------------------\n    65→# Function resolution\n    66→# ---------------------------------------------------------------------------\n    67→\n    68→def _resolve_fn(dotted_path: str) -> Callable[..., Any]:\n    69→    \"\"\"Resolve a dotted import path to a callable.\n    70→\n    71→    E.g. \"dharma_swarm.cascade_domains.code.generate\" →\n    72→         the generate function from code.py.\n    73→    \"\"\"\n    74→    parts = dotted_path.rsplit(\".\", 1)\n    75→    if len(parts) != 2:\n    76→        raise ImportError(f\"Invalid function path: {dotted_path!r}\")\n    77→    module_path, fn_name = parts\n    78→    mod = importlib.import_module(module_path)\n    79→    fn = getattr(mod, fn_name)\n    80→    if not callable(fn):\n    81→        raise TypeError(f\"{dotted_path} is not callable\")\n    82→    return fn\n    83→\n    84→\n    85→async def _call(fn: Callable[..., Any], *args: Any, **kwargs: Any) -> Any:\n    86→    \"\"\"Call a function, handling both sync and async.\"\"\"\n    87→    if inspect.iscoroutinefunction(fn):\n    88→        return await fn(*args, **kwargs)\n    89→    return fn(*args, **kwargs)\n    90→\n    91→\n    92→# ---------------------------------------------------------------------------\n    93→# LoopEngine\n    94→# ---------------------------------------------------------------------------\n    95→\n    96→class LoopEngine:\n    97→    \"\"\"Universal strange-loop engine.\n    98→\n    99→    Runs a domain through GENERATE → TEST → SCORE → GATE → eigenform →\n   100→    MUTATE → SELECT until convergence, eigenform, or limits.\n   101→\n   102→    Now with:\n   103→      - Checkpoint after every iteration (crash-safe resume)\n   104→      - InterruptGate at GATE phase (human-in-the-loop for Tier B/C)\n   105→    \"\"\"\n   106→\n   107→    def __init__(\n   108→        self,\n   109→        domain: LoopDomain,\n   110→        *,\n   111→        checkpoint_store: CheckpointStore | None = None,\n   112→        interrupt_gate: InterruptGate | None = None,\n   113→    ):\n   114→        self.domain = domain\n   115→        self._fns: dict[str, Callable[..., Any]] = {}\n   116→        self._store = checkpoint_store or _checkpoint_store\n   117→        self._gate = interrupt_gate or _interrupt_gate\n   118→\n   119→    def _resolve_all(self) -> None:\n   120→        \"\"\"Resolve all phase function references.\"\"\""}]},"uuid":"977d3820-92f6-4a5c-a638-5a1f5e41453b","timestamp":"2026-03-15T14:20:42.093Z","sourceToolAssistantUUID":"562736f2-52e3-4fe8-b0da-f5ece1765fa1","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
