{"parentUuid":"60143932-df05-465d-b03c-5f221418d0e6","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01TMq8uAntqa4NFfgMxyNf7p","toolUseID":"toolu_01TMq8uAntqa4NFfgMxyNf7p","timestamp":"2026-03-15T14:20:31.651Z","uuid":"9f80d51d-a65d-45c6-9c2c-0f8c85be7611","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"06f41937-0f31-43f3-ba25-aff2c14c0617","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49343f0463f23a8f","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TMq8uAntqa4NFfgMxyNf7p","type":"tool_result","content":"     1→\"\"\"Policy compiler for DHARMA SWARM.\n     2→\n     3→Compiles kernel principles and accepted claims into a unified Policy\n     4→that can evaluate actions against dharmic constraints. Immutable rules\n     5→(from the kernel) always override mutable rules (from the corpus).\n     6→\"\"\"\n     7→\n     8→from __future__ import annotations\n     9→\n    10→from typing import Any, Literal\n    11→\n    12→from pydantic import BaseModel, Field\n    13→\n    14→from dharma_swarm.models import _utc_now\n    15→\n    16→\n    17→# ---------------------------------------------------------------------------\n    18→# Data Models\n    19→# ---------------------------------------------------------------------------\n    20→\n    21→EnforcementLevel = Literal[\"block\", \"warn\", \"log\", \"gate_human\"]\n    22→\n    23→_SEVERITY_TO_ENFORCEMENT: dict[str, EnforcementLevel] = {\n    24→    \"critical\": \"block\",\n    25→    \"high\": \"warn\",\n    26→    \"medium\": \"log\",\n    27→}\n    28→\n    29→\n    30→class PolicyRule(BaseModel):\n    31→    \"\"\"A single rule inside a compiled policy.\"\"\"\n    32→\n    33→    source: str\n    34→    rule_text: str\n    35→    weight: float = Field(ge=0.0, le=1.0)\n    36→    is_immutable: bool\n    37→    enforcement_level: EnforcementLevel\n    38→\n    39→\n    40→class PolicyDecision(BaseModel):\n    41→    \"\"\"Result of checking an action against a policy.\"\"\"\n    42→\n    43→    allowed: bool\n    44→    violated_rules: list[PolicyRule] = Field(default_factory=list)\n    45→    reason: str = \"\"\n    46→\n    47→\n    48→class Policy(BaseModel):\n    49→    \"\"\"A compiled set of rules ready for action evaluation.\"\"\"\n    50→\n    51→    rules: list[PolicyRule] = Field(default_factory=list)\n    52→    context: str = \"\"\n    53→    compiled_at: str = Field(default_factory=lambda: _utc_now().isoformat())\n    54→\n    55→    def get_immutable_rules(self) -> list[PolicyRule]:\n    56→        \"\"\"Return all immutable (kernel-derived) rules.\"\"\"\n    57→        return [r for r in self.rules if r.is_immutable]\n    58→\n    59→    def get_mutable_rules(self) -> list[PolicyRule]:\n    60→        \"\"\"Return all mutable (corpus-derived) rules.\"\"\"\n    61→        return [r for r in self.rules if not r.is_immutable]\n    62→\n    63→    def check_action(self, action: str, context: str = \"\") -> PolicyDecision:\n    64→        \"\"\"Evaluate an action string against all policy rules.\n    65→\n    66→        Matching is keyword-based: every word in the rule_text is checked\n    67→        against the combined action+context string (case-insensitive).\n    68→        A rule is considered matched if *all* its keywords appear.\n    69→\n    70→        Blocking logic:\n    71→        - Immutable rule with enforcement_level=\"block\" -> not allowed.\n    72→        - Mutable rule with enforcement_level=\"block\" and weight > 0.7 -> not allowed.\n    73→        \"\"\"\n    74→        combined = (action + \" \" + context).lower()\n    75→        violated: list[PolicyRule] = []\n    76→\n    77→        for rule in self.rules:\n    78→            keywords = rule.rule_text.lower().split()\n    79→            if all(kw in combined for kw in keywords):\n    80→                violated.append(rule)\n    81→\n    82→        blocked = False\n    83→        reasons: list[str] = []\n    84→\n    85→        for rule in violated:\n    86→            if rule.enforcement_level == \"block\":\n    87→                if rule.is_immutable:\n    88→                    blocked = True\n    89→                    reasons.append(\n    90→                        f\"immutable block: {rule.source}\"\n    91→                    )\n    92→                elif rule.weight > 0.7:\n    93→                    blocked = True\n    94→                    reasons.append(\n    95→                        f\"mutable block (weight={rule.weight}): {rule.source}\"\n    96→                    )\n    97→\n    98→        return PolicyDecision(\n    99→            allowed=not blocked,\n   100→            violated_rules=violated,"}]},"uuid":"e62572c0-f1ff-4c9b-823f-f6dd940bfedb","timestamp":"2026-03-15T14:20:31.651Z","sourceToolAssistantUUID":"06f41937-0f31-43f3-ba25-aff2c14c0617","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
