{"parentUuid":"67343793-4f2a-4d12-8816-1edaf0f86b7c","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_015CDikU7gRzWdvnRUjBXmNx","toolUseID":"toolu_015CDikU7gRzWdvnRUjBXmNx","timestamp":"2026-03-15T14:20:10.526Z","uuid":"d9f27e3f-39ad-4cb4-bd99-169db7b48917","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"d9f27e3f-39ad-4cb4-bd99-169db7b48917","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_015CDikU7gRzWdvnRUjBXmNx","toolUseID":"toolu_015CDikU7gRzWdvnRUjBXmNx","timestamp":"2026-03-15T14:20:10.526Z","uuid":"b8ac928a-db9c-4ef2-b720-4abe7afcc3d1","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"be845d04-686c-4ac7-bd44-b8ca4430ac57","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49343f0463f23a8f","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015CDikU7gRzWdvnRUjBXmNx","type":"tool_result","content":"     1→\"\"\"System monitor -- swarm health tracking and anomaly detection.\n     2→\n     3→Watches traces, detects drift, tracks agent health, provides\n     4→actionable health summaries, and performs pop-quiz liveness checks.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→import logging\n    10→import statistics\n    11→from collections import Counter, defaultdict\n    12→from datetime import datetime, timedelta, timezone\n    13→from enum import Enum\n    14→from typing import Any, Optional\n    15→\n    16→from pydantic import BaseModel, Field\n    17→\n    18→from dharma_swarm.models import _new_id, _utc_now\n    19→from dharma_swarm.traces import TraceEntry, TraceStore\n    20→\n    21→logger = logging.getLogger(__name__)\n    22→\n    23→\n    24→# ---------------------------------------------------------------------------\n    25→# Enums\n    26→# ---------------------------------------------------------------------------\n    27→\n    28→\n    29→class HealthStatus(str, Enum):\n    30→    \"\"\"Overall health classification for agents or the swarm.\"\"\"\n    31→\n    32→    HEALTHY = \"healthy\"\n    33→    DEGRADED = \"degraded\"\n    34→    CRITICAL = \"critical\"\n    35→    UNKNOWN = \"unknown\"\n    36→\n    37→\n    38→# ---------------------------------------------------------------------------\n    39→# Data models\n    40→# ---------------------------------------------------------------------------\n    41→\n    42→\n    43→class Anomaly(BaseModel):\n    44→    \"\"\"A detected anomaly in swarm operations.\"\"\"\n    45→\n    46→    id: str = Field(default_factory=_new_id)\n    47→    detected_at: datetime = Field(default_factory=_utc_now)\n    48→    anomaly_type: str  # \"failure_spike\", \"fitness_drift\", \"agent_silent\", \"throughput_drop\"\n    49→    severity: str  # \"low\", \"medium\", \"high\"\n    50→    description: str\n    51→    related_traces: list[str] = Field(default_factory=list)\n    52→\n    53→\n    54→class AgentHealth(BaseModel):\n    55→    \"\"\"Health summary for a single agent.\"\"\"\n    56→\n    57→    agent_name: str\n    58→    total_actions: int = 0\n    59→    failures: int = 0\n    60→    success_rate: float = 1.0\n    61→    last_seen: Optional[datetime] = None\n    62→    status: HealthStatus = HealthStatus.UNKNOWN\n    63→\n    64→\n    65→class HealthReport(BaseModel):\n    66→    \"\"\"Full health report for the swarm.\"\"\"\n    67→\n    68→    timestamp: datetime = Field(default_factory=_utc_now)\n    69→    overall_status: HealthStatus = HealthStatus.UNKNOWN\n    70→    agent_health: list[AgentHealth] = Field(default_factory=list)\n    71→    anomalies: list[Anomaly] = Field(default_factory=list)\n    72→    total_traces: int = 0\n    73→    traces_last_hour: int = 0\n    74→    failure_rate: float = 0.0\n    75→    mean_fitness: Optional[float] = None\n    76→\n    77→\n    78→# ---------------------------------------------------------------------------\n    79→# Helpers\n    80→# ---------------------------------------------------------------------------\n    81→\n    82→\n    83→def _is_failure(entry: TraceEntry) -> bool:\n    84→    \"\"\"Return True if *entry* represents a failed operation.\"\"\"\n    85→    if entry.state in (\"failed\", \"rejected\", \"blocked\", \"rolled_back\"):\n    86→        return True\n    87→    action_lower = entry.action.lower()\n    88→    return any(w in action_lower for w in (\"fail\", \"error\", \"rejected\", \"blocked\", \"rolled_back\"))\n    89→\n    90→\n    91→def _entries_in_window(\n    92→    entries: list[TraceEntry], now: datetime, hours: float\n    93→) -> list[TraceEntry]:\n    94→    \"\"\"Return entries whose timestamp falls within *hours* before *now*.\"\"\"\n    95→    cutoff = now - timedelta(hours=hours)\n    96→    return [e for e in entries if e.timestamp >= cutoff]\n    97→\n    98→\n    99→# ---------------------------------------------------------------------------\n   100→# Monitor\n   101→# ---------------------------------------------------------------------------\n   102→\n   103→\n   104→class SystemMonitor:\n   105→    \"\"\"Monitors swarm health via TraceStore analysis.\n   106→\n   107→    All public methods are async to match the TraceStore interface.\n   108→    The monitor is pure analysis -- it never mutates the trace store.\n   109→    \"\"\"\n   110→\n   111→    def __init__(self, trace_store: TraceStore) -> None:\n   112→        self._store = trace_store\n   113→\n   114→    # -- public API ----------------------------------------------------------\n   115→\n   116→    async def check_health(self) -> HealthReport:\n   117→        \"\"\"Run a full health scan and return a report.\n   118→\n   119→        Combines agent health, anomaly detection, throughput, and\n   120→        fitness metrics into a single actionable report.\n   121→        \"\"\"\n   122→        all_entries = await self._store.get_recent(limit=10_000)\n   123→        if not all_entries:\n   124→            return HealthReport(overall_status=HealthStatus.UNKNOWN)\n   125→\n   126→        now = _utc_now()\n   127→        last_hour = _entries_in_window(all_entries, now, hours=1)\n   128→\n   129→        # Failure rate across all entries\n   130→        total = len(all_entries)\n   131→        failures = sum(1 for e in all_entries if _is_failure(e))\n   132→        failure_rate = failures / total if total else 0.0\n   133→\n   134→        # Mean fitness\n   135→        fitness_values = [\n   136→            e.fitness.weighted()\n   137→            for e in all_entries\n   138→            if e.fitness is not None\n   139→        ]\n   140→        mean_fitness: Optional[float] = None\n   141→        if fitness_values:\n   142→            mean_fitness = statistics.mean(fitness_values)\n   143→\n   144→        # Per-agent health\n   145→        agents = await self._all_agent_health(all_entries, now)\n   146→\n   147→        # Anomalies (from last hour)\n   148→        anomalies = self._detect_anomalies_from(all_entries, now, window_hours=1)\n   149→\n   150→        # Overall status"}]},"uuid":"9fcebf0d-4102-403c-b1a7-8337ff53a514","timestamp":"2026-03-15T14:20:10.526Z","sourceToolAssistantUUID":"be845d04-686c-4ac7-bd44-b8ca4430ac57","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
