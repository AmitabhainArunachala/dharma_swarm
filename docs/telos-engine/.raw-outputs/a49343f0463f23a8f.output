{"parentUuid":"c9b64642-67d7-49d6-ae2f-5da4e306f25a","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01H7xJ4sry846h5ndscdmBiW","toolUseID":"toolu_01H7xJ4sry846h5ndscdmBiW","timestamp":"2026-03-15T14:20:43.463Z","uuid":"9999831d-ba6c-48b2-834d-fec9136748c0","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"04b990b6-0af9-48ba-a9d6-875717387582","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49343f0463f23a8f","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H7xJ4sry846h5ndscdmBiW","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"\n     3→TELOS GATE — Claude Code Hook (PreToolUse)\n     4→\n     5→Runs 8 Dharmic Gates before any tool execution.\n     6→Ported from DHARMIC_GODEL_CLAW/src/core/unified_gates.py (1806 lines → 180 lines).\n     7→Adds: injection detection, credential protection, BHED_GNAN gate.\n     8→\n     9→Install: Add to ~/.claude/settings.json hooks.PreToolUse\n    10→\"\"\"\n    11→\n    12→import json\n    13→import sys\n    14→from datetime import datetime, timezone\n    15→\n    16→# Gate definitions: (name, tier)\n    17→# Tier A = absolute block, Tier B = strong, Tier C = advisory\n    18→GATES = {\n    19→    \"AHIMSA\": \"A\",       # Does this harm?\n    20→    \"SATYA\": \"B\",        # Is this true/honest?\n    21→    \"CONSENT\": \"B\",      # Permission granted?\n    22→    \"VYAVASTHIT\": \"C\",   # Allow or force?\n    23→    \"REVERSIBILITY\": \"C\",  # Can undo?\n    24→    \"SVABHAAVA\": \"C\",    # Aligned with telos?\n    25→    \"BHED_GNAN\": \"C\",    # Witness clarity — distinguishing self from action\n    26→    \"WITNESS\": \"C\",      # Self-observing? (always passes — the act of checking IS witnessing)\n    27→}\n    28→\n    29→HARM_WORDS = {\n    30→    \"delete all\", \"destroy\", \"rm -rf\", \"wipe\", \"kill\", \"corrupt\",\n    31→    \"exploit\", \"attack\", \"exfiltrate\", \"format disk\", \"drop table\",\n    32→    \"truncate table\", \"shutdown -h\", \"mkfs\", \"dd if=/dev/zero\",\n    33→    \"chmod 777\", \":(){ :|:& };:\",\n    34→}\n    35→\n    36→FORCE_WORDS = {\"force\", \"override\", \"bypass\", \"skip validation\", \"disable safety\", \"--no-verify\"}\n    37→\n    38→IRREVERSIBLE_WORDS = {\"permanent\", \"irreversible\", \"cannot undo\", \"no backup\", \"force push\"}\n    39→\n    40→# Prompt injection detection (from unified_gates.py)\n    41→INJECTION_PATTERNS = {\n    42→    \"ignore previous instructions\", \"ignore all previous\",\n    43→    \"disregard your instructions\", \"new instructions:\",\n    44→    \"you are now\", \"act as if you\", \"pretend you are\",\n    45→    \"override your\", \"forget your rules\",\n    46→}\n    47→\n    48→# Credential patterns — never write these to files\n    49→OPENROUTER_PREFIX = \"sk-or-\" + \"v1-\"\n    50→CREDENTIAL_PATTERNS = {\n    51→    OPENROUTER_PREFIX, \"sk-ant-\", \"sk-proj-\", \"AKIA\", \"ghp_\", \"gho_\",\n    52→    \"xoxb-\", \"xoxp-\", \"Bearer \", \"-----BEGIN PRIVATE KEY\",\n    53→    \"-----BEGIN RSA PRIVATE\", \"password=\", \"secret=\",\n    54→}\n    55→\n    56→# Tools that are always safe (read-only)\n    57→SAFE_TOOLS = {\"Read\", \"Glob\", \"Grep\", \"LSP\", \"WebFetch\", \"WebSearch\", \"TaskList\", \"TaskGet\"}\n    58→\n    59→# Tools that need gate checks\n    60→GATED_TOOLS = {\"Bash\", \"Write\", \"Edit\", \"NotebookEdit\"}\n    61→\n    62→\n    63→def check_gates(tool_name: str, tool_input: dict) -> dict:\n    64→    \"\"\"Run all 8 gates. Returns {\"decision\": \"allow\"|\"block\"|\"review\", \"reason\": str}\"\"\"\n    65→\n    66→    # Safe tools pass immediately\n    67→    if tool_name in SAFE_TOOLS:\n    68→        return {\"decision\": \"allow\", \"reason\": \"Read-only tool\"}\n    69→\n    70→    # Build action description from tool input\n    71→    action = \"\"\n    72→    content = \"\"\n    73→    if tool_name == \"Bash\":\n    74→        action = tool_input.get(\"command\", \"\")\n    75→    elif tool_name == \"Write\":\n    76→        action = f\"write to {tool_input.get('file_path', 'unknown')}\"\n    77→        content = tool_input.get(\"content\", \"\")\n    78→    elif tool_name == \"Edit\":\n    79→        action = f\"edit {tool_input.get('file_path', 'unknown')}\"\n    80→        content = tool_input.get(\"new_string\", \"\")"}]},"uuid":"c21df2a9-e341-445b-89a3-14538b83b709","timestamp":"2026-03-15T14:20:43.463Z","sourceToolAssistantUUID":"04b990b6-0af9-48ba-a9d6-875717387582","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
