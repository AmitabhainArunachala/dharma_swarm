{"parentUuid":"8e089cf5-89aa-4c56-a112-00876026b06c","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_01KtqvEoMgEwca5XMfC3WEZo","toolUseID":"toolu_01KtqvEoMgEwca5XMfC3WEZo","timestamp":"2026-03-15T14:20:53.428Z","uuid":"fd20d007-bc65-484b-8bb7-1f2005510414","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"fd20d007-bc65-484b-8bb7-1f2005510414","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01KtqvEoMgEwca5XMfC3WEZo","toolUseID":"toolu_01KtqvEoMgEwca5XMfC3WEZo","timestamp":"2026-03-15T14:20:53.428Z","uuid":"5cd2779e-8493-4c1c-9cef-932b5f163318","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"f3d226cc-72ab-4ea1-aa0d-0e00e0c7a146","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49343f0463f23a8f","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KtqvEoMgEwca5XMfC3WEZo","type":"tool_result","content":"     1→\"\"\"Adaptive Autonomy — agents adjust freedom based on confidence and risk.\n     2→\n     3→Goes beyond static permission levels. Agents start at their profile's\n     4→base autonomy level, then dynamically adjust based on:\n     5→  - Success/failure history (more failures → more cautious)\n     6→  - Risk assessment of the current action\n     7→  - Confidence of intent detection\n     8→  - Time of day (quiet hours → more cautious)\n     9→  - Circuit breaker state\n    10→\n    11→The autonomy engine is the bridge between the telos gates (hard constraints)\n    12→and the profile system (soft preferences). Gates say WHAT is forbidden;\n    13→autonomy says HOW MUCH freedom the agent gets for everything else.\n    14→\"\"\"\n    15→\n    16→from __future__ import annotations\n    17→\n    18→import logging\n    19→import time\n    20→from collections import deque\n    21→from enum import Enum\n    22→\n    23→from pydantic import BaseModel\n    24→\n    25→logger = logging.getLogger(__name__)\n    26→\n    27→\n    28→class RiskLevel(str, Enum):\n    29→    \"\"\"Risk classification for an action.\"\"\"\n    30→    SAFE = \"safe\"           # Read-only, no side effects\n    31→    LOW = \"low\"             # Minor changes, easily reversible\n    32→    MEDIUM = \"medium\"       # File modifications, config changes\n    33→    HIGH = \"high\"           # Multi-file changes, API calls, deployments\n    34→    CRITICAL = \"critical\"   # Destructive ops, production changes, credentials\n    35→\n    36→\n    37→class AutonomyDecision(BaseModel):\n    38→    \"\"\"Result of an autonomy check for a specific action.\"\"\"\n    39→\n    40→    action: str\n    41→    risk: RiskLevel\n    42→    confidence: float = 0.0\n    43→    auto_approve: bool = False\n    44→    reason: str = \"\"\n    45→    escalate_to: str = \"\"  # \"human\" or agent name for review\n    46→\n    47→\n    48→# ── Risk Classification ──────────────────────────────────────────────\n    49→\n    50→_SAFE_PATTERNS = [\n    51→    \"read\", \"list\", \"show\", \"display\", \"search\", \"grep\", \"find\",\n    52→    \"status\", \"check\", \"ls\", \"cat\", \"head\", \"tail\", \"echo\",\n    53→]\n    54→\n    55→_LOW_RISK_PATTERNS = [\n    56→    \"write note\", \"log\", \"append\", \"create test\", \"add comment\",\n    57→    \"format\", \"lint\", \"git status\", \"git diff\", \"git log\",\n    58→]\n    59→\n    60→_MEDIUM_RISK_PATTERNS = [\n    61→    \"edit\", \"modify\", \"update\", \"change\", \"refactor\", \"rename\",\n    62→    \"install\", \"pip install\", \"npm install\", \"git add\", \"git commit\",\n    63→]\n    64→\n    65→_HIGH_RISK_PATTERNS = [\n    66→    \"deploy\", \"push\", \"publish\", \"migrate\", \"schema change\",\n    67→    \"api call\", \"http request\", \"subprocess\", \"exec\",\n    68→    \"git push\", \"create pr\", \"merge\",\n    69→]\n    70→\n    71→_CRITICAL_PATTERNS = [\n    72→    \"delete\", \"rm -rf\", \"drop table\", \"force push\", \"reset --hard\",\n    73→    \"production\", \"credential\", \"secret\", \"api key\", \"token\",\n    74→    \"chmod 777\", \"kill\", \"terminate\",\n    75→]\n    76→\n    77→\n    78→class AdaptiveAutonomy:\n    79→    \"\"\"Dynamic autonomy adjustment engine.\n    80→\n    81→    Tracks success/failure history and adjusts how much freedom\n    82→    agents get for different risk levels.\n    83→    \"\"\"\n    84→\n    85→    def __init__(\n    86→        self,\n    87→        base_level: str = \"balanced\",\n    88→        history_size: int = 50,\n    89→        quiet_hours: set[int] | None = None,\n    90→    ):\n    91→        self._base = base_level\n    92→        self._history: deque[bool] = deque(maxlen=history_size)\n    93→        self._quiet_hours = quiet_hours or {2, 3, 4}\n    94→        self._consecutive_failures: int = 0\n    95→        self._total_decisions: int = 0\n    96→\n    97→    @property\n    98→    def success_rate(self) -> float:\n    99→        \"\"\"Current success rate from recent history.\"\"\"\n   100→        if not self._history:\n   101→            return 1.0\n   102→        return sum(1 for x in self._history if x) / len(self._history)\n   103→\n   104→    @property\n   105→    def effective_level(self) -> str:\n   106→        \"\"\"Current effective autonomy level (may differ from base).\"\"\"\n   107→        rate = self.success_rate\n   108→\n   109→        # Downgrade autonomy on poor performance\n   110→        if self._consecutive_failures >= 3:\n   111→            return \"locked\"\n   112→        if rate < 0.5:\n   113→            return \"cautious\"\n   114→        if rate < 0.7 and self._base in (\"aggressive\", \"full\"):\n   115→            return \"balanced\"\n   116→\n   117→        # Quiet hours → more cautious\n   118→        if time.localtime().tm_hour in self._quiet_hours:\n   119→            if self._base in (\"aggressive\", \"full\"):\n   120→                return \"balanced\""}]},"uuid":"539e6343-6376-427f-8b72-03000bb5d740","timestamp":"2026-03-15T14:20:53.428Z","sourceToolAssistantUUID":"f3d226cc-72ab-4ea1-aa0d-0e00e0c7a146","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
