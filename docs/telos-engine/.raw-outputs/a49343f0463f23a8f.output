{"parentUuid":"b70c5436-be09-43f2-acd2-cc8948acbd1b","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PreToolUse","hookName":"PreToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"pre:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"toolUseID":"toolu_015xxiB4AQu6HAm1VxtEM9A8","parentToolUseID":"toolu_015xxiB4AQu6HAm1VxtEM9A8","uuid":"e92a185f-3352-4089-a482-f06031e790cc","timestamp":"2026-03-15T14:21:08.313Z","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"e92a185f-3352-4089-a482-f06031e790cc","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_015xxiB4AQu6HAm1VxtEM9A8","toolUseID":"toolu_015xxiB4AQu6HAm1VxtEM9A8","timestamp":"2026-03-15T14:21:08.317Z","uuid":"d640bbe8-ac6c-471d-91d4-db83cae320cc","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"d640bbe8-ac6c-471d-91d4-db83cae320cc","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_015xxiB4AQu6HAm1VxtEM9A8","toolUseID":"toolu_015xxiB4AQu6HAm1VxtEM9A8","timestamp":"2026-03-15T14:21:08.317Z","uuid":"bfad4b3e-5ff3-48c5-aa5f-c19269681164","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"b70c5436-be09-43f2-acd2-cc8948acbd1b","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49343f0463f23a8f","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015xxiB4AQu6HAm1VxtEM9A8","type":"tool_result","content":"     1→\"\"\"Multi-layer context engine for dharma_swarm agents.\n     2→\n     3→Five layers, selected by role x thread x task:\n     4→\n     5→  L1 VISION    — PSMV crown jewels, Genome spec, ten_words, telos\n     6→  L2 RESEARCH  — CLAUDE1-9 (per thread), R_V data, experimental results\n     7→  L3 ENGINEER  — dgc-core code, dharma_swarm modules, test status, code map\n     8→  L4 OPS       — AGNI state, trishula inbox, manifest, shipped/pending\n     9→  L5 SWARM     — What other agents found this cycle (shared notes)\n    10→\n    11→Each role gets a different mix. Each thread shifts emphasis.\n    12→Context budget: ~30K chars max (fits in system prompt alongside v7 rules).\n    13→\"\"\"\n    14→\n    15→from __future__ import annotations\n    16→\n    17→import json\n    18→import sqlite3\n    19→import time\n    20→from datetime import timezone\n    21→from pathlib import Path\n    22→\n    23→from dharma_swarm.injection_scanner import scan_and_sanitize\n    24→\n    25→HOME = Path.home()\n    26→AGNI_WORKSPACE = HOME / \"agni-workspace\"\n    27→TRISHULA_INBOX = HOME / \"trishula\" / \"inbox\"\n    28→STATE_DIR = HOME / \".dharma\"\n    29→SHARED_DIR = STATE_DIR / \"shared\"\n    30→PSMV = HOME / \"Persistent-Semantic-Memory-Vault\"\n    31→\n    32→# ── File reading helper ──────────────────────────────────────────────\n    33→\n    34→def _read_file(path: Path, max_chars: int = 2000) -> str | None:\n    35→    \"\"\"Read a file, truncate if needed, scan for injection. Returns None if missing.\"\"\"\n    36→    if not path.exists():\n    37→        return None\n    38→    try:\n    39→        content = path.read_text()\n    40→        # Scan external files for prompt injection before inclusion\n    41→        content = scan_and_sanitize(content, path.name)\n    42→        if len(content) > max_chars:\n    43→            return content[:max_chars] + \"\\n... [truncated]\"\n    44→        return content\n    45→    except Exception:\n    46→        return None\n    47→\n    48→\n    49→def _read_head(path: Path, lines: int = 30) -> str | None:\n    50→    \"\"\"Read first N lines of a file.\"\"\"\n    51→    if not path.exists():\n    52→        return None\n    53→    try:\n    54→        with open(path) as f:\n    55→            return \"\".join(f.readline() for _ in range(lines))\n    56→    except Exception:\n    57→        return None\n    58→\n    59→\n    60→def _format_retrieval_line(hit) -> str:\n    61→    record = hit.record\n    62→    metadata = record.metadata\n    63→    source_kind = str(metadata.get(\"source_kind\", \"unknown\"))\n    64→    created_at = record.created_at\n    65→    if created_at.tzinfo is None:\n    66→        created_at = created_at.replace(tzinfo=timezone.utc)\n    67→    stamp = created_at.astimezone(timezone.utc).strftime(\"%Y-%m-%d %H:%MZ\")\n    68→\n    69→    if source_kind == \"note\":\n    70→        source_label = str(metadata.get(\"source_ref\") or metadata.get(\"source_path\") or \"note\")\n    71→        section = str(metadata.get(\"section_title\") or \"\")\n    72→        provenance = f\"{source_label} | {stamp}\"\n    73→        if section:\n    74→            provenance = f\"{provenance} | {section}\"\n    75→    else:\n    76→        event_type = str(metadata.get(\"event_type\") or \"event\")\n    77→        source = str(metadata.get(\"source\") or \"runtime\")\n    78→        provenance = f\"{event_type} @ {source} | {stamp}\"\n    79→\n    80→    snippet = record.text.replace(\"\\n\", \" \").strip()[:100]"}]},"uuid":"24f678d7-5f80-4461-9f3e-0f5aded4e517","timestamp":"2026-03-15T14:21:08.317Z","sourceToolAssistantUUID":"b70c5436-be09-43f2-acd2-cc8948acbd1b","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
