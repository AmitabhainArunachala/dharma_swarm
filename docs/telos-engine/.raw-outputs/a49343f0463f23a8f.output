{"parentUuid":"98c6e506-1667-4cad-81c9-d042d781b137","isSidechain":true,"agentId":"a49343f0463f23a8f","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01V7gKE5jioyqBfJs6hScBBa","toolUseID":"toolu_01V7gKE5jioyqBfJs6hScBBa","timestamp":"2026-03-15T14:20:15.030Z","uuid":"f1c7c7e2-815d-4fef-ac13-1a3afe8e1433","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"191c2555-48fe-48a9-a4cb-b47335002e49","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49343f0463f23a8f","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V7gKE5jioyqBfJs6hScBBa","type":"tool_result","content":"     1→\"\"\"Async agent lifecycle manager.\n     2→\n     3→Spawns agents, runs their work loop, handles heartbeats and shutdown.\n     4→Each AgentRunner manages a single agent; AgentPool manages the fleet.\n     5→\"\"\"\n     6→\n     7→from __future__ import annotations\n     8→\n     9→import asyncio\n    10→import logging\n    11→import os\n    12→import time\n    13→from datetime import datetime, timedelta, timezone\n    14→from typing import Any, Protocol, runtime_checkable\n    15→\n    16→from dharma_swarm.models import (\n    17→    AgentConfig,\n    18→    AgentRole,\n    19→    AgentState,\n    20→    AgentStatus,\n    21→    GateDecision,\n    22→    LLMRequest,\n    23→    LLMResponse,\n    24→    ProviderType,\n    25→    Task,\n    26→    TaskPriority,\n    27→)\n    28→from dharma_swarm.agent_memory import AgentMemoryBank\n    29→from dharma_swarm.telos_gates import check_with_reflective_reroute\n    30→\n    31→logger = logging.getLogger(__name__)\n    32→\n    33→_HEARTBEAT_THRESHOLD = timedelta(seconds=60)\n    34→_ERROR_PREFIXES = (\n    35→    \"error\",\n    36→    \"api error:\",\n    37→    \"timeout: exceeded limit\",\n    38→    \"not logged in · please run /login\",\n    39→    \"openrouter error:\",\n    40→    \"no openrouter_api_key set\",\n    41→)\n    42→_PRIORITY_SALIENCE = {\n    43→    TaskPriority.LOW: 0.30,\n    44→    TaskPriority.NORMAL: 0.50,\n    45→    TaskPriority.HIGH: 0.70,\n    46→    TaskPriority.URGENT: 0.90,\n    47→}\n    48→_TRUE_VALUES = {\"1\", \"true\", \"yes\", \"on\"}\n    49→_FALSE_VALUES = {\"0\", \"false\", \"no\", \"off\"}\n    50→_TOOLING_HINTS = (\n    51→    \"apply patch\",\n    52→    \"bug\",\n    53→    \"code\",\n    54→    \"edit\",\n    55→    \"file\",\n    56→    \"fix\",\n    57→    \"implement\",\n    58→    \"module\",\n    59→    \"patch\",\n    60→    \"pytest\",\n    61→    \"refactor\",\n    62→    \"script\",\n    63→    \"test\",\n    64→)\n    65→_FRONTIER_HINTS = (\n    66→    \"analyze\",\n    67→    \"architecture\",\n    68→    \"compare\",\n    69→    \"debug\",\n    70→    \"design\",\n    71→    \"evaluate\",\n    72→    \"incident\",\n    73→    \"investigate\",\n    74→    \"prove\",\n    75→    \"research\",\n    76→    \"root cause\",\n    77→    \"security\",\n    78→)\n    79→_PRIVILEGED_HINTS = (\n    80→    \"credential\",\n    81→    \"delete\",\n    82→    \"deploy\",\n    83→    \"drop table\",\n    84→    \"kill \",\n    85→    \"launchctl\",\n    86→    \"production\",\n    87→    \"rm -rf\",\n    88→    \"secret\",\n    89→    \"ssh\",\n    90→    \"sudo\",\n    91→)\n    92→\n    93→\n    94→# ---------------------------------------------------------------------------\n    95→# Duck-typed protocols for provider and sandbox (no direct imports)\n    96→# ---------------------------------------------------------------------------\n    97→\n    98→@runtime_checkable\n    99→class CompletionProvider(Protocol):\n   100→    \"\"\"Anything with an async ``complete`` method returning an LLMResponse.\"\"\""}]},"uuid":"465a883d-409b-437c-b425-cf50e92b14ee","timestamp":"2026-03-15T14:20:15.030Z","sourceToolAssistantUUID":"191c2555-48fe-48a9-a4cb-b47335002e49","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
