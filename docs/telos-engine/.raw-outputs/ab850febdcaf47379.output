{"parentUuid":"67043f73-a5ee-45c9-95e2-8aeaf968f0a5","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_017KSBGp7V7RmRLr4mvFFU5z","toolUseID":"toolu_017KSBGp7V7RmRLr4mvFFU5z","timestamp":"2026-03-15T13:47:03.172Z","uuid":"a7ce5831-5d4c-4f49-bd09-7ee29d9cd8c7","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"302fee48-0e2c-432b-93af-5ed2b5c76380","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017KSBGp7V7RmRLr4mvFFU5z","type":"tool_result","content":"     1→\"\"\"Trace store -- persistent lineage tracking for swarm agent actions.\n     2→\n     3→Named ``traces`` (not ``residual_stream``) to avoid confusion with the\n     4→mech-interp residual stream concept.  Ported from\n     5→~/DHARMIC_GODEL_CLAW/swarm/residual_stream.py into dharma_swarm conventions:\n     6→Pydantic BaseModel, async I/O via ``asyncio.to_thread``, no singletons.\n     7→\"\"\"\n     8→\n     9→from __future__ import annotations\n    10→\n    11→import asyncio\n    12→import json\n    13→import os\n    14→import tempfile\n    15→from datetime import datetime, timezone\n    16→from pathlib import Path\n    17→from typing import Any, Optional\n    18→\n    19→from pydantic import BaseModel, Field\n    20→\n    21→from dharma_swarm.archive import FitnessScore\n    22→from dharma_swarm.models import _new_id, _utc_now\n    23→\n    24→\n    25→# ---------------------------------------------------------------------------\n    26→# Utility\n    27→# ---------------------------------------------------------------------------\n    28→\n    29→\n    30→def atomic_write_json(path: Path, data: dict, indent: int = 2) -> None:\n    31→    \"\"\"Write *data* as JSON to *path* atomically.\n    32→\n    33→    Strategy: write to a temp file in the same directory, then\n    34→    ``os.replace()`` which is a POSIX atomic rename on the same\n    35→    filesystem.\n    36→    \"\"\"\n    37→    path = Path(path)\n    38→    path.parent.mkdir(parents=True, exist_ok=True)\n    39→\n    40→    fd, tmp_path = tempfile.mkstemp(dir=path.parent, suffix=\".tmp\")\n    41→    try:\n    42→        with os.fdopen(fd, \"w\") as f:\n    43→            json.dump(data, f, indent=indent, default=str)\n    44→        os.replace(tmp_path, path)\n    45→    except Exception:\n    46→        if os.path.exists(tmp_path):\n    47→            os.unlink(tmp_path)\n    48→        raise\n    49→\n    50→\n    51→# ---------------------------------------------------------------------------\n    52→# Data model\n    53→# ---------------------------------------------------------------------------\n    54→\n    55→\n    56→class TraceEntry(BaseModel):\n    57→    \"\"\"A single trace event in the swarm's operation log.\"\"\"\n    58→\n    59→    id: str = Field(default_factory=_new_id)\n    60→    timestamp: datetime = Field(default_factory=_utc_now)\n    61→    agent: str\n    62→    action: str  # e.g. \"agent_spawned\", \"task_completed\", \"pulse\", \"circuit_break\"\n    63→    state: str = \"active\"\n    64→    parent_id: Optional[str] = None\n    65→    fitness: Optional[FitnessScore] = None\n    66→    files_changed: list[str] = Field(default_factory=list)\n    67→    metadata: dict[str, Any] = Field(default_factory=dict)\n    68→\n    69→\n    70→# ---------------------------------------------------------------------------\n    71→# Store\n    72→# ---------------------------------------------------------------------------\n    73→\n    74→_DEFAULT_TRACE_PATH = Path.home() / \".dharma\" / \"traces\"\n    75→\n    76→\n    77→class TraceStore:\n    78→    \"\"\"File-backed trace store with history, archive, and pattern directories.\n    79→\n    80→    All public methods are async.  File I/O is delegated to\n    81→    ``asyncio.to_thread`` so the event loop never blocks.\n    82→    \"\"\"\n    83→\n    84→    def __init__(self, base_path: Path | None = None) -> None:\n    85→        self.base_path: Path = base_path or _DEFAULT_TRACE_PATH\n    86→        self.history_path: Path = self.base_path / \"history\"\n    87→        self.archive_path: Path = self.base_path / \"archive\"\n    88→        self.patterns_path: Path = self.base_path / \"patterns\"\n    89→\n    90→    # -- lifecycle -----------------------------------------------------------\n    91→\n    92→    async def init(self) -> None:\n    93→        \"\"\"Create directory structure on disk.\"\"\"\n    94→        for d in (self.history_path, self.archive_path, self.patterns_path):\n    95→            await asyncio.to_thread(d.mkdir, parents=True, exist_ok=True)\n    96→\n    97→    # -- write ---------------------------------------------------------------\n    98→\n    99→    async def log_entry(self, entry: TraceEntry) -> str:\n   100→        \"\"\"Persist *entry* to ``history/{entry.id}.json`` and return the id.\"\"\"\n   101→        dest = self.history_path / f\"{entry.id}.json\"\n   102→        data = json.loads(entry.model_dump_json())\n   103→        await asyncio.to_thread(atomic_write_json, dest, data)\n   104→        return entry.id\n   105→\n   106→    # -- read ----------------------------------------------------------------\n   107→\n   108→    async def get_entry(self, entry_id: str) -> TraceEntry | None:\n   109→        \"\"\"Load a single entry by id, or ``None`` if not found.\"\"\"\n   110→        path = self.history_path / f\"{entry_id}.json\"\n   111→        return await asyncio.to_thread(self._read_entry, path)\n   112→\n   113→    async def get_recent(self, limit: int = 20) -> list[TraceEntry]:\n   114→        \"\"\"Return the most recent entries sorted by timestamp descending.\"\"\"\n   115→        entries = await asyncio.to_thread(self._read_all_history)\n   116→        entries.sort(key=lambda e: e.timestamp, reverse=True)\n   117→        return entries[:limit]\n   118→\n   119→    async def get_lineage(self, entry_id: str) -> list[TraceEntry]:\n   120→        \"\"\"Walk the ``parent_id`` chain from *entry_id* back to root.\n   121→\n   122→        Returns a list ordered from the given entry back to the oldest\n   123→        ancestor (child-first).  Returns an empty list if *entry_id* is\n   124→        not found.\n   125→        \"\"\"\n   126→        lineage: list[TraceEntry] = []\n   127→        seen: set[str] = set()\n   128→        current_id: str | None = entry_id\n   129→\n   130→        while current_id and current_id not in seen:\n   131→            entry = await self.get_entry(current_id)\n   132→            if entry is None:\n   133→                break\n   134→            lineage.append(entry)\n   135→            seen.add(current_id)\n   136→            current_id = entry.parent_id\n   137→\n   138→        return lineage\n   139→\n   140→    # -- maintenance ---------------------------------------------------------\n   141→\n   142→    async def archive_old(self, max_age_hours: int = 24) -> int:\n   143→        \"\"\"Move entries older than *max_age_hours* to the archive directory.\n   144→\n   145→        Returns the number of entries archived.\n   146→        \"\"\"\n   147→        return await asyncio.to_thread(self._archive_old_sync, max_age_hours)\n   148→\n   149→    # -- private sync helpers ------------------------------------------------\n   150→\n   151→    @staticmethod\n   152→    def _read_entry(path: Path) -> TraceEntry | None:\n   153→        if not path.exists():\n   154→            return None\n   155→        try:\n   156→            with open(path) as f:\n   157→                data = json.load(f)\n   158→            return TraceEntry.model_validate(data)\n   159→        except (json.JSONDecodeError, ValueError, KeyError):\n   160→            return None\n   161→\n   162→    def _read_all_history(self) -> list[TraceEntry]:\n   163→        if not self.history_path.exists():\n   164→            return []\n   165→        entries: list[TraceEntry] = []\n   166→        for fp in self.history_path.glob(\"*.json\"):\n   167→            entry = self._read_entry(fp)\n   168→            if entry is not None:\n   169→                entries.append(entry)\n   170→        return entries\n   171→\n   172→    def _archive_old_sync(self, max_age_hours: int) -> int:\n   173→        if not self.history_path.exists():\n   174→            return 0\n   175→        now = datetime.now(timezone.utc)\n   176→        count = 0\n   177→        for fp in list(self.history_path.glob(\"*.json\")):\n   178→            entry = self._read_entry(fp)\n   179→            if entry is None:\n   180→                continue\n   181→            age_hours = (now - entry.timestamp).total_seconds() / 3600\n   182→            if age_hours > max_age_hours:\n   183→                dest = self.archive_path / fp.name\n   184→                self.archive_path.mkdir(parents=True, exist_ok=True)\n   185→                os.replace(fp, dest)\n   186→                count += 1\n   187→        return count\n   188→"}]},"uuid":"89efd03f-220a-48b0-8af5-3aca6c5f41b8","timestamp":"2026-03-15T13:47:03.160Z","sourceToolAssistantUUID":"302fee48-0e2c-432b-93af-5ed2b5c76380","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
