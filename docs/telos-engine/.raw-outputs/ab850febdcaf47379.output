{"parentUuid":"fdc6a4e7-adc2-420e-970b-fb97cfddf0e7","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01MeumKyn8jgv6cPdDKnUnL4","toolUseID":"toolu_01MeumKyn8jgv6cPdDKnUnL4","timestamp":"2026-03-15T13:46:52.743Z","uuid":"6857681c-d2ad-4ada-901d-fa14e6f0b935","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"a81dce86-2f27-4bd5-9622-7911532e53b6","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MeumKyn8jgv6cPdDKnUnL4","type":"tool_result","content":"<persisted-output>\nOutput too large (62.2KB). Full output saved to: /Users/dhyana/.claude/projects/-Users-dhyana/2ea96bb4-afee-473b-8609-a3975acc2c75/tool-results/toolu_01MeumKyn8jgv6cPdDKnUnL4.txt\n\nPreview (first 2KB):\n     1→\"\"\"Typed Ontology Layer — The Foundation of dharma_swarm.\n     2→\n     3→The Ontology is not a feature of the platform — it IS the platform.\n     4→\n     5→Palantir built this pattern for supply chains and kill chains.\n     6→We take the engineering and reforge it for Jagat Kalyan.\n     7→\n     8→Architecture:\n     9→  ObjectType   -> defines what CAN exist          (schema)\n    10→  OntologyObj  -> a specific INSTANCE              (data)\n    11→  LinkDef      -> how types relate                  (schema)\n    12→  Link         -> a specific relationship           (data)\n    13→  ActionDef    -> what you can DO                   (schema)\n    14→  ActionExec   -> a record of what was DONE         (audit)\n    15→  SecurityPolicy -> who can see/modify              (access control)\n    16→  OntologyRegistry -> central catalog of everything (the brain)\n    17→\n    18→Everything flows through the ontology:\n    19→- LLMs receive typed object context, not raw text (OAG > RAG)\n    20→- Mutations go through typed Actions (auditable, reversible, gated)\n    21→- Links are explicit and bidirectional (not implicit foreign keys)\n    22→- Security is per-object-type and per-field\n    23→- The act of defining IS witnessing (v7 rule 5)\n    24→\n    25→Inspired by Palantir Foundry, NATO JC3IEDM, Schema.org, GAIA Ledger.\n    26→Backward-compatible with existing Entity/ONTOLOGY API.\n    27→\"\"\"\n    28→\n    29→from __future__ import annotations\n    30→\n    31→import json\n    32→import logging\n    33→from dataclasses import dataclass\n    34→from datetime import date, datetime, timezone\n    35→from enum import Enum\n    36→from pathlib import Path\n    37→from typing import Any, Callable\n    38→\n    39→from pydantic import BaseModel, Field\n    40→\n    41→logger = logging.getLogger(__name__)\n    42→\n    43→\n    44→def _utc_now() -> datetime:\n    45→    return datetime.now(timezone.utc)\n    46→\n    47→\n    48→def _new_id() -> str:\n    49→    from uuid import uuid4\n...\n</persisted-output>"}]},"uuid":"80e6d560-e44d-4f2d-a86b-d58aca41f4ee","timestamp":"2026-03-15T13:46:52.743Z","sourceToolAssistantUUID":"a81dce86-2f27-4bd5-9622-7911532e53b6","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"80e6d560-e44d-4f2d-a86b-d58aca41f4ee","isSidechain":true,"agentId":"ab850febdcaf47379","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01LzNjQXPFRBDbwfUZsvjgDC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016Q4spBtq8WE5w1cVJ1K6au","name":"Read","input":{"file_path":"/Users/dhyana/dharma_swarm/dharma_swarm/temporal_graph.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":5,"cache_creation_input_tokens":698,"cache_read_input_tokens":16807,"cache_creation":{"ephemeral_5m_input_tokens":698,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"}},"requestId":"req_011CZ4yA18mT8K1xYgCj6TZU","type":"assistant","uuid":"da64b098-c77d-43aa-83ba-350a2f259511","timestamp":"2026-03-15T13:46:52.820Z","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"da64b098-c77d-43aa-83ba-350a2f259511","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PreToolUse","hookName":"PreToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"pre:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"toolUseID":"toolu_016Q4spBtq8WE5w1cVJ1K6au","parentToolUseID":"toolu_016Q4spBtq8WE5w1cVJ1K6au","uuid":"5746fb28-91c9-41a8-9548-fc6cff21c9ec","timestamp":"2026-03-15T13:46:52.820Z","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"5746fb28-91c9-41a8-9548-fc6cff21c9ec","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_016Q4spBtq8WE5w1cVJ1K6au","toolUseID":"toolu_016Q4spBtq8WE5w1cVJ1K6au","timestamp":"2026-03-15T13:46:52.826Z","uuid":"d9056192-78d9-448e-92bb-d9a1bcd16152","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"d9056192-78d9-448e-92bb-d9a1bcd16152","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_016Q4spBtq8WE5w1cVJ1K6au","toolUseID":"toolu_016Q4spBtq8WE5w1cVJ1K6au","timestamp":"2026-03-15T13:46:52.826Z","uuid":"df189543-cdef-4344-acf2-6740255cbd30","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"da64b098-c77d-43aa-83ba-350a2f259511","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016Q4spBtq8WE5w1cVJ1K6au","type":"tool_result","content":"     1→\"\"\"Temporal Knowledge Graph -- tracks idea lineage over time.\n     2→\n     3→Nodes: concept mentions (keywords extracted from shared notes)\n     4→Edges: co-occurrence in same note\n     5→Time: each node has first_seen, last_seen, frequency\n     6→\n     7→Enables: lineage queries, emerging/decaying concept detection,\n     8→co-occurrence analysis for cross-pollination insights.\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→import itertools\n    14→import logging\n    15→import re\n    16→import sqlite3\n    17→from datetime import datetime, timedelta, timezone\n    18→from pathlib import Path\n    19→\n    20→from pydantic import BaseModel, Field\n    21→\n    22→from dharma_swarm.models import _utc_now\n    23→\n    24→logger = logging.getLogger(__name__)\n    25→\n    26→# ---------------------------------------------------------------------------\n    27→# Stopwords -- English core + domain noise terms that carry no concept signal\n    28→# ---------------------------------------------------------------------------\n    29→\n    30→_STOPWORDS: frozenset[str] = frozenset({\n    31→    # English function words\n    32→    \"a\", \"an\", \"the\", \"is\", \"are\", \"was\", \"were\", \"be\", \"been\", \"being\",\n    33→    \"have\", \"has\", \"had\", \"do\", \"does\", \"did\", \"will\", \"would\", \"shall\",\n    34→    \"should\", \"may\", \"might\", \"must\", \"can\", \"could\", \"am\", \"it\", \"its\",\n    35→    \"in\", \"on\", \"at\", \"to\", \"for\", \"of\", \"with\", \"by\", \"from\", \"as\",\n    36→    \"into\", \"through\", \"during\", \"before\", \"after\", \"above\", \"below\",\n    37→    \"between\", \"out\", \"off\", \"over\", \"under\", \"again\", \"further\", \"then\",\n    38→    \"once\", \"here\", \"there\", \"when\", \"where\", \"why\", \"how\", \"all\", \"each\",\n    39→    \"every\", \"both\", \"few\", \"more\", \"most\", \"other\", \"some\", \"such\", \"no\",\n    40→    \"nor\", \"not\", \"only\", \"own\", \"same\", \"so\", \"than\", \"too\", \"very\",\n    41→    \"just\", \"but\", \"and\", \"or\", \"if\", \"while\", \"about\", \"up\", \"me\", \"my\",\n    42→    \"i\", \"we\", \"you\", \"he\", \"she\", \"they\", \"them\", \"his\", \"her\", \"our\",\n    43→    \"your\", \"this\", \"that\", \"these\", \"those\", \"what\", \"which\", \"who\",\n    44→    \"whom\", \"also\", \"like\", \"well\", \"back\", \"even\", \"still\", \"way\",\n    45→    # Domain noise -- appear everywhere, carry no concept signal\n    46→    \"file\", \"path\", \"note\", \"notes\", \"line\", \"lines\", \"found\", \"see\",\n    47→    \"used\", \"using\", \"make\", \"made\", \"need\", \"done\", \"says\", \"said\",\n    48→    \"true\", \"false\", \"none\", \"null\", \"data\", \"text\", \"list\", \"item\",\n    49→    \"type\", \"name\", \"work\", \"working\", \"result\", \"results\", \"output\",\n    50→})\n    51→\n    52→\n    53→# ---------------------------------------------------------------------------\n    54→# Pydantic models\n    55→# ---------------------------------------------------------------------------\n    56→\n    57→class ConceptNode(BaseModel):\n    58→    \"\"\"A concept in the temporal graph.\"\"\"\n    59→\n    60→    term: str\n    61→    first_seen: datetime\n    62→    last_seen: datetime\n    63→    frequency: int\n    64→    sources: list[str] = Field(default_factory=list)\n    65→\n    66→\n    67→class ConceptEdge(BaseModel):\n    68→    \"\"\"Co-occurrence edge between two concepts.\"\"\"\n    69→\n    70→    term_a: str\n    71→    term_b: str\n    72→    weight: int\n    73→    first_co_occurrence: datetime\n    74→    last_co_occurrence: datetime\n    75→\n    76→\n    77→# ---------------------------------------------------------------------------\n    78→# Schema\n    79→# ---------------------------------------------------------------------------\n    80→\n    81→_SCHEMA = \"\"\"\\\n    82→CREATE TABLE IF NOT EXISTS concepts (\n    83→    term TEXT PRIMARY KEY,\n    84→    first_seen TEXT NOT NULL,\n    85→    last_seen TEXT NOT NULL,\n    86→    frequency INTEGER NOT NULL DEFAULT 0\n    87→);\n    88→CREATE TABLE IF NOT EXISTS concept_sources (\n    89→    term TEXT NOT NULL,\n    90→    source TEXT NOT NULL,\n    91→    seen_at TEXT NOT NULL,\n    92→    UNIQUE(term, source)\n    93→);\n    94→CREATE INDEX IF NOT EXISTS idx_cs_term ON concept_sources(term);\n    95→CREATE INDEX IF NOT EXISTS idx_cs_seen ON concept_sources(seen_at);\n    96→CREATE TABLE IF NOT EXISTS co_occurrences (\n    97→    term_a TEXT NOT NULL,\n    98→    term_b TEXT NOT NULL,\n    99→    weight INTEGER NOT NULL DEFAULT 0,\n   100→    first_co TEXT NOT NULL,\n   101→    last_co TEXT NOT NULL,\n   102→    PRIMARY KEY (term_a, term_b)\n   103→);\n   104→CREATE INDEX IF NOT EXISTS idx_co_weight ON co_occurrences(weight DESC);\n   105→CREATE INDEX IF NOT EXISTS idx_co_last ON co_occurrences(last_co);\n   106→\"\"\"\n   107→\n   108→\n   109→# ---------------------------------------------------------------------------\n   110→# Core graph\n   111→# ---------------------------------------------------------------------------\n   112→\n   113→class TemporalKnowledgeGraph:\n   114→    \"\"\"Tracks concept appearance, development, and connection over time.\n   115→\n   116→    Uses SQLite for persistence at ``~/.dharma/db/temporal_graph.db``.\n   117→\n   118→    Tables:\n   119→        concepts       -- term (PK), first_seen, last_seen, frequency\n   120→        concept_sources -- term, source (file path), seen_at\n   121→        co_occurrences -- (term_a, term_b) PK, weight, first_co, last_co\n   122→    \"\"\"\n   123→\n   124→    def __init__(self, db_path: Path | None = None) -> None:\n   125→        self.db_path = db_path or (Path.home() / \".dharma\" / \"db\" / \"temporal_graph.db\")\n   126→        self._init_db()\n   127→\n   128→    # -- Setup ---------------------------------------------------------------\n   129→\n   130→    def _init_db(self) -> None:\n   131→        \"\"\"Create tables if they don't exist.\"\"\"\n   132→        self.db_path.parent.mkdir(parents=True, exist_ok=True)\n   133→        with self._connect() as conn:\n   134→            conn.executescript(_SCHEMA)\n   135→\n   136→    def _connect(self) -> sqlite3.Connection:\n   137→        \"\"\"Return a connection with row_factory set.\"\"\"\n   138→        conn = sqlite3.connect(str(self.db_path))\n   139→        conn.row_factory = sqlite3.Row\n   140→        conn.execute(\"PRAGMA journal_mode=WAL\")\n   141→        return conn\n   142→\n   143→    # -- Concept extraction --------------------------------------------------\n   144→\n   145→    def _extract_concepts(self, text: str, min_length: int = 4) -> list[str]:\n   146→        \"\"\"Extract meaningful concept terms from text.\n   147→\n   148→        Captures both single words and compound terms connected by underscores\n   149→        or hyphens (e.g. ``activation_patching``, ``value-space``).\n   150→\n   151→        Args:\n   152→            text: Raw note content.\n   153→            min_length: Minimum character length for a term to qualify.\n   154→\n   155→        Returns:\n   156→            Deduplicated list of lowercase concept terms.\n   157→        \"\"\"\n   158→        # First pass: find compound terms (underscore/hyphen connected)\n   159→        compound_pattern = re.compile(r\"[a-zA-Z][a-zA-Z0-9]*(?:[_-][a-zA-Z][a-zA-Z0-9]*)+\")\n   160→        compounds = {m.group().lower().replace(\"-\", \"_\") for m in compound_pattern.finditer(text)}\n   161→\n   162→        # Second pass: single words (alphanumeric, no surrounding underscores)\n   163→        word_pattern = re.compile(r\"\\b[a-zA-Z][a-zA-Z0-9]*\\b\")\n   164→        singles = {m.group().lower() for m in word_pattern.finditer(text)}\n   165→\n   166→        # Merge, filter by length and stopwords\n   167→        all_terms = compounds | singles\n   168→        return sorted(\n   169→            t for t in all_terms\n   170→            if len(t) >= min_length and t not in _STOPWORDS\n   171→        )\n   172→\n   173→    # -- Ingestion -----------------------------------------------------------\n   174→\n   175→    def ingest_note(self, path: Path, content: str | None = None) -> int:\n   176→        \"\"\"Ingest a single note file into the graph.\n   177→\n   178→        Extracts concepts, updates frequencies, records co-occurrences.\n   179→\n   180→        Args:\n   181→            path: Path to the note file.\n   182→            content: Optional pre-read content (avoids re-reading).\n   183→\n   184→        Returns:\n   185→            Number of concepts found in the note.\n   186→        \"\"\"\n   187→        path = Path(path)\n   188→        if content is None:\n   189→            try:\n   190→                content = path.read_text(encoding=\"utf-8\", errors=\"replace\")\n   191→            except OSError as exc:\n   192→                logger.warning(\"Cannot read %s: %s\", path, exc)\n   193→                return 0\n   194→\n   195→        concepts = self._extract_concepts(content)\n   196→        if not concepts:\n   197→            return 0\n   198→\n   199→        # Timestamp from file mtime, falling back to now\n   200→        try:\n   201→            mtime = datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc)\n   202→        except OSError:\n   203→            mtime = _utc_now()\n   204→\n   205→        ts_iso = mtime.isoformat()\n   206→        source_str = str(path)\n   207→\n   208→        with self._connect() as conn:\n   209→            for term in concepts:\n   210→                # Upsert concept\n   211→                conn.execute(\n   212→                    \"\"\"INSERT INTO concepts (term, first_seen, last_seen, frequency)\n   213→                       VALUES (?, ?, ?, 1)\n   214→                       ON CONFLICT(term) DO UPDATE SET\n   215→                           last_seen = MAX(last_seen, excluded.last_seen),\n   216→                           first_seen = MIN(first_seen, excluded.first_seen),\n   217→                           frequency = frequency + 1\"\"\",\n   218→                    (term, ts_iso, ts_iso),\n   219→                )\n   220→                # Record source\n   221→                conn.execute(\n   222→                    \"\"\"INSERT INTO concept_sources (term, source, seen_at)\n   223→                       VALUES (?, ?, ?)\n   224→                       ON CONFLICT(term, source) DO UPDATE SET\n   225→                           seen_at = MAX(seen_at, excluded.seen_at)\"\"\",\n   226→                    (term, source_str, ts_iso),\n   227→                )\n   228→\n   229→            # Co-occurrence edges: all pairs, canonical ordering (a < b)\n   230→            for a, b in itertools.combinations(concepts, 2):\n   231→                ta, tb = (a, b) if a < b else (b, a)\n   232→                conn.execute(\n   233→                    \"\"\"INSERT INTO co_occurrences (term_a, term_b, weight, first_co, last_co)\n   234→                       VALUES (?, ?, 1, ?, ?)\n   235→                       ON CONFLICT(term_a, term_b) DO UPDATE SET\n   236→                           weight = weight + 1,\n   237→                           first_co = MIN(first_co, excluded.first_co),\n   238→                           last_co = MAX(last_co, excluded.last_co)\"\"\",\n   239→                    (ta, tb, ts_iso, ts_iso),\n   240→                )\n   241→\n   242→        return len(concepts)\n   243→\n   244→    def build_from_notes(self, notes_dir: Path | None = None) -> dict[str, int]:\n   245→        \"\"\"Build/update graph from all shared notes.\n   246→\n   247→        Default directory: ``~/.dharma/shared/``\n   248→\n   249→        Returns:\n   250→            Dict with ``notes_processed``, ``concepts_found``, ``edges_created``.\n   251→        \"\"\"\n   252→        notes_dir = notes_dir or (Path.home() / \".dharma\" / \"shared\")\n   253→        if not notes_dir.is_dir():\n   254→            logger.info(\"Notes directory %s does not exist, nothing to build.\", notes_dir)\n   255→            return {\"notes_processed\": 0, \"concepts_found\": 0, \"edges_created\": 0}\n   256→\n   257→        note_files = sorted(notes_dir.glob(\"*.md\"))\n   258→        total_concepts = 0\n   259→        for nf in note_files:\n   260→            total_concepts += self.ingest_note(nf)\n   261→\n   262→        # Count totals from DB\n   263→        with self._connect() as conn:\n   264→            concept_count = conn.execute(\"SELECT COUNT(*) FROM concepts\").fetchone()[0]\n   265→            edge_count = conn.execute(\"SELECT COUNT(*) FROM co_occurrences\").fetchone()[0]\n   266→\n   267→        logger.info(\n   268→            \"Built graph: %d notes, %d concepts, %d edges\",\n   269→            len(note_files), concept_count, edge_count,\n   270→        )\n   271→        return {\n   272→            \"notes_processed\": len(note_files),\n   273→            \"concepts_found\": concept_count,\n   274→            \"edges_created\": edge_count,\n   275→        }\n   276→\n   277→    # -- Queries -------------------------------------------------------------\n   278→\n   279→    def lineage(self, concept: str, limit: int = 20) -> list[dict]:\n   280→        \"\"\"Trace the lineage of a concept through time.\n   281→\n   282→        Args:\n   283→            concept: The term to trace.\n   284→            limit: Maximum number of source entries to return.\n   285→\n   286→        Returns:\n   287→            List of ``{source, seen_at}`` dicts ordered chronologically.\n   288→        \"\"\"\n   289→        concept = concept.lower().replace(\"-\", \"_\")\n   290→        with self._connect() as conn:\n   291→            rows = conn.execute(\n   292→                \"\"\"SELECT source, seen_at FROM concept_sources\n   293→                   WHERE term = ?\n   294→                   ORDER BY seen_at ASC\n   295→                   LIMIT ?\"\"\",\n   296→                (concept, limit),\n   297→            ).fetchall()\n   298→        return [{\"source\": r[\"source\"], \"seen_at\": r[\"seen_at\"]} for r in rows]\n   299→\n   300→    def co_occurring(self, concept: str, limit: int = 10) -> list[dict]:\n   301→        \"\"\"Find concepts that frequently co-occur with the given concept.\n   302→\n   303→        Args:\n   304→            concept: The term to find co-occurrences for.\n   305→            limit: Maximum number of results.\n   306→\n   307→        Returns:\n   308→            List of ``{term, weight, first_co, last_co}`` ordered by weight desc.\n   309→        \"\"\"\n   310→        concept = concept.lower().replace(\"-\", \"_\")\n   311→        with self._connect() as conn:\n   312→            rows = conn.execute(\n   313→                \"\"\"SELECT\n   314→                       CASE WHEN term_a = ? THEN term_b ELSE term_a END AS partner,\n   315→                       weight, first_co, last_co\n   316→                   FROM co_occurrences\n   317→                   WHERE term_a = ? OR term_b = ?\n   318→                   ORDER BY weight DESC\n   319→                   LIMIT ?\"\"\",\n   320→                (concept, concept, concept, limit),\n   321→            ).fetchall()\n   322→        return [\n   323→            {\n   324→                \"term\": r[\"partner\"],\n   325→                \"weight\": r[\"weight\"],\n   326→                \"first_co\": r[\"first_co\"],\n   327→                \"last_co\": r[\"last_co\"],\n   328→            }\n   329→            for r in rows\n   330→        ]\n   331→\n   332→    def emerging(self, window_days: int = 7, min_freq: int = 2) -> list[ConceptNode]:\n   333→        \"\"\"Find concepts that appeared or accelerated recently.\n   334→\n   335→        A concept is *emerging* if its ``first_seen`` is within\n   336→        ``window_days`` of now and it has at least ``min_freq`` mentions.\n   337→\n   338→        Args:\n   339→            window_days: Lookback window in days.\n   340→            min_freq: Minimum frequency to qualify.\n   341→\n   342→        Returns:\n   343→            List of :class:`ConceptNode` sorted by frequency descending.\n   344→        \"\"\"\n   345→        cutoff = (_utc_now() - timedelta(days=window_days)).isoformat()\n   346→        with self._connect() as conn:\n   347→            rows = conn.execute(\n   348→                \"\"\"SELECT c.term, c.first_seen, c.last_seen, c.frequency\n   349→                   FROM concepts c\n   350→                   WHERE c.first_seen >= ? AND c.frequency >= ?\n   351→                   ORDER BY c.frequency DESC\"\"\",\n   352→                (cutoff, min_freq),\n   353→            ).fetchall()\n   354→\n   355→        results: list[ConceptNode] = []\n   356→        for r in rows:\n   357→            sources = self._sources_for(r[\"term\"])\n   358→            results.append(ConceptNode(\n   359→                term=r[\"term\"],\n   360→                first_seen=datetime.fromisoformat(r[\"first_seen\"]),\n   361→                last_seen=datetime.fromisoformat(r[\"last_seen\"]),\n   362→                frequency=r[\"frequency\"],\n   363→                sources=sources,\n   364→            ))\n   365→        return results\n   366→\n   367→    def decaying(self, window_days: int = 14, min_historical_freq: int = 3) -> list[ConceptNode]:\n   368→        \"\"\"Find concepts that were active but have not appeared recently.\n   369→\n   370→        A concept is *decaying* if its ``last_seen`` is older than\n   371→        ``window_days`` ago and its historical ``frequency`` meets the\n   372→        minimum threshold.\n   373→\n   374→        Args:\n   375→            window_days: How many days of silence qualifies as decay.\n   376→            min_historical_freq: Minimum past frequency (filters noise).\n   377→\n   378→        Returns:\n   379→            List of :class:`ConceptNode` sorted by frequency descending.\n   380→        \"\"\"\n   381→        cutoff = (_utc_now() - timedelta(days=window_days)).isoformat()\n   382→        with self._connect() as conn:\n   383→            rows = conn.execute(\n   384→                \"\"\"SELECT c.term, c.first_seen, c.last_seen, c.frequency\n   385→                   FROM concepts c\n   386→                   WHERE c.last_seen < ? AND c.frequency >= ?\n   387→                   ORDER BY c.frequency DESC\"\"\",\n   388→                (cutoff, min_historical_freq),\n   389→            ).fetchall()\n   390→\n   391→        results: list[ConceptNode] = []\n   392→        for r in rows:\n   393→            sources = self._sources_for(r[\"term\"])\n   394→            results.append(ConceptNode(\n   395→                term=r[\"term\"],\n   396→                first_seen=datetime.fromisoformat(r[\"first_seen\"]),\n   397→                last_seen=datetime.fromisoformat(r[\"last_seen\"]),\n   398→                frequency=r[\"frequency\"],\n   399→                sources=sources,\n   400→            ))\n   401→        return results\n   402→\n   403→    def hot_pairs(self, window_days: int = 7, limit: int = 10) -> list[ConceptEdge]:\n   404→        \"\"\"Find the most active concept pairs in the recent window.\n   405→\n   406→        Args:\n   407→            window_days: Lookback window in days.\n   408→            limit: Maximum number of pairs to return.\n   409→\n   410→        Returns:\n   411→            List of :class:`ConceptEdge` sorted by weight descending.\n   412→        \"\"\"\n   413→        cutoff = (_utc_now() - timedelta(days=window_days)).isoformat()\n   414→        with self._connect() as conn:\n   415→            rows = conn.execute(\n   416→                \"\"\"SELECT term_a, term_b, weight, first_co, last_co\n   417→                   FROM co_occurrences\n   418→                   WHERE last_co >= ?\n   419→                   ORDER BY weight DESC\n   420→                   LIMIT ?\"\"\",\n   421→                (cutoff, limit),\n   422→            ).fetchall()\n   423→        return [\n   424→            ConceptEdge(\n   425→                term_a=r[\"term_a\"],\n   426→                term_b=r[\"term_b\"],\n   427→                weight=r[\"weight\"],\n   428→                first_co_occurrence=datetime.fromisoformat(r[\"first_co\"]),\n   429→                last_co_occurrence=datetime.fromisoformat(r[\"last_co\"]),\n   430→            )\n   431→            for r in rows\n   432→        ]\n   433→\n   434→    def summary(self) -> str:\n   435→        \"\"\"Human-readable summary of the knowledge graph state.\"\"\"\n   436→        with self._connect() as conn:\n   437→            n_concepts = conn.execute(\"SELECT COUNT(*) FROM concepts\").fetchone()[0]\n   438→            n_edges = conn.execute(\"SELECT COUNT(*) FROM co_occurrences\").fetchone()[0]\n   439→            n_sources = conn.execute(\n   440→                \"SELECT COUNT(DISTINCT source) FROM concept_sources\"\n   441→            ).fetchone()[0]\n   442→\n   443→            top_concepts = conn.execute(\n   444→                \"SELECT term, frequency FROM concepts ORDER BY frequency DESC LIMIT 5\"\n   445→            ).fetchall()\n   446→\n   447→            top_edges = conn.execute(\n   448→                \"SELECT term_a, term_b, weight FROM co_occurrences ORDER BY weight DESC LIMIT 5\"\n   449→            ).fetchall()\n   450→\n   451→        lines = [\n   452→            f\"Temporal Knowledge Graph: {n_concepts} concepts, {n_edges} edges, {n_sources} sources\",\n   453→            \"\",\n   454→            \"Top concepts by frequency:\",\n   455→        ]\n   456→        for r in top_concepts:\n   457→            lines.append(f\"  {r['term']}: {r['frequency']}\")\n   458→\n   459→        lines.append(\"\")\n   460→        lines.append(\"Strongest co-occurrences:\")\n   461→        for r in top_edges:\n   462→            lines.append(f\"  {r['term_a']} + {r['term_b']}: {r['weight']}\")\n   463→\n   464→        return \"\\n\".join(lines)\n   465→\n   466→    # -- Internal helpers ----------------------------------------------------\n   467→\n   468→    def _sources_for(self, term: str) -> list[str]:\n   469→        \"\"\"Return distinct source paths for a concept term.\"\"\"\n   470→        with self._connect() as conn:\n   471→            rows = conn.execute(\n   472→                \"SELECT DISTINCT source FROM concept_sources WHERE term = ?\",\n   473→                (term,),\n   474→            ).fetchall()\n   475→        return [r[\"source\"] for r in rows]\n   476→"}]},"uuid":"879ea235-40b2-4327-864c-a50cb3f033f6","timestamp":"2026-03-15T13:46:52.825Z","sourceToolAssistantUUID":"da64b098-c77d-43aa-83ba-350a2f259511","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
