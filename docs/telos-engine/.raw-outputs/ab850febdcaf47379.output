{"parentUuid":"0381debf-2c46-4e34-b0b2-27347b4ff977","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NEQiujMDpNYG2XjuF19KHV","type":"tool_result","content":"     1→\"\"\"Typed decision ontology and deterministic decision-quality scoring.\n     2→\n     3→This module models decisions as first-class objects with evidence, objections,\n     4→reviews, and outcome metrics. The scoring is intentionally deterministic and\n     5→artifact-backed so DGC can judge decision quality using structure, grounding,\n     6→and traceability instead of prose style alone.\n     7→\"\"\"\n     8→\n     9→from __future__ import annotations\n    10→\n    11→import uuid\n    12→from datetime import datetime, timezone\n    13→from enum import Enum\n    14→\n    15→from typing import Any\n    16→\n    17→from pydantic import BaseModel, Field\n    18→\n    19→from dharma_swarm.decision_router import DecisionInput\n    20→from dharma_swarm.steelman_gate import SteelmanCheck, check_steelman\n    21→\n    22→\n    23→def _utc_now() -> datetime:\n    24→    return datetime.now(timezone.utc)\n    25→\n    26→\n    27→def _new_id() -> str:\n    28→    return uuid.uuid4().hex[:12]\n    29→\n    30→\n    31→def _clamp01(value: float) -> float:\n    32→    return max(0.0, min(1.0, float(value)))\n    33→\n    34→\n    35→def _ratio(numerator: int, denominator: int) -> float:\n    36→    if denominator <= 0:\n    37→        return 0.0\n    38→    return _clamp01(numerator / denominator)\n    39→\n    40→\n    41→class DecisionState(str, Enum):\n    42→    DRAFT = \"draft\"\n    43→    PROPOSED = \"proposed\"\n    44→    APPROVED = \"approved\"\n    45→    EXECUTING = \"executing\"\n    46→    OBSERVED = \"observed\"\n    47→    CLOSED = \"closed\"\n    48→\n    49→\n    50→class EvidenceKind(str, Enum):\n    51→    PRIMARY_SOURCE = \"primary_source\"\n    52→    REPO_FACT = \"repo_fact\"\n    53→    TEST = \"test\"\n    54→    BENCHMARK = \"benchmark\"\n    55→    RUNTIME = \"runtime\"\n    56→    USER_CONSTRAINT = \"user_constraint\"\n    57→    MODEL_OUTPUT = \"model_output\"\n    58→\n    59→\n    60→class ChallengeSeverity(str, Enum):\n    61→    LOW = \"low\"\n    62→    MEDIUM = \"medium\"\n    63→    HIGH = \"high\"\n    64→    CRITICAL = \"critical\"\n    65→\n    66→\n    67→class ReviewVerdict(str, Enum):\n    68→    PASS = \"pass\"\n    69→    WARN = \"warn\"\n    70→    FAIL = \"fail\"\n    71→\n    72→\n    73→class DecisionQualityVerdict(str, Enum):\n    74→    FRAGILE = \"fragile\"\n    75→    DEFENSIBLE = \"defensible\"\n    76→    AUDIT_READY = \"audit_ready\"\n    77→\n    78→\n    79→class DecisionContext(BaseModel):\n    80→    mission: str\n    81→    owner: str\n    82→    time_horizon: str = \"\"\n    83→    domains: list[str] = Field(default_factory=list)\n    84→    constraints: list[str] = Field(default_factory=list)\n    85→    assumptions: list[str] = Field(default_factory=list)\n    86→    risk_score: float = Field(default=0.5, ge=0.0, le=1.0)\n    87→    uncertainty: float = Field(default=0.5, ge=0.0, le=1.0)\n    88→    novelty: float = Field(default=0.3, ge=0.0, le=1.0)\n    89→    urgency: float = Field(default=0.5, ge=0.0, le=1.0)\n    90→    expected_impact: float = Field(default=0.5, ge=0.0, le=1.0)\n    91→    reversible: bool = True\n    92→\n    93→\n    94→class DecisionOption(BaseModel):\n    95→    option_id: str = Field(default_factory=_new_id)\n    96→    title: str\n    97→    description: str = \"\"\n    98→    selected: bool = False\n    99→    tradeoffs: list[str] = Field(default_factory=list)\n   100→\n   101→\n   102→class DecisionClaim(BaseModel):\n   103→    claim_id: str = Field(default_factory=_new_id)\n   104→    text: str\n   105→    supports_option_id: str = \"\"\n   106→    evidence_refs: list[str] = Field(default_factory=list)\n   107→    confidence: float = Field(default=0.5, ge=0.0, le=1.0)\n   108→\n   109→\n   110→class DecisionEvidence(BaseModel):\n   111→    evidence_id: str = Field(default_factory=_new_id)\n   112→    kind: EvidenceKind\n   113→    summary: str\n   114→    source_uri: str = \"\"\n   115→    confidence: float = Field(default=0.5, ge=0.0, le=1.0)\n   116→    verified: bool = False\n   117→    provenance_refs: list[str] = Field(default_factory=list)\n   118→\n   119→\n   120→class DecisionChallenge(BaseModel):\n   121→    challenge_id: str = Field(default_factory=_new_id)\n   122→    summary: str\n   123→    severity: ChallengeSeverity = ChallengeSeverity.MEDIUM\n   124→    source_agent: str = \"\"\n   125→    addressed: bool = False\n   126→    response: str = \"\"\n   127→\n   128→\n   129→class DecisionMetric(BaseModel):\n   130→    name: str\n   131→    baseline: str = \"\"\n   132→    target: str = \"\"\n   133→    measurement_plan: str = \"\"\n   134→    owner: str = \"\"\n   135→\n   136→\n   137→class DecisionReview(BaseModel):\n   138→    reviewer: str\n   139→    role: str = \"\"\n   140→    verdict: ReviewVerdict = ReviewVerdict.WARN\n   141→    notes: str = \"\"\n   142→\n   143→\n   144→class DecisionQualityAssessment(BaseModel):\n   145→    decision_id: str\n   146→    overall_score: float\n   147→    structural_score: float\n   148→    evidence_score: float\n   149→    challenge_score: float\n   150→    traceability_score: float\n   151→    observability_score: float\n   152→    verdict: DecisionQualityVerdict\n   153→    hard_failures: list[str] = Field(default_factory=list)\n   154→    warnings: list[str] = Field(default_factory=list)\n   155→    summary: str = \"\"\n   156→\n   157→\n   158→class DecisionRecord(BaseModel):\n   159→    decision_id: str = Field(default_factory=_new_id)\n   160→    title: str\n   161→    statement: str\n   162→    state: DecisionState = DecisionState.DRAFT\n   163→    context: DecisionContext\n   164→    options: list[DecisionOption] = Field(default_factory=list)\n   165→    claims: list[DecisionClaim] = Field(default_factory=list)\n   166→    evidence: list[DecisionEvidence] = Field(default_factory=list)\n   167→    challenges: list[DecisionChallenge] = Field(default_factory=list)\n   168→    metrics: list[DecisionMetric] = Field(default_factory=list)\n   169→    reviews: list[DecisionReview] = Field(default_factory=list)\n   170→    next_actions: list[str] = Field(default_factory=list)\n   171→    kill_criteria: list[str] = Field(default_factory=list)\n   172→    provenance_refs: list[str] = Field(default_factory=list)\n   173→    metadata: dict[str, Any] = Field(default_factory=dict)\n   174→    created_at: str = Field(default_factory=lambda: _utc_now().isoformat())\n   175→\n   176→    def selected_option(self) -> DecisionOption | None:\n   177→        for option in self.options:\n   178→            if option.selected:\n   179→                return option\n   180→        return None\n   181→\n   182→    def evaluate_quality(self) -> DecisionQualityAssessment:\n   183→        return evaluate_decision_quality(self)\n   184→\n   185→    def to_decision_input(\n   186→        self,\n   187→        *,\n   188→        assessment: DecisionQualityAssessment | None = None,\n   189→    ) -> DecisionInput:\n   190→        quality = assessment or self.evaluate_quality()\n   191→        complexity_signals = [\n   192→            _clamp01(len(self.options) / 3.0),\n   193→            _clamp01(len(self.claims) / 4.0),\n   194→            _clamp01(len(self.challenges) / 3.0),\n   195→            _clamp01(len(self.context.domains) / 3.0),\n   196→            self.context.expected_impact,\n   197→        ]\n   198→        complexity_score = sum(complexity_signals) / len(complexity_signals)\n   199→        requires_human = bool(quality.hard_failures) and self.context.expected_impact >= 0.7\n   200→\n   201→        return DecisionInput(\n   202→            action_name=self.title,\n   203→            risk_score=self.context.risk_score,\n   204→            uncertainty=max(self.context.uncertainty, 1.0 - quality.evidence_score),\n   205→            novelty=self.context.novelty,\n   206→            urgency=self.context.urgency,\n   207→            expected_impact=self.context.expected_impact,\n   208→            explicit_confidence=quality.overall_score,\n   209→            requires_human_consent=requires_human,\n   210→            privileged_action=(not self.context.reversible and self.context.expected_impact >= 0.7),\n   211→            context={\n   212→                \"complexity_score\": round(complexity_score, 4),\n   213→                \"reasoning_markers\": min(3, len(self.claims) + len(self.challenges)),\n   214→                \"broad_domain\": len(self.context.domains) >= 2,\n   215→                \"requires_verification\": quality.verdict != DecisionQualityVerdict.AUDIT_READY,\n   216→                \"has_multi_step\": len(self.next_actions) >= 2,\n   217→                \"domain_count\": len(self.context.domains),\n   218→                \"deliverable_count\": len(self.metrics) + len(self.next_actions),\n   219→                \"parallelizable_subtasks\": len(self.next_actions) >= 2,\n   220→                \"decision_quality_score\": round(quality.overall_score, 4),\n   221→                \"decision_quality_verdict\": quality.verdict.value,\n   222→                \"decision_hard_failure_count\": len(quality.hard_failures),\n   223→            },\n   224→        )\n   225→\n   226→\n   227→def evaluate_decision_quality(record: DecisionRecord) -> DecisionQualityAssessment:\n   228→    hard_failures: list[str] = []\n   229→    warnings: list[str] = []\n   230→\n   231→    selected_option = record.selected_option()\n   232→    if len(record.options) < 2:\n   233→        hard_failures.append(\"fewer_than_two_options\")\n   234→    if selected_option is None:\n   235→        hard_failures.append(\"no_selected_option\")\n   236→    if not record.evidence:\n   237→        hard_failures.append(\"no_evidence\")\n   238→    if not record.metrics:\n   239→        hard_failures.append(\"no_metrics\")\n   240→\n   241→    structural_score = _score_structure(record)\n   242→    evidence_score = _score_evidence(record)\n   243→    challenge_score, challenge_hard_failures, challenge_warnings = _score_challenges(record)\n   244→    traceability_score, trace_hard_failures, trace_warnings = _score_traceability(\n   245→        record,\n   246→        selected_option_id=selected_option.option_id if selected_option else \"\",\n   247→    )\n   248→    observability_score, observability_warnings = _score_observability(record)\n   249→\n   250→    hard_failures.extend(challenge_hard_failures)\n   251→    hard_failures.extend(trace_hard_failures)\n   252→    warnings.extend(challenge_warnings)\n   253→    warnings.extend(trace_warnings)\n   254→    warnings.extend(observability_warnings)\n   255→\n   256→    if not any(\n   257→        evidence.kind in {\n   258→            EvidenceKind.PRIMARY_SOURCE,\n   259→            EvidenceKind.REPO_FACT,\n   260→            EvidenceKind.TEST,\n   261→            EvidenceKind.BENCHMARK,\n   262→            EvidenceKind.RUNTIME,\n   263→            EvidenceKind.USER_CONSTRAINT,\n   264→        }\n   265→        for evidence in record.evidence\n   266→    ):\n   267→        warnings.append(\"no_grounded_evidence_kind\")\n   268→\n   269→    if not record.reviews:\n   270→        warnings.append(\"no_reviews\")\n   271→\n   272→    overall_score = _clamp01(\n   273→        (0.22 * structural_score)\n   274→        + (0.26 * evidence_score)\n   275→        + (0.18 * challenge_score)\n   276→        + (0.18 * traceability_score)\n   277→        + (0.16 * observability_score)\n   278→    )\n   279→\n   280→    if hard_failures or overall_score < 0.55:\n   281→        verdict = DecisionQualityVerdict.FRAGILE\n   282→    elif overall_score >= 0.85 and not warnings:\n   283→        verdict = DecisionQualityVerdict.AUDIT_READY\n   284→    else:\n   285→        verdict = DecisionQualityVerdict.DEFENSIBLE\n   286→\n   287→    summary = (\n   288→        f\"{verdict.value}: score={overall_score:.2f} \"\n   289→        f\"(structure={structural_score:.2f}, evidence={evidence_score:.2f}, \"\n   290→        f\"challenge={challenge_score:.2f}, traceability={traceability_score:.2f}, \"\n   291→        f\"observability={observability_score:.2f})\"\n   292→    )\n   293→    return DecisionQualityAssessment(\n   294→        decision_id=record.decision_id,\n   295→        overall_score=round(overall_score, 4),\n   296→        structural_score=round(structural_score, 4),\n   297→        evidence_score=round(evidence_score, 4),\n   298→        challenge_score=round(challenge_score, 4),\n   299→        traceability_score=round(traceability_score, 4),\n   300→        observability_score=round(observability_score, 4),\n   301→        verdict=verdict,\n   302→        hard_failures=sorted(set(hard_failures)),\n   303→        warnings=sorted(set(warnings)),\n   304→        summary=summary,\n   305→    )\n   306→\n   307→\n   308→def _score_structure(record: DecisionRecord) -> float:\n   309→    checks = [\n   310→        bool(record.title.strip()),\n   311→        bool(record.statement.strip()),\n   312→        bool(record.context.mission.strip()),\n   313→        bool(record.context.owner.strip()),\n   314→        bool(record.context.time_horizon.strip()),\n   315→        len(record.options) >= 2,\n   316→        record.selected_option() is not None,\n   317→        bool(record.context.constraints or record.context.assumptions),\n   318→    ]\n   319→    return _ratio(sum(1 for item in checks if item), len(checks))\n   320→\n   321→\n   322→def _score_evidence(record: DecisionRecord) -> float:\n   323→    if not record.evidence:\n   324→        return 0.0\n   325→    count_score = _clamp01(len(record.evidence) / 4.0)\n   326→    diversity_score = _clamp01(len({item.kind for item in record.evidence}) / 4.0)\n   327→    mean_confidence = sum(item.confidence for item in record.evidence) / len(record.evidence)\n   328→    verified_ratio = _ratio(sum(1 for item in record.evidence if item.verified), len(record.evidence))\n   329→    grounded_ratio = _ratio(\n   330→        sum(\n   331→            1\n   332→            for item in record.evidence\n   333→            if item.kind\n   334→            in {\n   335→                EvidenceKind.PRIMARY_SOURCE,\n   336→                EvidenceKind.REPO_FACT,\n   337→                EvidenceKind.TEST,\n   338→                EvidenceKind.BENCHMARK,\n   339→                EvidenceKind.RUNTIME,\n   340→                EvidenceKind.USER_CONSTRAINT,\n   341→            }\n   342→        ),\n   343→        len(record.evidence),\n   344→    )\n   345→    score = (\n   346→        0.25 * count_score\n   347→        + 0.20 * diversity_score\n   348→        + 0.25 * mean_confidence\n   349→        + 0.15 * verified_ratio\n   350→        + 0.15 * grounded_ratio\n   351→    )\n   352→    return _clamp01(score)\n   353→\n   354→\n   355→def _score_challenges(record: DecisionRecord) -> tuple[float, list[str], list[str]]:\n   356→    if not record.challenges:\n   357→        return 0.0, [\"no_counterarguments\"], []\n   358→\n   359→    steelman = check_steelman(\n   360→        SteelmanCheck(counterarguments=[item.summary for item in record.challenges])\n   361→    )\n   362→    substantive_score = _clamp01(steelman.substantive_counterarguments / 2.0)\n   363→    addressed_ratio = _ratio(sum(1 for item in record.challenges if item.addressed), len(record.challenges))\n   364→    unresolved_severe = sum(\n   365→        1\n   366→        for item in record.challenges\n   367→        if not item.addressed and item.severity in {ChallengeSeverity.HIGH, ChallengeSeverity.CRITICAL}\n   368→    )\n   369→    severity_penalty = 0.2 if unresolved_severe else 0.0\n   370→    gate_score = {\n   371→        \"PASS\": 1.0,\n   372→        \"WARN\": 0.45,\n   373→        \"FAIL\": 0.0,\n   374→    }[steelman.gate_result.value]\n   375→    score = _clamp01((0.40 * gate_score) + (0.30 * substantive_score) + (0.30 * addressed_ratio) - severity_penalty)\n   376→\n   377→    hard_failures: list[str] = []\n   378→    warnings: list[str] = []\n   379→    if steelman.gate_result.value == \"FAIL\":\n   380→        hard_failures.append(\"no_counterarguments\")\n   381→    if unresolved_severe:\n   382→        warnings.append(\"unresolved_high_severity_counterargument\")\n   383→    return score, hard_failures, warnings\n   384→\n   385→\n   386→def _score_traceability(\n   387→    record: DecisionRecord,\n   388→    *,\n   389→    selected_option_id: str,\n   390→) -> tuple[float, list[str], list[str]]:\n   391→    hard_failures: list[str] = []\n   392→    warnings: list[str] = []\n   393→\n   394→    if not record.claims:\n   395→        hard_failures.append(\"no_claims\")\n   396→        return 0.0, hard_failures, warnings\n   397→\n   398→    claims_with_evidence = _ratio(\n   399→        sum(1 for item in record.claims if item.evidence_refs),\n   400→        len(record.claims),\n   401→    )\n   402→    evidence_with_provenance = _ratio(\n   403→        sum(1 for item in record.evidence if item.provenance_refs or item.source_uri),\n   404→        len(record.evidence),\n   405→    )\n   406→    option_supported = 0.0\n   407→    if selected_option_id:\n   408→        option_supported = _ratio(\n   409→            sum(\n   410→                1\n   411→                for item in record.claims\n   412→                if item.supports_option_id == selected_option_id and item.evidence_refs\n   413→            ),\n   414→            1,\n   415→        )\n   416→        if option_supported == 0.0:\n   417→            hard_failures.append(\"selected_option_has_no_supported_claim\")\n   418→    review_coverage = _clamp01(len(record.reviews) / 2.0)\n   419→    review_quality = 0.0\n   420→    if record.reviews:\n   421→        verdict_scores = {\n   422→            ReviewVerdict.PASS: 1.0,\n   423→            ReviewVerdict.WARN: 0.5,\n   424→            ReviewVerdict.FAIL: 0.0,\n   425→        }\n   426→        review_quality = sum(verdict_scores[item.verdict] for item in record.reviews) / len(record.reviews)\n   427→        if any(item.verdict == ReviewVerdict.FAIL for item in record.reviews):\n   428→            warnings.append(\"failed_review_present\")\n   429→        if not any(item.verdict == ReviewVerdict.PASS for item in record.reviews):\n   430→            warnings.append(\"no_passing_review\")\n   431→    review_score = _clamp01((0.5 * review_coverage) + (0.5 * review_quality))\n   432→    if not record.provenance_refs:\n   433→        warnings.append(\"decision_missing_provenance_refs\")\n   434→\n   435→    score = _clamp01(\n   436→        (0.35 * claims_with_evidence)\n   437→        + (0.25 * evidence_with_provenance)\n   438→        + (0.25 * option_supported)\n   439→        + (0.15 * review_score)\n   440→    )\n   441→    return score, hard_failures, warnings\n   442→\n   443→\n   444→def _score_observability(record: DecisionRecord) -> tuple[float, list[str]]:\n   445→    warnings: list[str] = []\n   446→    if not record.metrics:\n   447→        return 0.0, warnings\n   448→\n   449→    metric_count_score = _clamp01(len(record.metrics) / 2.0)\n   450→    complete_metrics = _ratio(\n   451→        sum(\n   452→            1\n   453→            for metric in record.metrics\n   454→            if metric.target.strip() and metric.measurement_plan.strip() and metric.owner.strip()\n   455→        ),\n   456→        len(record.metrics),\n   457→    )\n   458→    next_action_score = 1.0 if record.next_actions else 0.0\n   459→    kill_criteria_score = 1.0 if record.kill_criteria else 0.0\n   460→    if not record.kill_criteria:\n   461→        warnings.append(\"no_kill_criteria\")\n   462→    if not record.next_actions:\n   463→        warnings.append(\"no_next_actions\")\n   464→    score = _clamp01(\n   465→        (0.30 * metric_count_score)\n   466→        + (0.30 * complete_metrics)\n   467→        + (0.20 * next_action_score)\n   468→        + (0.20 * kill_criteria_score)\n   469→    )\n   470→    return score, warnings\n   471→"}]},"uuid":"2663d4fd-a821-490b-bcab-a9768a594ae9","timestamp":"2026-03-15T13:46:52.539Z","sourceToolAssistantUUID":"0381debf-2c46-4e34-b0b2-27347b4ff977","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
