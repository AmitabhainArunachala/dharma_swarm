{"parentUuid":"514e60e4-e85a-4d36-96f2-804a9c3befc0","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_017Jmn2o8nP69KRyVDjC79Jj","toolUseID":"toolu_017Jmn2o8nP69KRyVDjC79Jj","timestamp":"2026-03-15T13:46:52.867Z","uuid":"724ac5d2-506f-467b-a9ba-abfa1ebb3a38","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"724ac5d2-506f-467b-a9ba-abfa1ebb3a38","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_017Jmn2o8nP69KRyVDjC79Jj","toolUseID":"toolu_017Jmn2o8nP69KRyVDjC79Jj","timestamp":"2026-03-15T13:46:52.867Z","uuid":"de6c4986-2e56-4c66-b37c-d2bdb09787b4","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"8d4926eb-ed73-4f89-886f-d0d144abdbb8","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017Jmn2o8nP69KRyVDjC79Jj","type":"tool_result","content":"     1→\"\"\"Data Lineage — Every output traces to its inputs.\n     2→\n     3→Palantir's Funnel gives every data transformation a lineage DAG.\n     4→Anduril's Lattice tracks sensor→track→action provenance.\n     5→NATO JC3IEDM records reporting-data alongside effective-data.\n     6→\n     7→This module gives dharma_swarm the same capability:\n     8→  - Every task execution records what it consumed and produced\n     9→  - Ancestor/descendant traversal for impact analysis\n    10→  - Root cause tracing (follow lineage back to original source)\n    11→  - Pipeline-aware: knows which Pipeline produced each artifact\n    12→  - SQLite-backed for persistence, async for non-blocking ops\n    13→\n    14→Integration:\n    15→  logic_layer.py  — Pipeline records lineage edges automatically\n    16→  ontology.py     — Artifact IDs are OntologyObj IDs\n    17→  agent_runner.py — Wire into task completion to auto-record\n    18→\"\"\"\n    19→\n    20→from __future__ import annotations\n    21→\n    22→import json\n    23→import logging\n    24→import sqlite3\n    25→from contextlib import contextmanager\n    26→from datetime import datetime, timezone\n    27→from pathlib import Path\n    28→from typing import Any\n    29→\n    30→from pydantic import BaseModel, Field\n    31→\n    32→logger = logging.getLogger(__name__)\n    33→\n    34→\n    35→def _utc_now() -> datetime:\n    36→    return datetime.now(timezone.utc)\n    37→\n    38→\n    39→def _new_id() -> str:\n    40→    from uuid import uuid4\n    41→    return uuid4().hex[:12]\n    42→\n    43→\n    44→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    45→# MODELS\n    46→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    47→\n    48→\n    49→class LineageEdge(BaseModel):\n    50→    \"\"\"Records that output artifacts were produced from input artifacts by a task.\n    51→\n    52→    This is the atomic unit of provenance: task X consumed [A, B] and\n    53→    produced [C, D] at time T, executed by agent Y in pipeline Z.\n    54→    \"\"\"\n    55→    edge_id: str = Field(default_factory=_new_id)\n    56→    task_id: str\n    57→    input_artifacts: list[str] = Field(default_factory=list)\n    58→    output_artifacts: list[str] = Field(default_factory=list)\n    59→    agent: str = \"\"\n    60→    pipeline_id: str = \"\"\n    61→    pipeline_label: str = \"\"\n    62→    block_id: str = \"\"\n    63→    operation: str = \"\"  # e.g., \"compute_rv\", \"archive\", \"design\"\n    64→    timestamp: str = Field(default_factory=lambda: _utc_now().isoformat())\n    65→    metadata: dict[str, Any] = Field(default_factory=dict)\n    66→\n    67→\n    68→class LineageNode(BaseModel):\n    69→    \"\"\"Summary of a single artifact's lineage position.\"\"\"\n    70→    artifact_id: str\n    71→    produced_by: list[str] = Field(default_factory=list)  # edge IDs that created it\n    72→    consumed_by: list[str] = Field(default_factory=list)  # edge IDs that consumed it\n    73→    first_seen: str = \"\"\n    74→    last_seen: str = \"\"\n    75→\n    76→\n    77→class ImpactReport(BaseModel):\n    78→    \"\"\"What downstream artifacts are affected if a given artifact changes.\"\"\"\n    79→    root_artifact: str\n    80→    affected_artifacts: list[str] = Field(default_factory=list)\n    81→    affected_tasks: list[str] = Field(default_factory=list)\n    82→    depth: int = 0\n    83→    total_descendants: int = 0\n    84→\n    85→\n    86→class ProvenanceChain(BaseModel):\n    87→    \"\"\"Full chain from an artifact back to its root sources.\"\"\"\n    88→    artifact_id: str\n    89→    chain: list[LineageEdge] = Field(default_factory=list)\n    90→    root_sources: list[str] = Field(default_factory=list)\n    91→    depth: int = 0\n    92→\n    93→\n    94→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    95→# LINEAGE GRAPH\n    96→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    97→\n    98→\n    99→_SCHEMA = \"\"\"\n   100→CREATE TABLE IF NOT EXISTS lineage_edges (\n   101→    edge_id TEXT PRIMARY KEY,\n   102→    task_id TEXT NOT NULL,\n   103→    agent TEXT DEFAULT '',\n   104→    pipeline_id TEXT DEFAULT '',\n   105→    pipeline_label TEXT DEFAULT '',\n   106→    block_id TEXT DEFAULT '',\n   107→    operation TEXT DEFAULT '',\n   108→    timestamp TEXT NOT NULL,\n   109→    metadata TEXT DEFAULT '{}'\n   110→);\n   111→\n   112→CREATE TABLE IF NOT EXISTS lineage_inputs (\n   113→    edge_id TEXT NOT NULL,\n   114→    artifact_id TEXT NOT NULL,\n   115→    FOREIGN KEY (edge_id) REFERENCES lineage_edges(edge_id)\n   116→);\n   117→\n   118→CREATE TABLE IF NOT EXISTS lineage_outputs (\n   119→    edge_id TEXT NOT NULL,\n   120→    artifact_id TEXT NOT NULL,\n   121→    FOREIGN KEY (edge_id) REFERENCES lineage_edges(edge_id)\n   122→);\n   123→\n   124→CREATE INDEX IF NOT EXISTS idx_inputs_artifact ON lineage_inputs(artifact_id);\n   125→CREATE INDEX IF NOT EXISTS idx_outputs_artifact ON lineage_outputs(artifact_id);\n   126→CREATE INDEX IF NOT EXISTS idx_inputs_edge ON lineage_inputs(edge_id);\n   127→CREATE INDEX IF NOT EXISTS idx_outputs_edge ON lineage_outputs(edge_id);\n   128→CREATE INDEX IF NOT EXISTS idx_edges_task ON lineage_edges(task_id);\n   129→CREATE INDEX IF NOT EXISTS idx_edges_pipeline ON lineage_edges(pipeline_id);\n   130→\"\"\"\n   131→\n   132→\n   133→class LineageGraph:\n   134→    \"\"\"SQLite-backed DAG of artifact dependencies.\n   135→\n   136→    Thread-safe via per-call connections (SQLite handles locking).\n   137→    Async methods use synchronous SQLite under the hood — safe for\n   138→    the IO patterns in dharma_swarm (no concurrent write contention).\n   139→\n   140→    Usage::\n   141→\n   142→        graph = LineageGraph()\n   143→        graph.record(LineageEdge(\n   144→            task_id=\"task_01\",\n   145→            input_artifacts=[\"prompts_v1\", \"model_config\"],\n   146→            output_artifacts=[\"rv_results_001\"],\n   147→            agent=\"researcher\",\n   148→            operation=\"compute_rv\",\n   149→        ))\n   150→\n   151→        # What produced this result?\n   152→        chain = graph.provenance(\"rv_results_001\")\n   153→\n   154→        # What breaks if prompts change?\n   155→        impact = graph.impact(\"prompts_v1\")\n   156→    \"\"\"\n   157→\n   158→    def __init__(self, db_path: Path | str | None = None) -> None:\n   159→        if db_path is None:\n   160→            db_path = Path.home() / \".dharma\" / \"lineage.db\"\n   161→        self.db_path = Path(db_path)\n   162→        self.db_path.parent.mkdir(parents=True, exist_ok=True)\n   163→        self._init_db()\n   164→\n   165→    def _init_db(self) -> None:\n   166→        with self._conn() as conn:\n   167→            conn.executescript(_SCHEMA)\n   168→\n   169→    @contextmanager\n   170→    def _conn(self):\n   171→        conn = sqlite3.connect(str(self.db_path))\n   172→        conn.execute(\"PRAGMA journal_mode=WAL\")\n   173→        conn.execute(\"PRAGMA foreign_keys=ON\")\n   174→        try:\n   175→            yield conn\n   176→            conn.commit()\n   177→        finally:\n   178→            conn.close()\n   179→\n   180→    # ── Recording ─────────────────────────────────────────────────────\n   181→\n   182→    def record(self, edge: LineageEdge) -> str:\n   183→        \"\"\"Record a lineage edge.  Returns the edge ID.\"\"\"\n   184→        with self._conn() as conn:\n   185→            conn.execute(\n   186→                \"\"\"INSERT INTO lineage_edges\n   187→                   (edge_id, task_id, agent, pipeline_id, pipeline_label,\n   188→                    block_id, operation, timestamp, metadata)\n   189→                   VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\"\"\",\n   190→                (\n   191→                    edge.edge_id, edge.task_id, edge.agent,\n   192→                    edge.pipeline_id, edge.pipeline_label,\n   193→                    edge.block_id, edge.operation, edge.timestamp,\n   194→                    json.dumps(edge.metadata),\n   195→                ),\n   196→            )\n   197→            for art_id in edge.input_artifacts:\n   198→                conn.execute(\n   199→                    \"INSERT INTO lineage_inputs (edge_id, artifact_id) VALUES (?, ?)\",\n   200→                    (edge.edge_id, art_id),\n   201→                )\n   202→            for art_id in edge.output_artifacts:\n   203→                conn.execute(\n   204→                    \"INSERT INTO lineage_outputs (edge_id, artifact_id) VALUES (?, ?)\",\n   205→                    (edge.edge_id, art_id),\n   206→                )\n   207→        return edge.edge_id\n   208→\n   209→    def record_transformation(\n   210→        self,\n   211→        task_id: str,\n   212→        inputs: list[str],\n   213→        outputs: list[str],\n   214→        agent: str = \"\",\n   215→        operation: str = \"\",\n   216→        pipeline_id: str = \"\",\n   217→        metadata: dict[str, Any] | None = None,\n   218→    ) -> str:\n   219→        \"\"\"Convenience method for recording a transformation.\"\"\"\n   220→        edge = LineageEdge(\n   221→            task_id=task_id,\n   222→            input_artifacts=inputs,\n   223→            output_artifacts=outputs,\n   224→            agent=agent,\n   225→            operation=operation,\n   226→            pipeline_id=pipeline_id,\n   227→            metadata=metadata or {},\n   228→        )\n   229→        return self.record(edge)\n   230→\n   231→    # ── Querying ──────────────────────────────────────────────────────\n   232→\n   233→    def _row_to_edge(self, row: tuple) -> LineageEdge:\n   234→        \"\"\"Convert a DB row + its inputs/outputs to a LineageEdge.\"\"\"\n   235→        edge_id = row[0]\n   236→        with self._conn() as conn:\n   237→            inputs = [\n   238→                r[0] for r in conn.execute(\n   239→                    \"SELECT artifact_id FROM lineage_inputs WHERE edge_id = ?\",\n   240→                    (edge_id,),\n   241→                ).fetchall()\n   242→            ]\n   243→            outputs = [\n   244→                r[0] for r in conn.execute(\n   245→                    \"SELECT artifact_id FROM lineage_outputs WHERE edge_id = ?\",\n   246→                    (edge_id,),\n   247→                ).fetchall()\n   248→            ]\n   249→        return LineageEdge(\n   250→            edge_id=row[0],\n   251→            task_id=row[1],\n   252→            agent=row[2] or \"\",\n   253→            pipeline_id=row[3] or \"\",\n   254→            pipeline_label=row[4] or \"\",\n   255→            block_id=row[5] or \"\",\n   256→            operation=row[6] or \"\",\n   257→            timestamp=row[7],\n   258→            metadata=json.loads(row[8]) if row[8] else {},\n   259→            input_artifacts=inputs,\n   260→            output_artifacts=outputs,\n   261→        )\n   262→\n   263→    def get_edge(self, edge_id: str) -> LineageEdge | None:\n   264→        \"\"\"Retrieve a single edge by ID.\"\"\"\n   265→        with self._conn() as conn:\n   266→            row = conn.execute(\n   267→                \"SELECT * FROM lineage_edges WHERE edge_id = ?\", (edge_id,)\n   268→            ).fetchone()\n   269→        if row is None:\n   270→            return None\n   271→        return self._row_to_edge(row)\n   272→\n   273→    def edges_for_task(self, task_id: str) -> list[LineageEdge]:\n   274→        \"\"\"Get all lineage edges for a task.\"\"\"\n   275→        with self._conn() as conn:\n   276→            rows = conn.execute(\n   277→                \"SELECT * FROM lineage_edges WHERE task_id = ? ORDER BY timestamp\",\n   278→                (task_id,),\n   279→            ).fetchall()\n   280→        return [self._row_to_edge(r) for r in rows]\n   281→\n   282→    def edges_for_pipeline(self, pipeline_id: str) -> list[LineageEdge]:\n   283→        \"\"\"Get all lineage edges for a pipeline execution.\"\"\"\n   284→        with self._conn() as conn:\n   285→            rows = conn.execute(\n   286→                \"SELECT * FROM lineage_edges WHERE pipeline_id = ? ORDER BY timestamp\",\n   287→                (pipeline_id,),\n   288→            ).fetchall()\n   289→        return [self._row_to_edge(r) for r in rows]\n   290→\n   291→    def producers_of(self, artifact_id: str) -> list[LineageEdge]:\n   292→        \"\"\"Get edges that produced this artifact (immediate parents).\"\"\"\n   293→        with self._conn() as conn:\n   294→            edge_ids = [\n   295→                r[0] for r in conn.execute(\n   296→                    \"SELECT edge_id FROM lineage_outputs WHERE artifact_id = ?\",\n   297→                    (artifact_id,),\n   298→                ).fetchall()\n   299→            ]\n   300→        if not edge_ids:\n   301→            return []\n   302→        with self._conn() as conn:\n   303→            placeholders = \",\".join(\"?\" * len(edge_ids))\n   304→            rows = conn.execute(\n   305→                f\"SELECT * FROM lineage_edges WHERE edge_id IN ({placeholders})\",\n   306→                edge_ids,\n   307→            ).fetchall()\n   308→        return [self._row_to_edge(r) for r in rows]\n   309→\n   310→    def consumers_of(self, artifact_id: str) -> list[LineageEdge]:\n   311→        \"\"\"Get edges that consumed this artifact (immediate children).\"\"\"\n   312→        with self._conn() as conn:\n   313→            edge_ids = [\n   314→                r[0] for r in conn.execute(\n   315→                    \"SELECT edge_id FROM lineage_inputs WHERE artifact_id = ?\",\n   316→                    (artifact_id,),\n   317→                ).fetchall()\n   318→            ]\n   319→        if not edge_ids:\n   320→            return []\n   321→        with self._conn() as conn:\n   322→            placeholders = \",\".join(\"?\" * len(edge_ids))\n   323→            rows = conn.execute(\n   324→                f\"SELECT * FROM lineage_edges WHERE edge_id IN ({placeholders})\",\n   325→                edge_ids,\n   326→            ).fetchall()\n   327→        return [self._row_to_edge(r) for r in rows]\n   328→\n   329→    # ── Traversal ─────────────────────────────────────────────────────\n   330→\n   331→    def ancestors(self, artifact_id: str, max_depth: int = 50) -> list[LineageEdge]:\n   332→        \"\"\"Walk backward: all edges in the provenance chain.\"\"\"\n   333→        visited_edges: set[str] = set()\n   334→        result: list[LineageEdge] = []\n   335→        frontier = [artifact_id]\n   336→        depth = 0\n   337→\n   338→        while frontier and depth < max_depth:\n   339→            next_frontier: list[str] = []\n   340→            for art_id in frontier:\n   341→                for edge in self.producers_of(art_id):\n   342→                    if edge.edge_id not in visited_edges:\n   343→                        visited_edges.add(edge.edge_id)\n   344→                        result.append(edge)\n   345→                        next_frontier.extend(edge.input_artifacts)\n   346→            frontier = next_frontier\n   347→            depth += 1\n   348→\n   349→        return result\n   350→\n   351→    def descendants(self, artifact_id: str, max_depth: int = 50) -> list[LineageEdge]:\n   352→        \"\"\"Walk forward: all edges downstream of an artifact.\"\"\"\n   353→        visited_edges: set[str] = set()\n   354→        result: list[LineageEdge] = []\n   355→        frontier = [artifact_id]\n   356→        depth = 0\n   357→\n   358→        while frontier and depth < max_depth:\n   359→            next_frontier: list[str] = []\n   360→            for art_id in frontier:\n   361→                for edge in self.consumers_of(art_id):\n   362→                    if edge.edge_id not in visited_edges:\n   363→                        visited_edges.add(edge.edge_id)\n   364→                        result.append(edge)\n   365→                        next_frontier.extend(edge.output_artifacts)\n   366→            frontier = next_frontier\n   367→            depth += 1\n   368→\n   369→        return result\n   370→\n   371→    def provenance(self, artifact_id: str, max_depth: int = 50) -> ProvenanceChain:\n   372→        \"\"\"Full provenance chain from artifact back to root sources.\"\"\"\n   373→        chain = self.ancestors(artifact_id, max_depth=max_depth)\n   374→\n   375→        # Root sources: inputs that have no producers\n   376→        all_inputs: set[str] = set()\n   377→        all_outputs: set[str] = set()\n   378→        for edge in chain:\n   379→            all_inputs.update(edge.input_artifacts)\n   380→            all_outputs.update(edge.output_artifacts)\n   381→        root_sources = sorted(all_inputs - all_outputs)\n   382→\n   383→        return ProvenanceChain(\n   384→            artifact_id=artifact_id,\n   385→            chain=chain,\n   386→            root_sources=root_sources,\n   387→            depth=len(chain),\n   388→        )\n   389→\n   390→    def impact(self, artifact_id: str, max_depth: int = 50) -> ImpactReport:\n   391→        \"\"\"What downstream artifacts and tasks are affected if this changes.\"\"\"\n   392→        desc_edges = self.descendants(artifact_id, max_depth=max_depth)\n   393→\n   394→        affected_artifacts: set[str] = set()\n   395→        affected_tasks: set[str] = set()\n   396→        max_d = 0\n   397→        frontier_depth: dict[str, int] = {artifact_id: 0}\n   398→\n   399→        for edge in desc_edges:\n   400→            task_depth = 0\n   401→            for inp in edge.input_artifacts:\n   402→                if inp in frontier_depth:\n   403→                    task_depth = max(task_depth, frontier_depth[inp] + 1)\n   404→            affected_tasks.add(edge.task_id)\n   405→            for out in edge.output_artifacts:\n   406→                affected_artifacts.add(out)\n   407→                frontier_depth[out] = task_depth\n   408→                max_d = max(max_d, task_depth)\n   409→\n   410→        return ImpactReport(\n   411→            root_artifact=artifact_id,\n   412→            affected_artifacts=sorted(affected_artifacts),\n   413→            affected_tasks=sorted(affected_tasks),\n   414→            depth=max_d,\n   415→            total_descendants=len(affected_artifacts),\n   416→        )\n   417→\n   418→    def root_causes(self, artifact_id: str) -> list[str]:\n   419→        \"\"\"Trace to the original source inputs (leaves of ancestor DAG).\"\"\"\n   420→        return self.provenance(artifact_id).root_sources\n   421→\n   422→    # ── Introspection ─────────────────────────────────────────────────\n   423→\n   424→    def stats(self) -> dict[str, int]:\n   425→        \"\"\"Basic statistics about the lineage graph.\"\"\"\n   426→        with self._conn() as conn:\n   427→            edges = conn.execute(\"SELECT COUNT(*) FROM lineage_edges\").fetchone()[0]\n   428→            inputs = conn.execute(\"SELECT COUNT(*) FROM lineage_inputs\").fetchone()[0]\n   429→            outputs = conn.execute(\"SELECT COUNT(*) FROM lineage_outputs\").fetchone()[0]\n   430→            unique_artifacts = conn.execute(\n   431→                \"\"\"SELECT COUNT(DISTINCT artifact_id) FROM (\n   432→                    SELECT artifact_id FROM lineage_inputs\n   433→                    UNION\n   434→                    SELECT artifact_id FROM lineage_outputs\n   435→                )\"\"\"\n   436→            ).fetchone()[0]\n   437→            pipelines = conn.execute(\n   438→                \"SELECT COUNT(DISTINCT pipeline_id) FROM lineage_edges WHERE pipeline_id != ''\"\n   439→            ).fetchone()[0]\n   440→        return {\n   441→            \"total_edges\": edges,\n   442→            \"total_input_refs\": inputs,\n   443→            \"total_output_refs\": outputs,\n   444→            \"unique_artifacts\": unique_artifacts,\n   445→            \"unique_pipelines\": pipelines,\n   446→        }\n   447→\n   448→    def summary(self) -> str:\n   449→        \"\"\"Human-readable summary.\"\"\"\n   450→        s = self.stats()\n   451→        return (\n   452→            f\"Lineage Graph: {s['total_edges']} edges, \"\n   453→            f\"{s['unique_artifacts']} artifacts, \"\n   454→            f\"{s['unique_pipelines']} pipelines\"\n   455→        )\n   456→\n   457→    def clear(self) -> None:\n   458→        \"\"\"Clear all lineage data.  Use with caution.\"\"\"\n   459→        with self._conn() as conn:\n   460→            conn.execute(\"DELETE FROM lineage_inputs\")\n   461→            conn.execute(\"DELETE FROM lineage_outputs\")\n   462→            conn.execute(\"DELETE FROM lineage_edges\")\n   463→"}]},"uuid":"4dcdad7c-69f3-4659-b78f-cfbb38d9f32c","timestamp":"2026-03-15T13:46:52.867Z","sourceToolAssistantUUID":"8d4926eb-ed73-4f89-886f-d0d144abdbb8","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
