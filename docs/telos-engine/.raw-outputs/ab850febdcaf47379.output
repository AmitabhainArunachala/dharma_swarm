{"parentUuid":"80dda985-a6c7-489b-aa31-24e83528d086","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VmeLxBXLkB1hwe5CQh4QTy","type":"tool_result","content":"     1→\"\"\"Semantic digester — deep reading of source files into a ConceptGraph.\n     2→\n     3→Phase 1 of the Semantic Evolution Engine.  Reads .py and .md files,\n     4→extracts structured meaning (concepts, claims, formal structures,\n     5→dependencies), profiles behavioral signatures, and populates a\n     6→:class:`ConceptGraph`.\n     7→\n     8→Extraction strategy:\n     9→  - Python files: AST-parsed docstrings, class/function names, import\n    10→    graph, formal pattern detection (Pydantic models, Protocol classes,\n    11→    mathematical structures).\n    12→  - Markdown files: header hierarchy, bold-defined terms, claim sentences,\n    13→    YAML/code-fenced formal blocks.\n    14→  - Both: behavioral profiling via :mod:`dharma_swarm.metrics` and\n    15→    connection finding via :mod:`dharma_swarm.ouroboros`.\n    16→\n    17→All failures are non-fatal — the digester skips unreadable files and\n    18→logs warnings.\n    19→\"\"\"\n    20→\n    21→from __future__ import annotations\n    22→\n    23→import ast\n    24→import logging\n    25→import re\n    26→from collections import defaultdict\n    27→from pathlib import Path\n    28→from typing import Any, Sequence\n    29→\n    30→from dharma_swarm.metrics import BehavioralSignature, MetricsAnalyzer\n    31→from dharma_swarm.semantic_gravity import (\n    32→    ConceptEdge,\n    33→    ConceptGraph,\n    34→    ConceptNode,\n    35→    EdgeType,\n    36→)\n    37→\n    38→logger = logging.getLogger(__name__)\n    39→\n    40→# ---------------------------------------------------------------------------\n    41→# Constants\n    42→# ---------------------------------------------------------------------------\n    43→\n    44→SKIP_DIRS = frozenset({\n    45→    \".git\", \"__pycache__\", \".mypy_cache\", \".pytest_cache\", \".venv\",\n    46→    \"node_modules\", \".tox\", \".eggs\", \"*.egg-info\",\n    47→})\n    48→\n    49→ALLOWED_PY_SUFFIXES = frozenset({\".py\"})\n    50→ALLOWED_MD_SUFFIXES = frozenset({\".md\", \".markdown\"})\n    51→ALLOWED_TEXT_SUFFIXES = frozenset({\".txt\"})\n    52→ALLOWED_NOTE_SUFFIXES = ALLOWED_MD_SUFFIXES | ALLOWED_TEXT_SUFFIXES\n    53→\n    54→FRONTMATTER_LINK_KEYS = frozenset({\"related\", \"see_also\", \"backlinks\", \"links\"})\n    55→\n    56→_WIKILINK_RE = re.compile(r\"\\[\\[([^\\]]+)\\]\\]\")\n    57→_MD_LINK_RE = re.compile(r\"\\[[^\\]]+\\]\\(([^)]+)\\)\")\n    58→\n    59→# Patterns that indicate a formal mathematical/computational structure\n    60→FORMAL_PATTERNS: list[tuple[str, str]] = [\n    61→    (r\"\\bmonad\\b\", \"monad\"),\n    62→    (r\"\\bcoalgebra\\b\", \"coalgebra\"),\n    63→    (r\"\\bsheaf\\b\", \"sheaf\"),\n    64→    (r\"\\bcohomolog\\w*\\b\", \"cohomology\"),\n    65→    (r\"\\bfunctor\\b\", \"functor\"),\n    66→    (r\"\\bdistributive\\s+law\\b\", \"distributive_law\"),\n    67→    (r\"\\bfixed[- ]?point\\b\", \"fixed_point\"),\n    68→    (r\"\\bmanifold\\b\", \"manifold\"),\n    69→    (r\"\\bgeodesic\\b\", \"geodesic\"),\n    70→    (r\"\\bfisher\\b\", \"fisher_metric\"),\n    71→    (r\"\\bparticipation\\s+ratio\\b\", \"participation_ratio\"),\n    72→    (r\"\\bkleisli\\b\", \"kleisli\"),\n    73→    (r\"\\bidempoten\\w*\\b\", \"idempotent\"),\n    74→    (r\"\\bbisimil\\w*\\b\", \"bisimulation\"),\n    75→    (r\"\\bstigmerg\\w*\\b\", \"stigmergy\"),\n    76→    (r\"\\banekanta\\b\", \"anekanta\"),\n    77→    (r\"\\bdharmic\\b\", \"dharmic\"),\n    78→    (r\"\\bouroboros\\b\", \"ouroboros\"),\n    79→    (r\"\\bentropy\\b\", \"entropy\"),\n    80→    (r\"\\bkolmogorov\\b\", \"kolmogorov_complexity\"),\n    81→    (r\"\\bR_V\\b\", \"rv_contraction\"),\n    82→]\n    83→\n    84→# Patterns that indicate a claim (assertion, hypothesis, invariant)\n    85→CLAIM_INDICATORS: list[str] = [\n    86→    r\"(?:must|shall|always|never|invariant|guarantee|ensure|require)\",\n    87→    r\"(?:implies|therefore|thus|hence|consequently)\",\n    88→    r\"(?:hypothesis|conjecture|claim|assert|proof|theorem|lemma)\",\n    89→    r\"(?:threshold|constraint|bound|limit|floor|ceiling)\",\n    90→]\n    91→\n    92→CLAIM_RE = re.compile(\n    93→    r\"(?:^|\\.\\s+)([A-Z][^.]*?(?:\"\n    94→    + \"|\".join(CLAIM_INDICATORS)\n    95→    + r\")[^.]*\\.)\",\n    96→    re.MULTILINE | re.IGNORECASE,\n    97→)\n    98→\n    99→# Category classification keywords\n   100→CATEGORY_KEYWORDS: dict[str, list[str]] = {"}]},"uuid":"599dbe09-e0c2-482d-a59c-818335206d85","timestamp":"2026-03-15T13:47:11.753Z","sourceToolAssistantUUID":"80dda985-a6c7-489b-aa31-24e83528d086","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
