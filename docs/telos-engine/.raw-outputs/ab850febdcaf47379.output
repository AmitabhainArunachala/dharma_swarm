{"parentUuid":"eebd86b9-8359-470c-a427-31dd2cea6efd","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014s5ncKqgwomtM28q4pK88k","type":"tool_result","content":"# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n# ENUMS\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n\nclass PropertyType(str, Enum):\n    \"\"\"Property data types.\"\"\"\n    STRING = \"string\"\n    TEXT = \"text\"\n    INTEGER = \"integer\"\n    FLOAT = \"float\"\n    BOOLEAN = \"boolean\"\n    DATETIME = \"datetime\"\n    ENUM = \"enum\"\n    LIST = \"list\"\n    DICT = \"dict\"\n    PATH = \"path\"\n    ID = \"id\"\n\n\nclass LinkCardinality(str, Enum):\n    ONE_TO_ONE = \"1:1\"\n    ONE_TO_MANY = \"1:N\"\n    MANY_TO_ONE = \"N:1\"\n    MANY_TO_MANY = \"N:N\"\n\n\nclass SecurityLevel(str, Enum):\n    PUBLIC = \"public\"\n    INTERNAL = \"internal\"\n    RESTRICTED = \"restricted\"\n    DHARMIC = \"dharmic\"\n\n\nclass ShaktiEnergy(str, Enum):\n    \"\"\"Which creative force primarily drives this object type.\"\"\"\n    MAHESHWARI = \"maheshwari\"\n    MAHAKALI = \"mahakali\"\n    MAHALAKSHMI = \"mahalakshmi\"\n    MAHASARASWATI = \"mahasaraswati\"\n\n\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n# META-SCHEMA (What CAN exist)\n# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n\nclass PropertyDef(BaseModel):","is_error":false}]},"uuid":"ae82fb71-42db-4999-a1c2-321c03dcff4e","timestamp":"2026-03-15T13:47:11.050Z","sourceToolAssistantUUID":"eebd86b9-8359-470c-a427-31dd2cea6efd","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
