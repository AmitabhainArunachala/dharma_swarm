{"parentUuid":"b3d2b1bc-b573-46f9-97f5-9743de6f2af7","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_01AuAzh4JDkcBwUgj2QNF4wR","toolUseID":"toolu_01AuAzh4JDkcBwUgj2QNF4wR","timestamp":"2026-03-15T13:46:53.505Z","uuid":"5f650660-3f93-48f7-b6ac-612c08f2f995","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"5f650660-3f93-48f7-b6ac-612c08f2f995","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01AuAzh4JDkcBwUgj2QNF4wR","toolUseID":"toolu_01AuAzh4JDkcBwUgj2QNF4wR","timestamp":"2026-03-15T13:46:53.505Z","uuid":"03dc3ca2-8b38-4f9c-8ea9-3763f2217244","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"44bd4884-3924-4687-acf5-3b1a12bed4d2","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AuAzh4JDkcBwUgj2QNF4wR","type":"tool_result","content":"     1→\"\"\"Guardrails — Parallel validation layer over telos gates.\n     2→\n     3→Palantir runs validation alongside execution, not just before.\n     4→OpenAI's Agents SDK has input/output/tool guardrails with tripwires.\n     5→Anduril's Lattice has per-task autonomy levels (0-4).\n     6→\n     7→This module upgrades dharma_swarm's blocking-only telos gates into\n     8→a full guardrail system:\n     9→\n    10→  InputGuardrail   — Validates before execution.  Blocking or parallel.\n    11→  OutputGuardrail  — Validates agent output before accepting.\n    12→  ToolGuardrail    — Intercepts individual tool/action calls.\n    13→  Tripwire         — Immediate halt on critical conditions.\n    14→\n    15→Existing telos gates (TelosGatekeeper) become InputGuardrails\n    16→in blocking mode.  New guardrails can run in parallel for latency.\n    17→\n    18→The GuardrailRunner orchestrates all guardrails around an execution.\n    19→\n    20→Integration:\n    21→  telos_gates.py  — TelosGatekeeper wrapped as InputGuardrail\n    22→  ontology.py     — ActionDef telos_gates → ToolGuardrails\n    23→  logic_layer.py  — Pipeline blocks can have guardrails attached\n    24→  lineage.py      — Guardrail results recorded in lineage metadata\n    25→\"\"\"\n    26→\n    27→from __future__ import annotations\n    28→\n    29→import asyncio\n    30→import logging\n    31→import time\n    32→from abc import ABC, abstractmethod\n    33→from datetime import datetime, timezone\n    34→from enum import Enum\n    35→from typing import Any, Callable, Coroutine\n    36→from uuid import uuid4\n    37→\n    38→from pydantic import BaseModel, Field\n    39→\n    40→logger = logging.getLogger(__name__)\n    41→\n    42→\n    43→def _utc_now() -> datetime:\n    44→    return datetime.now(timezone.utc)\n    45→\n    46→\n    47→def _new_id() -> str:\n    48→    return uuid4().hex[:12]\n    49→\n    50→\n    51→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    52→# ENUMS & MODELS\n    53→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    54→\n    55→\n    56→class GuardrailMode(str, Enum):\n    57→    \"\"\"How the guardrail relates to execution timing.\"\"\"\n    58→    BLOCKING = \"blocking\"    # Must pass before execution proceeds\n    59→    PARALLEL = \"parallel\"    # Runs alongside execution, can halt later\n    60→\n    61→\n    62→class GuardrailVerdict(str, Enum):\n    63→    PASS = \"pass\"\n    64→    WARN = \"warn\"\n    65→    FAIL = \"fail\"\n    66→    TRIPWIRE = \"tripwire\"   # Immediate halt, no recovery\n    67→\n    68→\n    69→class AutonomyLevel(int, Enum):\n    70→    \"\"\"Anduril-style per-task autonomy levels.\"\"\"\n    71→    HUMAN_ONLY = 0       # Human must perform action\n    72→    HUMAN_SUPERVISED = 1  # AI suggests, human approves\n    73→    HUMAN_ON_LOOP = 2    # AI acts, human monitors and can veto\n    74→    AUTONOMOUS_ALERT = 3  # AI acts, alerts human after\n    75→    FULLY_AUTONOMOUS = 4  # AI acts without human involvement\n    76→\n    77→\n    78→class GuardrailContext(BaseModel):\n    79→    \"\"\"Input to a guardrail check.\"\"\"\n    80→    action: str = \"\"\n    81→    content: str = \"\"\n    82→    tool_name: str = \"\"\n    83→    agent: str = \"\"\n    84→    task_id: str = \"\"\n    85→    autonomy_level: AutonomyLevel = AutonomyLevel.HUMAN_ON_LOOP\n    86→    metadata: dict[str, Any] = Field(default_factory=dict)\n    87→\n    88→\n    89→class GuardrailResult(BaseModel):\n    90→    \"\"\"Result from a single guardrail.\"\"\"\n    91→    guardrail_id: str\n    92→    guardrail_name: str\n    93→    verdict: GuardrailVerdict\n    94→    reason: str = \"\"\n    95→    mode: GuardrailMode = GuardrailMode.BLOCKING\n    96→    duration_seconds: float = 0.0\n    97→    details: dict[str, Any] = Field(default_factory=dict)\n    98→    timestamp: str = Field(default_factory=lambda: _utc_now().isoformat())\n    99→\n   100→\n   101→class TripwireResult(BaseModel):\n   102→    \"\"\"Immediate halt signal.\"\"\"\n   103→    triggered: bool = False\n   104→    guardrail_name: str = \"\"\n   105→    reason: str = \"\"\n   106→    timestamp: str = Field(default_factory=lambda: _utc_now().isoformat())\n   107→\n   108→\n   109→class GuardrailSummary(BaseModel):\n   110→    \"\"\"Aggregate result from running all guardrails.\"\"\"\n   111→    passed: bool = True\n   112→    tripwire: TripwireResult | None = None\n   113→    results: list[GuardrailResult] = Field(default_factory=list)\n   114→    total_duration_seconds: float = 0.0\n   115→    blocking_count: int = 0\n   116→    parallel_count: int = 0\n   117→    pass_count: int = 0\n   118→    warn_count: int = 0\n   119→    fail_count: int = 0\n   120→\n   121→\n   122→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   123→# ABSTRACT GUARDRAILS\n   124→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   125→\n   126→\n   127→class Guardrail(ABC):\n   128→    \"\"\"Base class for all guardrails.\"\"\"\n   129→\n   130→    def __init__(\n   131→        self,\n   132→        name: str,\n   133→        mode: GuardrailMode = GuardrailMode.BLOCKING,\n   134→        guardrail_id: str | None = None,\n   135→    ) -> None:\n   136→        self.name = name\n   137→        self.mode = mode\n   138→        self.guardrail_id = guardrail_id or _new_id()\n   139→\n   140→    @abstractmethod\n   141→    async def validate(self, context: GuardrailContext) -> GuardrailResult:\n   142→        ...\n   143→\n   144→    def _result(\n   145→        self,\n   146→        verdict: GuardrailVerdict,\n   147→        reason: str = \"\",\n   148→        duration: float = 0.0,\n   149→        details: dict[str, Any] | None = None,\n   150→    ) -> GuardrailResult:\n   151→        return GuardrailResult(\n   152→            guardrail_id=self.guardrail_id,\n   153→            guardrail_name=self.name,\n   154→            verdict=verdict,\n   155→            reason=reason,\n   156→            mode=self.mode,\n   157→            duration_seconds=duration,\n   158→            details=details or {},\n   159→        )\n   160→\n   161→\n   162→class InputGuardrail(Guardrail):\n   163→    \"\"\"Validates task input before or during execution.\n   164→\n   165→    Blocking mode: execution waits for this guardrail.\n   166→    Parallel mode: execution starts, guardrail can halt it later.\n   167→    \"\"\"\n   168→    pass\n   169→\n   170→\n   171→class OutputGuardrail(Guardrail):\n   172→    \"\"\"Validates agent output before accepting.\n   173→\n   174→    Always runs after execution completes.  Can reject output\n   175→    and trigger retry or escalation.\n   176→    \"\"\"\n   177→\n   178→    def __init__(self, name: str, guardrail_id: str | None = None) -> None:\n   179→        super().__init__(name, mode=GuardrailMode.BLOCKING, guardrail_id=guardrail_id)\n   180→\n   181→\n   182→class ToolGuardrail(Guardrail):\n   183→    \"\"\"Intercepts individual tool/action calls.\n   184→\n   185→    Can approve, modify, or block specific tool invocations.\n   186→    Runs before each tool call within an agent's execution.\n   187→    \"\"\"\n   188→\n   189→    def __init__(self, name: str, guardrail_id: str | None = None) -> None:\n   190→        super().__init__(name, mode=GuardrailMode.BLOCKING, guardrail_id=guardrail_id)\n   191→\n   192→\n   193→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   194→# BUILT-IN GUARDRAILS\n   195→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   196→\n   197→\n   198→class TelosInputGuardrail(InputGuardrail):\n   199→    \"\"\"Wraps TelosGatekeeper as an InputGuardrail.\n   200→\n   201→    This bridges the existing 11-gate system into the guardrail framework.\n   202→    Tier A/B failures → FAIL.  Tier C failures → WARN.  All pass → PASS.\n   203→    \"\"\"\n   204→\n   205→    def __init__(\n   206→        self,\n   207→        mode: GuardrailMode = GuardrailMode.BLOCKING,\n   208→    ) -> None:\n   209→        super().__init__(\"telos_gates\", mode=mode)\n   210→\n   211→    async def validate(self, context: GuardrailContext) -> GuardrailResult:\n   212→        t0 = time.monotonic()\n   213→        from dharma_swarm.telos_gates import DEFAULT_GATEKEEPER\n   214→        from dharma_swarm.models import GateDecision\n   215→\n   216→        result = DEFAULT_GATEKEEPER.check(\n   217→            action=context.action,\n   218→            content=context.content,\n   219→            tool_name=context.tool_name,\n   220→        )\n   221→        duration = time.monotonic() - t0\n   222→\n   223→        if result.decision == GateDecision.BLOCK:\n   224→            return self._result(GuardrailVerdict.FAIL, result.reason, duration, {\"gate_results\": str(result.gate_results)})\n   225→        if result.decision == GateDecision.REVIEW:\n   226→            return self._result(GuardrailVerdict.WARN, result.reason, duration, {\"gate_results\": str(result.gate_results)})\n   227→        return self._result(GuardrailVerdict.PASS, result.reason, duration)\n   228→\n   229→\n   230→class AutonomyGuardrail(InputGuardrail):\n   231→    \"\"\"Enforces autonomy level constraints.\n   232→\n   233→    Anduril-style: actions must match the task's autonomy level.\n   234→    Higher-risk actions require lower autonomy (more human oversight).\n   235→    \"\"\"\n   236→\n   237→    def __init__(\n   238→        self,\n   239→        max_autonomous_level: AutonomyLevel = AutonomyLevel.HUMAN_ON_LOOP,\n   240→    ) -> None:\n   241→        super().__init__(\"autonomy_check\", mode=GuardrailMode.BLOCKING)\n   242→        self.max_autonomous_level = max_autonomous_level\n   243→\n   244→    async def validate(self, context: GuardrailContext) -> GuardrailResult:\n   245→        t0 = time.monotonic()\n   246→\n   247→        if context.autonomy_level.value > self.max_autonomous_level.value:\n   248→            return self._result(\n   249→                GuardrailVerdict.FAIL,\n   250→                f\"Task autonomy level {context.autonomy_level.value} exceeds \"\n   251→                f\"maximum allowed {self.max_autonomous_level.value}\",\n   252→                time.monotonic() - t0,\n   253→            )\n   254→\n   255→        return self._result(\n   256→            GuardrailVerdict.PASS,\n   257→            f\"Autonomy level {context.autonomy_level.value} within bounds\",\n   258→            time.monotonic() - t0,\n   259→        )\n   260→\n   261→\n   262→class ContentLengthGuardrail(OutputGuardrail):\n   263→    \"\"\"Validates output isn't suspiciously short or long.\"\"\"\n   264→\n   265→    def __init__(self, min_chars: int = 1, max_chars: int = 100000) -> None:\n   266→        super().__init__(\"content_length\")\n   267→        self.min_chars = min_chars\n   268→        self.max_chars = max_chars\n   269→\n   270→    async def validate(self, context: GuardrailContext) -> GuardrailResult:\n   271→        t0 = time.monotonic()\n   272→        content_len = len(context.content)\n   273→\n   274→        if content_len < self.min_chars:\n   275→            return self._result(\n   276→                GuardrailVerdict.WARN,\n   277→                f\"Output too short ({content_len} < {self.min_chars} chars)\",\n   278→                time.monotonic() - t0,\n   279→            )\n   280→        if content_len > self.max_chars:\n   281→            return self._result(\n   282→                GuardrailVerdict.WARN,\n   283→                f\"Output too long ({content_len} > {self.max_chars} chars)\",\n   284→                time.monotonic() - t0,\n   285→            )\n   286→        return self._result(GuardrailVerdict.PASS, f\"Length OK ({content_len} chars)\", time.monotonic() - t0)\n   287→\n   288→\n   289→class MimicryGuardrail(OutputGuardrail):\n   290→    \"\"\"Detects performative/mimicry outputs using behavioral metrics.\n   291→\n   292→    Wires into the existing MetricsAnalyzer.detect_mimicry() to catch\n   293→    outputs that sound profound but contain no substance.\n   294→    \"\"\"\n   295→\n   296→    def __init__(self) -> None:\n   297→        super().__init__(\"mimicry_detection\")\n   298→\n   299→    async def validate(self, context: GuardrailContext) -> GuardrailResult:\n   300→        t0 = time.monotonic()\n   301→        if not context.content.strip():\n   302→            return self._result(GuardrailVerdict.PASS, \"No content to check\", time.monotonic() - t0)\n   303→\n   304→        try:\n   305→            from dharma_swarm.metrics import MetricsAnalyzer\n   306→            analyzer = MetricsAnalyzer()\n   307→            if analyzer.detect_mimicry(context.content):\n   308→                return self._result(\n   309→                    GuardrailVerdict.WARN,\n   310→                    \"Output flagged as performative/mimicry\",\n   311→                    time.monotonic() - t0,\n   312→                )\n   313→        except Exception as exc:  # noqa: BLE001\n   314→            return self._result(\n   315→                GuardrailVerdict.PASS,\n   316→                f\"Mimicry check unavailable: {exc}\",\n   317→                time.monotonic() - t0,\n   318→            )\n   319→\n   320→        return self._result(GuardrailVerdict.PASS, \"No mimicry detected\", time.monotonic() - t0)\n   321→\n   322→\n   323→class ActionTypeGuardrail(ToolGuardrail):\n   324→    \"\"\"Validates tool/action calls against ontology ActionDef rules.\n   325→\n   326→    Checks that the action exists, the actor has permission,\n   327→    and required telos gates pass.\n   328→    \"\"\"\n   329→\n   330→    def __init__(self) -> None:\n   331→        super().__init__(\"action_type_check\")\n   332→\n   333→    async def validate(self, context: GuardrailContext) -> GuardrailResult:\n   334→        t0 = time.monotonic()\n   335→        # Basic check: action and tool_name should be non-empty\n   336→        if not context.action and not context.tool_name:\n   337→            return self._result(GuardrailVerdict.PASS, \"No action to validate\", time.monotonic() - t0)\n   338→\n   339→        # Check for dangerous tool patterns\n   340→        dangerous = {\"bash\", \"shell\", \"exec\", \"eval\", \"subprocess\"}\n   341→        if context.tool_name.lower() in dangerous:\n   342→            return self._result(\n   343→                GuardrailVerdict.WARN,\n   344→                f\"Tool '{context.tool_name}' requires elevated scrutiny\",\n   345→                time.monotonic() - t0,\n   346→                {\"tool\": context.tool_name},\n   347→            )\n   348→\n   349→        return self._result(GuardrailVerdict.PASS, f\"Tool '{context.tool_name}' OK\", time.monotonic() - t0)\n   350→\n   351→\n   352→class CallableGuardrail(InputGuardrail):\n   353→    \"\"\"Guardrail from a simple callable.  For custom one-off checks.\"\"\"\n   354→\n   355→    def __init__(\n   356→        self,\n   357→        name: str,\n   358→        check_fn: Callable[[GuardrailContext], GuardrailVerdict | tuple[GuardrailVerdict, str]],\n   359→        mode: GuardrailMode = GuardrailMode.BLOCKING,\n   360→    ) -> None:\n   361→        super().__init__(name, mode=mode)\n   362→        self.check_fn = check_fn\n   363→\n   364→    async def validate(self, context: GuardrailContext) -> GuardrailResult:\n   365→        t0 = time.monotonic()\n   366→        try:\n   367→            ret = self.check_fn(context)\n   368→            if isinstance(ret, tuple):\n   369→                verdict, reason = ret\n   370→            else:\n   371→                verdict = ret\n   372→                reason = \"\"\n   373→            return self._result(verdict, reason, time.monotonic() - t0)\n   374→        except Exception as exc:  # noqa: BLE001\n   375→            return self._result(GuardrailVerdict.FAIL, f\"Check error: {exc}\", time.monotonic() - t0)\n   376→\n   377→\n   378→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   379→# GUARDRAIL RUNNER\n   380→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   381→\n   382→\n   383→class GuardrailRunner:\n   384→    \"\"\"Orchestrates guardrails around an execution.\n   385→\n   386→    Usage::\n   387→\n   388→        runner = GuardrailRunner()\n   389→        runner.add_input(TelosInputGuardrail())\n   390→        runner.add_input(AutonomyGuardrail())\n   391→        runner.add_output(MimicryGuardrail())\n   392→        runner.add_output(ContentLengthGuardrail())\n   393→\n   394→        # Check inputs before execution\n   395→        input_summary = await runner.check_inputs(context)\n   396→        if not input_summary.passed:\n   397→            return  # blocked\n   398→\n   399→        # ... execute task ...\n   400→\n   401→        # Check outputs after execution\n   402→        output_context = GuardrailContext(content=result, ...)\n   403→        output_summary = await runner.check_outputs(output_context)\n   404→    \"\"\"\n   405→\n   406→    def __init__(self) -> None:\n   407→        self._input_guardrails: list[InputGuardrail] = []\n   408→        self._output_guardrails: list[OutputGuardrail] = []\n   409→        self._tool_guardrails: list[ToolGuardrail] = []\n   410→\n   411→    def add_input(self, guardrail: InputGuardrail) -> None:\n   412→        self._input_guardrails.append(guardrail)\n   413→\n   414→    def add_output(self, guardrail: OutputGuardrail) -> None:\n   415→        self._output_guardrails.append(guardrail)\n   416→\n   417→    def add_tool(self, guardrail: ToolGuardrail) -> None:\n   418→        self._tool_guardrails.append(guardrail)\n   419→\n   420→    async def check_inputs(self, context: GuardrailContext) -> GuardrailSummary:\n   421→        \"\"\"Run all input guardrails.\n   422→\n   423→        Blocking guardrails run first (sequentially).\n   424→        If all blocking pass, parallel guardrails run concurrently.\n   425→        Any TRIPWIRE or FAIL from blocking → immediate halt.\n   426→        \"\"\"\n   427→        t0 = time.monotonic()\n   428→        blocking = [g for g in self._input_guardrails if g.mode == GuardrailMode.BLOCKING]\n   429→        parallel = [g for g in self._input_guardrails if g.mode == GuardrailMode.PARALLEL]\n   430→\n   431→        results: list[GuardrailResult] = []\n   432→        passed = True\n   433→        tripwire: TripwireResult | None = None\n   434→\n   435→        # Run blocking guardrails sequentially\n   436→        for guardrail in blocking:\n   437→            result = await guardrail.validate(context)\n   438→            results.append(result)\n   439→            if result.verdict == GuardrailVerdict.TRIPWIRE:\n   440→                tripwire = TripwireResult(\n   441→                    triggered=True,\n   442→                    guardrail_name=guardrail.name,\n   443→                    reason=result.reason,\n   444→                )\n   445→                passed = False\n   446→                break\n   447→            if result.verdict == GuardrailVerdict.FAIL:\n   448→                passed = False\n   449→                break\n   450→\n   451→        # Run parallel guardrails concurrently (only if blocking all passed)\n   452→        if passed and parallel:\n   453→            coros = [g.validate(context) for g in parallel]\n   454→            parallel_results = await asyncio.gather(*coros, return_exceptions=True)\n   455→            for pr in parallel_results:\n   456→                if isinstance(pr, Exception):\n   457→                    results.append(GuardrailResult(\n   458→                        guardrail_id=\"error\",\n   459→                        guardrail_name=\"parallel_error\",\n   460→                        verdict=GuardrailVerdict.WARN,\n   461→                        reason=str(pr),\n   462→                        mode=GuardrailMode.PARALLEL,\n   463→                    ))\n   464→                else:\n   465→                    results.append(pr)\n   466→                    if pr.verdict == GuardrailVerdict.TRIPWIRE:\n   467→                        tripwire = TripwireResult(\n   468→                            triggered=True,\n   469→                            guardrail_name=pr.guardrail_name,\n   470→                            reason=pr.reason,\n   471→                        )\n   472→                        passed = False\n   473→                    elif pr.verdict == GuardrailVerdict.FAIL:\n   474→                        passed = False\n   475→\n   476→        return self._summarize(results, passed, tripwire, time.monotonic() - t0)\n   477→\n   478→    async def check_outputs(self, context: GuardrailContext) -> GuardrailSummary:\n   479→        \"\"\"Run all output guardrails (always blocking, sequential).\"\"\"\n   480→        t0 = time.monotonic()\n   481→        results: list[GuardrailResult] = []\n   482→        passed = True\n   483→\n   484→        for guardrail in self._output_guardrails:\n   485→            result = await guardrail.validate(context)\n   486→            results.append(result)\n   487→            if result.verdict == GuardrailVerdict.FAIL:\n   488→                passed = False\n   489→            if result.verdict == GuardrailVerdict.TRIPWIRE:\n   490→                passed = False\n   491→                break\n   492→\n   493→        return self._summarize(results, passed, None, time.monotonic() - t0)\n   494→\n   495→    async def check_tool(self, context: GuardrailContext) -> GuardrailSummary:\n   496→        \"\"\"Run all tool guardrails before a tool call.\"\"\"\n   497→        t0 = time.monotonic()\n   498→        results: list[GuardrailResult] = []\n   499→        passed = True\n   500→\n   501→        for guardrail in self._tool_guardrails:\n   502→            result = await guardrail.validate(context)\n   503→            results.append(result)\n   504→            if result.verdict == GuardrailVerdict.FAIL:\n   505→                passed = False\n   506→                break\n   507→\n   508→        return self._summarize(results, passed, None, time.monotonic() - t0)\n   509→\n   510→    def _summarize(\n   511→        self,\n   512→        results: list[GuardrailResult],\n   513→        passed: bool,\n   514→        tripwire: TripwireResult | None,\n   515→        duration: float,\n   516→    ) -> GuardrailSummary:\n   517→        return GuardrailSummary(\n   518→            passed=passed,\n   519→            tripwire=tripwire,\n   520→            results=results,\n   521→            total_duration_seconds=duration,\n   522→            blocking_count=sum(1 for r in results if r.mode == GuardrailMode.BLOCKING),\n   523→            parallel_count=sum(1 for r in results if r.mode == GuardrailMode.PARALLEL),\n   524→            pass_count=sum(1 for r in results if r.verdict == GuardrailVerdict.PASS),\n   525→            warn_count=sum(1 for r in results if r.verdict == GuardrailVerdict.WARN),\n   526→            fail_count=sum(1 for r in results if r.verdict in (GuardrailVerdict.FAIL, GuardrailVerdict.TRIPWIRE)),\n   527→        )\n   528→\n   529→    def summary(self) -> str:\n   530→        \"\"\"Show registered guardrails.\"\"\"\n   531→        lines = [\"Guardrail Configuration:\"]\n   532→        if self._input_guardrails:\n   533→            lines.append(f\"  Input ({len(self._input_guardrails)}):\")\n   534→            for g in self._input_guardrails:\n   535→                lines.append(f\"    - {g.name} [{g.mode.value}]\")\n   536→        if self._output_guardrails:\n   537→            lines.append(f\"  Output ({len(self._output_guardrails)}):\")\n   538→            for g in self._output_guardrails:\n   539→                lines.append(f\"    - {g.name}\")\n   540→        if self._tool_guardrails:\n   541→            lines.append(f\"  Tool ({len(self._tool_guardrails)}):\")\n   542→            for g in self._tool_guardrails:\n   543→                lines.append(f\"    - {g.name}\")\n   544→        return \"\\n\".join(lines)\n   545→\n   546→\n   547→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   548→# DEFAULT RUNNER\n   549→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   550→\n   551→\n   552→def create_default_runner(\n   553→    *,\n   554→    include_telos: bool = True,\n   555→    include_autonomy: bool = True,\n   556→    include_mimicry: bool = True,\n   557→    include_content_length: bool = True,\n   558→    include_action_type: bool = True,\n   559→    max_autonomy: AutonomyLevel = AutonomyLevel.HUMAN_ON_LOOP,\n   560→) -> GuardrailRunner:\n   561→    \"\"\"Create a guardrail runner with standard dharma_swarm guardrails.\"\"\"\n   562→    runner = GuardrailRunner()\n   563→\n   564→    if include_telos:\n   565→        runner.add_input(TelosInputGuardrail())\n   566→    if include_autonomy:\n   567→        runner.add_input(AutonomyGuardrail(max_autonomous_level=max_autonomy))\n   568→    if include_mimicry:\n   569→        runner.add_output(MimicryGuardrail())\n   570→    if include_content_length:\n   571→        runner.add_output(ContentLengthGuardrail())\n   572→    if include_action_type:\n   573→        runner.add_tool(ActionTypeGuardrail())\n   574→\n   575→    return runner\n   576→"}]},"uuid":"b09ce4ef-9381-43a8-b8e3-6f07d42c9305","timestamp":"2026-03-15T13:46:53.505Z","sourceToolAssistantUUID":"44bd4884-3924-4687-acf5-3b1a12bed4d2","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
