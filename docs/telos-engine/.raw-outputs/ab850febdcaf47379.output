{"parentUuid":"87e98a4d-75f2-4599-b95d-e65e14b86282","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01Fk3ZYnrUhigah5MZSn1kxM","toolUseID":"toolu_01Fk3ZYnrUhigah5MZSn1kxM","timestamp":"2026-03-15T13:46:57.839Z","uuid":"34b73e44-8b62-4d18-848b-11a613bc1b7f","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"03f3c0bf-01d4-4765-8998-7b6483a06495","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fk3ZYnrUhigah5MZSn1kxM","type":"tool_result","content":"     1→\"\"\"Compile semantic clusters into campaign-grade briefs.\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import json\n     6→from datetime import datetime, timezone\n     7→from pathlib import Path\n     8→from typing import Any\n     9→\n    10→from pydantic import BaseModel, Field\n    11→\n    12→from dharma_swarm.mission_contract import (\n    13→    CampaignArtifact,\n    14→    ExecutionBrief,\n    15→    SemanticBrief,\n    16→)\n    17→from dharma_swarm.semantic_gravity import ConceptGraph, FileClusterSpec, HardeningReport\n    18→\n    19→\n    20→def _dedupe(items: list[str]) -> list[str]:\n    21→    seen: set[str] = set()\n    22→    out: list[str] = []\n    23→    for item in items:\n    24→        value = str(item).strip()\n    25→        if value and value not in seen:\n    26→            seen.add(value)\n    27→            out.append(value)\n    28→    return out\n    29→\n    30→\n    31→def _readiness(cluster: FileClusterSpec, report: HardeningReport) -> float:\n    32→    score = (cluster.hardening_score or 0.0) * 0.35 + report.overall_score * 0.65\n    33→    if report.passed:\n    34→        score += 0.05\n    35→    return round(max(0.0, min(score, 1.0)), 3)\n    36→\n    37→\n    38→def _concept_names(graph: ConceptGraph, cluster: FileClusterSpec) -> list[str]:\n    39→    names: list[str] = []\n    40→    for concept_id in cluster.core_concepts:\n    41→        node = graph.get_node(concept_id)\n    42→        if node is not None and node.name:\n    43→            names.append(node.name)\n    44→    return _dedupe(names)\n    45→\n    46→\n    47→def _cluster_evidence(graph: ConceptGraph, cluster: FileClusterSpec) -> list[str]:\n    48→    evidence: list[str] = []\n    49→    for concept_id in cluster.core_concepts:\n    50→        node = graph.get_node(concept_id)\n    51→        if node is not None and node.source_file:\n    52→            evidence.append(node.source_file)\n    53→    for file_spec in cluster.files:\n    54→        if file_spec.path:\n    55→            evidence.append(file_spec.path)\n    56→        evidence.extend(file_spec.imports_from)\n    57→    return _dedupe(evidence)\n    58→\n    59→\n    60→def _cluster_citations(graph: ConceptGraph, cluster: FileClusterSpec) -> list[str]:\n    61→    citations: list[str] = []\n    62→    for ann_id in cluster.research_annotations:\n    63→        ann = graph.get_annotation(ann_id)\n    64→        if ann is None:\n    65→            continue\n    66→        if ann.citation:\n    67→            citations.append(ann.citation)\n    68→        elif ann.external_source:\n    69→            citations.append(ann.external_source)\n    70→    return _dedupe(citations)\n    71→\n    72→\n    73→def compile_semantic_briefs(\n    74→    graph: ConceptGraph,\n    75→    clusters: list[FileClusterSpec],\n    76→    reports: list[HardeningReport],\n    77→    *,\n    78→    max_briefs: int = 3,\n    79→) -> list[SemanticBrief]:\n    80→    \"\"\"Promote hardened clusters into decision-grade semantic briefs.\"\"\"\n    81→    report_by_cluster = {report.cluster_id: report for report in reports}\n    82→    ranked = sorted(\n    83→        (\n    84→            cluster for cluster in clusters\n    85→            if cluster.id in report_by_cluster\n    86→        ),\n    87→        key=lambda cluster: (\n    88→            report_by_cluster[cluster.id].passed,\n    89→            report_by_cluster[cluster.id].overall_score,\n    90→            cluster.gravitational_mass,\n    91→        ),\n    92→        reverse=True,\n    93→    )\n    94→\n    95→    briefs: list[SemanticBrief] = []\n    96→    for cluster in ranked[:max_briefs]:\n    97→        report = report_by_cluster[cluster.id]\n    98→        concept_names = _concept_names(graph, cluster)\n    99→        citations = _cluster_citations(graph, cluster)\n   100→        next_actions = report.suggested_refinements[:3] or ["}]},"uuid":"456a0d5a-f895-4d3e-95f2-cf98aabe1e42","timestamp":"2026-03-15T13:46:57.836Z","sourceToolAssistantUUID":"03f3c0bf-01d4-4765-8998-7b6483a06495","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
