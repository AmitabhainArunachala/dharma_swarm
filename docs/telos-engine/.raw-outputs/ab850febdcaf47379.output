{"parentUuid":"99f7ca54-8dbb-4d3a-bdcc-bc348c27e4bf","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01MLuyVHWPnD6UiQrXEzjiHQ","toolUseID":"toolu_01MLuyVHWPnD6UiQrXEzjiHQ","timestamp":"2026-03-15T13:46:53.197Z","uuid":"4476df8a-65ae-4567-a5ce-d500b452e45f","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"0a58460d-4355-4683-8115-d306306804ba","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MLuyVHWPnD6UiQrXEzjiHQ","type":"tool_result","content":"     1→\"\"\"Deterministic Logic Layer — Palantir AIP Logic for dharma_swarm.\n     2→\n     3→Six block types, five deterministic, one non-deterministic:\n     4→\n     5→  ApplyAction     — Ontology mutation via typed ActionDef.  No tokens.\n     6→  ExecuteFunction — Deterministic callable.                 No tokens.\n     7→  Conditional     — If/else branching on context state.     No tokens.\n     8→  Loop            — Iterate over items with a body block.   No tokens.\n     9→  CreateVariable  — Set a value in context.                 No tokens.\n    10→  UseLLM          — NON-DETERMINISTIC.  Uses tokens.        Use sparingly.\n    11→\n    12→Pipeline chains blocks sequentially.  ExecutionContext carries state.\n    13→Every block records its result in the audit trail.  Every pipeline\n    14→records the ratio of deterministic vs LLM blocks actually executed.\n    15→\n    16→The goal: 80% deterministic, 20% LLM.  Palantir proved this works\n    17→at nation-state scale.  We take the precision, add telos gates.\n    18→\n    19→Integration:\n    20→  ontology.py      — ApplyAction calls registry.execute_action()\n    21→  decision_router  — route() determines reflex/deliberative/escalate\n    22→  telos_gates      — gate checks wired into ApplyAction\n    23→  dag_executor     — Pipeline can be used as a runner_fn\n    24→\"\"\"\n    25→\n    26→from __future__ import annotations\n    27→\n    28→import asyncio\n    29→import logging\n    30→import time\n    31→from abc import ABC, abstractmethod\n    32→from datetime import datetime, timezone\n    33→from enum import Enum\n    34→from typing import Any, Callable, Coroutine\n    35→from uuid import uuid4\n    36→\n    37→from pydantic import BaseModel, Field\n    38→\n    39→logger = logging.getLogger(__name__)\n    40→\n    41→\n    42→def _utc_now() -> datetime:\n    43→    return datetime.now(timezone.utc)\n    44→\n    45→\n    46→def _new_id() -> str:\n    47→    return uuid4().hex[:12]\n    48→\n    49→\n    50→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    51→# ENUMS\n    52→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    53→\n    54→\n    55→class BlockKind(str, Enum):\n    56→    \"\"\"Discriminant for the 6 logic block types.\"\"\"\n    57→    APPLY_ACTION = \"apply_action\"\n    58→    EXECUTE_FUNCTION = \"execute_function\"\n    59→    CONDITIONAL = \"conditional\"\n    60→    LOOP = \"loop\"\n    61→    CREATE_VARIABLE = \"create_variable\"\n    62→    USE_LLM = \"use_llm\"\n    63→\n    64→\n    65→class BlockStatus(str, Enum):\n    66→    PENDING = \"pending\"\n    67→    RUNNING = \"running\"\n    68→    SUCCESS = \"success\"\n    69→    FAILED = \"failed\"\n    70→    SKIPPED = \"skipped\"\n    71→    BLOCKED = \"blocked\"\n    72→\n    73→\n    74→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    75→# EXECUTION CONTEXT\n    76→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n    77→\n    78→\n    79→class ExecutionContext:\n    80→    \"\"\"Mutable state bag threaded through a pipeline.\n    81→\n    82→    Carries:\n    83→      state     — key/value store (variables, intermediate results)\n    84→      registry  — ontology registry reference (optional)\n    85→      gate_fn   — telos gate function (optional)\n    86→      llm_fn    — async callable for LLM inference (optional)\n    87→      metadata  — immutable pipeline-level config\n    88→    \"\"\"\n    89→\n    90→    def __init__(\n    91→        self,\n    92→        state: dict[str, Any] | None = None,\n    93→        registry: Any | None = None,\n    94→        gate_fn: Callable[[str, dict[str, Any]], dict[str, str]] | None = None,\n    95→        llm_fn: (\n    96→            Callable[[str, dict[str, Any]], Coroutine[Any, Any, str]] | None\n    97→        ) = None,\n    98→        metadata: dict[str, Any] | None = None,\n    99→    ) -> None:\n   100→        self.state: dict[str, Any] = dict(state) if state else {}\n   101→        self.registry = registry\n   102→        self.gate_fn = gate_fn\n   103→        self.llm_fn = llm_fn\n   104→        self.metadata: dict[str, Any] = dict(metadata) if metadata else {}\n   105→\n   106→    def get(self, key: str, default: Any = None) -> Any:\n   107→        return self.state.get(key, default)\n   108→\n   109→    def set(self, key: str, value: Any) -> None:\n   110→        self.state[key] = value\n   111→\n   112→    def resolve(self, template: str) -> str:\n   113→        \"\"\"Resolve {variable} references in a string template.\"\"\"\n   114→        result = template\n   115→        for key, value in self.state.items():\n   116→            placeholder = \"{\" + key + \"}\"\n   117→            if placeholder in result:\n   118→                result = result.replace(placeholder, str(value))\n   119→        return result\n   120→\n   121→    def resolve_dict(self, params: dict[str, Any]) -> dict[str, Any]:\n   122→        \"\"\"Resolve {variable} references in dict values.\"\"\"\n   123→        resolved: dict[str, Any] = {}\n   124→        for k, v in params.items():\n   125→            if isinstance(v, str) and \"{\" in v and \"}\" in v:\n   126→                resolved[k] = self.resolve(v)\n   127→            else:\n   128→                resolved[k] = v\n   129→        return resolved\n   130→\n   131→\n   132→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   133→# BLOCK RESULT\n   134→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   135→\n   136→\n   137→class BlockResult(BaseModel):\n   138→    \"\"\"Result of executing a single logic block.\"\"\"\n   139→    block_id: str\n   140→    kind: BlockKind\n   141→    status: BlockStatus\n   142→    output: Any = None\n   143→    error: str = \"\"\n   144→    duration_seconds: float = 0.0\n   145→    deterministic: bool = True\n   146→    tokens_used: int = 0\n   147→    started_at: str = \"\"\n   148→    finished_at: str = \"\"\n   149→    child_results: list[\"BlockResult\"] = Field(default_factory=list)\n   150→\n   151→    model_config = {\"arbitrary_types_allowed\": True}\n   152→\n   153→\n   154→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   155→# ABSTRACT BASE\n   156→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   157→\n   158→\n   159→class LogicBlock(ABC):\n   160→    \"\"\"Base for all logic blocks.\n   161→\n   162→    Every block has:\n   163→      - A kind (discriminant)\n   164→      - A unique ID\n   165→      - An optional label for audit trails\n   166→      - execute(context) -> BlockResult\n   167→    \"\"\"\n   168→\n   169→    def __init__(\n   170→        self,\n   171→        kind: BlockKind,\n   172→        label: str = \"\",\n   173→        block_id: str | None = None,\n   174→        store_as: str = \"\",\n   175→    ) -> None:\n   176→        self.kind = kind\n   177→        self.block_id = block_id or _new_id()\n   178→        self.label = label\n   179→        self.store_as = store_as  # if set, output stored in context.state[store_as]\n   180→\n   181→    @abstractmethod\n   182→    async def execute(self, context: ExecutionContext) -> BlockResult:\n   183→        ...\n   184→\n   185→    def _start_result(self) -> BlockResult:\n   186→        return BlockResult(\n   187→            block_id=self.block_id,\n   188→            kind=self.kind,\n   189→            status=BlockStatus.RUNNING,\n   190→            started_at=_utc_now().isoformat(),\n   191→        )\n   192→\n   193→    def _finish(\n   194→        self,\n   195→        result: BlockResult,\n   196→        *,\n   197→        status: BlockStatus,\n   198→        output: Any = None,\n   199→        error: str = \"\",\n   200→        tokens: int = 0,\n   201→        context: ExecutionContext | None = None,\n   202→    ) -> BlockResult:\n   203→        result.status = status\n   204→        result.output = output\n   205→        result.error = error\n   206→        result.tokens_used = tokens\n   207→        result.finished_at = _utc_now().isoformat()\n   208→        if self.store_as and context and status == BlockStatus.SUCCESS:\n   209→            context.set(self.store_as, output)\n   210→        return result\n   211→\n   212→\n   213→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   214→# BLOCK 1: APPLY ACTION  (deterministic ontology mutation)\n   215→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   216→\n   217→\n   218→class ApplyAction(LogicBlock):\n   219→    \"\"\"Execute a typed ontology action.  No LLM.  No tokens.\n   220→\n   221→    Calls registry.execute_action() with the resolved params.\n   222→    Telos gates run if gate_fn is set on the context.\n   223→    \"\"\"\n   224→\n   225→    def __init__(\n   226→        self,\n   227→        object_type: str,\n   228→        action_name: str,\n   229→        object_id: str = \"\",\n   230→        params: dict[str, Any] | None = None,\n   231→        *,\n   232→        label: str = \"\",\n   233→        block_id: str | None = None,\n   234→        store_as: str = \"\",\n   235→    ) -> None:\n   236→        super().__init__(BlockKind.APPLY_ACTION, label=label, block_id=block_id, store_as=store_as)\n   237→        self.object_type = object_type\n   238→        self.action_name = action_name\n   239→        self.object_id = object_id  # can be \"{var}\" template\n   240→        self.params = params or {}\n   241→\n   242→    async def execute(self, context: ExecutionContext) -> BlockResult:\n   243→        t0 = time.monotonic()\n   244→        result = self._start_result()\n   245→\n   246→        registry = context.registry\n   247→        if registry is None:\n   248→            return self._finish(result, status=BlockStatus.FAILED, error=\"no ontology registry in context\")\n   249→\n   250→        resolved_obj_id = context.resolve(self.object_id) if self.object_id else \"\"\n   251→        resolved_params = context.resolve_dict(self.params)\n   252→\n   253→        try:\n   254→            execution = registry.execute_action(\n   255→                object_type=self.object_type,\n   256→                action_name=self.action_name,\n   257→                object_id=resolved_obj_id,\n   258→                params=resolved_params,\n   259→                executed_by=context.metadata.get(\"executed_by\", \"logic_layer\"),\n   260→                gate_check=context.gate_fn,\n   261→            )\n   262→            result.duration_seconds = time.monotonic() - t0\n   263→\n   264→            if execution.result == \"blocked\":\n   265→                return self._finish(\n   266→                    result,\n   267→                    status=BlockStatus.BLOCKED,\n   268→                    error=execution.error,\n   269→                    output={\"gate_results\": execution.gate_results},\n   270→                    context=context,\n   271→                )\n   272→            if execution.result == \"failed\":\n   273→                return self._finish(result, status=BlockStatus.FAILED, error=execution.error, context=context)\n   274→\n   275→            return self._finish(\n   276→                result,\n   277→                status=BlockStatus.SUCCESS,\n   278→                output={\n   279→                    \"action\": self.action_name,\n   280→                    \"object_id\": resolved_obj_id,\n   281→                    \"gate_results\": execution.gate_results,\n   282→                },\n   283→                context=context,\n   284→            )\n   285→        except Exception as exc:  # noqa: BLE001\n   286→            result.duration_seconds = time.monotonic() - t0\n   287→            return self._finish(result, status=BlockStatus.FAILED, error=str(exc), context=context)\n   288→\n   289→\n   290→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   291→# BLOCK 2: EXECUTE FUNCTION  (deterministic callable)\n   292→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   293→\n   294→\n   295→class ExecuteFunction(LogicBlock):\n   296→    \"\"\"Execute a deterministic function.  No LLM.  No tokens.\n   297→\n   298→    The function receives the ExecutionContext and returns any value.\n   299→    Supports both sync and async callables.\n   300→    \"\"\"\n   301→\n   302→    def __init__(\n   303→        self,\n   304→        func: Callable[..., Any],\n   305→        args: dict[str, Any] | None = None,\n   306→        *,\n   307→        label: str = \"\",\n   308→        block_id: str | None = None,\n   309→        store_as: str = \"\",\n   310→    ) -> None:\n   311→        super().__init__(BlockKind.EXECUTE_FUNCTION, label=label, block_id=block_id, store_as=store_as)\n   312→        self.func = func\n   313→        self.args = args or {}\n   314→\n   315→    async def execute(self, context: ExecutionContext) -> BlockResult:\n   316→        t0 = time.monotonic()\n   317→        result = self._start_result()\n   318→\n   319→        resolved = context.resolve_dict(self.args)\n   320→\n   321→        try:\n   322→            ret = self.func(context, **resolved)\n   323→            if asyncio.iscoroutine(ret):\n   324→                ret = await ret\n   325→            result.duration_seconds = time.monotonic() - t0\n   326→            return self._finish(result, status=BlockStatus.SUCCESS, output=ret, context=context)\n   327→        except Exception as exc:  # noqa: BLE001\n   328→            result.duration_seconds = time.monotonic() - t0\n   329→            return self._finish(result, status=BlockStatus.FAILED, error=str(exc), context=context)\n   330→\n   331→\n   332→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   333→# BLOCK 3: CONDITIONAL  (if/else branching)\n   334→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   335→\n   336→\n   337→class Conditional(LogicBlock):\n   338→    \"\"\"Branch execution based on a predicate.  No LLM.  No tokens.\n   339→\n   340→    If condition(context) is truthy, runs if_true block.\n   341→    Otherwise runs if_false block (if provided, else skips).\n   342→    \"\"\"\n   343→\n   344→    def __init__(\n   345→        self,\n   346→        condition: Callable[[ExecutionContext], bool],\n   347→        if_true: LogicBlock,\n   348→        if_false: LogicBlock | None = None,\n   349→        *,\n   350→        label: str = \"\",\n   351→        block_id: str | None = None,\n   352→        store_as: str = \"\",\n   353→    ) -> None:\n   354→        super().__init__(BlockKind.CONDITIONAL, label=label, block_id=block_id, store_as=store_as)\n   355→        self.condition = condition\n   356→        self.if_true = if_true\n   357→        self.if_false = if_false\n   358→\n   359→    async def execute(self, context: ExecutionContext) -> BlockResult:\n   360→        t0 = time.monotonic()\n   361→        result = self._start_result()\n   362→\n   363→        try:\n   364→            branch = self.condition(context)\n   365→        except Exception as exc:  # noqa: BLE001\n   366→            result.duration_seconds = time.monotonic() - t0\n   367→            return self._finish(result, status=BlockStatus.FAILED, error=f\"condition error: {exc}\", context=context)\n   368→\n   369→        chosen = self.if_true if branch else self.if_false\n   370→        if chosen is None:\n   371→            result.duration_seconds = time.monotonic() - t0\n   372→            return self._finish(\n   373→                result, status=BlockStatus.SKIPPED, output={\"branch\": branch, \"note\": \"no else block\"}, context=context\n   374→            )\n   375→\n   376→        child_result = await chosen.execute(context)\n   377→        result.duration_seconds = time.monotonic() - t0\n   378→        result.child_results = [child_result]\n   379→        result.tokens_used = child_result.tokens_used\n   380→        result.deterministic = child_result.deterministic\n   381→        return self._finish(\n   382→            result,\n   383→            status=child_result.status,\n   384→            output={\"branch\": branch, \"child_output\": child_result.output},\n   385→            context=context,\n   386→        )\n   387→\n   388→\n   389→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   390→# BLOCK 4: LOOP  (iterate with a body block)\n   391→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   392→\n   393→\n   394→class Loop(LogicBlock):\n   395→    \"\"\"Iterate over items, running body for each.  No LLM (unless body uses one).\n   396→\n   397→    items_fn(context) returns the iterable.  Each item is set as\n   398→    context.state[item_var] before running the body block.\n   399→    \"\"\"\n   400→\n   401→    def __init__(\n   402→        self,\n   403→        items_fn: Callable[[ExecutionContext], list[Any]],\n   404→        body: LogicBlock,\n   405→        item_var: str = \"item\",\n   406→        max_iterations: int = 100,\n   407→        *,\n   408→        label: str = \"\",\n   409→        block_id: str | None = None,\n   410→        store_as: str = \"\",\n   411→    ) -> None:\n   412→        super().__init__(BlockKind.LOOP, label=label, block_id=block_id, store_as=store_as)\n   413→        self.items_fn = items_fn\n   414→        self.body = body\n   415→        self.item_var = item_var\n   416→        self.max_iterations = max_iterations\n   417→\n   418→    async def execute(self, context: ExecutionContext) -> BlockResult:\n   419→        t0 = time.monotonic()\n   420→        result = self._start_result()\n   421→\n   422→        try:\n   423→            items = self.items_fn(context)\n   424→        except Exception as exc:  # noqa: BLE001\n   425→            result.duration_seconds = time.monotonic() - t0\n   426→            return self._finish(result, status=BlockStatus.FAILED, error=f\"items_fn error: {exc}\", context=context)\n   427→\n   428→        child_results: list[BlockResult] = []\n   429→        total_tokens = 0\n   430→        all_deterministic = True\n   431→        outputs: list[Any] = []\n   432→\n   433→        for i, item in enumerate(items):\n   434→            if i >= self.max_iterations:\n   435→                logger.warning(\"Loop %s hit max_iterations=%d\", self.block_id, self.max_iterations)\n   436→                break\n   437→\n   438→            context.set(self.item_var, item)\n   439→            context.set(f\"{self.item_var}_index\", i)\n   440→            child = await self.body.execute(context)\n   441→            child_results.append(child)\n   442→            total_tokens += child.tokens_used\n   443→            if not child.deterministic:\n   444→                all_deterministic = False\n   445→            outputs.append(child.output)\n   446→\n   447→            if child.status in (BlockStatus.FAILED, BlockStatus.BLOCKED):\n   448→                result.duration_seconds = time.monotonic() - t0\n   449→                result.child_results = child_results\n   450→                result.tokens_used = total_tokens\n   451→                result.deterministic = all_deterministic\n   452→                return self._finish(\n   453→                    result,\n   454→                    status=child.status,\n   455→                    error=f\"loop iteration {i} {child.status.value}: {child.error}\",\n   456→                    output=outputs,\n   457→                    context=context,\n   458→                )\n   459→\n   460→        result.duration_seconds = time.monotonic() - t0\n   461→        result.child_results = child_results\n   462→        result.tokens_used = total_tokens\n   463→        result.deterministic = all_deterministic\n   464→        return self._finish(result, status=BlockStatus.SUCCESS, output=outputs, context=context)\n   465→\n   466→\n   467→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   468→# BLOCK 5: CREATE VARIABLE  (set state)\n   469→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   470→\n   471→\n   472→class CreateVariable(LogicBlock):\n   473→    \"\"\"Set a variable in context state.  No LLM.  No tokens.\n   474→\n   475→    Supports both static values and computed values (callable).\n   476→    \"\"\"\n   477→\n   478→    def __init__(\n   479→        self,\n   480→        name: str,\n   481→        value: Any = None,\n   482→        compute: Callable[[ExecutionContext], Any] | None = None,\n   483→        *,\n   484→        label: str = \"\",\n   485→        block_id: str | None = None,\n   486→    ) -> None:\n   487→        super().__init__(BlockKind.CREATE_VARIABLE, label=label, block_id=block_id, store_as=name)\n   488→        self.name = name\n   489→        self.value = value\n   490→        self.compute = compute\n   491→\n   492→    async def execute(self, context: ExecutionContext) -> BlockResult:\n   493→        t0 = time.monotonic()\n   494→        result = self._start_result()\n   495→\n   496→        try:\n   497→            if self.compute is not None:\n   498→                val = self.compute(context)\n   499→            else:\n   500→                val = self.value\n   501→            context.set(self.name, val)\n   502→            result.duration_seconds = time.monotonic() - t0\n   503→            return self._finish(result, status=BlockStatus.SUCCESS, output=val, context=context)\n   504→        except Exception as exc:  # noqa: BLE001\n   505→            result.duration_seconds = time.monotonic() - t0\n   506→            return self._finish(result, status=BlockStatus.FAILED, error=str(exc), context=context)\n   507→\n   508→\n   509→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   510→# BLOCK 6: USE LLM  (the ONE non-deterministic block)\n   511→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   512→\n   513→\n   514→class UseLLM(LogicBlock):\n   515→    \"\"\"NON-DETERMINISTIC.  Calls an LLM.  Uses tokens.  Use sparingly.\n   516→\n   517→    The prompt_template is resolved against context state.\n   518→    The llm_fn on context is called with (prompt, config).\n   519→    The response is stored in context.state[store_as].\n   520→    \"\"\"\n   521→\n   522→    def __init__(\n   523→        self,\n   524→        prompt_template: str,\n   525→        *,\n   526→        max_tokens: int = 1024,\n   527→        provider: str = \"\",\n   528→        model: str = \"\",\n   529→        temperature: float = 0.7,\n   530→        tools: list[str] | None = None,\n   531→        label: str = \"\",\n   532→        block_id: str | None = None,\n   533→        store_as: str = \"llm_output\",\n   534→    ) -> None:\n   535→        super().__init__(BlockKind.USE_LLM, label=label, block_id=block_id, store_as=store_as)\n   536→        self.prompt_template = prompt_template\n   537→        self.max_tokens = max_tokens\n   538→        self.provider = provider\n   539→        self.model = model\n   540→        self.temperature = temperature\n   541→        self.tools = tools or []\n   542→\n   543→    async def execute(self, context: ExecutionContext) -> BlockResult:\n   544→        t0 = time.monotonic()\n   545→        result = self._start_result()\n   546→        result.deterministic = False\n   547→\n   548→        if context.llm_fn is None:\n   549→            return self._finish(\n   550→                result, status=BlockStatus.FAILED, error=\"no llm_fn in context\", context=context\n   551→            )\n   552→\n   553→        prompt = context.resolve(self.prompt_template)\n   554→        config = {\n   555→            \"max_tokens\": self.max_tokens,\n   556→            \"temperature\": self.temperature,\n   557→            \"tools\": self.tools,\n   558→        }\n   559→        if self.provider:\n   560→            config[\"provider\"] = self.provider\n   561→        if self.model:\n   562→            config[\"model\"] = self.model\n   563→\n   564→        try:\n   565→            response = await context.llm_fn(prompt, config)\n   566→            result.duration_seconds = time.monotonic() - t0\n   567→            return self._finish(\n   568→                result, status=BlockStatus.SUCCESS, output=response,\n   569→                tokens=self.max_tokens, context=context,\n   570→            )\n   571→        except Exception as exc:  # noqa: BLE001\n   572→            result.duration_seconds = time.monotonic() - t0\n   573→            return self._finish(result, status=BlockStatus.FAILED, error=str(exc), context=context)\n   574→\n   575→\n   576→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   577→# PIPELINE\n   578→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   579→\n   580→\n   581→class PipelineResult(BaseModel):\n   582→    \"\"\"Result of executing a full pipeline.\"\"\"\n   583→    pipeline_id: str\n   584→    label: str = \"\"\n   585→    status: BlockStatus = BlockStatus.SUCCESS\n   586→    block_results: list[BlockResult] = Field(default_factory=list)\n   587→    total_duration_seconds: float = 0.0\n   588→    total_tokens: int = 0\n   589→    deterministic_blocks: int = 0\n   590→    nondeterministic_blocks: int = 0\n   591→    deterministic_ratio: float = 1.0\n   592→    started_at: str = \"\"\n   593→    finished_at: str = \"\"\n   594→\n   595→\n   596→class Pipeline:\n   597→    \"\"\"Sequential chain of LogicBlocks with shared context.\n   598→\n   599→    Blocks run in order.  Each block's output is available to subsequent\n   600→    blocks via context.state.  If any block fails or is blocked, the\n   601→    pipeline stops and propagates the failure.\n   602→\n   603→    Usage::\n   604→\n   605→        pipeline = Pipeline(\n   606→            blocks=[\n   607→                CreateVariable(\"model\", \"mistral-7b\"),\n   608→                ExecuteFunction(load_prompts, store_as=\"prompts\"),\n   609→                Conditional(\n   610→                    condition=lambda ctx: len(ctx.get(\"prompts\", [])) >= 20,\n   611→                    if_true=ExecuteFunction(compute_metrics, store_as=\"results\"),\n   612→                    if_false=ApplyAction(\"Experiment\", \"Fail\", params={\"reason\": \"insufficient prompts\"}),\n   613→                ),\n   614→                UseLLM(\"Analyze: {results}\", store_as=\"analysis\"),\n   615→                ApplyAction(\"Experiment\", \"Archive\", params={\"results\": \"{results}\"}),\n   616→            ],\n   617→            label=\"rv_experiment\",\n   618→        )\n   619→        result = await pipeline.execute(context)\n   620→        print(f\"Deterministic ratio: {result.deterministic_ratio:.0%}\")\n   621→    \"\"\"\n   622→\n   623→    def __init__(\n   624→        self,\n   625→        blocks: list[LogicBlock],\n   626→        label: str = \"\",\n   627→        pipeline_id: str | None = None,\n   628→        stop_on_failure: bool = True,\n   629→    ) -> None:\n   630→        self.blocks = blocks\n   631→        self.label = label\n   632→        self.pipeline_id = pipeline_id or _new_id()\n   633→        self.stop_on_failure = stop_on_failure\n   634→\n   635→    async def execute(\n   636→        self,\n   637→        context: ExecutionContext,\n   638→        on_block_complete: Callable[[BlockResult], Any] | None = None,\n   639→    ) -> PipelineResult:\n   640→        \"\"\"Execute all blocks sequentially.\"\"\"\n   641→        t0 = time.monotonic()\n   642→        result = PipelineResult(\n   643→            pipeline_id=self.pipeline_id,\n   644→            label=self.label,\n   645→            started_at=_utc_now().isoformat(),\n   646→        )\n   647→\n   648→        det_count = 0\n   649→        nondet_count = 0\n   650→        total_tokens = 0\n   651→\n   652→        for block in self.blocks:\n   653→            br = await block.execute(context)\n   654→            result.block_results.append(br)\n   655→            total_tokens += br.tokens_used\n   656→\n   657→            if br.deterministic:\n   658→                det_count += 1\n   659→            else:\n   660→                nondet_count += 1\n   661→\n   662→            if on_block_complete:\n   663→                cb_ret = on_block_complete(br)\n   664→                if asyncio.iscoroutine(cb_ret):\n   665→                    await cb_ret\n   666→\n   667→            if br.status in (BlockStatus.FAILED, BlockStatus.BLOCKED) and self.stop_on_failure:\n   668→                result.status = br.status\n   669→                break\n   670→        else:\n   671→            result.status = BlockStatus.SUCCESS\n   672→\n   673→        result.total_duration_seconds = time.monotonic() - t0\n   674→        result.total_tokens = total_tokens\n   675→        result.deterministic_blocks = det_count\n   676→        result.nondeterministic_blocks = nondet_count\n   677→        total_executed = det_count + nondet_count\n   678→        result.deterministic_ratio = det_count / total_executed if total_executed > 0 else 1.0\n   679→        result.finished_at = _utc_now().isoformat()\n   680→        return result\n   681→\n   682→    def block_summary(self) -> str:\n   683→        \"\"\"ASCII summary of the pipeline structure.\"\"\"\n   684→        lines = [f\"Pipeline: {self.label or self.pipeline_id}\", \"\"]\n   685→        for i, block in enumerate(self.blocks, 1):\n   686→            det_marker = \"LLM\" if block.kind == BlockKind.USE_LLM else \"DET\"\n   687→            label = block.label or block.kind.value\n   688→            lines.append(f\"  {i}. [{det_marker}] {label}\")\n   689→            if isinstance(block, Conditional):\n   690→                t_label = block.if_true.label or block.if_true.kind.value\n   691→                lines.append(f\"       if true  -> {t_label}\")\n   692→                if block.if_false:\n   693→                    f_label = block.if_false.label or block.if_false.kind.value\n   694→                    lines.append(f\"       if false -> {f_label}\")\n   695→            elif isinstance(block, Loop):\n   696→                b_label = block.body.label or block.body.kind.value\n   697→                lines.append(f\"       body -> {b_label} (max {block.max_iterations})\")\n   698→\n   699→        det = sum(1 for b in self.blocks if b.kind != BlockKind.USE_LLM)\n   700→        llm = sum(1 for b in self.blocks if b.kind == BlockKind.USE_LLM)\n   701→        total = det + llm\n   702→        ratio = det / total if total > 0 else 1.0\n   703→        lines.append(\"\")\n   704→        lines.append(f\"  {det} deterministic, {llm} LLM — {ratio:.0%} deterministic\")\n   705→        return \"\\n\".join(lines)\n   706→\n   707→\n   708→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   709→# PIPELINE BUILDER (convenience)\n   710→# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n   711→\n   712→\n   713→class PipelineBuilder:\n   714→    \"\"\"Fluent builder for pipelines.\n   715→\n   716→    Usage::\n   717→\n   718→        pipeline = (\n   719→            PipelineBuilder(\"experiment_run\")\n   720→            .set(\"model\", \"mistral-7b\")\n   721→            .call(load_config, store_as=\"config\")\n   722→            .branch(\n   723→                condition=lambda ctx: ctx.get(\"config\") is not None,\n   724→                if_true=ExecuteFunction(run_metrics, store_as=\"results\"),\n   725→                if_false=ApplyAction(\"Experiment\", \"Fail\"),\n   726→            )\n   727→            .llm(\"Analyze: {results}\", store_as=\"analysis\")\n   728→            .action(\"Experiment\", \"Archive\", params={\"data\": \"{results}\"})\n   729→            .build()\n   730→        )\n   731→    \"\"\"\n   732→\n   733→    def __init__(self, label: str = \"\") -> None:\n   734→        self._blocks: list[LogicBlock] = []\n   735→        self._label = label\n   736→\n   737→    def set(self, name: str, value: Any = None, compute: Callable | None = None) -> PipelineBuilder:\n   738→        \"\"\"Add a CreateVariable block.\"\"\"\n   739→        self._blocks.append(CreateVariable(name, value=value, compute=compute))\n   740→        return self\n   741→\n   742→    def call(\n   743→        self, func: Callable, args: dict[str, Any] | None = None, *, store_as: str = \"\", label: str = \"\"\n   744→    ) -> PipelineBuilder:\n   745→        \"\"\"Add an ExecuteFunction block.\"\"\"\n   746→        self._blocks.append(ExecuteFunction(func, args=args, store_as=store_as, label=label))\n   747→        return self\n   748→\n   749→    def action(\n   750→        self,\n   751→        object_type: str,\n   752→        action_name: str,\n   753→        object_id: str = \"\",\n   754→        params: dict[str, Any] | None = None,\n   755→        *,\n   756→        store_as: str = \"\",\n   757→        label: str = \"\",\n   758→    ) -> PipelineBuilder:\n   759→        \"\"\"Add an ApplyAction block.\"\"\"\n   760→        self._blocks.append(\n   761→            ApplyAction(object_type, action_name, object_id=object_id, params=params, store_as=store_as, label=label)\n   762→        )\n   763→        return self\n   764→\n   765→    def branch(\n   766→        self,\n   767→        condition: Callable[[ExecutionContext], bool],\n   768→        if_true: LogicBlock,\n   769→        if_false: LogicBlock | None = None,\n   770→        *,\n   771→        store_as: str = \"\",\n   772→        label: str = \"\",\n   773→    ) -> PipelineBuilder:\n   774→        \"\"\"Add a Conditional block.\"\"\"\n   775→        self._blocks.append(\n   776→            Conditional(condition, if_true, if_false, store_as=store_as, label=label)\n   777→        )\n   778→        return self\n   779→\n   780→    def loop(\n   781→        self,\n   782→        items_fn: Callable[[ExecutionContext], list],\n   783→        body: LogicBlock,\n   784→        item_var: str = \"item\",\n   785→        max_iterations: int = 100,\n   786→        *,\n   787→        store_as: str = \"\",\n   788→        label: str = \"\",\n   789→    ) -> PipelineBuilder:\n   790→        \"\"\"Add a Loop block.\"\"\"\n   791→        self._blocks.append(\n   792→            Loop(items_fn, body, item_var=item_var, max_iterations=max_iterations, store_as=store_as, label=label)\n   793→        )\n   794→        return self\n   795→\n   796→    def llm(\n   797→        self,\n   798→        prompt: str,\n   799→        *,\n   800→        store_as: str = \"llm_output\",\n   801→        max_tokens: int = 1024,\n   802→        provider: str = \"\",\n   803→        model: str = \"\",\n   804→        label: str = \"\",\n   805→    ) -> PipelineBuilder:\n   806→        \"\"\"Add a UseLLM block.\"\"\"\n   807→        self._blocks.append(\n   808→            UseLLM(prompt, store_as=store_as, max_tokens=max_tokens, provider=provider, model=model, label=label)\n   809→        )\n   810→        return self\n   811→\n   812→    def add(self, block: LogicBlock) -> PipelineBuilder:\n   813→        \"\"\"Add an arbitrary LogicBlock.\"\"\"\n   814→        self._blocks.append(block)\n   815→        return self\n   816→\n   817→    def build(self) -> Pipeline:\n   818→        \"\"\"Build the pipeline.\"\"\"\n   819→        return Pipeline(blocks=list(self._blocks), label=self._label)\n   820→"}]},"uuid":"d1c4fe18-dc07-417c-9e5d-d0dab9982ebc","timestamp":"2026-03-15T13:46:53.196Z","sourceToolAssistantUUID":"0a58460d-4355-4683-8115-d306306804ba","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
