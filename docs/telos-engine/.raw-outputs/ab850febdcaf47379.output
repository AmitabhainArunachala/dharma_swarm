{"parentUuid":"feacce62-2ce1-4ba5-b211-3e1d30b3ed15","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011DZdQ8UDHbj6dgWo48bwR1","type":"tool_result","content":"     1→\"\"\"Async SQLite-backed pub/sub message bus for agent-to-agent communication.\n     2→\n     3→Ported from the CHAIWALA sync MessageBus to async using aiosqlite.\n     4→All operations non-blocking. No global singletons.\n     5→\n     6→Supports typed artifact attachments linked to messages (ArtifactType from\n     7→handoff.py). Artifacts are stored in a dedicated ``artifacts`` table with\n     8→a foreign key back to ``messages(id)``.\n     9→\"\"\"\n    10→\n    11→from __future__ import annotations\n    12→\n    13→import json\n    14→from datetime import datetime, timezone\n    15→from pathlib import Path\n    16→from typing import Any\n    17→\n    18→import aiosqlite\n    19→\n    20→from dharma_swarm.models import (\n    21→    Message,\n    22→    MessagePriority,\n    23→    MessageStatus,\n    24→    _new_id,\n    25→)\n    26→\n    27→_MESSAGES_DDL = \"\"\"\n    28→CREATE TABLE IF NOT EXISTS messages (\n    29→    id TEXT PRIMARY KEY, from_agent TEXT NOT NULL, to_agent TEXT NOT NULL,\n    30→    subject TEXT, body TEXT NOT NULL, priority TEXT DEFAULT 'normal',\n    31→    status TEXT DEFAULT 'unread', created_at TEXT NOT NULL,\n    32→    read_at TEXT, reply_to TEXT, metadata TEXT DEFAULT '{}'\n    33→)\"\"\"\n    34→\n    35→_HEARTBEATS_DDL = \"\"\"\n    36→CREATE TABLE IF NOT EXISTS heartbeats (\n    37→    agent_id TEXT PRIMARY KEY, last_seen TEXT NOT NULL,\n    38→    status TEXT DEFAULT 'online', metadata TEXT DEFAULT '{}'\n    39→)\"\"\"\n    40→\n    41→_SUBSCRIPTIONS_DDL = \"\"\"\n    42→CREATE TABLE IF NOT EXISTS subscriptions (\n    43→    agent_id TEXT NOT NULL, topic TEXT NOT NULL,\n    44→    created_at TEXT NOT NULL, PRIMARY KEY (agent_id, topic)\n    45→)\"\"\"\n    46→\n    47→_ARTIFACTS_DDL = \"\"\"\n    48→CREATE TABLE IF NOT EXISTS artifacts (\n    49→    id TEXT PRIMARY KEY,\n    50→    message_id TEXT NOT NULL,\n    51→    artifact_type TEXT NOT NULL,\n    52→    content TEXT NOT NULL,\n    53→    summary TEXT DEFAULT '',\n    54→    files_touched TEXT DEFAULT '[]',\n    55→    metadata TEXT DEFAULT '{}',\n    56→    created_at TEXT NOT NULL,\n    57→    FOREIGN KEY (message_id) REFERENCES messages(id)\n    58→)\"\"\"\n    59→\n    60→_INDEXES = [\n    61→    \"CREATE INDEX IF NOT EXISTS idx_msg_to ON messages(to_agent)\",\n    62→    \"CREATE INDEX IF NOT EXISTS idx_msg_status ON messages(status)\",\n    63→    \"CREATE INDEX IF NOT EXISTS idx_msg_priority ON messages(priority)\",\n    64→    \"CREATE INDEX IF NOT EXISTS idx_sub_topic ON subscriptions(topic)\",\n    65→    \"CREATE INDEX IF NOT EXISTS idx_art_msg ON artifacts(message_id)\",\n    66→]\n    67→\n    68→_RECEIVE_ORDER = \"\"\"\n    69→ORDER BY\n    70→    CASE priority WHEN 'urgent' THEN 1 WHEN 'high' THEN 2\n    71→         WHEN 'normal' THEN 3 ELSE 4 END,\n    72→    created_at DESC\n    73→LIMIT ?\"\"\"\n    74→\n    75→\n    76→def _now_iso() -> str:\n    77→    return datetime.now(timezone.utc).isoformat()\n    78→\n    79→\n    80→def _row_to_message(row: aiosqlite.Row) -> Message:\n    81→    \"\"\"Convert a database row into a Message model.\"\"\"\n    82→    return Message(\n    83→        id=row[\"id\"], from_agent=row[\"from_agent\"], to_agent=row[\"to_agent\"],\n    84→        subject=row[\"subject\"], body=row[\"body\"],\n    85→        priority=MessagePriority(row[\"priority\"]),\n    86→        status=MessageStatus(row[\"status\"]),\n    87→        created_at=datetime.fromisoformat(row[\"created_at\"]),\n    88→        read_at=datetime.fromisoformat(row[\"read_at\"]) if row[\"read_at\"] else None,\n    89→        reply_to=row[\"reply_to\"],\n    90→        metadata=json.loads(row[\"metadata\"]) if row[\"metadata\"] else {},\n    91→    )\n    92→\n    93→\n    94→class MessageBus:\n    95→    \"\"\"Async SQLite message bus for inter-agent communication.\"\"\"\n    96→\n    97→    def __init__(self, db_path: Path) -> None:\n    98→        self.db_path = db_path\n    99→\n   100→    async def init_db(self) -> None:\n   101→        \"\"\"Create messages, heartbeats, subscriptions, and artifacts tables.\"\"\"\n   102→        self.db_path.parent.mkdir(parents=True, exist_ok=True)\n   103→        async with aiosqlite.connect(self.db_path) as db:\n   104→            for ddl in (\n   105→                _MESSAGES_DDL, _HEARTBEATS_DDL, _SUBSCRIPTIONS_DDL,\n   106→                _ARTIFACTS_DDL,\n   107→            ):\n   108→                await db.execute(ddl)\n   109→            for idx in _INDEXES:\n   110→                await db.execute(idx)\n   111→            await db.commit()\n   112→\n   113→    async def send(self, message: Message) -> str:\n   114→        \"\"\"Insert a message into the bus. Returns the message ID.\"\"\"\n   115→        async with aiosqlite.connect(self.db_path) as db:\n   116→            await db.execute(\n   117→                \"INSERT INTO messages (id, from_agent, to_agent, subject, body,\"\n   118→                \" priority, status, created_at, reply_to, metadata)\"\n   119→                \" VALUES (?,?,?,?,?,?,?,?,?,?)\",\n   120→                (message.id, message.from_agent, message.to_agent,\n   121→                 message.subject, message.body, message.priority.value,\n   122→                 message.status.value, message.created_at.isoformat(),\n   123→                 message.reply_to, json.dumps(message.metadata)),\n   124→            )\n   125→            await db.commit()\n   126→        return message.id\n   127→\n   128→    async def receive(\n   129→        self, agent_id: str, status: str = \"unread\", limit: int = 50,\n   130→    ) -> list[Message]:\n   131→        \"\"\"Fetch messages for an agent, ordered by priority then time.\"\"\"\n   132→        async with aiosqlite.connect(self.db_path) as db:\n   133→            db.row_factory = aiosqlite.Row\n   134→            query = (\"SELECT id, from_agent, to_agent, subject, body, priority,\"\n   135→                     \" status, created_at, read_at, reply_to, metadata\"\n   136→                     \" FROM messages WHERE to_agent = ?\")\n   137→            params: list[Any] = [agent_id]\n   138→            if status:\n   139→                query += \" AND status = ?\"\n   140→                params.append(status)\n   141→            query += _RECEIVE_ORDER\n   142→            params.append(limit)\n   143→            cursor = await db.execute(query, params)\n   144→            rows = await cursor.fetchall()\n   145→        return [_row_to_message(r) for r in rows]\n   146→\n   147→    async def mark_read(self, msg_id: str) -> None:\n   148→        \"\"\"Update message status to read.\"\"\"\n   149→        async with aiosqlite.connect(self.db_path) as db:\n   150→            await db.execute(\n   151→                \"UPDATE messages SET status='read', read_at=? WHERE id=?\",\n   152→                (_now_iso(), msg_id),\n   153→            )\n   154→            await db.commit()\n   155→\n   156→    async def reply(self, original_id: str, from_agent: str, body: str) -> str:\n   157→        \"\"\"Reply to an existing message. Returns the reply message ID.\"\"\"\n   158→        async with aiosqlite.connect(self.db_path) as db:\n   159→            db.row_factory = aiosqlite.Row\n   160→            cursor = await db.execute(\n   161→                \"SELECT from_agent, subject FROM messages WHERE id=?\",\n   162→                (original_id,),\n   163→            )\n   164→            row = await cursor.fetchone()\n   165→            if row is None:\n   166→                raise ValueError(f\"Message {original_id} not found\")\n   167→            reply_msg = Message(\n   168→                from_agent=from_agent,\n   169→                to_agent=row[\"from_agent\"],\n   170→                subject=f\"Re: {row['subject']}\" if row[\"subject\"] else None,\n   171→                body=body,\n   172→                reply_to=original_id,\n   173→            )\n   174→        return await self.send(reply_msg)\n   175→\n   176→    async def subscribe(self, agent_id: str, topic: str) -> None:\n   177→        \"\"\"Add a topic subscription for an agent.\"\"\"\n   178→        async with aiosqlite.connect(self.db_path) as db:\n   179→            await db.execute(\n   180→                \"INSERT OR IGNORE INTO subscriptions (agent_id, topic, created_at)\"\n   181→                \" VALUES (?,?,?)\",\n   182→                (agent_id, topic, _now_iso()),\n   183→            )\n   184→            await db.commit()\n   185→\n   186→    async def publish(self, topic: str, message: Message) -> list[str]:\n   187→        \"\"\"Fan-out a message to every subscriber of a topic. Returns sent IDs.\"\"\"\n   188→        async with aiosqlite.connect(self.db_path) as db:\n   189→            cursor = await db.execute(\n   190→                \"SELECT agent_id FROM subscriptions WHERE topic=?\", (topic,),\n   191→            )\n   192→            rows = await cursor.fetchall()\n   193→        sent_ids: list[str] = []\n   194→        for (agent_id,) in rows:\n   195→            fan_msg = message.model_copy(update={\n   196→                \"id\": _new_id(),\n   197→                \"to_agent\": agent_id,\n   198→                \"metadata\": {**message.metadata, \"topic\": topic},\n   199→            })\n   200→            sent_ids.append(await self.send(fan_msg))\n   201→        return sent_ids\n   202→\n   203→    async def heartbeat(\n   204→        self, agent_id: str, metadata: dict[str, Any] | None = None,\n   205→    ) -> None:\n   206→        \"\"\"Upsert a heartbeat for an agent.\"\"\"\n   207→        async with aiosqlite.connect(self.db_path) as db:\n   208→            await db.execute(\n   209→                \"INSERT OR REPLACE INTO heartbeats\"\n   210→                \" (agent_id, last_seen, status, metadata) VALUES (?,?,'online',?)\",\n   211→                (agent_id, _now_iso(), json.dumps(metadata or {})),\n   212→            )\n   213→            await db.commit()\n   214→\n   215→    async def get_agent_status(self, agent_id: str) -> dict[str, Any] | None:\n   216→        \"\"\"Check agent liveness. Returns None if agent unknown.\"\"\"\n   217→        async with aiosqlite.connect(self.db_path) as db:\n   218→            db.row_factory = aiosqlite.Row\n   219→            cursor = await db.execute(\n   220→                \"SELECT last_seen, status, metadata FROM heartbeats WHERE agent_id=?\",\n   221→                (agent_id,),\n   222→            )\n   223→            row = await cursor.fetchone()\n   224→        if row is None:\n   225→            return None\n   226→        last_seen = datetime.fromisoformat(row[\"last_seen\"])\n   227→        age = (datetime.now(timezone.utc) - last_seen).total_seconds() / 60.0\n   228→        return {\n   229→            \"agent_id\": agent_id,\n   230→            \"last_seen\": row[\"last_seen\"],\n   231→            \"status\": \"online\" if age < 10 else \"offline\",\n   232→            \"age_minutes\": round(age, 1),\n   233→            \"metadata\": json.loads(row[\"metadata\"]) if row[\"metadata\"] else {},\n   234→        }\n   235→\n   236→    async def get_stats(self) -> dict[str, Any]:\n   237→        \"\"\"Message counts, unread counts per agent, and known agent count.\"\"\"\n   238→        async with aiosqlite.connect(self.db_path) as db:\n   239→            total = (await (await db.execute(\n   240→                \"SELECT COUNT(*) FROM messages\")).fetchone())[0]  # type: ignore[index]\n   241→            unread = (await (await db.execute(\n   242→                \"SELECT COUNT(*) FROM messages WHERE status='unread'\"\n   243→            )).fetchone())[0]  # type: ignore[index]\n   244→            unread_by_agent: dict[str, int] = dict(await (await db.execute(\n   245→                \"SELECT to_agent, COUNT(*) FROM messages\"\n   246→                \" WHERE status='unread' GROUP BY to_agent\"\n   247→            )).fetchall())\n   248→            agents = (await (await db.execute(\n   249→                \"SELECT COUNT(*) FROM heartbeats\")).fetchone())[0]  # type: ignore[index]\n   250→        return {\n   251→            \"total_messages\": total, \"unread_messages\": unread,\n   252→            \"unread_by_agent\": unread_by_agent, \"known_agents\": agents,\n   253→            \"db_path\": str(self.db_path),\n   254→        }\n   255→\n   256→    async def list_messages(\n   257→        self,\n   258→        *,\n   259→        limit: int = 200,\n   260→        agent_id: str | None = None,\n   261→    ) -> list[Message]:\n   262→        \"\"\"List recent messages, optionally filtered to one agent.\"\"\"\n   263→        async with aiosqlite.connect(self.db_path) as db:\n   264→            db.row_factory = aiosqlite.Row\n   265→            query = (\n   266→                \"SELECT id, from_agent, to_agent, subject, body, priority,\"\n   267→                \" status, created_at, read_at, reply_to, metadata\"\n   268→                \" FROM messages\"\n   269→            )\n   270→            params: list[Any] = []\n   271→            if agent_id:\n   272→                query += \" WHERE from_agent = ? OR to_agent = ?\"\n   273→                params.extend([agent_id, agent_id])\n   274→            query += \" ORDER BY created_at DESC LIMIT ?\"\n   275→            params.append(max(1, int(limit)))\n   276→            cursor = await db.execute(query, params)\n   277→            rows = await cursor.fetchall()\n   278→        return [_row_to_message(row) for row in rows]\n   279→\n   280→    # ------------------------------------------------------------------\n   281→    # Artifact attachment support\n   282→    # ------------------------------------------------------------------\n   283→\n   284→    async def attach_artifact(\n   285→        self,\n   286→        message_id: str,\n   287→        artifact_type: str,\n   288→        content: str,\n   289→        summary: str = \"\",\n   290→        files_touched: list[str] | None = None,\n   291→        metadata: dict[str, Any] | None = None,\n   292→    ) -> str:\n   293→        \"\"\"Attach a typed artifact to an existing message.\n   294→\n   295→        Args:\n   296→            message_id: The message to attach the artifact to.\n   297→            artifact_type: A string from ArtifactType (e.g. ``\"code_diff\"``).\n   298→            content: The artifact payload (code, analysis text, etc.).\n   299→            summary: One-line summary for quick scanning.\n   300→            files_touched: List of file paths affected by this artifact.\n   301→            metadata: Arbitrary key-value metadata.\n   302→\n   303→        Returns:\n   304→            The generated artifact ID.\n   305→\n   306→        Raises:\n   307→            ValueError: If *message_id* does not reference an existing message.\n   308→        \"\"\"\n   309→        artifact_id = _new_id()\n   310→        async with aiosqlite.connect(self.db_path) as db:\n   311→            # Verify the parent message exists.\n   312→            cursor = await db.execute(\n   313→                \"SELECT id FROM messages WHERE id=?\", (message_id,),\n   314→            )\n   315→            if await cursor.fetchone() is None:\n   316→                raise ValueError(f\"Message {message_id} not found\")\n   317→            await db.execute(\n   318→                \"INSERT INTO artifacts\"\n   319→                \" (id, message_id, artifact_type, content, summary,\"\n   320→                \"  files_touched, metadata, created_at)\"\n   321→                \" VALUES (?,?,?,?,?,?,?,?)\",\n   322→                (\n   323→                    artifact_id,\n   324→                    message_id,\n   325→                    artifact_type,\n   326→                    content,\n   327→                    summary,\n   328→                    json.dumps(files_touched or []),\n   329→                    json.dumps(metadata or {}),\n   330→                    _now_iso(),\n   331→                ),\n   332→            )\n   333→            await db.commit()\n   334→        return artifact_id\n   335→\n   336→    async def get_artifacts(\n   337→        self,\n   338→        message_id: str,\n   339→        artifact_type: str | None = None,\n   340→    ) -> list[dict[str, Any]]:\n   341→        \"\"\"Retrieve artifacts attached to a message.\n   342→\n   343→        Args:\n   344→            message_id: The message whose artifacts to fetch.\n   345→            artifact_type: If provided, only return artifacts of this type.\n   346→\n   347→        Returns:\n   348→            List of artifact dicts with keys: ``id``, ``message_id``,\n   349→            ``artifact_type``, ``content``, ``summary``, ``files_touched``,\n   350→            ``metadata``, ``created_at``.\n   351→        \"\"\"\n   352→        async with aiosqlite.connect(self.db_path) as db:\n   353→            db.row_factory = aiosqlite.Row\n   354→            query = (\n   355→                \"SELECT id, message_id, artifact_type, content, summary,\"\n   356→                \" files_touched, metadata, created_at\"\n   357→                \" FROM artifacts WHERE message_id = ?\"\n   358→            )\n   359→            params: list[Any] = [message_id]\n   360→            if artifact_type is not None:\n   361→                query += \" AND artifact_type = ?\"\n   362→                params.append(artifact_type)\n   363→            query += \" ORDER BY created_at\"\n   364→            cursor = await db.execute(query, params)\n   365→            rows = await cursor.fetchall()\n   366→        return [\n   367→            {\n   368→                \"id\": row[\"id\"],\n   369→                \"message_id\": row[\"message_id\"],\n   370→                \"artifact_type\": row[\"artifact_type\"],\n   371→                \"content\": row[\"content\"],\n   372→                \"summary\": row[\"summary\"],\n   373→                \"files_touched\": json.loads(row[\"files_touched\"]),\n   374→                \"metadata\": json.loads(row[\"metadata\"]),\n   375→                \"created_at\": row[\"created_at\"],\n   376→            }\n   377→            for row in rows\n   378→        ]\n   379→\n   380→    async def send_with_artifacts(\n   381→        self,\n   382→        message: Message,\n   383→        artifacts: list[dict[str, Any]],\n   384→    ) -> str:\n   385→        \"\"\"Send a message with attached artifacts in a single transaction.\n   386→\n   387→        Each artifact dict must contain at least ``artifact_type`` and\n   388→        ``content``.  Optional keys: ``summary``, ``files_touched``,\n   389→        ``metadata``.\n   390→\n   391→        Args:\n   392→            message: The message to send.\n   393→            artifacts: List of artifact dicts to attach.\n   394→\n   395→        Returns:\n   396→            The message ID.\n   397→        \"\"\"\n   398→        async with aiosqlite.connect(self.db_path) as db:\n   399→            # Insert the message.\n   400→            await db.execute(\n   401→                \"INSERT INTO messages (id, from_agent, to_agent, subject, body,\"\n   402→                \" priority, status, created_at, reply_to, metadata)\"\n   403→                \" VALUES (?,?,?,?,?,?,?,?,?,?)\",\n   404→                (\n   405→                    message.id,\n   406→                    message.from_agent,\n   407→                    message.to_agent,\n   408→                    message.subject,\n   409→                    message.body,\n   410→                    message.priority.value,\n   411→                    message.status.value,\n   412→                    message.created_at.isoformat(),\n   413→                    message.reply_to,\n   414→                    json.dumps(message.metadata),\n   415→                ),\n   416→            )\n   417→            # Insert each artifact in the same transaction.\n   418→            for art in artifacts:\n   419→                artifact_id = _new_id()\n   420→                await db.execute(\n   421→                    \"INSERT INTO artifacts\"\n   422→                    \" (id, message_id, artifact_type, content, summary,\"\n   423→                    \"  files_touched, metadata, created_at)\"\n   424→                    \" VALUES (?,?,?,?,?,?,?,?)\",\n   425→                    (\n   426→                        artifact_id,\n   427→                        message.id,\n   428→                        art[\"artifact_type\"],\n   429→                        art[\"content\"],\n   430→                        art.get(\"summary\", \"\"),\n   431→                        json.dumps(art.get(\"files_touched\", [])),\n   432→                        json.dumps(art.get(\"metadata\", {})),\n   433→                        _now_iso(),\n   434→                    ),\n   435→                )\n   436→            await db.commit()\n   437→        return message.id\n   438→\n   439→    async def build_context_from_artifacts(\n   440→        self,\n   441→        agent_id: str,\n   442→        budget: int = 5000,\n   443→    ) -> str:\n   444→        \"\"\"Build injectable context from unread messages and their artifacts.\n   445→\n   446→        Reads all unread messages for *agent_id*, fetches their artifacts,\n   447→        and formats them into a priority-sorted context string truncated to\n   448→        *budget* characters.\n   449→\n   450→        Args:\n   451→            agent_id: The agent to build context for.\n   452→            budget: Maximum character count for the returned string.\n   453→\n   454→        Returns:\n   455→            Formatted context string, or ``\"\"`` if no unread messages with\n   456→            artifacts exist.\n   457→        \"\"\"\n   458→        messages = await self.receive(agent_id, status=\"unread\")\n   459→        if not messages:\n   460→            return \"\"\n   461→\n   462→        # Collect (message, artifacts) pairs; skip messages with no artifacts.\n   463→        msg_art_pairs: list[tuple[Message, list[dict[str, Any]]]] = []\n   464→        for msg in messages:\n   465→            arts = await self.get_artifacts(msg.id)\n   466→            if arts:\n   467→                msg_art_pairs.append((msg, arts))\n   468→\n   469→        if not msg_art_pairs:\n   470→            return \"\"\n   471→\n   472→        sections: list[str] = [\"# Artifact Context\"]\n   473→        used = len(sections[0])\n   474→\n   475→        for msg, arts in msg_art_pairs:\n   476→            header = (\n   477→                f\"\\n## [{msg.priority.value.upper()}] \"\n   478→                f\"From {msg.from_agent}: {msg.subject or '(no subject)'}\"\n   479→            )\n   480→            body_parts: list[str] = [header]\n   481→            for art in arts:\n   482→                label = art[\"artifact_type\"]\n   483→                summary = art.get(\"summary\") or art[\"content\"][:80]\n   484→                body_parts.append(f\"- **{label}**: {summary}\")\n   485→            section = \"\\n\".join(body_parts)\n   486→\n   487→            if used + len(section) > budget:\n   488→                remaining = budget - used\n   489→                if remaining > 40:\n   490→                    sections.append(section[:remaining] + \"\\n... [truncated]\")\n   491→                break\n   492→            sections.append(section)\n   493→            used += len(section)\n   494→\n   495→        return \"\\n\".join(sections)\n   496→"}]},"uuid":"a2b1bc9b-2f1e-4407-a858-7444183bb246","timestamp":"2026-03-15T13:46:53.748Z","sourceToolAssistantUUID":"feacce62-2ce1-4ba5-b211-3e1d30b3ed15","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
