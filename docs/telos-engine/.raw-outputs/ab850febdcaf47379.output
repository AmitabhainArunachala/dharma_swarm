{"parentUuid":"fcae0b8c-71c4-48dd-880a-2fb3f1797b78","isSidechain":true,"agentId":"ab850febdcaf47379","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01YKU5FAFYEPLDUxRtPqULDs","toolUseID":"toolu_01YKU5FAFYEPLDUxRtPqULDs","timestamp":"2026-03-15T13:46:56.980Z","uuid":"d5b103fb-7ec0-4270-9cd6-fd5cb1749022","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"d73d1043-5d6b-46e6-b455-c76b8e29ad76","isSidechain":true,"promptId":"74ab6cc1-259e-4f35-896b-31737bc09d28","agentId":"ab850febdcaf47379","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YKU5FAFYEPLDUxRtPqULDs","type":"tool_result","content":"     1→\"\"\"Semantic hardener — multi-angle quality verification for file clusters.\n     2→\n     3→Phase 4 of the Semantic Evolution Engine.  Each :class:`FileClusterSpec`\n     4→is tested from six orthogonal angles.  A cluster only survives if it\n     5→passes a configurable threshold of those angles.\n     6→\n     7→Angles\n     8→------\n     9→1. **Mathematical** — formal structures validated via info_geometry + telos gates\n    10→2. **Computational** — importability, no syntax errors, test stubs present\n    11→3. **Engineering** — behavioral metrics via MetricsAnalyzer, compression ratio\n    12→4. **Context Engineering** — docstring density, cross-reference completeness\n    13→5. **Swarm Dynamics** — sheaf-style cohomological connectivity across cluster\n    14→6. **Behavioral Health** — ouroboros behavioral scoring, mimicry detection\n    15→\n    16→Failed angles produce ``AngleVerdict.gaps`` that feed back into the\n    17→DIGEST phase for the next iteration.\n    18→\"\"\"\n    19→\n    20→from __future__ import annotations\n    21→\n    22→import ast\n    23→import logging\n    24→import re\n    25→from pathlib import Path\n    26→from statistics import mean\n    27→from typing import Any\n    28→\n    29→from dharma_swarm.metrics import BehavioralSignature, MetricsAnalyzer\n    30→from dharma_swarm.models import GateResult\n    31→from dharma_swarm.semantic_gravity import (\n    32→    AngleVerdict,\n    33→    ConceptGraph,\n    34→    ConceptNode,\n    35→    FileClusterSpec,\n    36→    HardeningAngle,\n    37→    HardeningReport,\n    38→)\n    39→\n    40→logger = logging.getLogger(__name__)\n    41→\n    42→_analyzer = MetricsAnalyzer()\n    43→\n    44→# ---------------------------------------------------------------------------\n    45→# Individual angle checkers\n    46→# ---------------------------------------------------------------------------\n    47→\n    48→\n    49→def _check_mathematical(\n    50→    cluster: FileClusterSpec,\n    51→    graph: ConceptGraph,\n    52→    *,\n    53→    project_root: Path,\n    54→) -> AngleVerdict:\n    55→    \"\"\"Angle 1: Mathematical — formal structures present and consistent.\n    56→\n    57→    Checks:\n    58→    - Core concepts have ≥1 formal structure\n    59→    - Formal structures referenced in the cluster files exist in the graph\n    60→    - Concept definitions are non-empty\n    61→    \"\"\"\n    62→    gaps: list[str] = []\n    63→    scores: list[float] = []\n    64→\n    65→    for cid in cluster.core_concepts:\n    66→        node = graph.get_node(cid)\n    67→        if node is None:\n    68→            gaps.append(f\"Missing concept node: {cid}\")\n    69→            scores.append(0.0)\n    70→            continue\n    71→\n    72→        # Formal structures present\n    73→        if node.formal_structures:\n    74→            scores.append(1.0)\n    75→        else:\n    76→            gaps.append(f\"Concept '{node.name}' has no formal structures\")\n    77→            scores.append(0.0)\n    78→\n    79→        # Definition present\n    80→        if node.definition:\n    81→            scores.append(1.0)\n    82→        else:\n    83→            gaps.append(f\"Concept '{node.name}' has no definition\")\n    84→            scores.append(0.3)\n    85→\n    86→        # Check edges exist for this concept\n    87→        degree = graph.degree(cid)\n    88→        if degree > 0:\n    89→            scores.append(min(1.0, degree / 3.0))\n    90→        else:\n    91→            gaps.append(f\"Concept '{node.name}' is isolated (0 edges)\")\n    92→            scores.append(0.0)\n    93→\n    94→    score = mean(scores) if scores else 0.0\n    95→    if score >= 0.7:\n    96→        result = GateResult.PASS\n    97→    elif score >= 0.4:\n    98→        result = GateResult.WARN\n    99→    else:\n   100→        result = GateResult.FAIL"}]},"uuid":"2b3b1565-3398-4616-b6f2-b59f6d4bd720","timestamp":"2026-03-15T13:46:56.979Z","sourceToolAssistantUUID":"d73d1043-5d6b-46e6-b455-c76b8e29ad76","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
