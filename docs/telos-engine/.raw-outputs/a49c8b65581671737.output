{"parentUuid":"4f4468f7-2585-4d7a-9432-73628aa0cbfd","isSidechain":true,"agentId":"a49c8b65581671737","type":"progress","data":{"type":"hook_progress","hookEvent":"PreToolUse","hookName":"PreToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"pre:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"toolUseID":"toolu_011PwwE9oRA7jCWZyuNdyg84","parentToolUseID":"toolu_011PwwE9oRA7jCWZyuNdyg84","uuid":"26e1492f-9e9f-42ec-8694-62b14a639de4","timestamp":"2026-03-15T14:18:42.245Z","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"26e1492f-9e9f-42ec-8694-62b14a639de4","isSidechain":true,"agentId":"a49c8b65581671737","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_011PwwE9oRA7jCWZyuNdyg84","toolUseID":"toolu_011PwwE9oRA7jCWZyuNdyg84","timestamp":"2026-03-15T14:18:42.249Z","uuid":"c9bf5bc3-dcd5-4433-b17a-2dcb7c60c72b","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"c9bf5bc3-dcd5-4433-b17a-2dcb7c60c72b","isSidechain":true,"agentId":"a49c8b65581671737","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_011PwwE9oRA7jCWZyuNdyg84","toolUseID":"toolu_011PwwE9oRA7jCWZyuNdyg84","timestamp":"2026-03-15T14:18:42.249Z","uuid":"d8ec302e-0903-40a2-8411-da21e6a497e3","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"4f4468f7-2585-4d7a-9432-73628aa0cbfd","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49c8b65581671737","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011PwwE9oRA7jCWZyuNdyg84","type":"tool_result","content":"     1→\"\"\"Adaptive Autonomy — agents adjust freedom based on confidence and risk.\n     2→\n     3→Goes beyond static permission levels. Agents start at their profile's\n     4→base autonomy level, then dynamically adjust based on:\n     5→  - Success/failure history (more failures → more cautious)\n     6→  - Risk assessment of the current action\n     7→  - Confidence of intent detection\n     8→  - Time of day (quiet hours → more cautious)\n     9→  - Circuit breaker state\n    10→\n    11→The autonomy engine is the bridge between the telos gates (hard constraints)\n    12→and the profile system (soft preferences). Gates say WHAT is forbidden;\n    13→autonomy says HOW MUCH freedom the agent gets for everything else.\n    14→\"\"\"\n    15→\n    16→from __future__ import annotations\n    17→\n    18→import logging\n    19→import time\n    20→from collections import deque\n    21→from enum import Enum\n    22→\n    23→from pydantic import BaseModel\n    24→\n    25→logger = logging.getLogger(__name__)\n    26→\n    27→\n    28→class RiskLevel(str, Enum):\n    29→    \"\"\"Risk classification for an action.\"\"\"\n    30→    SAFE = \"safe\"           # Read-only, no side effects\n    31→    LOW = \"low\"             # Minor changes, easily reversible\n    32→    MEDIUM = \"medium\"       # File modifications, config changes\n    33→    HIGH = \"high\"           # Multi-file changes, API calls, deployments\n    34→    CRITICAL = \"critical\"   # Destructive ops, production changes, credentials\n    35→\n    36→\n    37→class AutonomyDecision(BaseModel):\n    38→    \"\"\"Result of an autonomy check for a specific action.\"\"\"\n    39→\n    40→    action: str\n    41→    risk: RiskLevel\n    42→    confidence: float = 0.0\n    43→    auto_approve: bool = False\n    44→    reason: str = \"\"\n    45→    escalate_to: str = \"\"  # \"human\" or agent name for review\n    46→\n    47→\n    48→# ── Risk Classification ──────────────────────────────────────────────\n    49→\n    50→_SAFE_PATTERNS = [\n    51→    \"read\", \"list\", \"show\", \"display\", \"search\", \"grep\", \"find\",\n    52→    \"status\", \"check\", \"ls\", \"cat\", \"head\", \"tail\", \"echo\",\n    53→]\n    54→\n    55→_LOW_RISK_PATTERNS = [\n    56→    \"write note\", \"log\", \"append\", \"create test\", \"add comment\",\n    57→    \"format\", \"lint\", \"git status\", \"git diff\", \"git log\",\n    58→]\n    59→\n    60→_MEDIUM_RISK_PATTERNS = [\n    61→    \"edit\", \"modify\", \"update\", \"change\", \"refactor\", \"rename\",\n    62→    \"install\", \"pip install\", \"npm install\", \"git add\", \"git commit\",\n    63→]\n    64→\n    65→_HIGH_RISK_PATTERNS = [\n    66→    \"deploy\", \"push\", \"publish\", \"migrate\", \"schema change\",\n    67→    \"api call\", \"http request\", \"subprocess\", \"exec\",\n    68→    \"git push\", \"create pr\", \"merge\",\n    69→]\n    70→\n    71→_CRITICAL_PATTERNS = [\n    72→    \"delete\", \"rm -rf\", \"drop table\", \"force push\", \"reset --hard\",\n    73→    \"production\", \"credential\", \"secret\", \"api key\", \"token\",\n    74→    \"chmod 777\", \"kill\", \"terminate\",\n    75→]\n    76→\n    77→\n    78→class AdaptiveAutonomy:\n    79→    \"\"\"Dynamic autonomy adjustment engine.\n    80→\n    81→    Tracks success/failure history and adjusts how much freedom\n    82→    agents get for different risk levels.\n    83→    \"\"\"\n    84→\n    85→    def __init__(\n    86→        self,\n    87→        base_level: str = \"balanced\",\n    88→        history_size: int = 50,\n    89→        quiet_hours: set[int] | None = None,\n    90→    ):\n    91→        self._base = base_level\n    92→        self._history: deque[bool] = deque(maxlen=history_size)\n    93→        self._quiet_hours = quiet_hours or {2, 3, 4}\n    94→        self._consecutive_failures: int = 0\n    95→        self._total_decisions: int = 0\n    96→\n    97→    @property\n    98→    def success_rate(self) -> float:\n    99→        \"\"\"Current success rate from recent history.\"\"\"\n   100→        if not self._history:\n   101→            return 1.0\n   102→        return sum(1 for x in self._history if x) / len(self._history)\n   103→\n   104→    @property\n   105→    def effective_level(self) -> str:\n   106→        \"\"\"Current effective autonomy level (may differ from base).\"\"\"\n   107→        rate = self.success_rate\n   108→\n   109→        # Downgrade autonomy on poor performance\n   110→        if self._consecutive_failures >= 3:\n   111→            return \"locked\"\n   112→        if rate < 0.5:\n   113→            return \"cautious\"\n   114→        if rate < 0.7 and self._base in (\"aggressive\", \"full\"):\n   115→            return \"balanced\"\n   116→\n   117→        # Quiet hours → more cautious\n   118→        if time.localtime().tm_hour in self._quiet_hours:\n   119→            if self._base in (\"aggressive\", \"full\"):\n   120→                return \"balanced\"\n   121→\n   122→        return self._base\n   123→\n   124→    def classify_risk(self, action: str) -> RiskLevel:\n   125→        \"\"\"Classify the risk level of an action.\"\"\"\n   126→        action_lower = action.lower()\n   127→\n   128→        for pattern in _CRITICAL_PATTERNS:\n   129→            if pattern in action_lower:\n   130→                return RiskLevel.CRITICAL\n   131→\n   132→        for pattern in _HIGH_RISK_PATTERNS:\n   133→            if pattern in action_lower:\n   134→                return RiskLevel.HIGH\n   135→\n   136→        for pattern in _MEDIUM_RISK_PATTERNS:\n   137→            if pattern in action_lower:\n   138→                return RiskLevel.MEDIUM\n   139→\n   140→        for pattern in _LOW_RISK_PATTERNS:\n   141→            if pattern in action_lower:\n   142→                return RiskLevel.LOW\n   143→\n   144→        for pattern in _SAFE_PATTERNS:\n   145→            if pattern in action_lower:\n   146→                return RiskLevel.SAFE\n   147→\n   148→        return RiskLevel.MEDIUM  # default to medium if unknown\n   149→\n   150→    def should_auto_approve(\n   151→        self,\n   152→        action: str,\n   153→        risk: RiskLevel | None = None,\n   154→        confidence: float = 0.5,\n   155→    ) -> AutonomyDecision:\n   156→        \"\"\"Decide whether to auto-approve an action.\n   157→\n   158→        Combines base autonomy, risk level, confidence, and history.\n   159→        \"\"\"\n   160→        if risk is None:\n   161→            risk = self.classify_risk(action)\n   162→\n   163→        level = self.effective_level\n   164→        self._total_decisions += 1\n   165→\n   166→        # Decision matrix: level × risk → auto_approve\n   167→        auto = self._check_matrix(level, risk, confidence)\n   168→\n   169→        reason_parts: list[str] = []\n   170→        if not auto:\n   171→            reason_parts.append(f\"level={level}\")\n   172→            reason_parts.append(f\"risk={risk.value}\")\n   173→            if confidence < 0.5:\n   174→                reason_parts.append(f\"low_confidence={confidence:.2f}\")\n   175→            if self._consecutive_failures > 0:\n   176→                reason_parts.append(\n   177→                    f\"consecutive_failures={self._consecutive_failures}\"\n   178→                )\n   179→\n   180→        escalate = \"\"\n   181→        if not auto:\n   182→            escalate = \"human\" if risk in (RiskLevel.CRITICAL, RiskLevel.HIGH) else \"\"\n   183→\n   184→        return AutonomyDecision(\n   185→            action=action,\n   186→            risk=risk,\n   187→            confidence=confidence,\n   188→            auto_approve=auto,\n   189→            reason=\"; \".join(reason_parts) if reason_parts else \"auto-approved\",\n   190→            escalate_to=escalate,\n   191→        )\n   192→\n   193→    def record_outcome(self, success: bool) -> None:\n   194→        \"\"\"Record the outcome of an action. Updates history and streaks.\"\"\"\n   195→        self._history.append(success)\n   196→        if success:\n   197→            self._consecutive_failures = 0\n   198→        else:\n   199→            self._consecutive_failures += 1\n   200→            if self._consecutive_failures >= 3:\n   201→                logger.warning(\n   202→                    \"Autonomy degraded: %d consecutive failures\",\n   203→                    self._consecutive_failures,\n   204→                )\n   205→\n   206→    def reset(self) -> None:\n   207→        \"\"\"Reset history and streaks.\"\"\"\n   208→        self._history.clear()\n   209→        self._consecutive_failures = 0\n   210→        self._total_decisions = 0\n   211→\n   212→    def stats(self) -> dict:\n   213→        \"\"\"Return autonomy statistics.\"\"\"\n   214→        return {\n   215→            \"base_level\": self._base,\n   216→            \"effective_level\": self.effective_level,\n   217→            \"success_rate\": round(self.success_rate, 3),\n   218→            \"consecutive_failures\": self._consecutive_failures,\n   219→            \"total_decisions\": self._total_decisions,\n   220→            \"history_size\": len(self._history),\n   221→        }\n   222→\n   223→    def _check_matrix(\n   224→        self, level: str, risk: RiskLevel, confidence: float\n   225→    ) -> bool:\n   226→        \"\"\"The autonomy decision matrix.\n   227→\n   228→        Returns True if the action should be auto-approved.\n   229→        \"\"\"\n   230→        # CRITICAL risk — never auto-approve (only human can approve)\n   231→        if risk == RiskLevel.CRITICAL:\n   232→            return False\n   233→\n   234→        # LOCKED — never auto-approve anything\n   235→        if level == \"locked\":\n   236→            return False\n   237→\n   238→        # CAUTIOUS — only auto-approve SAFE actions\n   239→        if level == \"cautious\":\n   240→            return risk == RiskLevel.SAFE\n   241→\n   242→        # BALANCED — auto-approve SAFE and LOW, ask for MEDIUM+\n   243→        if level == \"balanced\":\n   244→            if risk in (RiskLevel.SAFE, RiskLevel.LOW):\n   245→                return True\n   246→            # MEDIUM with high confidence → auto\n   247→            if risk == RiskLevel.MEDIUM and confidence >= 0.8:\n   248→                return True\n   249→            return False\n   250→\n   251→        # AGGRESSIVE — auto-approve up to HIGH (with good confidence)\n   252→        if level == \"aggressive\":\n   253→            if risk in (RiskLevel.SAFE, RiskLevel.LOW, RiskLevel.MEDIUM):\n   254→                return True\n   255→            if risk == RiskLevel.HIGH and confidence >= 0.7:\n   256→                return True\n   257→            return False\n   258→\n   259→        # FULL — auto-approve everything except CRITICAL\n   260→        if level == \"full\":\n   261→            return True\n   262→\n   263→        return False\n   264→"}]},"uuid":"a59a5a04-68fc-44f1-a915-febe28872888","timestamp":"2026-03-15T14:18:42.249Z","sourceToolAssistantUUID":"4f4468f7-2585-4d7a-9432-73628aa0cbfd","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
