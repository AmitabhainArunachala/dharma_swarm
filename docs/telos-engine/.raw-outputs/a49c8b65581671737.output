{"parentUuid":"5e0ec346-46bd-4419-ac1e-913cbaebd58e","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49c8b65581671737","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q3sMatvToieqYmzMECmjMT","type":"tool_result","content":"   100→    diff: str = \"\"\n   101→    status: EvolutionStatus = EvolutionStatus.PENDING\n   102→    predicted_fitness: float = 0.0\n   103→    actual_fitness: Optional[FitnessScore] = None\n   104→    gate_decision: Optional[str] = None\n   105→    gate_reason: Optional[str] = None\n   106→    reflection_attempts: int = 0\n   107→    reflection_suggestions: list[str] = Field(default_factory=list)\n   108→    test_results: dict[str, Any] = Field(default_factory=dict)\n   109→    cycle_id: str | None = None\n   110→    execution_profile: str = \"default\"\n   111→    execution_matched_pattern: str | None = None\n   112→    execution_workspace: str | None = None\n   113→    execution_test_command: str | None = None\n   114→    execution_timeout: float | None = None\n   115→    execution_risk_level: str = \"medium\"\n   116→    execution_rollback_policy: str = \"revert_patch\"\n   117→    execution_expected_metrics: list[str] = Field(default_factory=list)\n   118→    evidence_tier: str = EvidenceTier.UNVALIDATED.value\n   119→    promotion_state: str = PromotionState.CANDIDATE.value\n   120→    experiment_id: str | None = None\n   121→    metadata: dict[str, Any] | None = None\n   122→\n   123→    @field_validator('component')\n   124→    @classmethod\n   125→    def validate_component_path(cls, v: str) -> str:\n   126→        \"\"\"Ensure component is a valid filesystem path.\"\"\"\n   127→        invalid_chars = ['<', '>', ':', '\"', '|', '?', '*']\n   128→        for char in invalid_chars:\n   129→            if char in v:\n   130→                raise ValueError(f\"Component contains invalid filesystem character '{char}'\")\n   131→        return v\n   132→\n   133→\n   134→class CycleResult(BaseModel):\n   135→    \"\"\"Summary of a single evolution cycle run.\"\"\"\n   136→\n   137→    cycle_id: str = Field(default_factory=_new_id)\n   138→    plan_id: str = \"\"\n   139→    proposals_submitted: int = 0\n   140→    proposals_gated: int = 0\n   141→    proposals_tested: int = 0\n   142→    proposals_archived: int = 0\n   143→    circuit_breakers_tripped: int = 0\n   144→    strategy_pivots: int = 0\n   145→    best_fitness: float = 0.0\n   146→    exploration_ratio: float = 0.0\n   147→    convergence_restart_triggered: bool = False\n   148→    restart_cycles_remaining: int = 0\n   149→    mutation_rate_applied: float = 0.0\n   150→    landscape_basin: str | None = None\n   151→    adaptive_strategy: str | None = None\n   152→    duration_seconds: float = 0.0\n   153→    reflection: str = \"\"\n   154→    lessons_learned: list[str] = Field(default_factory=list)\n   155→\n   156→\n   157→class EvolutionPlan(BaseModel):\n   158→    \"\"\"Planner output consumed by execution loops.\"\"\"\n   159→\n   160→    id: str = Field(default_factory=_new_id)\n   161→    planner_agent: str = \"darwin_planner\"\n   162→    summary: str = \"\"\n   163→    ordered_proposal_ids: list[str] = Field(default_factory=list)\n   164→    steps: list[str] = Field(default_factory=list)\n   165→    created_at: str = Field(default_factory=lambda: _utc_now().isoformat())\n   166→\n   167→\n   168→# ---------------------------------------------------------------------------\n   169→# Darwin Engine\n   170→# ---------------------------------------------------------------------------\n   171→\n   172→\n   173→class DarwinEngine:\n   174→    \"\"\"Orchestrates the full evolution cycle.\n   175→\n   176→    Creates proposals, runs them through dharmic safety gates, evaluates\n   177→    fitness, archives results, and selects parents for the next generation.\n   178→\n   179→    Args:\n   180→        archive_path: Path to the JSONL evolution archive. Defaults to\n   181→            ``~/.dharma/evolution/archive.jsonl``.\n   182→        traces_path: Base path for the trace store. Defaults to\n   183→            ``~/.dharma/traces``.\n   184→        predictor_path: Path to the fitness predictor history file.\n   185→            Defaults to ``~/.dharma/evolution/predictor_data.jsonl``.\n   186→        custom_fitness_weights: Optional custom weighting for fitness scoring.\n   187→            Partial overrides are merged onto canonical defaults.\n   188→    \"\"\"\n   189→\n   190→    def __init__(\n   191→        self,\n   192→        archive_path: Path | None = None,\n   193→        traces_path: Path | None = None,\n   194→        predictor_path: Path | None = None,\n   195→        circuit_breaker_limit: int = 3,\n   196→        max_reflection_reroutes: int = 2,\n   197→        custom_fitness_weights: dict[str, float] | None = None,\n   198→        use_ucb: bool = False,\n   199→        ucb_config: UCBConfig | None = None,\n   200→        convergence_config: ConvergenceConfig | None = None,\n   201→        mutation_rate: float = 0.1,\n   202→        landscape_probe_interval: int = 5,\n   203→        max_cycle_tokens: int = 0,\n   204→        landscape_probe_workspace: Path | None = None,\n   205→        landscape_probe_test_command: str = \"python3 -m pytest tests/ -q --tb=short\",\n   206→        landscape_probe_timeout: float = 60.0,\n   207→        probe_targets: ExecutionProfileRegistry | list[dict[str, Any]] | None = None,\n   208→        meta_evolution_interval: int = 0,\n   209→        meta_archive_path: Path | None = None,\n   210→        meta_poor_fitness_threshold: float = 0.5,\n   211→        meta_auto_apply: bool = True,\n   212→        experiment_log_path: Path | None = None,\n   213→        router_drift_thresholds: DriftGuardThresholds | None = None,\n   214→    ) -> None:\n   215→        self.archive = EvolutionArchive(path=archive_path)\n   216→        self.traces = TraceStore(base_path=traces_path)\n   217→        self.predictor = FitnessPredictor(history_path=predictor_path)\n   218→        self.experiment_log = ExperimentLog(\n   219→            path=experiment_log_path or (self.archive.path.parent / \"experiments.jsonl\")\n   220→        )\n   221→        self.experiment_memory = ExperimentMemory()\n   222→        self._circuit_breaker_limit = max(1, int(circuit_breaker_limit))\n   223→        self._max_reflection_reroutes = max(0, int(max_reflection_reroutes))\n   224→        self._fitness_weights = normalize_fitness_weights(custom_fitness_weights)\n   225→        self.use_ucb = bool(use_ucb)\n   226→        self.ucb_selector = UCBParentSelector(ucb_config)\n   227→        self.convergence_detector = ConvergenceDetector(convergence_config)\n   228→        self._base_mutation_rate = max(0.01, float(mutation_rate))\n   229→        self._map_elites_n_bins = self.archive.grid.n_bins\n   230→        self._landscape_probe_interval = max(1, int(landscape_probe_interval))\n   231→        self._landscape_probe_workspace = (\n   232→            Path(landscape_probe_workspace).resolve()\n   233→            if landscape_probe_workspace is not None\n   234→            else None\n   235→        )\n   236→        self._landscape_probe_test_command = landscape_probe_test_command\n   237→        self._landscape_probe_timeout = float(landscape_probe_timeout)\n   238→        self.execution_profile_registry = ExecutionProfileRegistry.from_configs(\n   239→            probe_targets\n   240→        )\n   241→        self._meta_evolution_interval = max(0, int(meta_evolution_interval))\n   242→        self.last_meta_evolution_result: Any | None = None\n   243→        self.last_coordination_summary: dict[str, Any] = {}\n   244→        self._meta_evolution_engine: Any | None = None\n   245→        if self._meta_evolution_interval > 0:\n   246→            from dharma_swarm.meta_evolution import MetaEvolutionEngine\n   247→\n   248→            self._meta_evolution_engine = MetaEvolutionEngine(\n   249→                self,\n   250→                meta_archive_path=meta_archive_path,\n   251→                n_object_cycles_per_meta=self._meta_evolution_interval,\n   252→                poor_meta_fitness_threshold=meta_poor_fitness_threshold,\n   253→                auto_apply=meta_auto_apply,\n   254→            )\n   255→        self._router_drift_thresholds = router_drift_thresholds or DriftGuardThresholds()\n   256→        self._completed_cycles = 0\n   257→        self._adaptive_strategy = \"explore\"\n   258→        self._max_cycle_tokens = max(0, int(max_cycle_tokens))\n   259→        self._session_tokens_used = 0\n   260→        self.last_landscape_probe: LandscapeProbe | None = None\n   261→        self.last_experiment_memory: ExperimentMemorySnapshot | None = None\n   262→        self.landscape_mapper = FitnessLandscapeMapper(self)\n   263→        self._forge: Any | None = None\n   264→        self._system_rv: Any | None = None\n   265→        self._dse_integrator: Any | None = None\n   266→        self._initialized: bool = False\n   267→        # Phase 4 velocity: content-hash skip for unchanged files\n   268→        self._file_hashes: dict[str, str] = {}\n   269→        # Phase 4 velocity: pending background trace tasks\n   270→        self._trace_tasks: set[asyncio.Task[None]] = set()\n   271→\n   272→    # -- Phase 4: fire-and-forget trace helper --------------------------------\n   273→\n   274→    def _trace_bg(self, entry: TraceEntry) -> None:\n   275→        \"\"\"Log a trace entry in the background without blocking the caller.\"\"\"\n   276→        task = asyncio.create_task(self.traces.log_entry(entry))\n   277→        self._trace_tasks.add(task)\n   278→        task.add_done_callback(self._trace_tasks.discard)\n   279→\n   280→    def get_fitness_weights(self) -> dict[str, float]:\n   281→        \"\"\"Return the active normalized fitness weights.\"\"\"\n   282→        return dict(self._fitness_weights)\n   283→\n   284→    def set_fitness_weights(\n   285→        self,\n   286→        weights: dict[str, float] | None = None,\n   287→    ) -> dict[str, float]:\n   288→        \"\"\"Set active fitness weights, falling back to canonical defaults.\"\"\"\n   289→        self._fitness_weights = normalize_fitness_weights(weights)\n   290→        return self.get_fitness_weights()\n   291→\n   292→    def score_fitness(self, fitness: FitnessScore | None) -> float:\n   293→        \"\"\"Score a fitness vector using the engine's active weights.\"\"\"\n   294→        if fitness is None:\n   295→            return 0.0\n   296→        return fitness.weighted(weights=self._fitness_weights)\n   297→\n   298→    def get_meta_parameter_state(self) -> dict[str, Any]:\n   299→        \"\"\"Export the engine knobs used by meta-evolution.\"\"\""}]},"uuid":"213b84cb-4518-4410-96dc-401fb038ebcd","timestamp":"2026-03-15T14:18:32.534Z","sourceToolAssistantUUID":"5e0ec346-46bd-4419-ac1e-913cbaebd58e","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
