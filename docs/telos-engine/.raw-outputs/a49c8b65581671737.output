{"parentUuid":"87ef5e88-6975-4709-be9f-13b3c52cb69f","isSidechain":true,"agentId":"a49c8b65581671737","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_01K4csoCZfkxgSA5yRrStSvr","toolUseID":"toolu_01K4csoCZfkxgSA5yRrStSvr","timestamp":"2026-03-15T14:18:18.562Z","uuid":"da7073d7-6e3a-4340-a3da-db81373f64b2","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"da7073d7-6e3a-4340-a3da-db81373f64b2","isSidechain":true,"agentId":"a49c8b65581671737","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01K4csoCZfkxgSA5yRrStSvr","toolUseID":"toolu_01K4csoCZfkxgSA5yRrStSvr","timestamp":"2026-03-15T14:18:18.563Z","uuid":"9e9be285-1eea-4f93-b2b0-9b8ad00dd110","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"8d27c0d7-abdd-4a9c-8399-91d3146a07c5","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49c8b65581671737","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K4csoCZfkxgSA5yRrStSvr","type":"tool_result","content":"     1→\"\"\"Stigmergic lattice -- emergent intelligence through accumulated marks.\n     2→\n     3→Agents leave marks on the environment (files they touch), creating\n     4→pheromone-trail-like coordination without direct communication.  Like\n     5→ant colonies: no single agent holds the whole picture, but the\n     6→accumulated observations form a shared intelligence layer.\n     7→\n     8→Uses JSONL for append-friendly persistence and ``aiofiles`` for\n     9→non-blocking I/O.\n    10→\"\"\"\n    11→\n    12→from __future__ import annotations\n    13→\n    14→from datetime import datetime, timedelta, timezone\n    15→from pathlib import Path\n    16→from typing import Literal\n    17→\n    18→import aiofiles\n    19→from pydantic import BaseModel, Field\n    20→\n    21→from dharma_swarm.models import _new_id, _utc_now\n    22→\n    23→# ---------------------------------------------------------------------------\n    24→# Data model\n    25→# ---------------------------------------------------------------------------\n    26→\n    27→Action = Literal[\"read\", \"write\", \"scan\", \"connect\", \"dream\"]\n    28→\n    29→\n    30→class StigmergicMark(BaseModel):\n    31→    \"\"\"A single mark left by an agent on the stigmergic lattice.\"\"\"\n    32→\n    33→    id: str = Field(default_factory=_new_id)\n    34→    timestamp: datetime = Field(default_factory=_utc_now)\n    35→    agent: str\n    36→    file_path: str\n    37→    action: Action\n    38→    observation: str = Field(max_length=200)\n    39→    salience: float = 0.5\n    40→    connections: list[str] = Field(default_factory=list)\n    41→    access_count: int = 0\n    42→\n    43→\n    44→# ---------------------------------------------------------------------------\n    45→# Store\n    46→# ---------------------------------------------------------------------------\n    47→\n    48→_DEFAULT_BASE = Path.home() / \".dharma\" / \"stigmergy\"\n    49→\n    50→\n    51→class StigmergyStore:\n    52→    \"\"\"File-backed stigmergic mark store.\n    53→\n    54→    Marks are appended to a JSONL file for fast writes.  Decay moves\n    55→    old marks to an archive file, keeping the hot file lean.\n    56→\n    57→    All public methods (except ``density``) are async, backed by\n    58→    ``aiofiles`` so the event loop never blocks.\n    59→    \"\"\"\n    60→\n    61→    def __init__(self, base_path: Path | None = None) -> None:\n    62→        self.base_path: Path = base_path or _DEFAULT_BASE\n    63→        self._marks_file: Path = self.base_path / \"marks.jsonl\"\n    64→        self._archive_file: Path = self.base_path / \"archive.jsonl\"\n    65→\n    66→    # -- write ---------------------------------------------------------------\n    67→\n    68→    async def leave_mark(self, mark: StigmergicMark) -> str:\n    69→        \"\"\"Append *mark* as a JSON line and return its id.\"\"\"\n    70→        self.base_path.mkdir(parents=True, exist_ok=True)\n    71→        line = mark.model_dump_json() + \"\\n\"\n    72→        async with aiofiles.open(self._marks_file, \"a\") as f:\n    73→            await f.write(line)\n    74→        return mark.id\n    75→\n    76→    # -- read ----------------------------------------------------------------\n    77→\n    78→    async def _load_marks(self) -> list[StigmergicMark]:\n    79→        \"\"\"Read all marks from the JSONL file.\"\"\"\n    80→        if not self._marks_file.exists():\n    81→            return []\n    82→        marks: list[StigmergicMark] = []\n    83→        async with aiofiles.open(self._marks_file, \"r\") as f:\n    84→            async for line in f:\n    85→                stripped = line.strip()\n    86→                if stripped:\n    87→                    marks.append(StigmergicMark.model_validate_json(stripped))\n    88→        return marks\n    89→\n    90→    async def read_marks(\n    91→        self,\n    92→        file_path: str | None = None,\n    93→        limit: int = 20,\n    94→    ) -> list[StigmergicMark]:\n    95→        \"\"\"Return recent marks, optionally filtered by *file_path*.\n    96→\n    97→        Results are sorted newest-first and capped at *limit*.\n    98→        \"\"\"\n    99→        marks = await self._load_marks()\n   100→        if file_path is not None:\n   101→            marks = [m for m in marks if m.file_path == file_path]\n   102→        marks.sort(key=lambda m: m.timestamp, reverse=True)\n   103→        return marks[:limit]\n   104→\n   105→    async def hot_paths(\n   106→        self,\n   107→        window_hours: float = 24,\n   108→        min_marks: int = 3,\n   109→    ) -> list[tuple[str, int]]:\n   110→        \"\"\"Return file paths with heavy recent activity.\n   111→\n   112→        Only marks within the last *window_hours* are counted.  Paths\n   113→        with fewer than *min_marks* marks are excluded.  Sorted by count\n   114→        descending.\n   115→        \"\"\"\n   116→        cutoff = datetime.now(timezone.utc) - timedelta(hours=window_hours)\n   117→        marks = await self._load_marks()\n   118→        counts: dict[str, int] = {}\n   119→        for m in marks:\n   120→            if m.timestamp >= cutoff:\n   121→                counts[m.file_path] = counts.get(m.file_path, 0) + 1\n   122→        result = [(path, count) for path, count in counts.items() if count >= min_marks]\n   123→        result.sort(key=lambda t: t[1], reverse=True)\n   124→        return result\n   125→\n   126→    async def high_salience(\n   127→        self,\n   128→        threshold: float = 0.7,\n   129→        limit: int = 10,\n   130→    ) -> list[StigmergicMark]:\n   131→        \"\"\"Return marks with salience >= *threshold*, sorted descending.\"\"\"\n   132→        marks = await self._load_marks()\n   133→        filtered = [m for m in marks if m.salience >= threshold]\n   134→        filtered.sort(key=lambda m: m.salience, reverse=True)\n   135→        return filtered[:limit]\n   136→\n   137→    async def connections_for(self, file_path: str) -> list[str]:\n   138→        \"\"\"Collect unique connections from all marks referencing *file_path*.\"\"\"\n   139→        marks = await self._load_marks()\n   140→        connections: set[str] = set()\n   141→        for m in marks:\n   142→            if m.file_path == file_path:\n   143→                connections.update(m.connections)\n   144→        return sorted(connections)\n   145→\n   146→    async def query_relevant(self, task_keywords: list[str], limit: int = 10) -> list[StigmergicMark]:\n   147→        \"\"\"Filter marks by keyword overlap, sorted by salience (PULL protocol).\"\"\"\n   148→        if not task_keywords:\n   149→            return await self.high_salience(limit=limit)\n   150→        marks = await self._load_marks()\n   151→        keywords_lower = [kw.lower() for kw in task_keywords if kw.strip()]\n   152→        if not keywords_lower:\n   153→            return await self.high_salience(limit=limit)\n   154→        relevant = [m for m in marks if any(kw in (m.observation + \" \" + m.file_path).lower() for kw in keywords_lower)]\n   155→        relevant.sort(key=lambda m: m.salience, reverse=True)\n   156→        return relevant[:limit]\n   157→\n   158→    # -- maintenance ---------------------------------------------------------\n   159→\n   160→    async def decay(self, max_age_hours: float = 168) -> int:\n   161→        \"\"\"Move marks older than *max_age_hours* to the archive file.\n   162→\n   163→        Returns the count of archived marks.\n   164→        \"\"\"\n   165→        marks = await self._load_marks()\n   166→        if not marks:\n   167→            return 0\n   168→\n   169→        cutoff = datetime.now(timezone.utc) - timedelta(hours=max_age_hours)\n   170→        keep: list[StigmergicMark] = []\n   171→        archive: list[StigmergicMark] = []\n   172→\n   173→        for m in marks:\n   174→            if m.timestamp < cutoff:\n   175→                archive.append(m)\n   176→            else:\n   177→                keep.append(m)\n   178→\n   179→        if not archive:\n   180→            return 0\n   181→\n   182→        # Append old marks to archive file\n   183→        self.base_path.mkdir(parents=True, exist_ok=True)\n   184→        async with aiofiles.open(self._archive_file, \"a\") as f:\n   185→            for m in archive:\n   186→                await f.write(m.model_dump_json() + \"\\n\")\n   187→\n   188→        # Rewrite marks file with only the kept marks\n   189→        async with aiofiles.open(self._marks_file, \"w\") as f:\n   190→            for m in keep:\n   191→                await f.write(m.model_dump_json() + \"\\n\")\n   192→\n   193→        return len(archive)\n   194→\n   195→    async def access_decay(self, decay_factor: float = 0.95) -> int:\n   196→        \"\"\"Decay marks based on access count -- unused marks fade faster.\"\"\"\n   197→        marks = await self._load_marks()\n   198→        if not marks:\n   199→            return 0\n   200→        dead_count = 0\n   201→        for m in marks:\n   202→            exponent = max(1, 3 - m.access_count)\n   203→            m.salience *= decay_factor ** exponent\n   204→            if m.salience < 0.1:\n   205→                dead_count += 1\n   206→        self.base_path.mkdir(parents=True, exist_ok=True)\n   207→        async with aiofiles.open(self._marks_file, \"w\") as f:\n   208→            for m in marks:\n   209→                await f.write(m.model_dump_json() + \"\\n\")\n   210→        return dead_count\n   211→\n   212→    # -- sync helpers --------------------------------------------------------\n   213→\n   214→    def density(self) -> int:\n   215→        \"\"\"Synchronous count of marks in the hot file (for quick checks).\"\"\"\n   216→        if not self._marks_file.exists():\n   217→            return 0\n   218→        count = 0\n   219→        with open(self._marks_file, \"r\") as f:\n   220→            for line in f:\n   221→                if line.strip():\n   222→                    count += 1\n   223→        return count\n   224→\n   225→\n   226→# ---------------------------------------------------------------------------\n   227→# Module-level convenience\n   228→# ---------------------------------------------------------------------------\n   229→\n   230→\n   231→async def leave_stigmergic_mark(\n   232→    agent: str,\n   233→    file_path: str,\n   234→    observation: str,\n   235→    salience: float = 0.5,\n   236→    connections: list[str] | None = None,\n   237→    action: Action = \"write\",\n   238→) -> str:\n   239→    \"\"\"Create a mark and persist it via a default store. Returns the mark id.\"\"\"\n   240→    mark = StigmergicMark(\n   241→        agent=agent,\n   242→        file_path=file_path,\n   243→        action=action,\n   244→        observation=observation,\n   245→        salience=salience,\n   246→        connections=connections or [],\n   247→    )\n   248→    store = StigmergyStore()\n   249→    return await store.leave_mark(mark)\n   250→"}]},"uuid":"534dcc97-bad7-4f93-8e06-cf7f57f53824","timestamp":"2026-03-15T14:18:18.562Z","sourceToolAssistantUUID":"8d27c0d7-abdd-4a9c-8399-91d3146a07c5","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
