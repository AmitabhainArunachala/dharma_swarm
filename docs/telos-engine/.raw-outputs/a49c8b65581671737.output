{"parentUuid":"e53d3ebf-523d-49b6-9440-9c6b3e68745c","isSidechain":true,"agentId":"a49c8b65581671737","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01A32ecEwLgwNgDLKvxQv5R9","toolUseID":"toolu_01A32ecEwLgwNgDLKvxQv5R9","timestamp":"2026-03-15T14:18:26.855Z","uuid":"418db7ae-03a7-4696-a7d7-1307dc33cb55","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"1b39f396-8df3-4db6-82d1-311e3b0f966d","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49c8b65581671737","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A32ecEwLgwNgDLKvxQv5R9","type":"tool_result","content":"     1→\"\"\"Darwin Engine -- self-improvement orchestration loop.\n     2→\n     3→Coordinates the full evolution cycle: propose mutations, gate-check them,\n     4→evaluate fitness, archive results, and select parents for the next generation.\n     5→\n     6→Pipeline:\n     7→    PROPOSE -> GATE CHECK -> WRITE CODE -> TEST -> EVALUATE FITNESS -> ARCHIVE -> SELECT NEXT PARENT\n     8→\"\"\"\n     9→\n    10→from __future__ import annotations\n    11→\n    12→import asyncio\n    13→from collections import defaultdict\n    14→import hashlib\n    15→import logging\n    16→import re\n    17→import shutil\n    18→from tempfile import TemporaryDirectory\n    19→import time\n    20→from collections.abc import Callable\n    21→from enum import Enum\n    22→from pathlib import Path\n    23→from typing import Any, Optional\n    24→\n    25→from pydantic import BaseModel, Field, field_validator\n    26→\n    27→from dharma_swarm.archive import (\n    28→    ArchiveEntry,\n    29→    EvolutionArchive,\n    30→    FitnessScore,\n    31→    normalize_fitness_weights,\n    32→)\n    33→from dharma_swarm.convergence import ConvergenceConfig, ConvergenceDetector\n    34→from dharma_swarm.diff_applier import DiffApplier\n    35→from dharma_swarm.elegance import evaluate_elegance\n    36→from dharma_swarm.execution_profile import (\n    37→    EvidenceTier,\n    38→    ExecutionProfileRegistry,\n    39→    PromotionState,\n    40→    ResolvedExecutionProfile,\n    41→    derive_promotion_state,\n    42→)\n    43→from dharma_swarm.experiment_memory import ExperimentMemory, ExperimentMemorySnapshot\n    44→from dharma_swarm.experiment_log import ExperimentLog, ExperimentRecord\n    45→from dharma_swarm.fitness_predictor import FitnessPredictor, ProposalFeatures\n    46→from dharma_swarm.jikoku_instrumentation import jikoku_auto_span\n    47→from dharma_swarm.landscape import FitnessLandscapeMapper, LandscapeProbe\n    48→from dharma_swarm.models import GateDecision, GateResult, SandboxResult, _new_id, _utc_now\n    49→from dharma_swarm.router_retrospective import (\n    50→    DriftGuardDecision,\n    51→    DriftGuardThresholds,\n    52→    RouteOutcomeRecord,\n    53→    RouteRetrospectiveArtifact,\n    54→    build_route_policy_archive_entry,\n    55→    build_route_retrospective,\n    56→    evaluate_router_drift,\n    57→)\n    58→from dharma_swarm.selector import select_parent\n    59→from dharma_swarm.telos_gates import check_with_reflective_reroute\n    60→from dharma_swarm.traces import TraceEntry, TraceStore\n    61→from dharma_swarm.ucb_selector import UCBConfig, UCBParentSelector\n    62→\n    63→logger = logging.getLogger(__name__)\n    64→\n    65→\n    66→# ---------------------------------------------------------------------------\n    67→# Enums\n    68→# ---------------------------------------------------------------------------\n    69→\n    70→\n    71→class EvolutionStatus(str, Enum):\n    72→    \"\"\"Lifecycle status of an evolution proposal.\"\"\"\n    73→\n    74→    PENDING = \"pending\"\n    75→    REFLECTING = \"reflecting\"\n    76→    GATED = \"gated\"\n    77→    WRITING = \"writing\"\n    78→    TESTING = \"testing\"\n    79→    EVALUATED = \"evaluated\"\n    80→    ARCHIVED = \"archived\"\n    81→    REJECTED = \"rejected\"\n    82→\n    83→\n    84→# ---------------------------------------------------------------------------\n    85→# Data models\n    86→# ---------------------------------------------------------------------------\n    87→\n    88→\n    89→class Proposal(BaseModel):\n    90→    \"\"\"A proposed code change to be evaluated by the Darwin Engine.\"\"\"\n    91→\n    92→    id: str = Field(default_factory=_new_id)\n    93→    component: str\n    94→    change_type: str  # \"mutation\", \"crossover\", \"ablation\"\n    95→    description: str\n    96→    parent_id: Optional[str] = None\n    97→    spec_ref: str | None = None\n    98→    requirement_refs: list[str] = Field(default_factory=list)\n    99→    think_notes: str = \"\"\n   100→    diff: str = \"\""}]},"uuid":"ecf505b5-df2e-4fd3-be86-bb80eaf60f71","timestamp":"2026-03-15T14:18:26.854Z","sourceToolAssistantUUID":"1b39f396-8df3-4db6-82d1-311e3b0f966d","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
