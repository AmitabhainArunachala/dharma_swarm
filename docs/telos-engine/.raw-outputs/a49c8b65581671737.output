{"parentUuid":"b009297a-8ca6-4e72-9a12-8906299c7555","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49c8b65581671737","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0126UNqZR2k72rhoV2idw5Ej","type":"tool_result","content":"     1→\"\"\"Persisted meta-evolution for Darwin Engine hyperparameters.\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→import math\n     6→import random\n     7→from pathlib import Path\n     8→from statistics import mean, pvariance\n     9→from typing import Any, Mapping, Sequence\n    10→\n    11→from pydantic import BaseModel, Field, field_validator\n    12→\n    13→from dharma_swarm.archive import FITNESS_DIMENSIONS, normalize_fitness_weights\n    14→from dharma_swarm.evolution import CycleResult, DarwinEngine, Proposal\n    15→from dharma_swarm.models import _new_id, _utc_now\n    16→\n    17→\n    18→class MetaParameters(BaseModel):\n    19→    \"\"\"Evolution hyperparameters that can be adapted over time.\"\"\"\n    20→\n    21→    fitness_weights: dict[str, float] = Field(\n    22→        default_factory=normalize_fitness_weights,\n    23→    )\n    24→    mutation_rate: float = 0.1\n    25→    exploration_coeff: float = 1.0\n    26→    circuit_breaker_limit: int = 3\n    27→    map_elites_n_bins: int = 5\n    28→\n    29→    @field_validator(\"fitness_weights\", mode=\"before\")\n    30→    @classmethod\n    31→    def _normalize_weights(cls, value: dict[str, float] | None) -> dict[str, float]:\n    32→        return normalize_fitness_weights(value)\n    33→\n    34→\n    35→class MetaEvolutionResult(BaseModel):\n    36→    \"\"\"Outcome of one meta-evolution cycle.\"\"\"\n    37→\n    38→    id: str = Field(default_factory=_new_id)\n    39→    timestamp: str = Field(default_factory=lambda: _utc_now().isoformat())\n    40→    meta_parameters: MetaParameters\n    41→    object_cycles_completed: int = 0\n    42→    avg_fitness_trend: float = 0.0\n    43→    meta_fitness: float = 0.0\n    44→    improvement_over_baseline: float = 0.0\n    45→    fitness_trajectory: list[float] = Field(default_factory=list)\n    46→    trigger: str = \"manual\"\n    47→    source_cycle_ids: list[str] = Field(default_factory=list)\n    48→    evolved_parameters: bool = False\n    49→    applied_parameters: bool = False\n    50→    coordination_pressure: float = 0.0\n    51→    coordination_summary: dict[str, Any] = Field(default_factory=dict)\n    52→\n    53→\n    54→class MetaArchiveEntry(BaseModel):\n    55→    \"\"\"Archived meta-configuration with its observed performance.\"\"\"\n    56→\n    57→    id: str = Field(default_factory=_new_id)\n    58→    meta_parameters: MetaParameters\n    59→    meta_fitness: float\n    60→    n_object_cycles: int\n    61→    fitness_trajectory: list[float]\n    62→    created_at: str = Field(default_factory=lambda: _utc_now().isoformat())\n    63→\n    64→\n    65→class MetaEvolutionEngine:\n    66→    \"\"\"Run object-level Darwin cycles and evolve the hyperparameters above them.\"\"\"\n    67→\n    68→    def __init__(\n    69→        self,\n    70→        darwin_engine: DarwinEngine,\n    71→        meta_archive_path: Path | None = None,\n    72→        n_object_cycles_per_meta: int = 10,\n    73→        poor_meta_fitness_threshold: float = 0.5,\n    74→        auto_apply: bool = True,\n    75→        max_weight_shift: float = 0.08,\n    76→        max_mutation_delta: float = 0.05,\n    77→        max_exploration_delta: float = 0.25,\n    78→        max_circuit_breaker_delta: int = 1,\n    79→        max_grid_delta: int = 1,\n    80→        seed: int | None = None,"}]},"uuid":"273e26c5-e74d-4f80-b618-7a0c0261ea66","timestamp":"2026-03-15T14:18:50.646Z","sourceToolAssistantUUID":"b009297a-8ca6-4e72-9a12-8906299c7555","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
