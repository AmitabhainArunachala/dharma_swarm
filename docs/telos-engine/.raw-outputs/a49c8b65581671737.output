{"parentUuid":"ec7caf42-23fb-4eb2-bcb1-8743e33d6e59","isSidechain":true,"agentId":"a49c8b65581671737","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_01KsVRLbH7vSrsE6ptvMRydM","toolUseID":"toolu_01KsVRLbH7vSrsE6ptvMRydM","timestamp":"2026-03-15T14:18:27.391Z","uuid":"c1275d04-485c-4215-b1c1-352fbeb4680e","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"c1275d04-485c-4215-b1c1-352fbeb4680e","isSidechain":true,"agentId":"a49c8b65581671737","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_01KsVRLbH7vSrsE6ptvMRydM","toolUseID":"toolu_01KsVRLbH7vSrsE6ptvMRydM","timestamp":"2026-03-15T14:18:27.391Z","uuid":"40fba524-803c-4ec8-8062-30324c0cfafb","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"6a0d70ba-b79b-44c3-98f1-7bb0d3ae00b3","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49c8b65581671737","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KsVRLbH7vSrsE6ptvMRydM","type":"tool_result","content":"     1→\"\"\"Signal Bus — in-process event bus for inter-loop temporal coherence.\n     2→\n     3→The shared downbeat. Loops emit typed signals; other loops drain and respond.\n     4→This is the ONLY mechanism for loops to feel each other's rhythms.\n     5→\n     6→Not a message bus (that's agent-to-agent). This is loop-to-loop:\n     7→  - cascade emits CASCADE_EIGENFORM_DISTANCE\n     8→  - audit emits ANOMALY_DETECTED\n     9→  - recognition emits RECOGNITION_UPDATED\n    10→  - swarm drains ANOMALY_DETECTED to suppress director during crises\n    11→\n    12→Events expire after a configurable TTL (default: 2 cycle intervals).\n    13→Thread-safe via asyncio primitives (designed for single event loop).\n    14→\"\"\"\n    15→\n    16→from __future__ import annotations\n    17→\n    18→import time\n    19→from collections import deque\n    20→from typing import Any\n    21→\n    22→\n    23→class SignalBus:\n    24→    \"\"\"Simple in-process event bus for inter-loop signaling.\n    25→\n    26→    Not async — emit/drain are synchronous because they only touch\n    27→    an in-memory deque.  Designed for a single asyncio event loop\n    28→    where all loops share one bus instance.\n    29→\n    30→    Attributes:\n    31→        ttl_seconds: Events older than this are dropped on drain.\n    32→    \"\"\"\n    33→\n    34→    def __init__(self, ttl_seconds: float = 300.0) -> None:\n    35→        self.ttl_seconds = ttl_seconds\n    36→        self._events: deque[tuple[float, dict[str, Any]]] = deque()\n    37→\n    38→    def emit(self, event: dict[str, Any]) -> None:\n    39→        \"\"\"Emit a signal event.\n    40→\n    41→        Args:\n    42→            event: Dict with at minimum a ``\"type\"`` key (str).\n    43→                   Additional keys are payload.\n    44→\n    45→        Example::\n    46→\n    47→            bus.emit({\"type\": \"ANOMALY_DETECTED\", \"severity\": \"high\"})\n    48→        \"\"\"\n    49→        self._events.append((time.monotonic(), event))\n    50→\n    51→    def drain(\n    52→        self,\n    53→        event_types: list[str] | None = None,\n    54→    ) -> list[dict[str, Any]]:\n    55→        \"\"\"Consume matching events, removing expired ones.\n    56→\n    57→        Args:\n    58→            event_types: If provided, only return events whose ``\"type\"``\n    59→                         is in this list.  If None, return all events.\n    60→\n    61→        Returns:\n    62→            List of event dicts that matched (consumed — won't appear again).\n    63→        \"\"\"\n    64→        now = time.monotonic()\n    65→        cutoff = now - self.ttl_seconds\n    66→\n    67→        # Separate into: expired (drop), matched (return), kept (stay)\n    68→        matched: list[dict[str, Any]] = []\n    69→        kept: deque[tuple[float, dict[str, Any]]] = deque()\n    70→\n    71→        while self._events:\n    72→            ts, event = self._events.popleft()\n    73→            if ts < cutoff:\n    74→                continue  # expired — drop\n    75→            event_type = event.get(\"type\", \"\")\n    76→            if event_types is None or event_type in event_types:\n    77→                matched.append(event)\n    78→            else:\n    79→                kept.append((ts, event))\n    80→\n    81→        self._events = kept\n    82→        return matched\n    83→\n    84→    def peek(\n    85→        self,\n    86→        event_types: list[str] | None = None,\n    87→    ) -> list[dict[str, Any]]:\n    88→        \"\"\"Like drain, but non-destructive — events stay in the bus.\n    89→\n    90→        Args:\n    91→            event_types: Filter by type, or None for all.\n    92→\n    93→        Returns:\n    94→            List of matching event dicts (not consumed).\n    95→        \"\"\"\n    96→        now = time.monotonic()\n    97→        cutoff = now - self.ttl_seconds\n    98→\n    99→        return [\n   100→            event\n   101→            for ts, event in self._events\n   102→            if ts >= cutoff\n   103→            and (event_types is None or event.get(\"type\", \"\") in event_types)\n   104→        ]\n   105→\n   106→    @property\n   107→    def pending_count(self) -> int:\n   108→        \"\"\"Number of non-expired events currently in the bus.\"\"\"\n   109→        now = time.monotonic()\n   110→        cutoff = now - self.ttl_seconds\n   111→        return sum(1 for ts, _ in self._events if ts >= cutoff)\n   112→\n   113→    def clear(self) -> None:\n   114→        \"\"\"Drop all events.\"\"\"\n   115→        self._events.clear()\n   116→\n   117→    # Module-level singleton\n   118→    _instance: SignalBus | None = None\n   119→\n   120→    @classmethod\n   121→    def get(cls) -> SignalBus:\n   122→        \"\"\"Return the module-level singleton SignalBus instance.\"\"\"\n   123→        if cls._instance is None:\n   124→            cls._instance = cls()\n   125→        return cls._instance\n   126→"}]},"uuid":"7676d6ef-f0aa-4f36-bc0a-b238d04acb0e","timestamp":"2026-03-15T14:18:27.391Z","sourceToolAssistantUUID":"6a0d70ba-b79b-44c3-98f1-7bb0d3ae00b3","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
