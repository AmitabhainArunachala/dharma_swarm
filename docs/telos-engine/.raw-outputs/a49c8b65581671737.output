{"parentUuid":"17c69b34-35fe-4c90-8f7b-1181b8a31b9f","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49c8b65581671737","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XTjSbPtwsX3RdDqW8ecgrn","type":"tool_result","content":"     1→\"\"\"Universal Loop Engine — F(S) = S.\n     2→\n     3→The cascade engine runs any domain through the universal pattern:\n     4→  GENERATE → TEST → SCORE → GATE → eigenform check → MUTATE → SELECT → repeat\n     5→\n     6→Phase functions are resolved via importlib from string refs in LoopDomain.\n     7→Handles both sync and async callables.\n     8→\n     9→The META domain evolves LoopDomain configs themselves — the strange loop\n    10→where the system's configuration is a candidate for its own optimization.\n    11→\"\"\"\n    12→\n    13→from __future__ import annotations\n    14→\n    15→import asyncio\n    16→import importlib\n    17→import inspect\n    18→import logging\n    19→import time\n    20→from collections.abc import Callable\n    21→from typing import Any\n    22→\n    23→from dharma_swarm.checkpoint import (\n    24→    CheckpointStore,\n    25→    InterruptDecision,\n    26→    InterruptGate,\n    27→    InterruptRequest,\n    28→    LoopCheckpoint,\n    29→)\n    30→from dharma_swarm.models import LoopDomain, LoopResult\n    31→\n    32→logger = logging.getLogger(__name__)\n    33→\n    34→# Module-level singletons — shared across all engine runs\n    35→_checkpoint_store = CheckpointStore()\n    36→_interrupt_gate = InterruptGate()\n    37→\n    38→\n    39→# ---------------------------------------------------------------------------\n    40→# Domain registry\n    41→# ---------------------------------------------------------------------------\n    42→\n    43→_DOMAIN_MODULES: dict[str, str] = {\n    44→    \"code\": \"dharma_swarm.cascade_domains.code\",\n    45→    \"product\": \"dharma_swarm.cascade_domains.product\",\n    46→    \"skill\": \"dharma_swarm.cascade_domains.skill\",\n    47→    \"research\": \"dharma_swarm.cascade_domains.research\",\n    48→    \"meta\": \"dharma_swarm.cascade_domains.meta\",\n    49→}\n    50→\n    51→\n    52→def get_registered_domains() -> dict[str, LoopDomain]:\n    53→    \"\"\"Load all registered domain configs.\"\"\"\n    54→    domains: dict[str, LoopDomain] = {}\n    55→    for name, module_path in _DOMAIN_MODULES.items():\n    56→        try:\n    57→            mod = importlib.import_module(module_path)\n    58→            domains[name] = mod.get_domain()\n    59→        except Exception as e:\n    60→            logger.warning(\"Failed to load domain %s: %s\", name, e)\n    61→    return domains\n    62→\n    63→\n    64→# ---------------------------------------------------------------------------\n    65→# Function resolution\n    66→# ---------------------------------------------------------------------------\n    67→\n    68→def _resolve_fn(dotted_path: str) -> Callable[..., Any]:\n    69→    \"\"\"Resolve a dotted import path to a callable.\n    70→\n    71→    E.g. \"dharma_swarm.cascade_domains.code.generate\" →\n    72→         the generate function from code.py.\n    73→    \"\"\"\n    74→    parts = dotted_path.rsplit(\".\", 1)\n    75→    if len(parts) != 2:\n    76→        raise ImportError(f\"Invalid function path: {dotted_path!r}\")\n    77→    module_path, fn_name = parts\n    78→    mod = importlib.import_module(module_path)\n    79→    fn = getattr(mod, fn_name)\n    80→    if not callable(fn):\n    81→        raise TypeError(f\"{dotted_path} is not callable\")\n    82→    return fn\n    83→\n    84→\n    85→async def _call(fn: Callable[..., Any], *args: Any, **kwargs: Any) -> Any:\n    86→    \"\"\"Call a function, handling both sync and async.\"\"\"\n    87→    if inspect.iscoroutinefunction(fn):\n    88→        return await fn(*args, **kwargs)\n    89→    return fn(*args, **kwargs)\n    90→\n    91→\n    92→# ---------------------------------------------------------------------------\n    93→# LoopEngine\n    94→# ---------------------------------------------------------------------------\n    95→\n    96→class LoopEngine:\n    97→    \"\"\"Universal strange-loop engine.\n    98→\n    99→    Runs a domain through GENERATE → TEST → SCORE → GATE → eigenform →\n   100→    MUTATE → SELECT until convergence, eigenform, or limits.\n   101→\n   102→    Now with:\n   103→      - Checkpoint after every iteration (crash-safe resume)\n   104→      - InterruptGate at GATE phase (human-in-the-loop for Tier B/C)\n   105→    \"\"\"\n   106→\n   107→    def __init__(\n   108→        self,\n   109→        domain: LoopDomain,\n   110→        *,\n   111→        checkpoint_store: CheckpointStore | None = None,\n   112→        interrupt_gate: InterruptGate | None = None,\n   113→    ):\n   114→        self.domain = domain\n   115→        self._fns: dict[str, Callable[..., Any]] = {}\n   116→        self._store = checkpoint_store or _checkpoint_store\n   117→        self._gate = interrupt_gate or _interrupt_gate\n   118→\n   119→    def _resolve_all(self) -> None:\n   120→        \"\"\"Resolve all phase function references.\"\"\"\n   121→        self._fns[\"generate\"] = _resolve_fn(self.domain.generate_fn)\n   122→        self._fns[\"test\"] = _resolve_fn(self.domain.test_fn)\n   123→        self._fns[\"score\"] = _resolve_fn(self.domain.score_fn)\n   124→        self._fns[\"gate\"] = _resolve_fn(self.domain.gate_fn)\n   125→        self._fns[\"mutate\"] = _resolve_fn(self.domain.mutate_fn)\n   126→        self._fns[\"select\"] = _resolve_fn(self.domain.select_fn)\n   127→        self._fns[\"eigenform\"] = _resolve_fn(self.domain.eigenform_fn)\n   128→\n   129→    async def run(\n   130→        self,\n   131→        seed: dict[str, Any] | None = None,\n   132→        *,\n   133→        context: dict[str, Any] | None = None,\n   134→        resume: bool = True,\n   135→    ) -> LoopResult:\n   136→        \"\"\"Run the full loop until convergence or limits.\n   137→\n   138→        If *resume* is True (default), checks for an existing checkpoint\n   139→        and resumes from the saved iteration. On crash/restart, no work\n   140→        is lost.\n   141→        \"\"\"\n   142→        self._resolve_all()\n   143→        ctx = context or {}\n   144→\n   145→        result = LoopResult(domain=self.domain.name)\n   146→        start = time.monotonic()\n   147→\n   148→        current = seed\n   149→        previous: dict[str, Any] | None = None\n   150→        candidates: list[dict[str, Any]] = []\n   151→        best_score = 0.0\n   152→        start_iteration = 0\n   153→\n   154→        # --- RESUME FROM CHECKPOINT ---\n   155→        if resume:\n   156→            cp = self._store.load(self.domain.name, result.cycle_id)\n   157→            if cp is None:\n   158→                # Also check for any checkpoint for this domain (latest)\n   159→                existing = self._store.list_checkpoints(self.domain.name)\n   160→                if existing and not existing[0].converged:\n   161→                    cp = existing[0]\n   162→                    result.cycle_id = cp.cycle_id\n   163→\n   164→            if cp is not None and not cp.converged:\n   165→                logger.info(\n   166→                    \"Resuming %s from checkpoint: iteration=%d, best=%.3f\",\n   167→                    self.domain.name, cp.iteration, cp.best_score,\n   168→                )\n   169→                current = cp.current\n   170→                previous = cp.previous\n   171→                candidates = cp.candidates\n   172→                best_score = cp.best_score\n   173→                result.fitness_trajectory = cp.fitness_trajectory\n   174→                result.eigenform_trajectory = cp.eigenform_trajectory\n   175→                result.cycle_id = cp.cycle_id\n   176→                start_iteration = cp.iteration\n   177→                start = time.monotonic() - cp.elapsed_seconds\n   178→\n   179→        for iteration in range(start_iteration, self.domain.max_iterations):\n   180→            elapsed = time.monotonic() - start\n   181→            if elapsed > self.domain.max_duration_seconds:\n   182→                result.converged = True\n   183→                result.convergence_reason = f\"time limit ({self.domain.max_duration_seconds}s)\"\n   184→                break\n   185→\n   186→            # GENERATE\n   187→            artifact = await _call(self._fns[\"generate\"], current, ctx)\n   188→\n   189→            # TEST\n   190→            artifact = await _call(self._fns[\"test\"], artifact, ctx)\n   191→\n   192→            # SCORE\n   193→            artifact = await _call(self._fns[\"score\"], artifact, ctx)\n   194→            score = artifact.get(\"score\", 0.0)\n   195→            result.fitness_trajectory.append(score)\n   196→            if score > best_score:\n   197→                best_score = score\n   198→\n   199→            # GATE (with interrupt support)\n   200→            gate_result = await _call(self._fns[\"gate\"], artifact, ctx)\n   201→            gate_passed = gate_result.get(\"passed\", True)\n   202→            gate_tier = gate_result.get(\"tier\", \"C\")\n   203→\n   204→            # Tier A/B gate failures trigger interrupt for operator review\n   205→            if not gate_passed and gate_tier in (\"A\", \"B\"):\n   206→                interrupt_req = InterruptRequest(\n   207→                    domain=self.domain.name,\n   208→                    cycle_id=result.cycle_id,\n   209→                    iteration=iteration,\n   210→                    phase=\"gate\",\n   211→                    reason=f\"Tier {gate_tier} gate blocked: {gate_result.get('reason', 'unknown')}\",\n   212→                    artifact=artifact,\n   213→                    gate_results=gate_result,\n   214→                )\n   215→                response = await self._gate.interrupt(interrupt_req)\n   216→\n   217→                if response.decision == InterruptDecision.REJECT:\n   218→                    result.interrupted = True\n   219→                    result.interrupt_reason = f\"Operator rejected at iteration {iteration}: {response.reason}\"\n   220→                    logger.info(\"Operator rejected: %s\", response.reason)\n   221→                    break\n   222→                elif response.decision == InterruptDecision.MODIFY:\n   223→                    if response.modified_artifact:\n   224→                        artifact = response.modified_artifact\n   225→                        score = artifact.get(\"score\", score)\n   226→                    # Fall through — operator modified, continue loop\n   227→                elif response.decision == InterruptDecision.APPROVE:\n   228→                    gate_passed = True  # Override gate\n   229→\n   230→            if not gate_passed:\n   231→                logger.debug(\n   232→                    \"Gate blocked iteration %d: %s\",\n   233→                    iteration,\n   234→                    gate_result.get(\"reason\", \"\"),\n   235→                )\n   236→                # Still checkpoint even on gate block\n   237→                self._save_checkpoint(\n   238→                    result, iteration, current, previous,\n   239→                    candidates, best_score, time.monotonic() - start,\n   240→                )\n   241→                continue\n   242→\n   243→            # EIGENFORM CHECK\n   244→            if previous is not None:\n   245→                distance = await _call(\n   246→                    self._fns[\"eigenform\"], artifact, previous\n   247→                )\n   248→                result.eigenform_trajectory.append(distance)\n   249→                if distance < self.domain.eigenform_epsilon:\n   250→                    result.eigenform_reached = True\n   251→                    result.converged = True\n   252→                    result.convergence_reason = (\n   253→                        f\"eigenform (distance={distance:.4f} < \"\n   254→                        f\"epsilon={self.domain.eigenform_epsilon})\"\n   255→                    )\n   256→                    result.iterations_completed = iteration + 1\n   257→                    result.best_fitness = best_score\n   258→                    result.duration_seconds = time.monotonic() - start\n   259→                    # Clean up checkpoint on successful convergence\n   260→                    self._store.delete(self.domain.name, result.cycle_id)\n   261→                    return result\n   262→            else:\n   263→                result.eigenform_trajectory.append(float(\"inf\"))\n   264→\n   265→            # Check fitness threshold convergence\n   266→            if score >= self.domain.fitness_threshold:\n   267→                window = self.domain.convergence_window\n   268→                if len(result.fitness_trajectory) >= window:\n   269→                    recent = result.fitness_trajectory[-window:]\n   270→                    variance = _variance(recent)\n   271→                    if variance < 0.001:\n   272→                        result.converged = True\n   273→                        result.convergence_reason = (\n   274→                            f\"fitness plateau (var={variance:.6f})\"\n   275→                        )\n   276→                        break\n   277→\n   278→            # MUTATE\n   279→            mutation_rate = self._adjusted_mutation_rate(result.eigenform_trajectory)\n   280→            mutated = await _call(\n   281→                self._fns[\"mutate\"], artifact, ctx, mutation_rate\n   282→            )\n   283→            candidates.append(artifact)\n   284→            if len(candidates) > 10:\n   285→                candidates = candidates[-10:]\n   286→\n   287→            # SELECT\n   288→            previous = current\n   289→            current = await _call(self._fns[\"select\"], candidates, ctx)\n   290→\n   291→            # --- CHECKPOINT after every iteration ---\n   292→            self._save_checkpoint(\n   293→                result, iteration + 1, current, previous,\n   294→                candidates, best_score, time.monotonic() - start,\n   295→            )\n   296→\n   297→        result.iterations_completed = min(\n   298→            len(result.fitness_trajectory), self.domain.max_iterations\n   299→        )\n   300→        result.best_fitness = best_score\n   301→        result.duration_seconds = time.monotonic() - start\n   302→\n   303→        # Clean up checkpoint on completion\n   304→        if result.converged or result.interrupted:\n   305→            self._store.delete(self.domain.name, result.cycle_id)\n   306→\n   307→        return result\n   308→\n   309→    def _save_checkpoint(\n   310→        self,\n   311→        result: LoopResult,\n   312→        iteration: int,\n   313→        current: dict[str, Any] | None,\n   314→        previous: dict[str, Any] | None,\n   315→        candidates: list[dict[str, Any]],\n   316→        best_score: float,\n   317→        elapsed: float,\n   318→    ) -> None:\n   319→        \"\"\"Save a checkpoint after an iteration. Fire-and-forget.\"\"\"\n   320→        try:\n   321→            cp = LoopCheckpoint(\n   322→                domain=self.domain.name,\n   323→                cycle_id=result.cycle_id,\n   324→                iteration=iteration,\n   325→                current=current,\n   326→                previous=previous,\n   327→                candidates=candidates,\n   328→                best_score=best_score,\n   329→                fitness_trajectory=list(result.fitness_trajectory),\n   330→                eigenform_trajectory=list(result.eigenform_trajectory),\n   331→                elapsed_seconds=elapsed,\n   332→                converged=result.converged,\n   333→                interrupted=result.interrupted,\n   334→                interrupt_reason=result.interrupt_reason,\n   335→            )\n   336→            path = self._store.save(cp)\n   337→            logger.debug(\"Checkpoint saved: %s\", path)\n   338→        except Exception as e:\n   339→            logger.warning(\"Failed to save checkpoint: %s\", e)\n   340→\n   341→    def _adjusted_mutation_rate(\n   342→        self, eigenform_trajectory: list[float]\n   343→    ) -> float:\n   344→        \"\"\"Adjust mutation rate based on eigenform distance trend.\"\"\"\n   345→        base = self.domain.mutation_rate\n   346→        if len(eigenform_trajectory) < 2:\n   347→            return base\n   348→\n   349→        recent = eigenform_trajectory[-3:]\n   350→        avg_distance = sum(\n   351→            d for d in recent if d != float(\"inf\")\n   352→        ) / max(1, sum(1 for d in recent if d != float(\"inf\")))\n   353→\n   354→        # Close to eigenform → reduce mutation\n   355→        if avg_distance < self.domain.eigenform_epsilon * 3:\n   356→            return base * 0.5\n   357→        # Far from eigenform → increase mutation\n   358→        if avg_distance > 1.0:\n   359→            return min(0.5, base * 1.5)\n   360→        return base\n   361→\n   362→\n   363→# ---------------------------------------------------------------------------\n   364→# Convenience\n   365→# ---------------------------------------------------------------------------\n   366→\n   367→def _variance(values: list[float]) -> float:\n   368→    \"\"\"Population variance of a list of floats.\"\"\"\n   369→    if len(values) < 2:\n   370→        return 0.0\n   371→    mean = sum(values) / len(values)\n   372→    return sum((v - mean) ** 2 for v in values) / len(values)\n   373→\n   374→\n   375→def get_interrupt_gate() -> InterruptGate:\n   376→    \"\"\"Return the module-level interrupt gate (for CLI/API to resolve interrupts).\"\"\"\n   377→    return _interrupt_gate\n   378→\n   379→\n   380→def get_checkpoint_store() -> CheckpointStore:\n   381→    \"\"\"Return the module-level checkpoint store.\"\"\"\n   382→    return _checkpoint_store\n   383→\n   384→\n   385→async def feedback_ascent(result: LoopResult) -> None:\n   386→    \"\"\"Feed loop results back into the recognition seed — the strange loop.\n   387→\n   388→    When a cascade domain completes, its results update the recognition seed\n   389→    so future agent context includes what the system learned. This is the\n   390→    ascent path: execution → synthesis → context → execution.\n   391→\n   392→    Also emits a signal so other loops can feel the completion.\n   393→    \"\"\"\n   394→    from pathlib import Path\n   395→\n   396→    # 1. Emit signal to bus\n   397→    try:\n   398→        from dharma_swarm.signal_bus import SignalBus\n   399→\n   400→        bus = SignalBus.get()\n   401→        bus.emit({\n   402→            \"type\": \"CASCADE_COMPLETE\",\n   403→            \"domain\": result.domain,\n   404→            \"converged\": result.converged,\n   405→            \"best_fitness\": result.best_fitness,\n   406→            \"eigenform_reached\": result.eigenform_reached,\n   407→            \"iterations\": result.iterations_completed,\n   408→        })\n   409→        if result.eigenform_reached:\n   410→            bus.emit({\n   411→                \"type\": \"CASCADE_EIGENFORM_DISTANCE\",\n   412→                \"domain\": result.domain,\n   413→                \"distance\": result.eigenform_trajectory[-1]\n   414→                if result.eigenform_trajectory else 0.0,\n   415→            })\n   416→    except Exception as e:\n   417→        logger.debug(\"Signal emission failed: %s\", e)\n   418→\n   419→    # 2. Append to cascade history for recognition engine to consume\n   420→    try:\n   421→        import json\n   422→        history_dir = Path.home() / \".dharma\" / \"meta\"\n   423→        history_dir.mkdir(parents=True, exist_ok=True)\n   424→        history_file = history_dir / \"cascade_history.jsonl\"\n   425→        entry = {\n   426→            \"domain\": result.domain,\n   427→            \"converged\": result.converged,\n   428→            \"best_fitness\": result.best_fitness,\n   429→            \"eigenform_reached\": result.eigenform_reached,\n   430→            \"iterations\": result.iterations_completed,\n   431→            \"duration\": result.duration_seconds,\n   432→            \"convergence_reason\": result.convergence_reason,\n   433→            \"timestamp\": time.time(),\n   434→        }\n   435→        with open(history_file, \"a\") as f:\n   436→            f.write(json.dumps(entry) + \"\\n\")\n   437→    except Exception as e:\n   438→        logger.debug(\"Cascade history write failed: %s\", e)\n   439→\n   440→    # 3. Write stigmergy mark for agent context (L8)\n   441→    try:\n   442→        from dharma_swarm.stigmergy import StigmergicMark, StigmergyStore\n   443→\n   444→        store = StigmergyStore()\n   445→        status = \"EIGENFORM\" if result.eigenform_reached else (\"CONVERGED\" if result.converged else \"INCOMPLETE\")\n   446→        mark = StigmergicMark(\n   447→            agent=\"cascade_engine\",\n   448→            file_path=f\"cascade_domain_{result.domain}\",\n   449→            action=\"write\",\n   450→            observation=f\"cascade:{result.domain} fitness={result.best_fitness:.3f} {status} iter={result.iterations_completed}\",\n   451→            salience=0.7 if result.eigenform_reached else 0.5,\n   452→        )\n   453→        await store.leave_mark(mark)\n   454→    except Exception as e:\n   455→        logger.debug(\"Stigmergy mark failed: %s\", e)\n   456→\n   457→\n   458→async def run_domain(\n   459→    domain_name: str,\n   460→    *,\n   461→    seed: dict[str, Any] | None = None,\n   462→    context: dict[str, Any] | None = None,\n   463→    config: dict[str, Any] | None = None,\n   464→    resume: bool = True,\n   465→) -> LoopResult:\n   466→    \"\"\"Convenience: load a domain by name and run it.\n   467→\n   468→    If *resume* is True, resumes from the last checkpoint if one exists.\n   469→    Automatically calls feedback_ascent() on completion.\n   470→    \"\"\"\n   471→    module_path = _DOMAIN_MODULES.get(domain_name)\n   472→    if not module_path:\n   473→        raise ValueError(\n   474→            f\"Unknown domain: {domain_name!r}. \"\n   475→            f\"Available: {sorted(_DOMAIN_MODULES)}\"\n   476→        )\n   477→    mod = importlib.import_module(module_path)\n   478→    domain = mod.get_domain(config)\n   479→    engine = LoopEngine(domain)\n   480→    result = await engine.run(seed, context=context, resume=resume)\n   481→\n   482→    # Feed results back into the recognition seed (strange loop closure)\n   483→    await feedback_ascent(result)\n   484→\n   485→    return result\n   486→"}]},"uuid":"3bb56850-e27f-4615-b022-e6dee73d2b8f","timestamp":"2026-03-15T14:18:17.166Z","sourceToolAssistantUUID":"17c69b34-35fe-4c90-8f7b-1181b8a31b9f","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
