{"parentUuid":"a5de3f1f-2282-46ab-bac6-2a9de0495521","isSidechain":true,"agentId":"a49c8b65581671737","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"callback"},"parentToolUseID":"toolu_014C8NSYhxE8zFnK5gb24NUM","toolUseID":"toolu_014C8NSYhxE8zFnK5gb24NUM","timestamp":"2026-03-15T14:18:22.557Z","uuid":"7ce1c305-b46a-48c6-8543-46c4311271d8","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
{"parentUuid":"807aa100-3101-4eec-af71-f3e47f9b906f","isSidechain":true,"promptId":"3cfdca64-d5a0-407a-b98d-81d58c820453","agentId":"a49c8b65581671737","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014C8NSYhxE8zFnK5gb24NUM","type":"tool_result","content":"     1→\"\"\"Parent selection strategies for the evolution engine.\n     2→\n     3→Ported from ~/DHARMIC_GODEL_CLAW/src/dgm/selector.py into dharma_swarm\n     4→conventions: async functions, type hints, no singletons.\n     5→\n     6→Four strategies balance exploration vs. exploitation when choosing\n     7→which archive entries to evolve from:\n     8→\n     9→- **tournament**: random k-way tournament (default, good balance)\n    10→- **roulette**: fitness-proportional (exploitation-heavy)\n    11→- **rank**: rank-based probability (smoother than roulette)\n    12→- **elite**: top-n deterministic (pure exploitation)\n    13→\"\"\"\n    14→\n    15→from __future__ import annotations\n    16→\n    17→import random\n    18→from typing import Any\n    19→\n    20→from dharma_swarm.archive import ArchiveEntry, EvolutionArchive\n    21→\n    22→\n    23→# ---------------------------------------------------------------------------\n    24→# Internal helpers\n    25→# ---------------------------------------------------------------------------\n    26→\n    27→\n    28→async def _get_applied(archive: EvolutionArchive) -> list[ArchiveEntry]:\n    29→    \"\"\"Return all entries with status ``\"applied\"``.\n    30→\n    31→    Uses ``archive.get_best()`` with a very large *n* so the archive's own\n    32→    filtering logic is reused.  The result is sorted by descending fitness,\n    33→    which several strategies rely on.\n    34→    \"\"\"\n    35→    return await archive.get_best(n=999_999)\n    36→\n    37→\n    38→async def _count_children(archive: EvolutionArchive) -> dict[str, int]:\n    39→    \"\"\"Count direct children for each entry in the archive.\n    40→\n    41→    Returns:\n    42→        Mapping from entry_id to number of direct children.\n    43→    \"\"\"\n    44→    counts: dict[str, int] = {}\n    45→    for entry in archive._entries.values():\n    46→        if entry.parent_id:\n    47→            counts[entry.parent_id] = counts.get(entry.parent_id, 0) + 1\n    48→    return counts\n    49→\n    50→\n    51→def _novelty_weight(\n    52→    entry: ArchiveEntry,\n    53→    child_counts: dict[str, int],\n    54→    weights: dict[str, float] | None = None,\n    55→) -> float:\n    56→    \"\"\"Compute novelty-adjusted weight with ouroboros behavioral bias.\n    57→\n    58→    Formula: fitness * novelty * behavioral_modifier\n    59→    - novelty = 1/(1+n_children) — exploration vs exploitation\n    60→    - behavioral_modifier: entries whose test_results contain\n    61→      genuine recognition get a 1.1x boost; mimicry gets 0.8x penalty.\n    62→      This connects the ouroboros behavioral metrics to selection pressure.\n    63→\n    64→    Args:\n    65→        entry: The archive entry to weight.\n    66→        child_counts: Mapping from entry_id to child count.\n    67→\n    68→    Returns:\n    69→        Novelty-adjusted weight (always >= 0).\n    70→    \"\"\"\n    71→    fitness = entry.fitness.weighted(weights=weights)\n    72→    n_children = child_counts.get(entry.id, 0)\n    73→    novelty = 1.0 / (1.0 + n_children)\n    74→\n    75→    # Behavioral modifier from ouroboros (stored by evolution.py)\n    76→    behavioral = 1.0\n    77→    if entry.test_results:\n    78→        if entry.test_results.get(\"gaia_drifting\"):\n    79→            behavioral *= 0.85  # Goodhart drift penalty\n    80→        # Future: check for L4 behavioral tags when stored in test_results\n    81→\n    82→    return fitness * novelty * behavioral\n    83→\n    84→\n    85→# ---------------------------------------------------------------------------\n    86→# Selection strategies\n    87→# ---------------------------------------------------------------------------\n    88→\n    89→\n    90→async def tournament_select(\n    91→    archive: EvolutionArchive,\n    92→    k: int = 3,\n    93→    weights: dict[str, float] | None = None,\n    94→) -> ArchiveEntry | None:\n    95→    \"\"\"Pick *k* random applied entries and return the fittest.\n    96→\n    97→    If the archive has fewer than *k* applied entries, all available\n    98→    entries participate in the tournament.  Returns ``None`` when the\n    99→    archive contains no applied entries.\n   100→\n   101→    Args:\n   102→        archive: The evolution archive to draw from.\n   103→        k: Tournament size.  Larger *k* increases selection pressure.\n   104→\n   105→    Returns:\n   106→        The winning ``ArchiveEntry``, or ``None`` if no candidates exist.\n   107→    \"\"\"\n   108→    candidates = await _get_applied(archive)\n   109→    if not candidates:\n   110→        return None\n   111→\n   112→    pool_size = min(k, len(candidates))\n   113→    pool = random.sample(candidates, pool_size)\n   114→    child_counts = await _count_children(archive)\n   115→    return max(pool, key=lambda e: _novelty_weight(e, child_counts, weights=weights))\n   116→\n   117→\n   118→async def roulette_select(\n   119→    archive: EvolutionArchive,\n   120→    weights: dict[str, float] | None = None,\n   121→) -> ArchiveEntry | None:\n   122→    \"\"\"Fitness-proportional (roulette wheel) selection.\n   123→\n   124→    Each applied entry's probability of being selected equals its\n   125→    weighted fitness divided by the total fitness of all candidates.\n   126→    When all fitnesses are zero, falls back to uniform random choice.\n   127→\n   128→    Args:\n   129→        archive: The evolution archive to draw from.\n   130→\n   131→    Returns:\n   132→        A single ``ArchiveEntry``, or ``None`` if no candidates exist.\n   133→    \"\"\"\n   134→    candidates = await _get_applied(archive)\n   135→    if not candidates:\n   136→        return None\n   137→\n   138→    child_counts = await _count_children(archive)\n   139→    candidate_weights = [\n   140→        _novelty_weight(e, child_counts, weights=weights) for e in candidates\n   141→    ]\n   142→    total = sum(candidate_weights)\n   143→\n   144→    if total == 0.0:\n   145→        return random.choice(candidates)\n   146→\n   147→    return random.choices(candidates, weights=candidate_weights, k=1)[0]\n   148→\n   149→\n   150→async def rank_select(\n   151→    archive: EvolutionArchive,\n   152→    weights: dict[str, float] | None = None,\n   153→) -> ArchiveEntry | None:\n   154→    \"\"\"Rank-based selection.\n   155→\n   156→    Applied entries are sorted by ascending fitness and assigned integer\n   157→    rank weights (worst=1, best=N).  Selection uses rank-based\n   158→    probability, which compresses the fitness scale and avoids\n   159→    domination by a single super-fit individual.\n   160→\n   161→    Args:\n   162→        archive: The evolution archive to draw from.\n   163→\n   164→    Returns:\n   165→        A single ``ArchiveEntry``, or ``None`` if no candidates exist.\n   166→    \"\"\"\n   167→    candidates = await _get_applied(archive)\n   168→    if not candidates:\n   169→        return None\n   170→\n   171→    # Sort ascending so rank 1 = worst, rank N = best.\n   172→    child_counts = await _count_children(archive)\n   173→    sorted_asc = sorted(\n   174→        candidates,\n   175→        key=lambda e: _novelty_weight(e, child_counts, weights=weights),\n   176→    )\n   177→    rank_weights = list(range(1, len(sorted_asc) + 1))\n   178→\n   179→    return random.choices(sorted_asc, weights=rank_weights, k=1)[0]\n   180→\n   181→\n   182→async def elite_select(\n   183→    archive: EvolutionArchive,\n   184→    n: int = 3,\n   185→    weights: dict[str, float] | None = None,\n   186→) -> list[ArchiveEntry]:\n   187→    \"\"\"Return the top *n* entries by weighted fitness.\n   188→\n   189→    This is a thin wrapper around ``archive.get_best(n)`` that provides\n   190→    a consistent interface with the other selectors.\n   191→\n   192→    Args:\n   193→        archive: The evolution archive to draw from.\n   194→        n: How many elite entries to return.\n   195→\n   196→    Returns:\n   197→        A list of up to *n* ``ArchiveEntry`` objects, sorted by\n   198→        descending fitness.  May be empty if no applied entries exist.\n   199→    \"\"\"\n   200→    return await archive.get_best(n=n, weights=weights)\n   201→\n   202→\n   203→# ---------------------------------------------------------------------------\n   204→# Dispatch\n   205→# ---------------------------------------------------------------------------\n   206→\n   207→_STRATEGIES: dict[str, str] = {\n   208→    \"tournament\": \"tournament_select\",\n   209→    \"roulette\": \"roulette_select\",\n   210→    \"rank\": \"rank_select\",\n   211→    \"elite\": \"elite_select\",\n   212→}\n   213→\n   214→\n   215→async def select_parent(\n   216→    archive: EvolutionArchive,\n   217→    strategy: str = \"tournament\",\n   218→    **kwargs: Any,\n   219→) -> ArchiveEntry | None:\n   220→    \"\"\"Unified dispatch for parent selection.\n   221→\n   222→    Args:\n   223→        archive: The evolution archive to draw from.\n   224→        strategy: One of ``\"tournament\"``, ``\"roulette\"``, ``\"rank\"``,\n   225→            or ``\"elite\"``.\n   226→        **kwargs: Forwarded to the chosen strategy function (e.g.\n   227→            ``k=5`` for tournament, ``n=3`` for elite).\n   228→\n   229→    Returns:\n   230→        A single ``ArchiveEntry``, or ``None`` when the archive is empty.\n   231→\n   232→    Raises:\n   233→        ValueError: If *strategy* is not recognised.\n   234→    \"\"\"\n   235→    if strategy not in _STRATEGIES:\n   236→        raise ValueError(\n   237→            f\"Unknown selection strategy {strategy!r}. \"\n   238→            f\"Choose from: {', '.join(sorted(_STRATEGIES))}\"\n   239→        )\n   240→\n   241→    if strategy == \"elite\":\n   242→        entries = await elite_select(archive, **kwargs)\n   243→        return entries[0] if entries else None\n   244→\n   245→    if strategy == \"tournament\":\n   246→        return await tournament_select(archive, **kwargs)\n   247→\n   248→    if strategy == \"roulette\":\n   249→        return await roulette_select(archive, **kwargs)\n   250→\n   251→    # rank\n   252→    return await rank_select(archive, **kwargs)\n   253→"}]},"uuid":"2705e413-9d8f-429a-88ca-d0ffab9d3c5f","timestamp":"2026-03-15T14:18:22.557Z","sourceToolAssistantUUID":"807aa100-3101-4eec-af71-f3e47f9b906f","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
