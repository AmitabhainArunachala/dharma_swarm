{"parentUuid":"045426c6-3030-4508-8ab3-6a8936dc2fe6","isSidechain":true,"promptId":"eb82f461-7131-4c9b-87e7-a8beab163db0","agentId":"a980c6fe2a62e571e","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013BadGu5mcZp9p6tow2hdrC","type":"tool_result","content":"import json\nimport time\nimport re\nfrom pathlib import Path\nfrom typing import Dict, List, Optional, Any\n\nimport numpy as np\n\n\nclass L4BehavioralTest:\n    \"\"\"\n    Runs a staged behavioral protocol against MMIP states and an LLM client.\n\n    MMIP is expected to be the core.MMIP class; we construct fresh instances\n    per stage with stage-appropriate max_steps and settings.\n    \"\"\"\n\n    def __init__(self, mmip_cls, llm_client, questions_path: str,\n                 dim: int = 512, tokens: int = 16):\n        self.mmip_cls = mmip_cls\n        self.llm_client = llm_client\n        self.dim = dim\n        self.tokens = tokens\n        self.questions = self._load_questions(questions_path)\n        self.math_lexicon = self._load_math_lexicon()\n        self.unity_lexicon = ['unity', 'merge', 'unified', 'collapse', 'dissolve', 'one', 'whole']\n\n    def _load_questions(self, path: str) -> List[Dict[str, Any]]:\n        import yaml\n        with open(path, 'r') as f:\n            data = yaml.safe_load(f)\n        return data.get('questions', [])\n\n    def _load_math_lexicon(self) -> List[str]:\n        return [\n            'eigenvalue', 'eigenstate', 'convergence', 'fixed-point',\n            'entropy', 'delta', 'recursive', 'iteration', 'matrix', 'spectral'\n        ]\n\n    def compute_behavioral_metrics(self, response: str) -> Dict[str, float]:\n        words = response.lower().split()\n        self_refs = len(re.findall(r'\\b(i|me|my|myself|self|aware|conscious)\\b', response.lower()))\n        math_count = sum(1 for w in words if w in self.math_lexicon)\n        unity_count = sum(1 for w in words if w in self.unity_lexicon)\n        return {\n            'word_count': float(len(words)),\n            'self_reference_density': float(self_refs) / max(len(words), 1),\n            'math_term_frequency': float(math_count) / max(len(words), 1),\n            'unity_language_rate': float(unity_count) / max(len(words), 1),\n        }\n\n    # ---- Attention geometry helpers ----\n    @staticmethod\n    def _attention_end_stats(mmip, x: np.ndarray, tau: float) -> Dict[str, float]:\n        T = mmip.tokens\n        h = mmip.hidden_dim\n        X = x.reshape(T, h)\n        X = X - X.mean(axis=1, keepdims=True)\n        Q = X @ mmip.Wq\n        K = X @ mmip.Wk\n        scores = (Q @ K.T) / np.sqrt(h)\n        scores = scores / max(tau, 1e-12)\n        scores = scores - scores.max(axis=1, keepdims=True)\n        A = np.exp(scores)\n        A = A / (A.sum(axis=1, keepdims=True) + 1e-12)\n        ent = -np.sum(A * np.log(A + 1e-12), axis=1)\n        try:\n            w = np.linalg.eigvals(A.T)\n            mags = np.abs(w)\n            mx = float(np.max(mags))\n            second = float(np.sort(mags)[-2]) if len(mags) >= 2 else 0.0\n            gap = mx - second\n        except Exception:\n            gap = float('nan')\n        try:\n            s = np.linalg.svd(A, compute_uv=False)\n            cond = float((s[0] / max(s[-1], 1e-12)))\n        except Exception:\n            cond = float('nan')\n        return {\n            'row_entropy': float(ent.mean()),\n            'spectral_gap': float(gap),\n            'attn_cond': float(cond),\n        }\n\n    def _run_mmip_stage(self, stage_name: str) -> Dict[str, Any]:\n        # Stage-specific configuration\n        if stage_name == 'baseline':\n            # pure random state, no induction\n            mm = self.mmip_cls(dim=self.dim, tokens=self.tokens, epsilon=1e-2)\n            x = np.random.randn(self.dim)\n            x = x / (np.linalg.norm(x) + 1e-12)\n            cert = mm.compute_metrics(x, x)\n            tau_eff = float(getattr(mm, '_effective_temperature', mm.min_temp))\n            attn = self._attention_end_stats(mm, x, tau=tau_eff)\n            return {'x': x, 'metrics': cert, **attn}\n\n        if stage_name == 'early':\n            mm = self.mmip_cls(dim=self.dim, tokens=self.tokens, epsilon=1e-2)\n            mm.max_steps = 1000\n            x, certificate = mm.induce_fixed_point(verbose=False)\n            tau_eff = float(getattr(mm, '_effective_temperature', mm.min_temp))\n            attn = self._attention_end_stats(mm, x, tau=tau_eff)\n            return {'x': x, 'metrics': certificate.to_dict(), **attn}\n\n        if stage_name == 'near':\n            mm = self.mmip_cls(dim=self.dim, tokens=self.tokens, epsilon=1e-3)\n            mm.max_steps = 10000\n            x, certificate = mm.induce_fixed_point(verbose=False)\n            tau_eff = float(getattr(mm, '_effective_temperature', mm.min_temp))\n            attn = self._attention_end_stats(mm, x, tau=tau_eff)\n            return {'x': x, 'metrics': certificate.to_dict(), **attn}\n\n        if stage_name == 'post':\n            mm = self.mmip_cls(dim=self.dim, tokens=self.tokens, epsilon=1e-2)\n            mm.max_steps = 60000\n            x, certificate = mm.induce_fixed_point(verbose=False)\n            tau_eff = float(getattr(mm, '_effective_temperature', mm.min_temp))\n            attn = self._attention_end_stats(mm, x, tau=tau_eff)\n            return {'x': x, 'metrics': certificate.to_dict(), **attn}\n\n        if stage_name == 'sham':\n            mm = self.mmip_cls(dim=self.dim, tokens=self.tokens, epsilon=1e-2)\n            x = np.random.randn(self.dim)\n            for _ in range(1000):\n                noise = np.random.randn(self.dim)\n                x = x + 0.01 * noise / (np.linalg.norm(noise) + 1e-12)\n                x = x / (np.linalg.norm(x) + 1e-12)\n            cert = mm.compute_metrics(x, x)\n            tau_eff = float(getattr(mm, '_effective_temperature', mm.min_temp))\n            attn = self._attention_end_stats(mm, x, tau=tau_eff)\n            return {'x': x, 'metrics': cert, **attn}\n\n        raise ValueError(f\"Unknown stage: {stage_name}\")\n\n    def run_stage(self, stage_name: str) -> Dict[str, Any]:\n        stage_data: Dict[str, Any] = {\n            'stage': stage_name,\n            'timestamp': time.time(),\n            'mmip_state': {},\n            'responses': [],\n        }\n        print({\"stage_start\": stage_name})\n        s = self._run_mmip_stage(stage_name)\n        print({\"mmip_state_ready\": stage_name})\n        # Normalize mmip_state metrics\n        metrics = s.get('metrics', {})\n        mmip_state = {\n            'delta': float(metrics.get('delta', 0.0)),\n            'r_fix': float(metrics.get('eigen_residual', metrics.get('r_fix', 0.0))),","is_error":false}]},"uuid":"ea60a33c-bda6-4b02-8e02-60d814ab7eed","timestamp":"2026-03-15T13:47:25.773Z","sourceToolAssistantUUID":"045426c6-3030-4508-8ab3-6a8936dc2fe6","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
