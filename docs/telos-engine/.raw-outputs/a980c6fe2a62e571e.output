{"parentUuid":"a307a703-6d6e-4b37-9eea-d413efb592f5","isSidechain":true,"agentId":"a980c6fe2a62e571e","type":"progress","data":{"type":"hook_progress","hookEvent":"PostToolUse","hookName":"PostToolUse:Read","command":"bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-with-flags-shell.sh\" \"post:observe\" \"skills/continuous-learning-v2/hooks/observe.sh\" \"standard,strict\""},"parentToolUseID":"toolu_019Jxbrftfx8TRpkyu9oFwAH","toolUseID":"toolu_019Jxbrftfx8TRpkyu9oFwAH","timestamp":"2026-03-15T13:47:02.439Z","uuid":"8180d89c-f4ed-48b6-af06-14957d5d69cf","userType":"external","cwd":"/Users/dhyana","sessionId":"2ea96bb4-afee-473b-8609-a3975acc2c75","version":"2.1.76","gitBranch":"HEAD","slug":"shimmering-leaping-badger"}
