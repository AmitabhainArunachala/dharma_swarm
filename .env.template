# API Keys for Subconscious Fleet Providers
# Copy to .env and fill in your keys

# Anthropic (Claude Sonnet 4.6)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, etc.)
OPENAI_API_KEY=

# OpenRouter (Multi-provider router)
OPENROUTER_API_KEY=

# Ollama (Local models - no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# NVIDIA NIM (NVIDIA Inference Microservices)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Moonshot (Moonshot AI models)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Groq (Fast inference)
GROQ_API_KEY=

# Deepseek (Deepseek models)
DEEPSEEK_API_KEY=

# Together AI (Multiple open models)
TOGETHER_API_KEY=

# --- Router runtime controls ---
# FastText language model path (optional but recommended)
DGC_FASTTEXT_MODEL_PATH=/Users/dhyana/.dharma/models/lid.176.bin

# Sticky cache-affinity (prevent mid-session provider thrash)
DGC_ROUTER_STICKY_SECONDS=300
DGC_ROUTER_STICKY_MIN_TOKENS=10000

# Shared circuit breaker state (optional Redis)
DGC_ROUTER_REDIS_URL=redis://127.0.0.1:6379/0

# Canary rollout for new lanes
DGC_ROUTER_CANARY_PERCENT=5
DGC_ROUTER_CANARY_PROVIDER=anthropic
DGC_ROUTER_CANARY_MODEL=claude-sonnet-4-6

# Online routing reward updates
DGC_ROUTER_LEARNING_ENABLED=1
DGC_ROUTER_LEARNING_ALPHA=0.15

# Persistent routing memory + live routed agent execution
DGC_ROUTER_MEMORY_DB=/Users/dhyana/.dharma/logs/router/routing_memory.sqlite3
DGC_AGENT_ROUTED_EXECUTION=1

# Instructions:
# 1. Copy this file to .env
# 2. Fill in your API keys
# 3. Or use macOS keychain (see README for keychain setup)
